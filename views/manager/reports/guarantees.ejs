<!DOCTYPE html>
<html lang="en" data-bs-theme="light"><head><meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1" /><title><%= title %> · Manager</title><link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" /><link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" /><link href="/css/styles.css" rel="stylesheet" /></head>
<body><%- include('../partials/topbar', { user }) %><%- include('../partials/sidebar') %><main class="main"><div class="container-fluid py-3">
<div class="d-flex align-items-center justify-content-between mb-4"><div><h2 class="mb-0"><%= title %></h2><div class="text-muted">Bank guarantee oversight report</div></div></div>
<div class="row g-3 mb-4"><div class="col-md-4"><div class="card shadow-sm"><div class="card-body"><div class="text-muted small">Guarantees</div><div class="fs-4 fw-semibold"><%= totals.totalGuarantees %></div></div></div></div><div class="col-md-4"><div class="card shadow-sm"><div class="card-body"><div class="text-muted small">Loan Amount</div><div class="fs-4 fw-semibold"><%= Number(totals.totalAmount || 0).toLocaleString() %></div></div></div></div><div class="col-md-4"><div class="card shadow-sm"><div class="card-body"><div class="text-muted small">Monthly Deduction</div><div class="fs-4 fw-semibold"><%= Number(totals.totalMonthly || 0).toLocaleString() %></div></div></div></div></div>
<div class="card mb-4 shadow-sm"><div class="card-body"><form method="GET" class="row g-3"><div class="col-md-2"><label class="form-label">PFNo</label><input class="form-control" name="pfNo" value="<%= filters.pfNo %>"></div><div class="col-md-3"><label class="form-label">Staff Name</label><input class="form-control" name="staffName" value="<%= filters.staffName %>"></div><div class="col-md-3"><label class="form-label">Department</label><select class="form-select" name="department"><option value="">All</option><% departments.forEach((item)=>{ %><option value="<%= item.Code %>" <%= filters.department===item.Code?'selected':'' %>><%= item.Dept %></option><% }) %></select></div><div class="col-md-2"><label class="form-label">Bank</label><select class="form-select" name="bank"><option value="">All</option><% banks.forEach((item)=>{ %><option value="<%= item.Code %>" <%= filters.bank===item.Code?'selected':'' %>><%= item.Bank %></option><% }) %></select></div><div class="col-md-2"><label class="form-label">Approval</label><select class="form-select" name="approvalStatus"><option value="">All</option><option value="pending" <%= filters.approvalStatus==='pending'?'selected':'' %>>Pending</option><option value="approved" <%= filters.approvalStatus==='approved'?'selected':'' %>>Approved</option><option value="rejected" <%= filters.approvalStatus==='rejected'?'selected':'' %>>Rejected</option></select></div><div class="col-md-2"><label class="form-label">From Date</label><input type="date" class="form-control" name="dateFrom" value="<%= filters.dateFrom %>"></div><div class="col-md-2"><label class="form-label">To Date</label><input type="date" class="form-control" name="dateTo" value="<%= filters.dateTo %>"></div><div class="col-md-3 d-flex align-items-end gap-2"><button class="btn btn-primary">Filter</button><a href="/manager/reports/guarantees" class="btn btn-secondary">Reset</a></div></form></div></div>
<div class="d-flex justify-content-end mb-3 d-print-none"><div class="btn-group"><button class="btn btn-success" onclick="exportExcel()">Export to Excel</button><button class="btn btn-danger" onclick="exportPDF()">Export to PDF</button><button class="btn btn-secondary" onclick="window.print()">Print</button></div></div>
<div class="card shadow-sm" id="printableArea"><div class="card-body"><div class="d-none d-print-block text-center mb-4"><h2 class="fw-bold"><%= company.Com_Name %></h2><h4 class="text-decoration-underline">Guarantees Report</h4></div><div class="table-responsive"><table class="table table-striped table-hover" id="dataTable"><thead><tr><th>Ref No</th><th>PFNo</th><th>Name</th><th>Dept</th><th>Bank</th><th>Loan Date</th><th>Loan Amount</th><th>Monthly</th><th>Expiry</th><th>Clearance</th><th>Approved</th></tr></thead><tbody><% if (!rows.length) { %><tr><td colspan="11" class="text-center">No records found.</td></tr><% } %><% rows.forEach((row)=>{ %><tr><td><%= row.RefNo || '-' %></td><td><%= row.PFNO %></td><td><%= row.SName || '-' %></td><td><%= row.DeptName || '-' %></td><td><%= row.BankName || row.Bank || '-' %></td><td><%= row.LoanDate ? new Date(row.LoanDate).toLocaleDateString() : '-' %></td><td><%= Number(row.LoanAmount || 0).toLocaleString() %></td><td><%= Number(row.Monthly || 0).toLocaleString() %></td><td><%= row.ExpiryDate ? new Date(row.ExpiryDate).toLocaleDateString() : '-' %></td><td><%= Number(row.Clearance || 0) ? 'Cleared' : 'Open' %></td><td><% if (Number(row.Approved || 0) === 0) { %>Pending<% } else if (Number(row.Approved || 0) === 2) { %>Rejected<% } else { %>Approved<% } %></td></tr><% }) %></tbody></table></div></div></div>
<script src="/vendor/bootstrap.bundle.min.js"></script><script src="/js/dashboard.js"></script><script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script><script src="https://cdn.sheetjs.com/xlsx-0.19.3/package/dist/xlsx.full.min.js"></script><script>function exportPDF(){const e=document.getElementById('printableArea');const h=e.querySelector('.d-print-block');const x=h&&h.classList.contains('d-none');if(x)h.classList.remove('d-none');html2pdf().set({margin:10,filename:'manager_guarantees_report.pdf',image:{type:'jpeg',quality:0.98},html2canvas:{scale:2},jsPDF:{unit:'mm',format:'a4',orientation:'landscape'}}).from(e).save().then(()=>{if(x)h.classList.add('d-none');});}function exportExcel(){const wb=XLSX.utils.table_to_book(document.getElementById('dataTable'),{sheet:'Guarantees'});XLSX.writeFile(wb,'manager_guarantees_report.xlsx');}</script></div></main></body></html>
