<!DOCTYPE html>
<html lang="en" data-bs-theme="light"><head><meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1" /><title><%= title %> · Manager</title><link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" /><link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" /><link href="/css/styles.css" rel="stylesheet" /></head>
<body><%- include('../partials/topbar', { user }) %><%- include('../partials/sidebar') %><main class="main"><div class="container-fluid py-3">
<div class="d-flex align-items-center justify-content-between mb-4"><div><h2 class="mb-0"><%= title %></h2><div class="text-muted">Oversight report for active staff vehicle insurance records</div></div></div>
<div class="card mb-4 shadow-sm"><div class="card-body"><form method="GET" class="row g-3"><div class="col-md-2"><label class="form-label">PFNo</label><input class="form-control" name="pfNo" value="<%= filters.pfNo %>"></div><div class="col-md-3"><label class="form-label">Staff Name</label><input class="form-control" name="staffName" value="<%= filters.staffName %>"></div><div class="col-md-3"><label class="form-label">Department</label><select class="form-select" name="department"><option value="">All</option><% departments.forEach((item)=>{ %><option value="<%= item.Code %>" <%= filters.department===item.Code?'selected':'' %>><%= item.Dept %></option><% }) %></select></div><div class="col-md-2"><label class="form-label">Insurer</label><select class="form-select" name="insurer"><option value="">All</option><% insurers.forEach((item)=>{ %><option value="<%= item.InsCode %>" <%= filters.insurer===item.InsCode?'selected':'' %>><%= item.InsName %></option><% }) %></select></div><div class="col-md-2"><label class="form-label">Approval</label><select class="form-select" name="approvalStatus"><option value="">All</option><option value="pending" <%= filters.approvalStatus==='pending'?'selected':'' %>>Pending</option><option value="approved" <%= filters.approvalStatus==='approved'?'selected':'' %>>Approved</option><option value="rejected" <%= filters.approvalStatus==='rejected'?'selected':'' %>>Rejected</option></select></div><div class="col-md-2"><label class="form-label">Expiry From</label><input type="date" class="form-control" name="expiryFrom" value="<%= filters.expiryFrom %>"></div><div class="col-md-2"><label class="form-label">Expiry To</label><input type="date" class="form-control" name="expiryTo" value="<%= filters.expiryTo %>"></div><div class="col-md-3 d-flex align-items-end gap-2"><button class="btn btn-primary">Filter</button><a href="/manager/reports/vehicle-insurance" class="btn btn-secondary">Reset</a></div></form></div></div>
<div class="d-flex justify-content-end mb-3 d-print-none"><div class="btn-group"><button class="btn btn-success" onclick="exportExcel()">Export to Excel</button><button class="btn btn-danger" onclick="exportPDF()">Export to PDF</button><button class="btn btn-secondary" onclick="window.print()">Print</button></div></div>
<div class="card shadow-sm" id="printableArea"><div class="card-body"><div class="d-none d-print-block text-center mb-4"><h2 class="fw-bold"><%= company.Com_Name %></h2><h4 class="text-decoration-underline">Vehicle Insurance Report</h4></div><div class="table-responsive"><table class="table table-striped table-hover" id="dataTable"><thead><tr><th>PFNo</th><th>Name</th><th>Department</th><th>Policy No</th><th>Insurer</th><th>Amount</th><th>Premium</th><th>Expiry</th><th>Renewed</th><th>Approval</th></tr></thead><tbody><% if (!rows.length) { %><tr><td colspan="10" class="text-center">No records found.</td></tr><% } %><% rows.forEach((row)=>{ %><tr><td><%= row.PFNo %></td><td><%= row.SName || '-' %></td><td><%= row.DeptName || '-' %></td><td><%= row.PolNo || '-' %></td><td><%= row.InsurerName || row.Insurer || '-' %></td><td><%= Number(row.InsAmount || 0).toLocaleString() %></td><td><%= Number(row.Premium || 0).toLocaleString() %></td><td><%= row.DateExp ? new Date(row.DateExp).toLocaleDateString() : '-' %></td><td><%= Number(row.Renewed || 0) ? 'Yes' : 'No' %></td><td><% if (Number(row.Approved || 0) === 0) { %>Pending<% } else if (Number(row.Approved || 0) === 2) { %>Rejected<% } else { %>Approved<% } %></td></tr><% }) %></tbody></table></div></div></div>
<script src="/vendor/bootstrap.bundle.min.js"></script><script src="/js/dashboard.js"></script><script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script><script src="https://cdn.sheetjs.com/xlsx-0.19.3/package/dist/xlsx.full.min.js"></script><script>function exportPDF(){const e=document.getElementById('printableArea');const h=e.querySelector('.d-print-block');const x=h&&h.classList.contains('d-none');if(x)h.classList.remove('d-none');html2pdf().set({margin:10,filename:'manager_vehicle_insurance_report.pdf',image:{type:'jpeg',quality:0.98},html2canvas:{scale:2},jsPDF:{unit:'mm',format:'a4',orientation:'landscape'}}).from(e).save().then(()=>{if(x)h.classList.add('d-none');});}function exportExcel(){const wb=XLSX.utils.table_to_book(document.getElementById('dataTable'),{sheet:'Vehicle Insurance'});XLSX.writeFile(wb,'manager_vehicle_insurance_report.xlsx');}</script></div></main></body></html>
