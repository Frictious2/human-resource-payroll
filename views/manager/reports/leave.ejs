<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> · Manager</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="/css/styles.css" rel="stylesheet" />
</head>
<body>
    <%- include('../partials/topbar', { user }) %>
    <%- include('../partials/sidebar') %>

    <main class="main">
        <div class="container-fluid py-3">
            <div class="d-flex align-items-center justify-content-between mb-4">
                <div>
                    <h2 class="mb-0"><%= title %></h2>
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb mt-2 mb-0">
                            <li class="breadcrumb-item"><a href="/manager/dashboard" class="text-decoration-none">Home</a></li>
                            <li class="breadcrumb-item">Reports</li>
                            <li class="breadcrumb-item active">Leave</li>
                        </ol>
                    </nav>
                </div>
            </div>

            <div class="card mb-4 shadow-sm">
                <div class="card-body">
                    <form method="GET" class="row g-3">
                        <div class="col-md-2"><label for="pfNo" class="form-label">PFNo</label><input type="text" class="form-control" id="pfNo" name="pfNo" value="<%= filters.pfNo %>"></div>
                        <div class="col-md-3"><label for="staffName" class="form-label">Staff Name</label><input type="text" class="form-control" id="staffName" name="staffName" value="<%= filters.staffName %>"></div>
                        <div class="col-md-2">
                            <label for="leaveType" class="form-label">Leave Type</label>
                            <select class="form-select" id="leaveType" name="leaveType">
                                <option value="">All</option>
                                <% leaveTypes.forEach((item) => { %><option value="<%= item.Code %>" <%= filters.leaveType === item.Code ? 'selected' : '' %>><%= item.LeaveType %></option><% }) %>
                            </select>
                        </div>
                        <div class="col-md-2"><label for="leaveYear" class="form-label">Leave Year</label><input type="text" class="form-control" id="leaveYear" name="leaveYear" value="<%= filters.leaveYear %>"></div>
                        <div class="col-md-3">
                            <label for="department" class="form-label">Department</label>
                            <select class="form-select" id="department" name="department">
                                <option value="">All</option>
                                <% departments.forEach((item) => { %><option value="<%= item.Code %>" <%= filters.department === item.Code ? 'selected' : '' %>><%= item.Dept %></option><% }) %>
                            </select>
                        </div>
                        <div class="col-md-2">
                            <label for="approvedStatus" class="form-label">Approval</label>
                            <select class="form-select" id="approvedStatus" name="approvedStatus">
                                <option value="">All</option>
                                <option value="pending" <%= filters.approvedStatus === 'pending' ? 'selected' : '' %>>Pending</option>
                                <option value="approved" <%= filters.approvedStatus === 'approved' ? 'selected' : '' %>>Approved</option>
                                <option value="rejected" <%= filters.approvedStatus === 'rejected' ? 'selected' : '' %>>Rejected</option>
                            </select>
                        </div>
                        <div class="col-md-2">
                            <label for="resumedStatus" class="form-label">Resumed</label>
                            <select class="form-select" id="resumedStatus" name="resumedStatus">
                                <option value="">All</option>
                                <option value="resumed" <%= filters.resumedStatus === 'resumed' ? 'selected' : '' %>>Resumed</option>
                                <option value="not_resumed" <%= filters.resumedStatus === 'not_resumed' ? 'selected' : '' %>>Not Resumed</option>
                            </select>
                        </div>
                        <div class="col-md-2"><label for="dateFrom" class="form-label">From Date</label><input type="date" class="form-control" id="dateFrom" name="dateFrom" value="<%= filters.dateFrom %>"></div>
                        <div class="col-md-2"><label for="dateTo" class="form-label">To Date</label><input type="date" class="form-control" id="dateTo" name="dateTo" value="<%= filters.dateTo %>"></div>
                        <div class="col-md-3 d-flex align-items-end gap-2"><button type="submit" class="btn btn-primary"><i class="bi bi-filter"></i> Filter</button><a href="/manager/reports/leave" class="btn btn-secondary"><i class="bi bi-arrow-counterclockwise"></i> Reset</a></div>
                    </form>
                </div>
            </div>

            <div class="d-flex justify-content-end mb-3 d-print-none">
                <div class="btn-group">
                    <button type="button" class="btn btn-success" onclick="exportExcel()"><i class="bi bi-file-earmark-excel"></i> Export to Excel</button>
                    <button type="button" class="btn btn-danger" onclick="exportPDF()"><i class="bi bi-file-earmark-pdf"></i> Export to PDF</button>
                    <button type="button" class="btn btn-secondary" onclick="window.print()"><i class="bi bi-printer"></i> Print</button>
                </div>
            </div>

            <div class="card shadow-sm" id="printableArea">
                <div class="card-body">
                    <div class="d-none d-print-block text-center mb-4"><h2 class="fw-bold"><%= company.Com_Name %></h2><h4 class="text-decoration-underline">Leave Report</h4></div>
                    <div class="table-responsive">
                        <table class="table table-striped table-hover" id="dataTable">
                            <thead><tr><th>PFNo</th><th>Name</th><th>Department</th><th>Leave Type</th><th>Year</th><th>Start Date</th><th>Days</th><th>Resumption</th><th>Bal. Days</th><th>With Pay</th><th>Allowance</th><th>Taxable</th><th>Tax</th><th>Resumed</th><th>Approved</th></tr></thead>
                            <tbody>
                                <% if (!rows.length) { %><tr><td colspan="15" class="text-center">No records found.</td></tr><% } %>
                                <% rows.forEach((row) => { %>
                                    <tr>
                                        <td><%= row.PFNO %></td><td><%= row.SName || '-' %></td><td><%= row.DeptName || '-' %></td><td><%= row.LeaveType || row.LType %></td><td><%= row.LYear || '-' %></td>
                                        <td><%= row.StartDate ? new Date(row.StartDate).toLocaleDateString() : '-' %></td><td><%= row.LDays ?? '-' %></td><td><%= row.ResumptionDate ? new Date(row.ResumptionDate).toLocaleDateString() : '-' %></td>
                                        <td><%= row.BalDays ?? '-' %></td><td><%= Number(row.WithPay || 0) ? 'Yes' : 'No' %></td><td><%= Number(row.Allowance || 0).toLocaleString() %></td>
                                        <td><%= Number(row.Taxable || 0).toLocaleString() %></td><td><%= Number(row.Tax || 0).toLocaleString() %></td><td><%= Number(row.Resumed || 0) ? 'Yes' : 'No' %></td>
                                        <td><% if (Number(row.Approved || 0) === 0) { %>Pending<% } else if (Number(row.Approved || 0) === 2) { %>Rejected<% } else { %>Approved<% } %></td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <script src="/vendor/bootstrap.bundle.min.js"></script>
    <script src="/js/dashboard.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
    <script src="https://cdn.sheetjs.com/xlsx-0.19.3/package/dist/xlsx.full.min.js"></script>
    <script>
        function exportPDF() {
            const element = document.getElementById('printableArea');
            const header = element.querySelector('.d-print-block');
            const wasHidden = header && header.classList.contains('d-none');
            if (wasHidden) header.classList.remove('d-none');
            html2pdf().set({ margin: 10, filename: 'manager_leave_report.pdf', image: { type: 'jpeg', quality: 0.98 }, html2canvas: { scale: 2 }, jsPDF: { unit: 'mm', format: 'a4', orientation: 'landscape' } }).from(element).save().then(() => {
                if (wasHidden) header.classList.add('d-none');
            });
        }
        function exportExcel() {
            const table = document.getElementById('dataTable');
            const wb = XLSX.utils.table_to_book(table, { sheet: 'Leave Report' });
            XLSX.writeFile(wb, 'manager_leave_report.xlsx');
        }
    </script>
</body>
</html>
