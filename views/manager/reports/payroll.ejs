<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> · <%= group %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="/css/styles.css" rel="stylesheet" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
    <style>
        .report-card {
            transition: transform 0.2s;
            cursor: pointer;
        }
        .report-card:hover {
            transform: translateY(-5px);
        }
        
        @media print {
            body.print-payslip * {
                visibility: hidden;
            }
            body.print-payslip #payslipContainer,
            body.print-payslip #payslipContainer * {
                visibility: visible;
            }
            body.print-payslip #payslipContainer {
                position: absolute;
                left: 0;
                top: 0;
                width: 100%;
                margin: 0;
                padding: 0;
                box-shadow: none !important;
            }
            body.print-payslip .modal-backdrop,
            body.print-payslip .modal-header,
            body.print-payslip .btn-close {
                display: none !important;
            }
        }
        
        #payslipContainer {
            font-size: 0.82rem;
            line-height: 1.2;
        }
        .payslip-header h3 { font-weight: bold; margin-bottom: 3px; font-size: 1.05rem; }
        .payslip-header p { margin-bottom: 2px; font-size: 0.8rem; }
        .payslip-section-title { font-weight: bold; border-bottom: 2px solid #000; margin-bottom: 6px; padding-bottom: 3px; font-size: 0.9rem; }
        .info-row { margin-bottom: 3px; }
        .amount-col { text-align: right; }
        .payslip-page {
            min-height: 297mm;
            page-break-after: always;
        }
    </style>
</head>
<body>
    <%- include('../partials/topbar', { user }) %>
    <%- include('../partials/sidebar') %>

    <main class="main">
        <div class="container-fluid">
            <div class="d-flex align-items-center justify-content-between mb-4">
                <h2 class="mb-0"><%= title %></h2>
            </div>

            <div class="row g-4">
                <div class="col-md-4">
                    <div class="card shadow-sm h-100 report-card" data-bs-toggle="modal" data-bs-target="#payslipModal">
                        <div class="card-body text-center p-5">
                            <i class="bi bi-file-earmark-text fs-1 text-primary mb-3"></i>
                            <h4 class="card-title">Payslip</h4>
                            <p class="card-text text-muted">Generate and print staff payslips</p>
                        </div>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="card shadow-sm h-100 report-card" data-bs-toggle="modal" data-bs-target="#voucherModal">
                        <div class="card-body text-center p-5">
                            <i class="bi bi-receipt fs-1 text-success mb-3"></i>
                            <h4 class="card-title">Voucher</h4>
                            <p class="card-text text-muted">View payment vouchers</p>
                        </div>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="card shadow-sm h-100 report-card">
                        <div class="card-body text-center p-5">
                            <i class="bi bi-cash-coin fs-1 text-warning mb-3"></i>
                            <h4 class="card-title">Bonus/Backlog</h4>
                            <p class="card-text text-muted">Bonus and backlog reports</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="modal fade" id="payslipModal" tabindex="-1" aria-hidden="true">
                <div class="modal-dialog">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title">Payslip Report</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <div class="modal-body">
                            <form id="payslipForm">
                                <div class="mb-3">
                                    <label class="form-label d-block">Report Scope</label>
                                    <div class="form-check form-check-inline">
                                        <input class="form-check-input" type="radio" name="reportScope" id="scopeAll" value="all" checked>
                                        <label class="form-check-label" for="scopeAll">All</label>
                                    </div>
                                    <div class="form-check form-check-inline">
                                        <input class="form-check-input" type="radio" name="reportScope" id="scopeStaff" value="staff">
                                        <label class="form-check-label" for="scopeStaff">Staff</label>
                                    </div>
                                </div>

                                <div class="mb-3">
                                    <label for="staffId" class="form-label">Staff ID</label>
                                    <input type="text" class="form-control" id="staffId" name="staffId" readonly>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label">Name</label>
                                    <div id="staffNameDisplay" class="form-control bg-light text-muted" style="min-height: 38px;"></div>
                                </div>

                                <div class="mb-3">
                                    <label for="period" class="form-label">Period (Month/Year)</label>
                                    <input type="month" class="form-control" id="period" name="period" required>
                                </div>

                                <div class="form-check mb-4">
                                    <input class="form-check-input" type="checkbox" id="displayYearly" name="displayYearly">
                                    <label class="form-check-label" for="displayYearly">
                                        Display Yearly Payments
                                    </label>
                                </div>

                                <div class="d-flex gap-2 justify-content-end">
                                    <button type="button" class="btn btn-info text-white" id="btnPreview"><i class="bi bi-eye"></i> Preview</button>
                                    <button type="button" class="btn btn-secondary" id="btnPrint"><i class="bi bi-printer"></i> Print</button>
                                    <button type="button" class="btn btn-danger" id="btnPdf"><i class="bi bi-file-pdf"></i> PDF</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>

            <div class="modal fade" id="voucherModal" tabindex="-1" aria-hidden="true">
                <div class="modal-dialog modal-lg">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title">Voucher Options</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <div class="modal-body">
                            <form id="voucherForm">
                                <div class="mb-3">
                                    <div class="row">
                                        <div class="col-md-4">
                                            <h6 class="mb-2">Select</h6>
                                            <div class="form-check">
                                                <input class="form-check-input" type="radio" name="voucherGroup" id="voucherGroupBank" value="bank" checked>
                                                <label class="form-check-label" for="voucherGroupBank">Bank</label>
                                            </div>
                                            <div class="form-check">
                                                <input class="form-check-input" type="radio" name="voucherGroup" id="voucherGroupCheque" value="cheque">
                                                <label class="form-check-label" for="voucherGroupCheque">Cheque</label>
                                            </div>
                                            <div class="form-check">
                                                <input class="form-check-input" type="radio" name="voucherGroup" id="voucherGroupMaster" value="master">
                                                <label class="form-check-label" for="voucherGroupMaster">Master</label>
                                            </div>
                                        </div>
                                        <div class="col-md-4">
                                            <div class="mb-3">
                                                <label for="voucherPeriod" class="form-label">Period</label>
                                                <input type="month" class="form-control" id="voucherPeriod" name="voucherPeriod">
                                            </div>
                                            <div class="mb-3">
                                                <label for="voucherType" class="form-label">Type</label>
                                                <select class="form-select" id="voucherType" name="voucherType">
                                                    <option value="rent">Rent</option>
                                                    <option value="inducement">Inducement</option>
                                                    <option value="leave">Leave</option>
                                                </select>
                                            </div>
                                        </div>
                                        <div class="col-md-4">
                                            <h6 class="mb-2">Payment</h6>
                                            <div class="form-check">
                                                <input class="form-check-input voucher-scope" type="checkbox" id="voucherScopeSalary" value="salary">
                                                <label class="form-check-label" for="voucherScopeSalary">Salary</label>
                                            </div>
                                            <div class="form-check">
                                                <input class="form-check-input voucher-scope" type="checkbox" id="voucherScopeYearly" value="yearly">
                                                <label class="form-check-label" for="voucherScopeYearly">Yearly</label>
                                            </div>
                                            <div class="form-check">
                                                <input class="form-check-input voucher-scope" type="checkbox" id="voucherScopeEos" value="eos">
                                                <label class="form-check-label" for="voucherScopeEos">EOS</label>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="mb-3">
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" id="voucherPrintContractors" name="voucherPrintContractors">
                                        <label class="form-check-label" for="voucherPrintContractors">Print Contractors</label>
                                    </div>
                                </div>
                                <div class="mb-3">
                                    <h6 class="mb-2">Signatures</h6>
                                    <div class="row align-items-center mb-2">
                                        <div class="col-md-3">
                                            <div class="form-check">
                                                <input class="form-check-input signature-toggle" type="checkbox" id="signature1Toggle">
                                                <label class="form-check-label" for="signature1Toggle">Signature 1</label>
                                            </div>
                                        </div>
                                        <div class="col-md-4 d-none" id="signature1SelectCol">
                                            <select class="form-select signature-select" id="signature1Select">
                                                <option value="">Select staff</option>
                                                <% if (typeof staffList !== 'undefined' && Array.isArray(staffList)) { %>
                                                    <% staffList.forEach(function(st) { %>
                                                        <option value="<%= st.PFNo %>" data-name="<%= st.SName %>"><%= st.PFNo %> - <%= st.SName %></option>
                                                    <% }); %>
                                                <% } %>
                                            </select>
                                        </div>
                                        <div class="col-md-5 d-none" id="signature1NameCol">
                                            <input type="text" class="form-control" id="signature1Name" readonly>
                                        </div>
                                    </div>
                                    <div class="row align-items-center mb-2">
                                        <div class="col-md-3">
                                            <div class="form-check">
                                                <input class="form-check-input signature-toggle" type="checkbox" id="signature2Toggle">
                                                <label class="form-check-label" for="signature2Toggle">Signature 2</label>
                                            </div>
                                        </div>
                                        <div class="col-md-4 d-none" id="signature2SelectCol">
                                            <select class="form-select signature-select" id="signature2Select">
                                                <option value="">Select staff</option>
                                                <% if (typeof staffList !== 'undefined' && Array.isArray(staffList)) { %>
                                                    <% staffList.forEach(function(st) { %>
                                                        <option value="<%= st.PFNo %>" data-name="<%= st.SName %>"><%= st.PFNo %> - <%= st.SName %></option>
                                                    <% }); %>
                                                <% } %>
                                            </select>
                                        </div>
                                        <div class="col-md-5 d-none" id="signature2NameCol">
                                            <input type="text" class="form-control" id="signature2Name" readonly>
                                        </div>
                                    </div>
                                    <div class="row align-items-center mb-2">
                                        <div class="col-md-3">
                                            <div class="form-check">
                                                <input class="form-check-input signature-toggle" type="checkbox" id="signature3Toggle">
                                                <label class="form-check-label" for="signature3Toggle">Signature 3</label>
                                            </div>
                                        </div>
                                        <div class="col-md-4 d-none" id="signature3SelectCol">
                                            <select class="form-select signature-select" id="signature3Select">
                                                <option value="">Select staff</option>
                                                <% if (typeof staffList !== 'undefined' && Array.isArray(staffList)) { %>
                                                    <% staffList.forEach(function(st) { %>
                                                        <option value="<%= st.PFNo %>" data-name="<%= st.SName %>"><%= st.PFNo %> - <%= st.SName %></option>
                                                    <% }); %>
                                                <% } %>
                                            </select>
                                        </div>
                                        <div class="col-md-5 d-none" id="signature3NameCol">
                                            <input type="text" class="form-control" id="signature3Name" readonly>
                                        </div>
                                    </div>
                                    <div class="d-flex gap-2 justify-content-end mt-4">
                                        <button type="button" class="btn btn-info text-white" id="btnVoucherPreview"><i class="bi bi-eye"></i> Preview</button>
                                        <button type="button" class="btn btn-secondary" id="btnVoucherPrint"><i class="bi bi-printer"></i> Print</button>
                                        <button type="button" class="btn btn-danger" id="btnVoucherPdf"><i class="bi bi-file-pdf"></i> PDF</button>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>

            <div class="modal fade" id="previewModal" tabindex="-1" aria-hidden="true">
                <div class="modal-dialog modal-fullscreen">
                    <div class="modal-content bg-light">
                        <div class="modal-header">
                            <h5 class="modal-title">Payslip Preview</h5>
                            <div class="ms-auto d-flex gap-2 align-items-center">
                                <button class="btn btn-secondary" id="prevBtn" disabled><i class="bi bi-arrow-left"></i> Previous</button>
                                <span class="badge bg-secondary fs-6" id="recordCounter"></span>
                                <button class="btn btn-secondary" id="nextBtn" disabled>Next <i class="bi bi-arrow-right"></i></button>
                                <div class="vr mx-2"></div>
                                <button class="btn btn-danger" onclick="downloadPdfWithScope()"><i class="bi bi-file-pdf"></i> PDF</button>
                                <button type="button" class="btn-close ms-2" data-bs-dismiss="modal" aria-label="Close"></button>
                            </div>
                        </div>
                        <div class="modal-body d-flex justify-content-center overflow-auto p-4">
                            <div id="payslipContainer" class="bg-white shadow p-5 position-relative" style="width: 210mm; min-height: 297mm; color: black;">
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <footer class="mt-4 py-3 text-center text-muted border-top">
                <%- include('../partials/footer') %>
            </footer>
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        const deductionMap = [
            { label: 'INCOME TAX', key: 'Tax' },
            { label: 'NASSIT-EMP', key: 'NassitEmp' },
            { label: 'PROV-EMP', key: 'GratEmp' },
            { label: 'LOAN DED', key: 'Ded1' },
            { label: 'UNION DUES', key: 'Ded2' },
            { label: 'INTEREST', key: 'Ded3' },
            { label: 'ADV-RENT-DED', key: 'Ded4' },
            { label: 'DED05', key: 'Ded5' }
        ];

        const additionMap = [
            { label: 'SALARY', key: 'Salary' },
            { label: 'RENT', key: 'Allw02' },
            { label: 'TRANSPORT', key: 'Allw03' },
            { label: 'WELFARE', key: 'Allw04' },
            { label: 'INDUCEMENT', key: 'Allw05' },
            { label: 'COLA', key: 'Allw06' },
            { label: 'BIKE ALLW', key: 'Allw07' },
            { label: 'EOS', key: 'Allw08' },
            { label: 'BONUS', key: 'Allw09' },
            { label: 'CAR MAINT', key: 'Allw10' },
            { label: 'RESPONSIBILITY', key: 'Allw11' },
            { label: 'MAID', key: 'Allw12' },
            { label: 'ACTING', key: 'Allw14' },
            { label: 'PROFESSIONAL', key: 'Allw16' },
            { label: 'RISK', key: 'Allw17' },
            { label: 'ACADEMIC', key: 'Allw19' }
        ];

        let currentData = [];
        let currentIndex = 0;
        let companyInfo = {};
        let periodInfo = {};
        let labels = { code32: 'Code 32', code41: 'NASSIT INST', code42: 'GRATUITY INST' };
        let cumulativeMap = {};
        let yearlyEnabled = false;
        let yearlyMap = {};
        let currentScope = 'all';

        let isVoucherMode = false;

        document.addEventListener('DOMContentLoaded', () => {
            const scopeAll = document.getElementById('scopeAll');
            const scopeStaff = document.getElementById('scopeStaff');
            const staffIdInput = document.getElementById('staffId');
            const staffNameDisplay = document.getElementById('staffNameDisplay');
            
            function updateStaffInputState() {
                if (scopeAll.checked) {
                    staffIdInput.readOnly = true;
                    staffIdInput.value = '';
                    staffNameDisplay.textContent = '';
                } else {
                    staffIdInput.readOnly = false;
                    staffIdInput.focus();
                }
            }
            scopeAll.addEventListener('change', updateStaffInputState);
            scopeStaff.addEventListener('change', updateStaffInputState);

            staffIdInput.addEventListener('blur', async () => {
                const pfno = staffIdInput.value.trim();
                if (!pfno) {
                    staffNameDisplay.textContent = '';
                    return;
                }
                try {
                    staffNameDisplay.textContent = 'Loading...';
                    const response = await fetch(`/manager/api/staff/${pfno}/name`);
                    const data = await response.json();
                    if (response.ok) {
                        staffNameDisplay.textContent = data.name;
                    } else {
                        staffNameDisplay.textContent = 'Staff not found';
                    }
                } catch (error) {
                    staffNameDisplay.textContent = 'Error fetching name';
                }
            });

            document.getElementById('btnPreview').addEventListener('click', () => loadPayslip('preview'));
            document.getElementById('btnPrint').addEventListener('click', () => loadPayslip('print'));
            document.getElementById('btnPdf').addEventListener('click', () => loadPayslip('pdf'));

            document.getElementById('prevBtn').addEventListener('click', () => {
                if (currentIndex > 0) {
                    currentIndex--;
                    renderPayslip(currentIndex);
                }
            });
            document.getElementById('nextBtn').addEventListener('click', () => {
                if (currentIndex < currentData.length - 1) {
                    currentIndex++;
                    renderPayslip(currentIndex);
                }
            });

            const voucherScopeInputs = document.querySelectorAll('.voucher-scope');
            voucherScopeInputs.forEach(input => {
                input.addEventListener('change', e => {
                    if (e.target.checked) {
                        voucherScopeInputs.forEach(other => {
                            if (other !== e.target) {
                                other.checked = false;
                            }
                        });
                    }
                });
            });

            const signatureToggles = [
                { toggleId: 'signature1Toggle', selectId: 'signature1Select', nameId: 'signature1Name', selectColId: 'signature1SelectCol', nameColId: 'signature1NameCol' },
                { toggleId: 'signature2Toggle', selectId: 'signature2Select', nameId: 'signature2Name', selectColId: 'signature2SelectCol', nameColId: 'signature2NameCol' },
                { toggleId: 'signature3Toggle', selectId: 'signature3Select', nameId: 'signature3Name', selectColId: 'signature3SelectCol', nameColId: 'signature3NameCol' }
            ];

            signatureToggles.forEach(cfg => {
                const toggle = document.getElementById(cfg.toggleId);
                const select = document.getElementById(cfg.selectId);
                const nameInput = document.getElementById(cfg.nameId);
                const selectCol = document.getElementById(cfg.selectColId);
                const nameCol = document.getElementById(cfg.nameColId);

                if (toggle && select && nameInput && selectCol && nameCol) {
                    toggle.addEventListener('change', () => {
                        if (toggle.checked) {
                            selectCol.classList.remove('d-none');
                            nameCol.classList.remove('d-none');
                        } else {
                            selectCol.classList.add('d-none');
                            nameCol.classList.add('d-none');
                            select.value = '';
                            nameInput.value = '';
                        }
                    });

                    select.addEventListener('change', () => {
                        const option = select.options[select.selectedIndex];
                        const staffName = option ? option.getAttribute('data-name') || '' : '';
                        nameInput.value = staffName;
                    });
                }
            });
        });

        async function loadPayslip(action) {
            isVoucherMode = false;
            const period = document.getElementById('period').value;
            if (!period) {
                alert('Please select a period');
                return;
            }
            const [year, month] = period.split('-');
            const scope = document.querySelector('input[name="reportScope"]:checked').value;
            const pfno = document.getElementById('staffId').value.trim();

            if (scope === 'staff' && !pfno) {
                alert('Please enter a Staff ID');
                return;
            }

            try {
                const inputModal = bootstrap.Modal.getInstance(document.getElementById('payslipModal'));
                const yearly = document.getElementById('displayYearly') ? (document.getElementById('displayYearly').checked ? '1' : '0') : '0';
                const url = `/data-entry/api/reports/payslip?month=${parseInt(month)}&year=${year}&scope=${scope}&pfno=${pfno}&yearly=${yearly}`;
                const response = await fetch(url);
                const result = await response.json();

                if (!result.data || result.data.length === 0) {
                    alert('No payroll data found for this selection.');
                    return;
                }

                currentData = result.data;
                companyInfo = result.company;
                periodInfo = result.period;
                labels = result.labels || labels;
                cumulativeMap = {};
                if (Array.isArray(result.cumulative)) {
                    result.cumulative.forEach(row => {
                        cumulativeMap[row.PFNo] = row;
                    });
                }
                currentIndex = 0;
                currentScope = scope;
                yearlyEnabled = !!result.yearly;
                yearlyMap = result.yearlyTotals || {};

                inputModal.hide();
                
                const previewModal = new bootstrap.Modal(document.getElementById('previewModal'));
                
                // Show UI elements for Payslip
                document.getElementById('prevBtn').style.display = 'inline-block';
                document.getElementById('nextBtn').style.display = 'inline-block';
                document.getElementById('recordCounter').style.display = 'inline-block';
                document.querySelector('#previewModal .modal-title').textContent = 'Payslip Preview';
                
                renderPayslip(0);
                previewModal.show();

                if (action === 'print') {
                   setTimeout(() => {
                        if (currentScope === 'all') {
                            renderAllPayslips();
                        }
                        triggerPrint();
                   }, 500);
                } else if (action === 'pdf') {
                   setTimeout(() => {
                        if (currentScope === 'all') {
                            renderAllPayslips();
                        }
                        downloadPdf();
                   }, 500);
                }

            } catch (error) {
                console.error(error);
                alert('Error fetching payslip data');
            }
        }

        function formatCurrency(value) {
            return parseFloat(value || 0).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
        }
        
        function getMonthName(monthNum) {
             const date = new Date();
             date.setMonth(monthNum - 1);
             return date.toLocaleString('en-US', { month: 'long' });
        }

        function renderPayslip(index) {
            const data = currentData[index];
            const container = document.getElementById('payslipContainer');
            
            document.getElementById('prevBtn').disabled = index === 0;
            document.getElementById('nextBtn').disabled = index === currentData.length - 1;
            document.getElementById('recordCounter').textContent = `${index + 1} / ${currentData.length}`;

            let totalAdditions = 0;
            let totalDeductions = 0;
            
            const additionsHtml = additionMap.map(item => {
                const val = parseFloat(data[item.key] || 0);
                totalAdditions += val;
                return `
                    <div class="d-flex justify-content-between info-row">
                        <span>${item.label}</span>
                        <span>${formatCurrency(val)}</span>
                    </div>
                `;
            }).join('');

            const deductionsHtml = deductionMap.map(item => {
                const val = parseFloat(data[item.key] || 0);
                totalDeductions += val;
                return `
                    <div class="d-flex justify-content-between info-row">
                        <span>${item.label}</span>
                        <span>${formatCurrency(val)}</span>
                    </div>
                `;
            }).join('');
            
            const netPay = totalAdditions - totalDeductions;
            const totalIncomeVal = (data.TotalIncome != null ? parseFloat(data.TotalIncome) : totalAdditions);
            const taxableIncomeVal = (data.Taxable != null ? parseFloat(data.Taxable) : 0);

            const cum = cumulativeMap[data.PFNo] || {};
            const cumNassitEmp = parseFloat(cum.TotNassitEmp || 0);
            const cumNassitInst = parseFloat(cum.TotNassitInst || 0);
            const cumGratEmp = parseFloat(cum.TotGratEmp || 0);
            const cumGratInst = parseFloat(cum.TotGratInst || 0);
            const nassitTotal = cumNassitEmp + cumNassitInst;
            const provFundBalance = parseFloat(data.GratEmp || 0) + parseFloat(data.GratInst || 0);

            const yearlyItems = yearlyEnabled && yearlyMap[data.PFNo] ? yearlyMap[data.PFNo] : null;
            const yearlyHtml = yearlyEnabled ? `
                <div class="mt-4">
                    <h5 class="payslip-section-title text-center">Yearly Payments</h5>
                    <div class="row fw-bold text-decoration-underline mb-1">
                        <div class="col-4">Allowance</div>
                        <div class="col-2 text-end">Gross</div>
                        <div class="col-2 text-end">Tax</div>
                        <div class="col-2 text-end">Net</div>
                    </div>
                    ${
                        yearlyItems && yearlyItems.length > 0
                            ? yearlyItems.map(it => {
                                const gross = parseFloat(it.amount || 0);
                                const tax = parseFloat(it.tax || 0);
                                const net = gross - tax;
                                return `
                                    <div class="row info-row">
                                        <div class="col-4">${it.label}</div>
                                        <div class="col-2 text-end">${formatCurrency(gross)}</div>
                                        <div class="col-2 text-end">${formatCurrency(tax)}</div>
                                        <div class="col-2 text-end">${formatCurrency(net)}</div>
                                    </div>
                                `;
                              }).join('')
                            : `<div class="text-center text-muted">No yearly payments</div>`
                    }
                </div>
            ` : '';

            container.innerHTML = `
                <div class="payslip-header mb-3">
                    <div class="d-flex justify-content-center align-items-center mb-1">
                        ${companyInfo.logo ? `<img src="${companyInfo.logo}" alt="Company Logo" style="max-height: 60px;" class="me-3">` : ''}
                        <div class="text-center">
                            <h3 class="mb-0">${companyInfo.name || 'Company Name'}</h3>
                            <p class="mb-0">${companyInfo.address || 'Address'}</p>
                        </div>
                    </div>
                    <h4 class="mt-2 text-center text-uppercase text-decoration-underline">Payslip for period ending ${getMonthName(periodInfo.month)} ${periodInfo.year}</h4>
                </div>

                <div class="row mb-4 border-bottom pb-3">
                    <div class="col-6">
                        <div class="d-flex justify-content-between mb-2"><strong>Name:</strong> <span>${data.SName || ''}</span></div>
                        <div class="d-flex justify-content-between mb-2"><strong>Employee ID:</strong> <span>${data.PFNo || ''}</span></div>
                        <div class="d-flex justify-content-between mb-2"><strong>Department:</strong> <span>${data.DeptName || ''}</span></div>
                    </div>
                    <div class="col-6">
                        <div class="d-flex justify-content-between mb-2"><strong>Account No:</strong> <span>${data.AccountNo || ''}</span></div>
                        <div class="d-flex justify-content-between mb-2"><strong>Job Title:</strong> <span>${data.JobTitleName || ''}</span></div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-6 border-end">
                        <h5 class="payslip-section-title">Additions</h5>
                        ${additionsHtml}
                    </div>
                    <div class="col-6">
                        <h5 class="payslip-section-title">Deductions</h5>
                        ${deductionsHtml}
                        <div class="d-flex justify-content-between border-top mt-2 pt-2 fw-bold">
                            <span>TOTAL DEDUCTIONS</span>
                            <span>${formatCurrency(totalDeductions)}</span>
                        </div>
                        <div class="d-flex justify-content-between mt-4 pt-2">
                            <span class="fw-bold">NET INCOME</span>
                            <span class="fw-bold">${formatCurrency(netPay)}</span>
                        </div>
                    </div>
                </div>

                <div class="row mt-3">
                    <div class="col-6">
                        <div class="d-flex justify-content-between info-row">
                            <span class="fw-bold">TOTAL INCOME</span>
                            <span class="fw-bold">${formatCurrency(totalIncomeVal)}</span>
                        </div>
                        <div class="d-flex justify-content-between info-row">
                            <span class="fw-bold">Taxable Income</span>
                            <span class="fw-bold">${formatCurrency(taxableIncomeVal)}</span>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="d-flex justify-content-between info-row">
                            <span class="fw-bold">${labels.code42 || 'Code 42'}</span>
                            <span class="fw-bold">${formatCurrency(data.GratInst || 0)}</span>
                        </div>
                        <div class="d-flex justify-content-between info-row">
                            <span class="fw-bold">${labels.code41 || 'Code 41'}</span>
                            <span class="fw-bold">${formatCurrency(data.NassitInst || 0)}</span>
                        </div>
                    </div>
                </div>

                <div class="mt-4">
                    <h5 class="payslip-section-title">Cumulative Balances</h5>
                    <div class="row">
                        <div class="col-6">
                            <div class="d-flex justify-content-between info-row">
                                <span>${labels.code32 || 'Code 32'}</span>
                                <span>${formatCurrency(cumNassitEmp)}</span>
                            </div>
                            <div class="d-flex justify-content-between info-row">
                                <span>NASSIT TOTAL</span>
                                <span>${formatCurrency(nassitTotal)}</span>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="d-flex justify-content-between info-row">
                                <span>${labels.code41 || 'Code 41'}</span>
                                <span>${formatCurrency(cumNassitInst)}</span>
                            </div>
                            <div class="d-flex justify-content-between info-row">
                                <span>Prov. Fund Balance</span>
                                <span>${formatCurrency(provFundBalance)}</span>
                            </div>
                        </div>
                    </div>
                </div>
                ${yearlyHtml}
                <div class="mt-5 pt-5 text-center text-muted" style="font-size: 0.8rem;">
                    <p>Generated on ${new Date().toLocaleDateString()}</p>
                </div>
            `;
        }

        function buildPayslipHtml(data) {
            let totalAdditions = 0;
            let totalDeductions = 0;
            const additionsHtml = additionMap.map(item => {
                const val = parseFloat(data[item.key] || 0);
                totalAdditions += val;
                return `
                    <div class="d-flex justify-content-between info-row">
                        <span>${item.label}</span>
                        <span>${formatCurrency(val)}</span>
                    </div>
                `;
            }).join('');
            const deductionsHtml = deductionMap.map(item => {
                const val = parseFloat(data[item.key] || 0);
                totalDeductions += val;
                return `
                    <div class="d-flex justify-content-between info-row">
                        <span>${item.label}</span>
                        <span>${formatCurrency(val)}</span>
                    </div>
                `;
            }).join('');
            const netPay = totalAdditions - totalDeductions;
            const totalIncomeVal = (data.TotalIncome != null ? parseFloat(data.TotalIncome) : totalAdditions);
            const taxableIncomeVal = (data.Taxable != null ? parseFloat(data.Taxable) : 0);
            const cum = cumulativeMap[data.PFNo] || {};
            const cumNassitEmp = parseFloat(cum.TotNassitEmp || 0);
            const cumNassitInst = parseFloat(cum.TotNassitInst || 0);
            const nassitTotal = cumNassitEmp + cumNassitInst;
            const provFundBalance = parseFloat(data.GratEmp || 0) + parseFloat(data.GratInst || 0);
            const yearlyItems = yearlyEnabled && yearlyMap[data.PFNo] ? yearlyMap[data.PFNo] : null;
            const yearlyHtml = yearlyEnabled ? `
                <div class="mt-4">
                    <h5 class="payslip-section-title text-center">Yearly Payments</h5>
                    <div class="row fw-bold text-decoration-underline mb-1">
                        <div class="col-4">Allowance</div>
                        <div class="col-2 text-end">Gross</div>
                        <div class="col-2 text-end">Tax</div>
                        <div class="col-2 text-end">Net</div>
                    </div>
                    ${
                        yearlyItems && yearlyItems.length > 0
                            ? yearlyItems.map(it => {
                                const gross = parseFloat(it.amount || 0);
                                const tax = parseFloat(it.tax || 0);
                                const net = gross - tax;
                                return `
                                    <div class="row info-row">
                                        <div class="col-4">${it.label}</div>
                                        <div class="col-2 text-end">${formatCurrency(gross)}</div>
                                        <div class="col-2 text-end">${formatCurrency(tax)}</div>
                                        <div class="col-2 text-end">${formatCurrency(net)}</div>
                                    </div>
                                `;
                              }).join('')
                            : `<div class="text-center text-muted">No yearly payments</div>`
                    }
                </div>
            ` : '';
            return `
                <div class="payslip-header mb-3">
                    <div class="d-flex justify-content-center align-items-center mb-1">
                        ${companyInfo.logo ? `<img src="${companyInfo.logo}" alt="Company Logo" style="max-height: 60px;" class="me-3">` : ''}
                        <div class="text-center">
                            <h3 class="mb-0">${companyInfo.name || 'Company Name'}</h3>
                            <p class="mb-0">${companyInfo.address || 'Address'}</p>
                        </div>
                    </div>
                    <h4 class="mt-2 text-center text-uppercase text-decoration-underline">Payslip for period ending ${getMonthName(periodInfo.month)} ${periodInfo.year}</h4>
                </div>
                <div class="row mb-4 border-bottom pb-3">
                    <div class="col-6">
                        <div class="d-flex justify-content-between mb-2"><strong>Name:</strong> <span>${data.SName || ''}</span></div>
                        <div class="d-flex justify-content-between mb-2"><strong>Employee ID:</strong> <span>${data.PFNo || ''}</span></div>
                        <div class="d-flex justify-content-between mb-2"><strong>Department:</strong> <span>${data.DeptName || ''}</span></div>
                    </div>
                    <div class="col-6">
                        <div class="d-flex justify-content-between mb-2"><strong>Account No:</strong> <span>${data.AccountNo || ''}</span></div>
                        <div class="d-flex justify-content-between mb-2"><strong>Job Title:</strong> <span>${data.JobTitleName || ''}</span></div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-6 border-end">
                        <h5 class="payslip-section-title">Additions</h5>
                        ${additionsHtml}
                    </div>
                    <div class="col-6">
                        <h5 class="payslip-section-title">Deductions</h5>
                        ${deductionsHtml}
                        <div class="d-flex justify-content-between border-top mt-2 pt-2 fw-bold">
                            <span>TOTAL DEDUCTIONS</span>
                            <span>${formatCurrency(totalDeductions)}</span>
                        </div>
                        <div class="d-flex justify-content-between mt-4 pt-2">
                            <span class="fw-bold">NET INCOME</span>
                            <span class="fw-bold">${formatCurrency(netPay)}</span>
                        </div>
                    </div>
                </div>
                <div class="row mt-3">
                    <div class="col-6">
                        <div class="d-flex justify-content-between info-row">
                            <span class="fw-bold">TOTAL INCOME</span>
                            <span class="fw-bold">${formatCurrency(totalIncomeVal)}</span>
                        </div>
                        <div class="d-flex justify-content-between info-row">
                            <span class="fw-bold">Taxable Income</span>
                            <span class="fw-bold">${formatCurrency(taxableIncomeVal)}</span>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="d-flex justify-content-between info-row">
                            <span class="fw-bold">${labels.code42 || 'Code 42'}</span>
                            <span class="fw-bold">${formatCurrency(data.GratInst || 0)}</span>
                        </div>
                        <div class="d-flex justify-content-between info-row">
                            <span class="fw-bold">${labels.code41 || 'Code 41'}</span>
                            <span class="fw-bold">${formatCurrency(data.NassitInst || 0)}</span>
                        </div>
                    </div>
                </div>
                <div class="mt-4">
                    <h5 class="payslip-section-title">Cumulative Balances</h5>
                    <div class="row">
                        <div class="col-6">
                            <div class="d-flex justify-content-between info-row">
                                <span>${labels.code32 || 'Code 32'}</span>
                                <span>${formatCurrency(parseFloat(cumulativeMap[data.PFNo]?.TotNassitEmp || 0))}</span>
                            </div>
                            <div class="d-flex justify-content-between info-row">
                                <span>NASSIT TOTAL</span>
                                <span>${formatCurrency(parseFloat(cumulativeMap[data.PFNo]?.TotNassitEmp || 0) + parseFloat(cumulativeMap[data.PFNo]?.TotNassitInst || 0))}</span>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="d-flex justify-content-between info-row">
                                <span>${labels.code41 || 'Code 41'}</span>
                                <span>${formatCurrency(parseFloat(cumulativeMap[data.PFNo]?.TotNassitInst || 0))}</span>
                            </div>
                            <div class="d-flex justify-content-between info-row">
                                <span>Prov. Fund Balance</span>
                                <span>${formatCurrency(parseFloat(data.GratEmp || 0) + parseFloat(data.GratInst || 0))}</span>
                            </div>
                        </div>
                    </div>
                </div>
                ${yearlyHtml}
                <div class="mt-5 pt-5 text-center text-muted" style="font-size: 0.8rem;">
                    <p>Generated on ${new Date().toLocaleDateString()}</p>
                </div>
            `;
        }

        function renderAllPayslips() {
            const container = document.getElementById('payslipContainer');
            const pages = currentData.map(rec => {
                const pageHtml = buildPayslipHtml(rec);
                return `<div class="payslip-page">${pageHtml}</div>`;
            }).join('');
            container.innerHTML = pages;
        }

        function downloadPdf() {
            const element = document.getElementById('payslipContainer');
            
            // Customize options based on mode
            const filename = isVoucherMode 
                ? `Voucher_${new Date().toISOString().slice(0,10)}.pdf`
                : `payslip_${currentData[currentIndex]?.PFNo || 'all'}.pdf`;

            const opt = {
                margin:       0,
                filename:     filename,
                image:        { type: 'jpeg', quality: 0.98 },
                html2canvas:  { scale: 2 },
                jsPDF:        { unit: 'mm', format: 'a4', orientation: 'portrait' },
                pagebreak:    { mode: ['css', 'legacy'] }
            };
            html2pdf().set(opt).from(element).save();
        }

        function triggerPrint() {
            document.body.classList.add('print-payslip');
            window.print();
            setTimeout(() => {
                document.body.classList.remove('print-payslip');
            }, 500);
        }
        function downloadPdfWithScope() {
            if (currentScope === 'all' && !isVoucherMode) {
                renderAllPayslips();
                setTimeout(() => downloadPdf(), 200);
            } else {
                downloadPdf();
            }
        }

        // Voucher Logic
        document.getElementById('btnVoucherPreview').addEventListener('click', () => loadVoucher('preview'));
        document.getElementById('btnVoucherPrint').addEventListener('click', () => loadVoucher('print'));
        document.getElementById('btnVoucherPdf').addEventListener('click', () => loadVoucher('pdf'));

        async function loadVoucher(action) {
            isVoucherMode = true;
            const periodInput = document.getElementById('voucherPeriod');
            const period = periodInput ? periodInput.value : '';
            
            if (!period) {
                alert('Please select a period');
                return;
            }
            const [year, month] = period.split('-');
            
            const groupEl = document.querySelector('input[name="voucherGroup"]:checked');
            if (!groupEl) {
                alert('Please select a group');
                return;
            }
            const group = groupEl.value;
            
            const scopes = [];
            document.querySelectorAll('.voucher-scope:checked').forEach(cb => scopes.push(cb.value));
            
            if (scopes.length === 0) {
                alert('Please select at least one payment scope (Salary, Yearly, EOS)');
                return;
            }
            
            const signatures = [];
            if (document.getElementById('signature1Toggle').checked) signatures.push({ name: document.getElementById('signature1Name').value, title: 'Prepared By' });
            if (document.getElementById('signature2Toggle').checked) signatures.push({ name: document.getElementById('signature2Name').value, title: 'Checked By' });
            if (document.getElementById('signature3Toggle').checked) signatures.push({ name: document.getElementById('signature3Name').value, title: 'Approved By' });

            try {
                const voucherModal = bootstrap.Modal.getInstance(document.getElementById('voucherModal'));
                voucherModal.hide();

                const response = await fetch('/data-entry/api/reports/voucher/preview', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ month, year, group, scope: scopes })
                });
                
                const result = await response.json();
                if (!result.success || !result.data || result.data.length === 0) {
                    alert('No data found');
                    return;
                }
                
                renderVoucherPreview(result, signatures);
                
                const previewModal = new bootstrap.Modal(document.getElementById('previewModal'));
                // Reset UI elements for Voucher
                document.getElementById('prevBtn').style.display = 'none';
                document.getElementById('nextBtn').style.display = 'none';
                document.getElementById('recordCounter').style.display = 'none';
                document.querySelector('#previewModal .modal-title').textContent = 'Voucher Preview';

                previewModal.show();

                if (action === 'print') {
                   setTimeout(() => {
                        triggerPrint();
                   }, 500);
                } else if (action === 'pdf') {
                   setTimeout(() => {
                        downloadPdf();
                   }, 500);
                }
                
            } catch (e) {
                console.error(e);
                alert('Error generating voucher');
            }
        }

        function renderVoucherPreview(result, signatures) {
             const { company, data, meta } = result;
             const container = document.getElementById('payslipContainer');
             container.innerHTML = ''; // Clear container

             const ROWS_PER_PAGE = 20;
             const totalPages = Math.ceil(data.length / ROWS_PER_PAGE);
             let totalNet = 0;
             let overallTotalNet = 0; // To track total across all pages if needed, but usually total is at bottom

             // Calculate overall total first
             data.forEach(row => {
                 overallTotalNet += parseFloat(row.NetIncome || 0);
             });

             let html = '';

             for (let page = 0; page < totalPages; page++) {
                 const start = page * ROWS_PER_PAGE;
                 const end = start + ROWS_PER_PAGE;
                 const chunk = data.slice(start, end);
                 
                 let chunkHtml = '';
                 chunk.forEach((row, i) => {
                     const net = parseFloat(row.NetIncome || 0);
                     chunkHtml += `
                        <tr>
                            <td>${start + i + 1}</td>
                            <td>${row.PFNo}</td>
                            <td>${row.SName}</td>
                            <td>${row.BankName || ''}</td>
                            <td>${row.StaffAccount || ''}</td>
                            <td class="text-end">${formatCurrency(net)}</td>
                            <td style="width: 100px;"></td>
                        </tr>
                     `;
                 });

                 // Fill empty rows if needed to maintain height? No, flexible is better.
                 
                 const isLastPage = page === totalPages - 1;
                 
                 const sigHtml = signatures.map(sig => `
                    <div class="text-center" style="min-width: 150px;">
                        <div class="border-bottom border-dark mb-2" style="height: 40px;"></div>
                        <p class="fw-bold mb-0">${sig.name}</p>
                        <small>${sig.title}</small>
                    </div>
                 `).join('');

                 const headerHtml = `
                    <div class="text-center mb-4">
                        ${company.LogoPath ? `<img src="${company.LogoPath}" style="height: 60px;" class="mb-2">` : ''}
                        <h3 class="fw-bold mb-0 text-uppercase">${company.Com_Name || 'Company Name'}</h3>
                        <p class="mb-2">${company.Address || ''}</p>
                        <h4 class="text-uppercase text-decoration-underline mt-3">PAYMENT VOUCHER - ${meta.group.toUpperCase()}</h4>
                        <p class="fw-bold">PERIOD: ${meta.year}-${meta.month}</p>
                    </div>
                 `;

                 const footerHtml = isLastPage ? `
                    <tfoot class="fw-bold">
                        <tr>
                            <td colspan="5" class="text-end">TOTAL</td>
                            <td class="text-end">${formatCurrency(overallTotalNet)}</td>
                            <td></td>
                        </tr>
                    </tfoot>
                 ` : '';

                 const signatureSection = isLastPage ? `
                    <div class="d-flex justify-content-around mt-5 pt-5">
                        ${sigHtml}
                    </div>
                 ` : '';

                 const pageContent = `
                    <div class="payslip-page p-5 position-relative bg-white" style="min-height: 297mm; width: 210mm; margin: 0 auto;">
                        ${headerHtml}
                        <table class="table table-bordered table-sm" style="font-size: 0.8rem;">
                            <thead class="table-light">
                                <tr>
                                    <th>#</th>
                                    <th>PF No</th>
                                    <th>Name</th>
                                    <th>Bank</th>
                                    <th>Account No</th>
                                    <th class="text-end">Net Pay</th>
                                    <th>Signature</th>
                                </tr>
                            </thead>
                            <tbody>${chunkHtml}</tbody>
                            ${footerHtml}
                        </table>
                        ${signatureSection}
                        <div class="mt-4 text-center text-muted small">
                            Page ${page + 1} of ${totalPages} - Generated on ${new Date().toLocaleDateString()}
                        </div>
                    </div>
                 `;
                 
                 html += pageContent;
             }

             container.innerHTML = html;
        }
    </script>
</body>
</html>
