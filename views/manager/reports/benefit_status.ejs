<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> · Manager</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="/css/styles.css" rel="stylesheet" />
</head>
<body>
<%- include('../partials/topbar') %>
<%- include('../partials/sidebar') %>
<main class="main">
    <div class="container-fluid py-3">
        <div class="d-flex align-items-center justify-content-between mb-4">
            <div>
                <h2 class="mb-0"><%= title %></h2>
                <nav aria-label="breadcrumb"><ol class="breadcrumb mt-2 mb-0"><li class="breadcrumb-item"><a href="/manager/dashboard" class="text-decoration-none">Home</a></li><li class="breadcrumb-item">Reports</li><li class="breadcrumb-item active">Benefit Status</li></ol></nav>
            </div>
        </div>

        <div class="card shadow-sm mb-4">
            <div class="card-body">
                <form id="benefitForm" action="/manager/api/reports/benefit-status/calculate" method="POST" class="row g-3">
                    <div class="col-md-3">
                        <label class="form-label fw-bold">Preview Type</label>
                        <div class="d-flex gap-3 pt-2">
                            <div class="form-check"><input class="form-check-input" type="radio" name="searchType" id="typeExGratia" value="ex-gracia" checked><label class="form-check-label" for="typeExGratia">Ex-Gratia</label></div>
                            <div class="form-check"><input class="form-check-input" type="radio" name="searchType" id="typeEOS" value="eos"><label class="form-check-label" for="typeEOS">End of Service Benefit</label></div>
                        </div>
                    </div>
                    <div class="col-md-2">
                        <label for="pfNo" class="form-label">PFNo</label>
                        <input type="text" class="form-control" id="pfNo" name="pfNo" value="<%= filters?.pfNo || '' %>" placeholder="Leave blank for all">
                        <input type="hidden" name="staffId" value="<%= filters?.pfNo || '' %>">
                    </div>
                    <div class="col-md-3">
                        <label for="department" class="form-label">Department</label>
                        <select class="form-select" id="department" name="department">
                            <option value="">All Departments</option>
                            <% (departments || []).forEach((item) => { %>
                                <option value="<%= item.Code %>" <%= filters?.department === item.Code ? 'selected' : '' %>><%= item.Dept %></option>
                            <% }) %>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label for="endDate" class="form-label">Preview Date</label>
                        <input type="date" class="form-control" id="endDate" name="endDate" value="<%= filters?.previewDate || '' %>" required>
                    </div>
                    <div class="col-md-2 d-flex align-items-end">
                        <button type="submit" class="btn btn-primary w-100"><i class="bi bi-calculator"></i> Generate Preview</button>
                    </div>
                </form>
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="card-body text-muted">
                Ex-Gratia preview uses the staff date of employment and the selected preview date, then reads only the latest approved basic salary from <code>tblsalary</code>. End of Service Benefit preview uses the selected preview date with the existing <code>tblEOSCalc</code> parameters and the latest approved basic salary. Leave PFNo blank to return all matching staff, or enter a PFNo to preview one staff member only.
            </div>
        </div>
    </div>

    <footer class="mt-4 py-3 text-center text-muted border-top">
        <%- include('../partials/footer') %>
    </footer>
</main>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
    document.addEventListener('DOMContentLoaded', function () {
        const pfNoInput = document.getElementById('pfNo');
        const staffIdInput = document.querySelector('input[name="staffId"]');
        if (pfNoInput && staffIdInput) {
            pfNoInput.addEventListener('input', function () {
                staffIdInput.value = pfNoInput.value;
            });
        }
    });
</script>
</body>
</html>
