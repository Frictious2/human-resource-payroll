<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> · HR & Payroll</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="/css/styles.css" rel="stylesheet" />
</head>
<body>
    <%- include('../partials/topbar', { user }) %>
    <%- include('../partials/sidebar') %>

    <main class="main">
        <div class="container-fluid">
            <div class="d-flex align-items-center justify-content-between mb-4">
                <div>
                    <h2 class="mb-0">Approve Income Setup</h2>
                    <div class="text-muted">Review pending salary and allowance setups</div>
                </div>
            </div>

            <div class="card shadow-sm">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Scale Date</th>
                                    <th>Grade</th>
                                    <th>Currency</th>
                                    <th>Levels</th>
                                    <th>Notches</th>
                                    <th>Increment</th>
                                    <th class="text-end">Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if ((allowances || []).length > 0) { %>
                                    <% allowances.forEach(a => { %>
                                        <tr>
                                            <td><%= a.ScaleDate ? new Date(a.ScaleDate).toLocaleDateString() : '-' %></td>
                                            <td><%= a.Grade || '-' %></td>
                                            <td><%= a.PayCurrency || '-' %></td>
                                            <td><%= (a.StartLevel || '-') %> - <%= (a.EndLevel || '-') %></td>
                                            <td><%= a.Notches || '-' %></td>
                                            <td><%= a.Increment || '-' %></td>
                                            <td class="text-end">
                                                <a class="btn btn-sm btn-primary" href="/manager/approve/income-setup/view?grade=<%= a.Grade %>&scaleDate=<%= a.ScaleDate %>">
                                                    <i class="bi bi-eye"></i> View
                                                </a>
                                            </td>
                                        </tr>
                                    <% }) %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="7" class="text-center py-4 text-muted">No pending setups</td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
