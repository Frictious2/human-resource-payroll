<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> · HR & Payroll</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="/css/styles.css" rel="stylesheet" />
    <style>
        .dependant-over-age {
            color: #dc3545;
            font-weight: 600;
        }
    </style>
</head>
<body>
    <%- include('../partials/topbar', { user }) %>
    <%- include('../partials/sidebar') %>

    <main class="main">
        <div class="container-fluid">
            <div class="d-flex align-items-center justify-content-between mb-4">
                <div>
                    <h2 class="mb-0">View Staff Record</h2>
                    <div class="text-muted">Read-only review. Approve or Reject below.</div>
                </div>
            </div>

            <div class="card shadow-sm">
                <div class="card-header bg-white">
                    <ul class="nav nav-tabs card-header-tabs" id="staffTabs" role="tablist">
                        <li class="nav-item" role="presentation">
                            <button class="nav-link active" id="personal-tab" data-bs-toggle="tab" data-bs-target="#personal" type="button" role="tab" aria-controls="personal" aria-selected="true">1. Personal</button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link" id="employment-tab" data-bs-toggle="tab" data-bs-target="#employment" type="button" role="tab" aria-controls="employment" aria-selected="false">2. Employment</button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link" id="nkin-tab" data-bs-toggle="tab" data-bs-target="#nkin" type="button" role="tab" aria-controls="nkin" aria-selected="false">3. Next of Kin</button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link" id="education-tab" data-bs-toggle="tab" data-bs-target="#education" type="button" role="tab" aria-controls="education" aria-selected="false">4. Education</button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link" id="dependants-tab" data-bs-toggle="tab" data-bs-target="#dependants" type="button" role="tab" aria-controls="dependants" aria-selected="false">5. Dependants</button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link" id="financial-tab" data-bs-toggle="tab" data-bs-target="#financial" type="button" role="tab" aria-controls="financial" aria-selected="false">6. Financial</button>
                        </li>
                    </ul>
                </div>
                <div class="card-body">
                    <div class="tab-content" id="staffTabsContent">
                        <div class="tab-pane fade show active" id="personal" role="tabpanel" aria-labelledby="personal-tab">
                            <div class="row g-3">
                                <div class="col-md-12">
                                    <label class="form-label">Staff Name</label>
                                    <input type="text" class="form-control" value="<%= staff.SName %>" disabled>
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label">Date of Birth</label>
                                    <input type="date" class="form-control" id="dob" value="<%= staff.DOB ? staff.DOB.toISOString().split('T')[0] : '' %>" disabled>
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label">Gender</label>
                                    <select class="form-select" disabled>
                                        <% sex.forEach(s => { %>
                                            <option value="<%= s.SexCode %>" <%= staff.SexCode === s.SexCode ? 'selected' : '' %>><%= s.Status %></option>
                                        <% }) %>
                                    </select>
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label">Marital Status</label>
                                    <select class="form-select" disabled>
                                        <% mstatus.forEach(m => { %>
                                            <option value="<%= m.Code %>" <%= staff.MStatus === m.Code ? 'selected' : '' %>><%= m.Status %></option>
                                        <% }) %>
                                    </select>
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label">Nationality</label>
                                    <select class="form-select" disabled>
                                        <% nations.forEach(n => { %>
                                            <option value="<%= n.NationCode %>" <%= staff.NationCode === n.NationCode ? 'selected' : '' %>><%= n.Nation %></option>
                                        <% }) %>
                                    </select>
                                </div>
                                <div class="col-md-12">
                                    <label class="form-label">Address</label>
                                    <input type="text" class="form-control" value="<%= staff.Address || '' %>" disabled>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label">City</label>
                                    <input type="text" class="form-control" value="<%= staff.City || '' %>" disabled>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label">Phone</label>
                                    <input type="text" class="form-control" value="<%= staff.Phone || '' %>" disabled>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label">Email</label>
                                    <input type="email" class="form-control" value="<%= staff.Email || '' %>" disabled>
                                </div>
                                <div class="col-md-12">
                                    <label class="form-label">Photo</label>
                                    <% if (staff.PhotoPath) { %>
                                        <img src="<%= staff.PhotoPath %>" alt="Staff Photo" style="max-height: 120px; border: 1px solid #ddd; padding: 5px;">
                                    <% } %>
                                </div>
                            </div>
                        </div>

                        <div class="tab-pane fade" id="employment" role="tabpanel" aria-labelledby="employment-tab">
                            <div class="row g-3">
                                <div class="col-md-3">
                                    <label class="form-label">Staff ID</label>
                                    <input type="text" class="form-control" id="pfno" value="<%= staff.PFNo %>" disabled>
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label">Date Employed</label>
                                    <input type="date" class="form-control" id="doe" value="<%= staff.DOE ? staff.DOE.toISOString().split('T')[0] : '' %>" disabled>
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label">Date Confirmed</label>
                                    <input type="date" class="form-control" value="<%= staff.DateConfirmed ? staff.DateConfirmed.toISOString().split('T')[0] : '' %>" disabled>
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label">Current Grade Date</label>
                                    <input type="date" class="form-control" id="cGradeDate" value="<%= staff.CGradeDate ? staff.CGradeDate.toISOString().split('T')[0] : '' %>" disabled>
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label">Current Dept Date</label>
                                    <input type="date" class="form-control" id="cDeptDate" value="<%= staff.CDeptDate ? staff.CDeptDate.toISOString().split('T')[0] : '' %>" disabled>
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label">Current Grade</label>
                                    <select class="form-select" disabled>
                                        <% grades.forEach(g => { %>
                                            <option value="<%= g.GradeCode %>" <%= staff.CGrade === g.GradeCode ? 'selected' : '' %>><%= g.Grade %></option>
                                        <% }) %>
                                    </select>
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label">Grade Employed</label>
                                    <select class="form-select" disabled>
                                        <% grades.forEach(g => { %>
                                            <option value="<%= g.GradeCode %>" <%= staff.GradeCode === g.GradeCode ? 'selected' : '' %>><%= g.Grade %></option>
                                        <% }) %>
                                    </select>
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label">Department Employed</label>
                                    <select class="form-select" disabled>
                                        <% depts.forEach(d => { %>
                                            <option value="<%= d.Code %>" <%= staff.DEmp === d.Code ? 'selected' : '' %>><%= d.Dept %></option>
                                        <% }) %>
                                    </select>
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label">Employment Status</label>
                                    <select class="form-select" disabled>
                                        <% empStatuses.forEach(es => { %>
                                            <option value="<%= es.Code %>" <%= staff.EmpStatus === es.Code ? 'selected' : '' %>><%= es.EmpStatus %></option>
                                        <% }) %>
                                    </select>
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label">Current Department</label>
                                    <select class="form-select" disabled>
                                        <% depts.forEach(d => { %>
                                            <option value="<%= d.Code %>" <%= staff.CDept === d.Code ? 'selected' : '' %>><%= d.Dept %></option>
                                        <% }) %>
                                    </select>
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label">Job Title</label>
                                    <select class="form-select" disabled>
                                        <% jobTitles.forEach(j => { %>
                                            <option value="<%= j.Code %>" <%= staff.JobTitle === j.Code ? 'selected' : '' %>><%= j.JobTitle %></option>
                                        <% }) %>
                                    </select>
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label">Employment Type</label>
                                    <select class="form-select" disabled>
                                        <% empTypes.forEach(e => { %>
                                            <option value="<%= e.TypeCode %>" <%= staff.EmpType === e.TypeCode ? 'selected' : '' %>><%= e.TypeName %></option>
                                        <% }) %>
                                    </select>
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label">Notch</label>
                                    <input type="number" class="form-control" value="<%= staff.Notch || '' %>" disabled>
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label">Level</label>
                                    <select class="form-select" disabled>
                                        <% levels.forEach(l => { %>
                                            <option value="<%= l.LCode %>" <%= staff.Level === l.LCode ? 'selected' : '' %>><%= l.Level %></option>
                                        <% }) %>
                                    </select>
                                </div>
                                <div class="col-md-3 d-flex align-items-center mt-4">
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" <%= staff.UnionMember === 'Y' ? 'checked' : '' %> disabled>
                                        <label class="form-check-label">Union Member</label>
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label">HOD</label>
                                    <select class="form-select" disabled>
                                        <option value="N" <%= staff.HOD !== 'Y' ? 'selected' : '' %> >No</option>
                                        <option value="Y" <%= staff.HOD === 'Y' ? 'selected' : '' %> >Yes</option>
                                    </select>
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label">HOD Start</label>
                                    <input type="date" class="form-control" value="<%= staff.HOD_SDate ? staff.HOD_SDate.toISOString().split('T')[0] : '' %>" disabled>
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label">HOD End</label>
                                    <input type="date" class="form-control" value="<%= staff.HOD_EDate ? staff.HOD_EDate.toISOString().split('T')[0] : '' %>" disabled>
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label">Vehicle</label>
                                    <select class="form-select" disabled>
                                        <% vehicles.forEach(v => { %>
                                            <option value="<%= v.VType %>" <%= staff.Vehicle === v.VType ? 'selected' : '' %>><%= v.VType %></option>
                                        <% }) %>
                                    </select>
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label">Vehicle Start</label>
                                    <input type="date" class="form-control" value="<%= staff.CarSDate ? staff.CarSDate.toISOString().split('T')[0] : '' %>" disabled>
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label">Vehicle End</label>
                                    <input type="date" class="form-control" value="<%= staff.CarEDate ? staff.CarEDate.toISOString().split('T')[0] : '' %>" disabled>
                                </div>
                                <div class="col-12 mt-4">
                                    <h6 class="text-muted border-bottom pb-2">In Years (Calculated)</h6>
                                </div>
                                <div class="col-md-2">
                                    <label class="form-label">Age</label>
                                    <input type="text" class="form-control bg-light" id="calcAge" readonly>
                                </div>
                                <div class="col-md-2">
                                    <label class="form-label">Served</label>
                                    <input type="text" class="form-control bg-light" id="calcServed" readonly>
                                </div>
                                <div class="col-md-2">
                                    <label class="form-label">To Retirement</label>
                                    <input type="text" class="form-control bg-light" id="calcRetire" readonly>
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label">Department Tenure</label>
                                    <input type="text" class="form-control bg-light" id="calcDeptTenure" readonly>
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label">Grade Tenure</label>
                                    <input type="text" class="form-control bg-light" id="calcGradeTenure" readonly>
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label">Last Leave</label>
                                    <input type="text" class="form-control bg-light" id="lastLeave" value="<%= lastLeave || '' %>" readonly>
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label">Retires (Year)</label>
                                    <input type="text" class="form-control bg-light" id="retiresYear" readonly>
                                </div>
                            </div>
                        </div>

                        <div class="tab-pane fade" id="nkin" role="tabpanel" aria-labelledby="nkin-tab">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label">Next of Kin Name</label>
                                    <input type="text" class="form-control" value="<%= staff.NKin || '' %>" disabled>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Relationship</label>
                                    <select class="form-select" disabled>
                                        <% relations.forEach(r => { %>
                                            <option value="<%= r.RCode %>" <%= staff.NKinRelationship === r.RCode ? 'selected' : '' %>><%= r.Relation %></option>
                                        <% }) %>
                                    </select>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Address</label>
                                    <input type="text" class="form-control" value="<%= staff.NKinAddr || '' %>" disabled>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Phone</label>
                                    <input type="text" class="form-control" value="<%= staff.NKinPhone || '' %>" disabled>
                                </div>
                            </div>
                        </div>

                        <div class="tab-pane fade" id="education" role="tabpanel" aria-labelledby="education-tab">
                            <div class="mb-2">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" <%= staff.Academic === 'Y' ? 'checked' : '' %> disabled>
                                    <label class="form-check-label fw-bold">Academic Qualification?</label>
                                </div>
                            </div>
                            <% if (staff.Academic === 'Y') { %>
                            <div class="table-responsive">
                                <table class="table table-bordered">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Code</th>
                                            <th>Qualification Name</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% qualifications.forEach(q => { %>
                                            <tr>
                                                <td><%= q.QType %></td>
                                                <td><%= q.QName %></td>
                                            </tr>
                                        <% }) %>
                                    </tbody>
                                </table>
                            </div>
                            <% } %>
                        </div>

                        <div class="tab-pane fade" id="dependants" role="tabpanel" aria-labelledby="dependants-tab">
                            <div class="table-responsive">
                                <table class="table table-bordered">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Name</th>
                                            <th>Relationship</th>
                                            <th>Date of Birth</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% dependants.forEach(d => { 
                                            let isOver18 = false;
                                            if (d.Birthdate) {
                                                const dob = new Date(d.Birthdate);
                                                const now = new Date();
                                                let age = now.getFullYear() - dob.getFullYear();
                                                const m = now.getMonth() - dob.getMonth();
                                                if (m < 0 || (m === 0 && now.getDate() < dob.getDate())) age--;
                                                isOver18 = age > 18;
                                            }
                                        %>
                                            <tr class="<%= isOver18 ? 'dependant-over-age' : '' %>">
                                                <td><%= d.Dependant %></td>
                                                <td><%= d.Relation %></td>
                                                <td><%= d.Birthdate || '' %></td>
                                            </tr>
                                        <% }) %>
                                    </tbody>
                                </table>
                            </div>
                            <div class="text-muted small mt-2">Dependants above 18 are shown in red.</div>
                        </div>

                        <div class="tab-pane fade" id="financial" role="tabpanel" aria-labelledby="financial-tab">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label">Account Number</label>
                                    <input type="text" class="form-control" value="<%= staff.AccountNo || '' %>" disabled>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">NASSIT Number</label>
                                    <input type="text" class="form-control" value="<%= staff.NASSITNo || '' %>" disabled>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Contract Exp</label>
                                    <input type="date" class="form-control" value="<%= staff.Contract_Exp ? staff.Contract_Exp.toISOString().split('T')[0] : '' %>" disabled>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="mt-4 d-flex justify-content-between">
                        <a href="/manager/approve/new-staff" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Back</a>
                        <form action="/manager/approve/new-staff" method="POST" class="d-inline">
                            <input type="hidden" name="pfno" value="<%= staff.PFNo %>">
                            <button type="submit" name="action" value="approve" class="btn btn-success">
                                <i class="bi bi-check-circle"></i> Approve
                            </button>
                            <button type="submit" name="action" value="reject" class="btn btn-danger">
                                <i class="bi bi-x-circle"></i> Reject
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        (function calc() {
            const retireAge = <%= retireAge %>;
            const dobEl = document.getElementById('dob');
            const doeEl = document.getElementById('doe');
            const cGradeDateEl = document.getElementById('cGradeDate');
            const cDeptDateEl = document.getElementById('cDeptDate');

            const now = new Date();
            function parse(el) { return el && el.value ? new Date(el.value) : null; }

            const dob = parse(dobEl);
            const doe = parse(doeEl);
            const cgd = parse(cGradeDateEl);
            const cdd = parse(cDeptDateEl);

            function yearsSince(date) {
                if (!date) return '';
                let y = now.getFullYear() - date.getFullYear();
                const m = now.getMonth() - date.getMonth();
                if (m < 0 || (m === 0 && now.getDate() < date.getDate())) y--;
                return y;
            }

            const age = yearsSince(dob);
            const served = yearsSince(doe);
            const gradeTenure = yearsSince(cgd);
            const deptTenure = yearsSince(cdd);

            document.getElementById('calcAge').value = age || '';
            document.getElementById('calcServed').value = served || '';
            document.getElementById('calcGradeTenure').value = gradeTenure || '';
            document.getElementById('calcDeptTenure').value = deptTenure || '';
            document.getElementById('calcRetire').value = (typeof age === 'number') ? Math.max(0, retireAge - age) : '';

            if (dob) {
                document.getElementById('retiresYear').value = dob.getFullYear() + retireAge;
            }
        })();
    </script>
</body>
</html>
