<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Approve Acting Allowance · HR & Payroll</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <link href="/css/styles.css" rel="stylesheet" />
</head>
<body>
    <%- include('../partials/topbar', { user }) %>
    <%- include('../partials/sidebar') %>

    <main class="main">
        <div class="container-fluid">
            <div class="d-flex align-items-center justify-content-between mb-4">
                <div>
                    <h2 class="mb-0">Approve Acting Allowance</h2>
                    <div class="text-muted">Review and approve acting allowance requests</div>
                </div>
            </div>

            <div class="card shadow-sm">
                <div class="card-body">
                    <% if (actingRecords && actingRecords.length > 0) { %>
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead class="table-light">
                                    <tr>
                                        <th>Staff</th>
                                        <th>Current Position</th>
                                        <th>Acting Position</th>
                                        <th>Period</th>
                                        <th>Allowance</th>
                                        <th>Entry Date</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% actingRecords.forEach(record => { %>
                                        <tr>
                                            <td>
                                                <strong><%= record.SName %></strong><br>
                                                <small class="text-muted"><%= record.PFNo %></small>
                                            </td>
                                            <td>
                                                <div><strong>Grade:</strong> <%= record.CurrentGradeName %></div>
                                                <div><strong>Title:</strong> <%= record.CurrentJobTitleName %></div>
                                                <div><strong>Salary:</strong> <%= Number(record.CGrade_Salary).toLocaleString() %></div>
                                            </td>
                                            <td>
                                                <div><strong>Department:</strong> <%= record.ActingDeptName %></div>
                                                <div><strong>Grade:</strong> <%= record.ActingGradeName %></div>
                                                <div><strong>Title:</strong> <%= record.ActingJobTitleName %></div>
                                                <div><strong>Point:</strong> <%= record.GradeDifference %></div>
                                            </td>
                                            <td>
                                                <div><strong>Days:</strong> <%= record.A_Days %></div>
                                                <div><strong>Start:</strong> <%= new Date(record.SDate).toLocaleDateString() %></div>
                                                <div><strong>End:</strong> <%= record.EDate ? new Date(record.EDate).toLocaleDateString() : 'N/A' %></div>
                                            </td>
                                            <td>
                                                <strong><%= Number(record.A_Salary).toLocaleString() %></strong>
                                            </td>
                                            <td>
                                                <%= new Date(record.EntryDate).toLocaleDateString() %>
                                            </td>
                                            <td>
                                                <button class="btn btn-sm btn-success me-1" onclick="approveRecord('<%= record.RefNo %>')">
                                                    <i class="bi bi-check-circle"></i> Approve
                                                </button>
                                                <button class="btn btn-sm btn-danger" onclick="rejectRecord('<%= record.RefNo %>')">
                                                    <i class="bi bi-x-circle"></i> Reject
                                                </button>
                                            </td>
                                        </tr>
                                    <% }) %>
                                </tbody>
                            </table>
                        </div>
                    <% } else { %>
                        <div class="text-center py-5">
                            <i class="bi bi-inbox display-1 text-muted"></i>
                            <h5 class="text-muted mt-3">No pending acting allowance requests</h5>
                            <p class="text-muted">There are no acting allowance requests awaiting approval at this time.</p>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>
    </main>

    <script>
        async function approveRecord(refNo) {
            if (confirm('Are you sure you want to approve this acting allowance request?')) {
                try {
                    const response = await fetch('/manager/api/approve/acting-allowance', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                        },
                        body: JSON.stringify({
                            refNo: refNo,
                            action: 'approve'
                        })
                    });

                    const result = await response.json();

                    if (result.success) {
                        alert('Acting allowance approved successfully');
                        location.reload();
                    } else {
                        alert('Error approving acting allowance');
                    }
                } catch (error) {
                    console.error('Approval error:', error);
                    alert('Error approving record');
                }
            }
        }

        async function rejectRecord(refNo) {
            if (confirm('Are you sure you want to reject this acting allowance request?')) {
                try {
                    const response = await fetch('/manager/api/approve/acting-allowance', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                        },
                        body: JSON.stringify({
                            refNo: refNo,
                            action: 'reject'
                        })
                    });

                    const result = await response.json();

                    if (result.success) {
                        alert('Acting allowance rejected successfully');
                        location.reload();
                    } else {
                        alert('Error rejecting acting allowance');
                    }
                } catch (error) {
                    console.error('Rejection error:', error);
                    alert('Error rejecting record');
                }
            }
        }
    </script>
</body>
</html>