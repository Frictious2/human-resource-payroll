<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> · HR & Payroll</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="/css/styles.css" rel="stylesheet" />
</head>
<body>
    <%- include('../partials/topbar', { user }) %>
    <%- include('../partials/sidebar') %>

    <main class="main">
        <div class="container-fluid">
            <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
                <h1 class="h2"><%= companyName %></h1>
            </div>

            <div class="card shadow-sm mb-4">
                <div class="card-header bg-white">
                    <h5 class="mb-0">Approve Promotions / Demotions</h5>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-hover table-bordered">
                            <thead class="table-light">
                                <tr>
                                    <th>PFNo</th>
                                    <th>Name</th>
                                    <th>Date</th>
                                    <th>Type</th>
                                    <th>Current Grade</th>
                                    <th>New Grade</th>
                                    <th>New Job Title</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (promotions.length === 0) { %>
                                    <tr><td colspan="8" class="text-center">No pending records found.</td></tr>
                                <% } else { %>
                                    <% promotions.forEach(p => { %>
                                        <tr>
                                            <td><%= p.PFNO %></td>
                                            <td><%= p.SName %></td>
                                            <td><%= new Date(p.PDate).toLocaleDateString() %></td>
                                            <td>
                                                <% if (p.Mode === 'D') { %>
                                                    <span class="badge bg-danger">Demotion</span>
                                                <% } else { %>
                                                    <span class="badge bg-success">Promotion</span>
                                                <% } %>
                                            </td>
                                            <td><%= p.PrevGradeDesc %></td>
                                            <td><%= p.NewGradeDesc %></td>
                                            <td><%= p.NewJobTitleDesc %></td>
                                            <td>
                                                <button class="btn btn-sm btn-success btn-approve" 
                                                        data-pfno="<%= p.PFNO %>" 
                                                        data-date="<%= new Date(p.PDate).toISOString().split('T')[0] %>">
                                                    <i class="bi bi-check-circle"></i> Approve
                                                </button>
                                            </td>
                                        </tr>
                                    <% }) %>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.querySelectorAll('.btn-approve').forEach(btn => {
            btn.addEventListener('click', async function() {
                if (!confirm('Are you sure you want to approve this promotion? This will update the staff record.')) return;

                const pfno = this.dataset.pfno;
                const pDate = this.dataset.date;

                try {
                    const res = await fetch('/manager/approve/promotion-demotion', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ pfno, pDate })
                    });
                    const data = await res.json();

                    if (data.success) {
                        if (data.letterHtml) {
                            const win = window.open('', '_blank');
                            win.document.write(data.letterHtml);
                            win.document.close();
                            // Optional: win.print();
                        }
                        alert('Approved successfully! Letter generated.');
                        location.reload();
                    } else {
                        alert('Error: ' + (data.message || 'Failed to approve'));
                    }
                } catch (err) {
                    console.error(err);
                    alert('Server error');
                }
            });
        });
    </script>
</body>
</html>
