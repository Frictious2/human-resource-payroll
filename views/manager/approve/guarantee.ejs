<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Approve Bank Guarantee · HR & Payroll</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet"
          integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
          crossorigin="anonymous" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css"
          rel="stylesheet" />
    <link href="/css/styles.css" rel="stylesheet" />
</head>
<body>
<%- include('../partials/topbar') %>
<%- include('../partials/sidebar') %>

<main class="main">
    <div class="container-fluid">
        <h2 class="mb-4">Approve Bank Loan Guarantee</h2>

        <div class="card shadow-sm">
            <div class="card-header bg-white py-3">
                <h5 class="mb-0 text-primary">Pending Guarantees</h5>
            </div>
            <div class="card-body">
                <% if (guarantees && guarantees.length > 0) { %>
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>Ref No</th>
                                    <th>EMP-ID</th>
                                    <th>Name</th>
                                    <th>Bank</th>
                                    <th>Amount</th>
                                    <th>Duration</th>
                                    <th>Monthly</th>
                                    <th>Loan Date</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% guarantees.forEach(g => { %>
                                    <tr>
                                        <td><%= g.RefNo %></td>
                                        <td><%= g.PFNO %></td>
                                        <td><%= g.Name %></td>
                                        <td><%= g.BankName %></td>
                                        <td><%= parseFloat(g.LoanAmount).toFixed(2) %></td>
                                        <td><%= g.Duration %> M</td>
                                        <td><%= parseFloat(g.Monthly).toFixed(2) %></td>
                                        <td><%= new Date(g.LoanDate).toLocaleDateString() %></td>
                                        <td>
                                            <button class="btn btn-sm btn-success me-1" onclick="processGuarantee('<%= g.RefNo %>', 'approve')">Approve</button>
                                            <button class="btn btn-sm btn-danger" onclick="processGuarantee('<%= g.RefNo %>', 'reject')">Reject</button>
                                        </td>
                                    </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>
                <% } else { %>
                    <div class="alert alert-info">No pending bank guarantees found.</div>
                <% } %>
            </div>
        </div>
    </div>
    
    <footer class="mt-4 py-3 text-center text-muted border-top">
        <%- include('../partials/footer') %>
    </footer>
</main>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

<script>
    function processGuarantee(refNo, action) {
        const confirmMsg = action === 'approve' ? 'Approve this guarantee?' : 'Reject this guarantee?';
        if (confirm(confirmMsg)) {
            fetch('/manager/api/approve/guarantee', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ refNo, action })
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    location.reload();
                } else {
                    alert('Error: ' + (data.error || 'Operation failed'));
                }
            })
            .catch(error => console.error('Error:', error));
        }
    }
</script>

</body>
</html>