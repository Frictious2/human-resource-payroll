<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> · HR & Payroll</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="/css/styles.css" rel="stylesheet" />
</head>
<body>
    <%- include('../partials/topbar', { user }) %>
    <%- include('../partials/sidebar') %>

    <main class="main">
        <div class="container-fluid">
            <div class="d-flex align-items-center justify-content-between mb-4">
                <div>
                    <h2 class="mb-0">Approve Redundancy</h2>
                    <div class="text-muted">Review and approve staff redundancy requests</div>
                </div>
            </div>

            <div class="card shadow-sm">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Emp-ID</th>
                                    <th>Staff Name</th>
                                    <th>Department</th>
                                    <th>Served (Years)</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (requests.length > 0) { %>
                                    <% requests.forEach(req => { %>
                                        <tr>
                                            <td><%= req.PFNo %></td>
                                            <td><%= req.SName %></td>
                                            <td><%= req.Department %></td>
                                            <td><%= req.Served %></td>
                                            <td>
                                                <form action="/manager/approve/redundancy" method="POST" onsubmit="return confirm('Confirm redundancy approval for <%= req.SName %>?');">
                                                    <input type="hidden" name="pfno" value="<%= req.PFNo %>">
                                                    <button type="submit" class="btn btn-sm btn-success">
                                                        <i class="bi bi-check-lg"></i> Approve
                                                    </button>
                                                </form>
                                            </td>
                                        </tr>
                                    <% }) %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="5" class="text-center py-4 text-muted">No pending redundancy requests</td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
