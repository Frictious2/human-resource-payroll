<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> · Manager</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="/css/styles.css" rel="stylesheet" />
</head>
<body>
    <%- include('../partials/topbar', { user, role }) %>
    <%- include('../partials/sidebar') %>

    <main class="main">
        <div class="container-fluid">
            <div class="d-flex align-items-center justify-content-between mb-3">
                <div>
                    <h2 class="mb-0">Approve Edited Payroll</h2>
                    <div class="text-muted">Review and approve edited staff payroll records</div>
                </div>
            </div>

            <div class="card shadow-sm">
                <div class="card-body table-responsive">
                    <table class="table table-sm table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>PFNo</th>
                                <th>Name</th>
                                <th>Grade</th>
                                <th class="text-end">Salary</th>
                                <th class="text-end">Net Income</th>
                                <th>Date</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if ((records || []).length === 0) { %>
                                <tr>
                                    <td colspan="7" class="text-center text-muted">No pending edited payroll records</td>
                                </tr>
                            <% } %>
                            <% (records || []).forEach(r => { %>
                                <tr>
                                    <td><%= r.PFNo %></td>
                                    <td><%= r.SName %></td>
                                    <td><%= r.GradeName %></td>
                                    <td class="text-end"><%= r.Salary %></td>
                                    <td class="text-end"><%= r.NetIncome %></td>
                                    <td><%= r.PDate.toISOString ? r.PDate.toISOString().substring(0,10) : r.PDate %></td>
                                    <td class="text-end">
                                        <a class="btn btn-sm btn-primary" href="/manager/approve/edited-payroll/view?pfno=<%= r.PFNo %>&pdate=<%= encodeURIComponent(r.PDate.toISOString ? r.PDate.toISOString() : r.PDate) %>">
                                            View
                                        </a>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
