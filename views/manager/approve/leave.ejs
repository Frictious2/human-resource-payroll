<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="/css/styles.css" rel="stylesheet" />
</head>
<body>
    <%- include('../partials/topbar', { user }) %>
    <%- include('../partials/sidebar') %>

    <main class="main">
        <div class="container-fluid">
            <div class="d-flex align-items-center justify-content-between mb-4">
                <h2 class="mb-0"><%= title %></h2>
            </div>

            <div class="row g-4">
                <!-- Card 1: Application -->
                <div class="col-12 col-md-6 col-lg-4 col-xl-3">
                    <div class="card shadow-sm h-100">
                        <div class="card-body text-center">
                            <i class="bi bi-file-earmark-check fs-1 text-primary mb-3"></i>
                            <h5 class="card-title">Application</h5>
                            <p class="card-text text-muted">Approve leave applications</p>
                            <a href="/manager/approve/leave-application" class="btn btn-outline-primary stretched-link">Go to Approvals</a>
                        </div>
                    </div>
                </div>

                <!-- Card 2: Recall -->
                <div class="col-12 col-md-6 col-lg-4 col-xl-3">
                    <div class="card shadow-sm h-100">
                        <div class="card-body text-center">
                            <i class="bi bi-arrow-return-left fs-1 text-warning mb-3"></i>
                            <h5 class="card-title">Recall</h5>
                            <p class="card-text text-muted">Approve recall requests</p>
                            <a href="/manager/approve/leave-recall" class="btn btn-outline-warning stretched-link">Go to Recall</a>
                        </div>
                    </div>
                </div>

                <!-- Card 3: Purchase -->
                <div class="col-12 col-md-6 col-lg-4 col-xl-3">
                    <div class="card shadow-sm h-100">
                        <div class="card-body text-center">
                            <i class="bi bi-cart-check fs-1 text-success mb-3"></i>
                            <h5 class="card-title">Purchase</h5>
                            <p class="card-text text-muted">Approve leave purchases</p>
                            <a href="/manager/approve/leave-purchase" class="btn btn-outline-success stretched-link">Go to Purchase</a>
                        </div>
                    </div>
                </div>

                <!-- Card 4: On Leave -->
                <div class="col-12 col-md-6 col-lg-4 col-xl-3">
                    <div class="card shadow-sm h-100">
                        <div class="card-body text-center">
                            <i class="bi bi-calendar2-check fs-1 text-info mb-3"></i>
                            <h5 class="card-title">On Leave</h5>
                            <p class="card-text text-muted">View staff currently on leave</p>
                            <a href="/manager/approve/on-leave" class="btn btn-outline-info stretched-link">View On Leave</a>
                        </div>
                    </div>
                </div>

                <!-- Card 5: Outstanding Leave -->
                <div class="col-12 col-md-6 col-lg-4 col-xl-3">
                    <div class="card shadow-sm h-100">
                        <div class="card-body text-center">
                            <i class="bi bi-hourglass-bottom fs-1 text-danger mb-3"></i>
                            <h5 class="card-title">Outstanding Leave</h5>
                            <p class="card-text text-muted">View outstanding balances</p>
                            <button type="button" class="btn btn-outline-danger stretched-link" data-bs-toggle="modal" data-bs-target="#outstandingModal">View Outstanding</button>
                        </div>
                    </div>
                </div>
            </div>

            <footer class="mt-4 py-3 text-center text-muted border-top">
                <%- include('../partials/footer') %>
            </footer>
        </div>
    </main>

    <!-- Outstanding Report Modal -->
    <div class="modal fade" id="outstandingModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">View Outstanding Leave</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <form id="outstandingForm" action="/manager/leave/outstanding-report" method="GET" target="_blank">
                        <div class="mb-3">
                            <label class="form-label">Filter By</label>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="filter" id="filterAll" value="All" checked onchange="toggleStaffInput()">
                                <label class="form-check-label" for="filterAll">All Staff</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="filter" id="filterStaff" value="Staff" onchange="toggleStaffInput()">
                                <label class="form-check-label" for="filterStaff">Specific Staff</label>
                            </div>
                        </div>
                        
                        <div class="mb-3" id="staffInputContainer" style="display: none;">
                            <label class="form-label">Staff ID / PF No</label>
                            <input type="text" class="form-control" name="staffId" placeholder="Enter Staff ID">
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Leave Type</label>
                            <select class="form-select" name="type" required>
                                <option value="Outstanding">Outstanding (Balance > 0)</option>
                                <option value="Recalled">Recalled</option>
                                <option value="Purchased">Purchased</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Year</label>
                            <input type="number" class="form-control" name="year" value="<%= new Date().getFullYear() %>" required>
                        </div>
                        
                        <button type="submit" class="btn btn-primary w-100">Generate Report</button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <script>
        function toggleStaffInput() {
            const isStaff = document.getElementById('filterStaff').checked;
            document.getElementById('staffInputContainer').style.display = isStaff ? 'block' : 'none';
            const staffInput = document.querySelector('input[name="staffId"]');
            if (isStaff) staffInput.setAttribute('required', 'required');
            else {
                staffInput.removeAttribute('required');
                staffInput.value = '';
            }
        }
    </script>


    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/scripts.js"></script>
</body>
</html>
