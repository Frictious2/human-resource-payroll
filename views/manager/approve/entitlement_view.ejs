<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> · HR & Payroll</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="/css/styles.css" rel="stylesheet" />
</head>
<body>
    <%- include('../partials/topbar', { user }) %>
    <%- include('../partials/sidebar') %>

    <main class="main">
        <div class="container-fluid">
            <div class="d-flex align-items-center justify-content-between mb-3">
                <div>
                    <h2 class="mb-0">View Entitlement</h2>
                    <div class="text-muted">Read-only review</div>
                </div>
            </div>

            <div class="card shadow-sm">
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-3">
                            <label class="form-label">Staff</label>
                            <input type="text" class="form-control" value="<%= staff.PFNo %> - <%= staff.SName %>" disabled>
                        </div>
                    </div>

                    <hr class="my-3">
                    <h5 class="mb-3">Payment Details</h5>
                    <div class="row g-3">
                        <div class="col-md-3">
                            <label class="form-label">Paythrough</label>
                            <select class="form-select" disabled>
                                <option value="">Select...</option>
                                <% paythrough.forEach(p => { %>
                                    <option value="<%= p.Code %>" <%= String(entitle.PayThrough) === String(p.Code) ? 'selected' : '' %>><%= p.PayThrough %></option>
                                <% }) %>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Bank</label>
                            <select class="form-select" disabled>
                                <option value="">Select...</option>
                                <% banks.forEach(b => { %>
                                    <option value="<%= b.Code %>" <%= String(entitle.Bank) === String(b.Code) ? 'selected' : '' %>><%= b.Bank %></option>
                                <% }) %>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Account Number</label>
                            <input type="text" class="form-control" value="<%= entitle.AccountNo || '' %>" disabled>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Company Account Number</label>
                            <select class="form-select" disabled>
                                <option value="">Select...</option>
                                <% (companyBBANs || []).forEach(cb => { %>
                                    <option value="<%= cb.BBAN %>" <%= String(entitle.PayingBBAN) === String(cb.BBAN) ? 'selected' : '' %>>
                                        <%= cb.Bank %> — <%= cb.Short %> — <%= cb.BBAN %>
                                    </option>
                                <% }) %>
                            </select>
                        </div>
                    </div>

                    <hr class="my-3">
                    <h5 class="mb-3">Payroll Items</h5>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="row row-cols-1">
                                <% items.forEach((it, idx) => { if (idx % 2 === 0) { 
                                    const val = it.Code === '01' ? entitle.Salary : entitle['Allw' + it.Code];
                                %>
                                    <div class="col mb-2">
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" <%= Number(val) === -1 ? 'checked' : '' %> disabled>
                                            <label class="form-check-label"><%= it.Income %></label>
                                        </div>
                                    </div>
                                <% } }) %>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="row row-cols-1">
                                <% items.forEach((it, idx) => { if (idx % 2 === 1) { 
                                    const val = it.Code === '01' ? entitle.Salary : entitle['Allw' + it.Code];
                                %>
                                    <div class="col mb-2">
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" <%= Number(val) === -1 ? 'checked' : '' %> disabled>
                                            <label class="form-check-label"><%= it.Income %></label>
                                        </div>
                                    </div>
                                <% } }) %>
                            </div>
                        </div>
                    </div>

                    <div class="mt-4 d-flex justify-content-between">
                        <a href="/manager/approve/entitlement" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Back</a>
                        <form action="/manager/approve/entitlement" method="POST" class="d-inline">
                            <input type="hidden" name="pfno" value="<%= staff.PFNo %>">
                            <button type="submit" name="action" value="approve" class="btn btn-success">
                                <i class="bi bi-check-circle"></i> Approve
                            </button>
                            <button type="submit" name="action" value="reject" class="btn btn-danger">
                                <i class="bi bi-x-circle"></i> Reject
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
