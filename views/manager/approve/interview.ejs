<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> · HR & Payroll</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="/css/styles.css" rel="stylesheet" />
</head>
<body>
    <!-- Top Navbar -->
    <%- include('../partials/topbar', { user }) %>

    <!-- Sidebar -->
    <%- include('../partials/sidebar') %>

    <!-- Main Content -->
    <main class="main">
        <div class="container-fluid">
            <!-- Header -->
            <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
                <h1 class="h2">Approve Interview Selection</h1>
            </div>

            <!-- Alerts -->
            <div id="alertContainer"></div>

            <!-- Applicants Table -->
            <div class="card shadow-sm">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">Pending Approvals</h5>
                    <div>
                        <button class="btn btn-danger me-2" id="btnReject" disabled>
                            <i class="bi bi-x-circle"></i> Reject Selected
                        </button>
                        <button class="btn btn-success" id="btnApprove" disabled>
                            <i class="bi bi-check-circle"></i> Approve & Invite Selected
                        </button>
                    </div>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-hover table-bordered" id="applicantsTable">
                            <thead class="table-light">
                                <tr>
                                    <th style="width: 40px;"><input type="checkbox" id="selectAll"></th>
                                    <th>Ref No</th>
                                    <th>Name</th>
                                    <th>Email</th>
                                    <th>Exam Grade</th>
                                    <th>Date Applied</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (applicants && applicants.length > 0) { %>
                                    <% applicants.forEach(app => { %>
                                        <tr data-refno="<%= app.RefNo %>" data-name="<%= app.SName %>" data-email="<%= app.Email %>">
                                            <td><input type="checkbox" class="row-checkbox" value="<%= app.RefNo %>"></td>
                                            <td><%= app.RefNo %></td>
                                            <td><%= app.SName %></td>
                                            <td><%= app.Email || 'N/A' %></td>
                                            <td><%= app.Result || 'N/A' %></td>
                                            <td><%= app.DApplied ? new Date(app.DApplied).toLocaleDateString() : 'N/A' %></td>
                                        </tr>
                                    <% }) %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="6" class="text-center">No pending interview approvals found.</td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <!-- Email Modal -->
    <div class="modal fade" id="emailModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Invitation Email Content</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="emailContent" class="form-label">Message Body</label>
                        <textarea class="form-control" id="emailContent" rows="10" placeholder="Enter the content of the letter/email here...">
Dear Applicant,

We are pleased to invite you for an interview at our office.
Please refer to the attached details.

Best regards,
HR Team
                        </textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-primary" id="btnSendEmails">
                        <i class="bi bi-send"></i> Approve & Send
                    </button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        const table = document.getElementById('applicantsTable');
        const selectAll = document.getElementById('selectAll');
        const checkboxes = table.querySelectorAll('.row-checkbox');
        const btnApprove = document.getElementById('btnApprove');
        const btnReject = document.getElementById('btnReject');
        const alertContainer = document.getElementById('alertContainer');

        function showAlert(message, type = 'success') {
            const alertHtml = `
                <div class="alert alert-${type} alert-dismissible fade show" role="alert">
                    ${message}
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            `;
            alertContainer.innerHTML = alertHtml;
        }

        function updateButtons() {
            const checked = Array.from(checkboxes).some(cb => cb.checked);
            btnApprove.disabled = !checked;
            btnReject.disabled = !checked;
        }

        selectAll.addEventListener('change', () => {
            checkboxes.forEach(cb => cb.checked = selectAll.checked);
            updateButtons();
        });

        checkboxes.forEach(cb => {
            cb.addEventListener('change', updateButtons);
        });

        // Approve Button Click -> Open Modal
        btnApprove.addEventListener('click', () => {
            const modal = new bootstrap.Modal(document.getElementById('emailModal'));
            modal.show();
        });

        // Send Emails (Confirm Approval)
        document.getElementById('btnSendEmails').addEventListener('click', async () => {
            const content = document.getElementById('emailContent').value;
            if (!content) {
                alert('Please enter email content.');
                return;
            }

            const selectedApps = [];
            checkboxes.forEach(cb => {
                if (cb.checked) {
                    const row = cb.closest('tr');
                    selectedApps.push({
                        RefNo: row.dataset.refno,
                        Name: row.dataset.name,
                        Email: row.dataset.email
                    });
                }
            });

            const btn = document.getElementById('btnSendEmails');
            const originalText = btn.innerHTML;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> Processing...';
            btn.disabled = true;

            try {
                const response = await fetch('/manager/approve/interview', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ applicants: selectedApps, content })
                });

                const result = await response.json();

                if (response.ok) {
                    bootstrap.Modal.getInstance(document.getElementById('emailModal')).hide();
                    showAlert(`Successfully approved and sent ${result.sentCount} emails.`);
                    setTimeout(() => location.reload(), 2000);
                } else {
                    throw new Error(result.error || 'Failed to approve');
                }
            } catch (error) {
                console.error(error);
                alert('Error: ' + error.message);
            } finally {
                btn.innerHTML = originalText;
                btn.disabled = false;
            }
        });

        // Reject Button Click
        btnReject.addEventListener('click', async () => {
            if (!confirm('Are you sure you want to reject the selected applicants? They will be removed from the approval list.')) return;

            const selectedRefNos = [];
            checkboxes.forEach(cb => {
                if (cb.checked) selectedRefNos.push(cb.value);
            });

            const originalText = btnReject.innerHTML;
            btnReject.innerHTML = '<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> Processing...';
            btnReject.disabled = true;

            try {
                const response = await fetch('/manager/reject/interview', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ refNos: selectedRefNos })
                });

                const result = await response.json();

                if (response.ok) {
                    showAlert('Selected applicants rejected successfully.');
                    setTimeout(() => location.reload(), 2000);
                } else {
                    throw new Error(result.error || 'Failed to reject');
                }
            } catch (error) {
                console.error(error);
                alert('Error: ' + error.message);
            } finally {
                btnReject.innerHTML = originalText;
                btnReject.disabled = false;
            }
        });
    </script>
</body>
</html>
