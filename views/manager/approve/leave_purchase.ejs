<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <link href="/css/styles.css" rel="stylesheet">
</head>
<body>
    <%- include('../partials/topbar', { user }) %>
    <%- include('../partials/sidebar', { path }) %>

    <main class="main">
        <div class="container-fluid">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2><%= title %></h2>
            </div>

            <!-- Pending Purchases Table -->
            <div class="card shadow-sm">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0 text-primary"><i class="bi bi-clock-history me-2"></i>Pending Requests</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Staff</th>
                                    <th>Year</th>
                                    <th>Days Purchased</th>
                                    <th>Amount</th>
                                    <th>Date Purchased</th>
                                    <th>Method</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (pendingPurchases.length > 0) { %>
                                    <% pendingPurchases.forEach(purchase => { %>
                                        <tr>
                                            <td>
                                                <div class="fw-bold"><%= purchase.SName %></div>
                                                <small class="text-muted"><%= purchase.PFNO %></small>
                                            </td>
                                            <td><%= purchase.LYear %></td>
                                            <td><%= purchase.DaysPurchased %></td>
                                            <td><%= purchase.Allowance %></td>
                                            <td><%= new Date(purchase.DatePurchased).toLocaleDateString() %></td>
                                            <td><%= purchase.PayThrough || purchase.Method %></td>
                                            <td>
                                                <button class="btn btn-sm btn-primary view-btn" 
                                                    data-bs-toggle="modal" 
                                                    data-bs-target="#viewPurchaseModal"
                                                    data-purchase='<%- JSON.stringify(purchase) %>'>
                                                    <i class="bi bi-eye"></i> View
                                                </button>
                                            </td>
                                        </tr>
                                    <% }); %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="7" class="text-center py-4 text-muted">
                                            No pending leave purchase requests found.
                                        </td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <!-- View Purchase Modal -->
    <div class="modal fade" id="viewPurchaseModal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Leave Purchase Details</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <form id="approveForm" action="/manager/api/approve/leave-purchase" method="POST">
                        <input type="hidden" id="lCount" name="lCount">
                        <input type="hidden" id="action" name="action">

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label text-muted">Staff Name</label>
                                <input type="text" class="form-control" id="staffName" readonly>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label text-muted">PF No</label>
                                <input type="text" class="form-control" id="pfNo" readonly>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label text-muted">Leave Year</label>
                                <input type="text" class="form-control" id="leaveYear" readonly>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label text-muted">Days Purchased</label>
                                <input type="text" class="form-control" id="daysPurchased" readonly>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label text-muted">Amount</label>
                                <input type="text" class="form-control" id="amount" readonly>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label text-muted">Date Purchased</label>
                                <input type="text" class="form-control" id="datePurchased" readonly>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label text-muted">Payment Method</label>
                                <input type="text" class="form-control" id="method" readonly>
                            </div>
                            
                            <!-- Bank Details Section (Conditional) -->
                            <div id="bankDetails" class="row g-3 mt-0 d-none">
                                <div class="col-md-6">
                                    <label class="form-label text-muted">Bank</label>
                                    <input type="text" class="form-control" id="bank" readonly>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label text-muted">BBAN</label>
                                    <input type="text" class="form-control" id="bban" readonly>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                    <button type="button" class="btn btn-danger" onclick="submitApproval('reject')">Reject</button>
                    <button type="button" class="btn btn-success" onclick="submitApproval('approve')">Approve</button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        const viewModal = document.getElementById('viewPurchaseModal');
        viewModal.addEventListener('show.bs.modal', function (event) {
            const button = event.relatedTarget;
            const purchase = JSON.parse(button.getAttribute('data-purchase'));
            
            // Populate fields
            document.getElementById('lCount').value = purchase.LCount;
            document.getElementById('staffName').value = purchase.SName;
            document.getElementById('pfNo').value = purchase.PFNO;
            document.getElementById('leaveYear').value = purchase.LYear;
            document.getElementById('daysPurchased').value = purchase.DaysPurchased;
            document.getElementById('amount').value = purchase.Allowance;
            document.getElementById('datePurchased').value = new Date(purchase.DatePurchased).toLocaleDateString();
            document.getElementById('method').value = purchase.PayThrough || purchase.Method;
            
            // Handle Bank Details
            const bankDetails = document.getElementById('bankDetails');
            if (purchase.Bank || purchase.BBAN) {
                bankDetails.classList.remove('d-none');
                document.getElementById('bank').value = purchase.Bank || '';
                document.getElementById('bban').value = purchase.BBAN || '';
            } else {
                bankDetails.classList.add('d-none');
            }
        });

        function submitApproval(actionType) {
            if (!confirm(`Are you sure you want to ${actionType} this request?`)) return;
            
            document.getElementById('action').value = actionType;
            document.getElementById('approveForm').submit();
        }
    </script>
</body>
</html>
