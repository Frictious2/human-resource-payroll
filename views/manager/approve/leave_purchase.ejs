<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="/css/styles.css" rel="stylesheet" />
</head>
<body>
    <%- include('../../partials/topbar', { user }) %>
    <%- include('../../partials/sidebar') %>

    <main class="main">
        <div class="container-fluid">
            <div class="d-flex align-items-center justify-content-between mb-4">
                <h2 class="mb-0"><%= title %></h2>
                <a href="/manager/approve/leave" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left"></i> Back
                </a>
            </div>

            <div class="card shadow-sm">
                <div class="card-header bg-white">
                    <h5 class="mb-0">Pending Leave Purchase Requests</h5>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>Staff</th>
                                    <th>Year</th>
                                    <th>Days Purchased</th>
                                    <th>Amount</th>
                                    <th>Date Purchased</th>
                                    <th>Status</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (pendingPurchases.length > 0) { %>
                                    <% pendingPurchases.forEach(purchase => { %>
                                        <tr>
                                            <td>
                                                <div class="fw-bold"><%= purchase.SName %></div>
                                                <small class="text-muted"><%= purchase.PFNO %></small>
                                            </td>
                                            <td><%= purchase.LYear %></td>
                                            <td><%= purchase.DaysPurchased %></td>
                                            <td><%= purchase.Allowance %></td>
                                            <td><%= new Date(purchase.DatePurchased).toLocaleDateString() %></td>
                                            <td>
                                                <span class="badge bg-warning text-dark">Pending</span>
                                            </td>
                                            <td>
                                                <button class="btn btn-sm btn-info text-white view-btn"
                                                    data-purchase='<%- JSON.stringify(purchase) %>'>
                                                    <i class="bi bi-eye"></i> View
                                                </button>
                                            </td>
                                        </tr>
                                    <% }); %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="7" class="text-center py-4 text-muted">
                                            No pending leave purchase requests found
                                        </td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <footer class="mt-4 py-3 text-center text-muted border-top">
                <%- include('../../partials/footer') %>
            </footer>
        </div>
    </main>

    <!-- Purchase Details Modal -->
    <div class="modal fade" id="purchaseModal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Leave Purchase Details</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <form id="purchaseForm">
                        <input type="hidden" id="purchaseId">
                        <input type="hidden" id="purchasePFNo">
                        
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Staff Name</label>
                                <input type="text" class="form-control" id="staffName" readonly>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Leave Year</label>
                                <input type="text" class="form-control" id="leaveYear" readonly>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Days Purchased</label>
                                <input type="number" class="form-control" id="daysPurchased" readonly>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Purchase Amount</label>
                                <input type="text" class="form-control" id="amount" readonly>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Date Purchased</label>
                                <input type="text" class="form-control" id="datePurchased" readonly>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Payment Method</label>
                                <input type="text" class="form-control" id="method" readonly>
                            </div>
                            <div class="col-md-6" id="bankDiv" style="display:none;">
                                <label class="form-label">Bank</label>
                                <input type="text" class="form-control" id="bank" readonly>
                            </div>
                            <div class="col-md-6" id="bbanDiv" style="display:none;">
                                <label class="form-label">BBAN</label>
                                <input type="text" class="form-control" id="bban" readonly>
                            </div>
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-danger" onclick="submitApproval(2)">Reject</button>
                    <button type="button" class="btn btn-success" onclick="submitApproval(1)">Approve</button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        const purchaseModal = new bootstrap.Modal(document.getElementById('purchaseModal'));
        let currentPurchaseId = null;

        document.querySelectorAll('.view-btn').forEach(btn => {
            btn.addEventListener('click', function() {
                const purchase = JSON.parse(this.dataset.purchase);
                currentPurchaseId = purchase.LCount; // Using LCount as ID

                document.getElementById('purchaseId').value = purchase.LCount;
                document.getElementById('purchasePFNo').value = purchase.PFNO;
                document.getElementById('staffName').value = purchase.SName;
                document.getElementById('leaveYear').value = purchase.LYear;
                document.getElementById('daysPurchased').value = purchase.DaysPurchased;
                document.getElementById('amount').value = purchase.Allowance;
                document.getElementById('datePurchased').value = new Date(purchase.DatePurchased).toLocaleDateString();
                document.getElementById('method').value = purchase.PayThrough || purchase.Method;
                
                if (purchase.Bank) {
                    document.getElementById('bankDiv').style.display = 'block';
                    document.getElementById('bank').value = purchase.Bank;
                } else {
                    document.getElementById('bankDiv').style.display = 'none';
                }

                if (purchase.BBAN) {
                    document.getElementById('bbanDiv').style.display = 'block';
                    document.getElementById('bban').value = purchase.BBAN;
                } else {
                    document.getElementById('bbanDiv').style.display = 'none';
                }

                purchaseModal.show();
            });
        });

        async function submitApproval(status) {
            if (!confirm(status === 1 ? 'Are you sure you want to Approve this purchase?' : 'Are you sure you want to Reject this purchase?')) {
                return;
            }

            try {
                const response = await fetch('/manager/api/approve/leave-purchase', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        id: currentPurchaseId,
                        status: status
                    })
                });

                const result = await response.json();
                if (result.success) {
                    alert('Success!');
                    location.reload();
                } else {
                    alert('Error: ' + (result.error || 'Unknown error'));
                }
            } catch (error) {
                console.error(error);
                alert('Request failed');
            }
        }
    </script>
</body>
</html>