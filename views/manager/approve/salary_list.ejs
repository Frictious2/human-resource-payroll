<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> · Manager</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="/css/styles.css" rel="stylesheet" />
</head>
<body>
    <%- include('../partials/topbar', { user, role }) %>
    <%- include('../partials/sidebar') %>

    <main class="main">
        <div class="container-fluid">
            <div class="d-flex align-items-center justify-content-between mb-3">
                <div>
                    <h2 class="mb-0">Approve Salary Setup</h2>
                    <div class="text-muted">Review and approve new or edited staff payroll information</div>
                </div>
            </div>

            <div class="card shadow-sm">
                <div class="card-body table-responsive">
                    <% if (records.length === 0) { %>
                        <div class="text-center py-5 text-muted">
                            <i class="bi bi-check-circle fs-1"></i>
                            <p class="mt-2">No pending salary approvals.</p>
                        </div>
                    <% } else { %>
                        <table class="table table-hover align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>EMP-ID</th>
                                    <th>Staff Name</th>
                                    <th>Department</th>
                                    <th>Date of Entry</th>
                                    <th class="text-end">Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% records.forEach(rec => { %>
                                    <tr>
                                        <td><%= rec.PFNo %></td>
                                        <td><%= rec.SName %></td>
                                        <td><%= rec.Dept %></td>
                                        <td><%= rec.DateKeyed ? new Date(rec.DateKeyed).toLocaleDateString() : '-' %></td>
                                        <td class="text-end">
                                            <a href="/manager/approve/salary/view?pfno=<%= rec.PFNo %>&pdate=<%= rec.PDate.toISOString().split('T')[0] %>" class="btn btn-sm btn-primary">
                                                <i class="bi bi-eye"></i> View
                                            </a>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    <% } %>
                </div>
            </div>
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
