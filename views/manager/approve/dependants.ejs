<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> · HR & Payroll</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="/css/styles.css" rel="stylesheet" />
</head>
<body>
    <%- include('../partials/topbar', { user }) %>
    <%- include('../partials/sidebar') %>

    <main class="main">
        <div class="container-fluid">
            <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
                <h1 class="h2">Manager Dashboard</h1>
            </div>

            <div class="card shadow-sm mb-4">
                <div class="card-header bg-warning text-dark">
                    <h5 class="mb-0"><i class="bi bi-people"></i> Approve Dependants</h5>
                </div>
                <div class="card-body">
                    <% if (dependants.length === 0) { %>
                        <div class="alert alert-info">No pending dependant approvals found.</div>
                    <% } else { %>
                        <div class="table-responsive">
                            <table class="table table-striped table-hover align-middle">
                                <thead class="table-dark">
                                    <tr>
                                        <th>Staff ID</th>
                                        <th>Staff Name</th>
                                        <th>D-Name</th>
                                        <th>Relation</th>
                                        <th>Date Closed</th>
                                        <th>Reason</th>
                                        <th>Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% dependants.forEach(d => { %>
                                        <tr id="row-<%= d.PFNo %>-<%= d.DepNo %>">
                                            <td><%= d.PFNo %></td>
                                            <td><%= d.SName %></td>
                                            <td><%= d.Dependant %></td>
                                            <td><%= d.Relation || d.RCode %></td>
                                            <td><%= d.DateClosed ? new Date(d.DateClosed).toLocaleDateString() : 'Active' %></td>
                                            <td><%= d.ReasonText || d.ReasonCode || '' %></td>
                                            <td>
                                                <button class="btn btn-success btn-sm btn-action" 
                                                        data-pfno="<%= d.PFNo %>" 
                                                        data-depno="<%= d.DepNo %>" 
                                                        data-action="approve">
                                                    <i class="bi bi-check-lg"></i> Approve
                                                </button>
                                                <button class="btn btn-danger btn-sm btn-action" 
                                                        data-pfno="<%= d.PFNo %>" 
                                                        data-depno="<%= d.DepNo %>" 
                                                        data-action="reject">
                                                    <i class="bi bi-x-lg"></i> Reject
                                                </button>
                                            </td>
                                        </tr>
                                    <% }); %>
                                </tbody>
                            </table>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const buttons = document.querySelectorAll('.btn-action');

            buttons.forEach(btn => {
                btn.addEventListener('click', async () => {
                    const pfno = btn.dataset.pfno;
                    const depNo = btn.dataset.depno;
                    const action = btn.dataset.action;

                    if (!confirm(`Are you sure you want to ${action.toUpperCase()} this dependant?`)) {
                        return;
                    }

                    try {
                        const res = await fetch('/manager/approve/dependants', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ pfno, depNo, action })
                        });
                        const data = await res.json();

                        if (res.ok) {
                            alert(data.message);
                            // Remove row
                            const row = document.getElementById(`row-${pfno}-${depNo}`);
                            if (row) row.remove();
                            
                            // Check if table empty
                            const tbody = document.querySelector('tbody');
                            if (tbody && tbody.children.length === 0) {
                                location.reload();
                            }
                        } else {
                            alert('Error: ' + data.error);
                        }
                    } catch (err) {
                        console.error(err);
                        alert('An error occurred.');
                    }
                });
            });
        });
    </script>
</body>
</html>