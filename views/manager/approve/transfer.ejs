<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> · HR & Payroll</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="/css/styles.css" rel="stylesheet" />
</head>
<body>
    <%- include('../partials/topbar', { user }) %>
    <%- include('../partials/sidebar') %>

    <main class="main">
        <div class="container-fluid">
            <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
                <h1 class="h2"><%= companyName %></h1>
            </div>

            <div class="card shadow-sm mb-4">
                <div class="card-header bg-warning text-dark">
                    <h5 class="mb-0"><i class="bi bi-check-circle"></i> Approve Staff Transfers</h5>
                </div>
                <div class="card-body">
                    <% if (transfers.length === 0) { %>
                        <div class="alert alert-info">No pending transfer approvals found.</div>
                    <% } else { %>
                        <div class="table-responsive">
                            <table class="table table-striped table-hover align-middle">
                                <thead class="table-dark">
                                    <tr>
                                        <th>Emp-ID</th>
                                        <th>Date</th>
                                        <th>Staff Name</th>
                                        <th>Prev Dept</th>
                                        <th>Transferred To</th>
                                        <th>Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% transfers.forEach(t => { %>
                                        <tr id="row-<%= t.PFNO %>">
                                            <td><%= t.PFNO %></td>
                                            <td><%= new Date(t.TDate).toLocaleDateString() %></td>
                                            <td><%= t.SName %></td>
                                            <td><%= t.PrevDeptName || t.PrevDept %></td>
                                            <td><%= t.TDeptName || t.TDept %></td>
                                            <td>
                                                <button class="btn btn-success btn-sm btn-action" 
                                                        data-pfno="<%= t.PFNO %>" 
                                                        data-tdate="<%= t.TDate %>" 
                                                        data-dept="<%= t.TDept %>" 
                                                        data-action="approve">
                                                    <i class="bi bi-check-lg"></i> Approve
                                                </button>
                                                <button class="btn btn-danger btn-sm btn-action" 
                                                        data-pfno="<%= t.PFNO %>" 
                                                        data-tdate="<%= t.TDate %>" 
                                                        data-dept="<%= t.TDept %>" 
                                                        data-action="reject">
                                                    <i class="bi bi-x-lg"></i> Reject
                                                </button>
                                            </td>
                                        </tr>
                                    <% }); %>
                                </tbody>
                            </table>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const buttons = document.querySelectorAll('.btn-action');

            buttons.forEach(btn => {
                btn.addEventListener('click', async () => {
                    const pfno = btn.dataset.pfno;
                    const tDate = btn.dataset.tdate; // Keep original format from DB (ISO string likely)
                    const newDeptCode = btn.dataset.dept;
                    const action = btn.dataset.action;

                    if (!confirm(`Are you sure you want to ${action.toUpperCase()} this transfer?`)) {
                        return;
                    }

                    try {
                        const res = await fetch('/manager/approve/transfer', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ pfno, tDate, newDeptCode, action })
                        });
                        const data = await res.json();

                        if (res.ok) {
                            alert(data.message);
                            // Remove row from table
                            const row = document.getElementById(`row-${pfno}`);
                            if (row) row.remove();
                            
                            // Reload if table empty
                            if (document.querySelectorAll('tbody tr').length === 0) {
                                location.reload();
                            }
                        } else {
                            alert(data.error || 'Operation failed');
                        }
                    } catch (error) {
                        console.error(error);
                        alert('Server error');
                    }
                });
            });
        });
    </script>
</body>
</html>