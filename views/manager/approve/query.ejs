<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> · HR & Payroll</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="/css/styles.css" rel="stylesheet" />
</head>
<body>
    <%- include('../partials/topbar', { user }) %>
    <%- include('../partials/sidebar') %>

    <main class="main">
        <div class="container-fluid">
            <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
                <h1 class="h2"><%= companyName %></h1>
            </div>

            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="bi bi-check-circle"></i> Approve Staff Queries</h5>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-hover table-bordered table-striped" id="approvalTable">
                            <thead class="table-light">
                                <tr>
                                    <th>Emp-ID</th>
                                    <th>Date</th>
                                    <th>Name</th>
                                    <th>Type</th>
                                    <th>Reaction</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (queries && queries.length > 0) { %>
                                    <% queries.forEach(q => { %>
                                        <tr>
                                            <td><%= q.PFNO %></td>
                                            <td><%= q.QDateFormatted %></td>
                                            <td><%= q.SName %></td>
                                            <td><%= q.QTypeName || q.QTypeCode %></td>
                                            <td><%= q.MResponseName || '' %></td>
                                            <td>
                                                <button class="btn btn-sm btn-success btn-approve" 
                                                        data-pfno="<%= q.PFNO %>" 
                                                        data-qdate="<%= q.QDateFormatted %>"
                                                        data-rawqdate="<%= q.QDateFull %>">
                                                    <i class="bi bi-check-lg"></i> Approve
                                                </button>
                                            </td>
                                        </tr>
                                    <% }) %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="6" class="text-center">No pending queries to approve</td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const approveButtons = document.querySelectorAll('.btn-approve');

            approveButtons.forEach(btn => {
                btn.addEventListener('click', async function() {
                    if (!confirm('Are you sure you want to approve this query?')) return;

                    const pfno = this.dataset.pfno;
                    const qDate = this.dataset.rawqdate; // Use raw date for DB matching

                    try {
                        const res = await fetch('/manager/approve/query', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ pfno, qDate })
                        });

                        const result = await res.json();
                        
                        if (res.ok && result.success) {
                            // Remove row from table
                            this.closest('tr').remove();
                            
                            // Check if table is empty
                            const tbody = document.querySelector('tbody');
                            if (tbody.children.length === 0) {
                                tbody.innerHTML = '<tr><td colspan="6" class="text-center">No pending queries to approve</td></tr>';
                            }
                        } else {
                            alert(result.error || 'Failed to approve query');
                        }
                    } catch (err) {
                        console.error(err);
                        alert('Error connecting to server');
                    }
                });
            });
        });
    </script>
</body>
</html>