<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Approve Increments · HR & Payroll</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <link href="/css/styles.css" rel="stylesheet" />
</head>
<body>
    <%- include('../partials/topbar', { user }) %>
    <%- include('../partials/sidebar') %>

    <main class="main">
        <div class="container-fluid">
            <div class="d-flex align-items-center justify-content-between mb-4">
                <div>
                    <h2 class="mb-0">Approve Increments</h2>
                    <div class="text-muted">Review and approve pending increments and salary adjustments</div>
                </div>
            </div>

            <div class="card shadow-sm">
                <div class="card-body">
                    <% if (increments.length === 0) { %>
                        <div class="alert alert-info">No pending increments found.</div>
                    <% } else { %>
                        <div class="table-responsive">
                            <table class="table table-hover align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th>Date</th>
                                        <th>Staff</th>
                                        <th>Type</th>
                                        <th>Grade</th>
                                        <th>Inc No</th>
                                        <th>Days</th>
                                        <th>Pay Type</th>
                                        <th>Keyed By</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% increments.forEach(inc => { %>
                                        <tr>
                                            <td><%= new Date(inc.IncDate).toLocaleDateString() %></td>
                                            <td>
                                                <div><%= inc.SName %></div>
                                                <small class="text-muted"><%= inc.PFNo %></small>
                                            </td>
                                            <td><%= inc.InsType || inc.Type %></td>
                                            <td><%= inc.Grade %></td>
                                            <td><%= inc.IncNo %></td>
                                            <td><%= inc.Days %></td>
                                            <td>
                                                <% if (inc.FPay) { %><span class="badge bg-success">Full Pay</span><% } %>
                                                <% if (inc.PPay) { %><span class="badge bg-warning text-dark">Part Pay</span><% } %>
                                                <% if (inc.WPay) { %><span class="badge bg-danger">Without Pay</span><% } %>
                                            </td>
                                            <td>
                                                <div><%= inc.KeyedinBy %></div>
                                                <small class="text-muted"><%= new Date(inc.DateKeyed).toLocaleDateString() %></small>
                                            </td>
                                            <td>
                                                <button class="btn btn-sm btn-primary" 
                                                    onclick="viewDetails('<%= inc.PFNo %>', '<%= inc.SName %>', '<%= inc.IncDateStr %>', '<%= inc.InsType || inc.Type %>', '<%= inc.Type %>', '<%= inc.Grade %>', '<%= inc.IncNo %>', '<%= inc.Days %>', <%= inc.FPay %>, <%= inc.PPay %>, <%= inc.WPay %>)">
                                                    View
                                                </button>
                                            </td>
                                        </tr>
                                    <% }) %>
                                </tbody>
                            </table>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>

        <!-- Details Modal -->
        <div class="modal fade" id="detailsModal" tabindex="-1">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Increment Details</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <dl class="row">
                            <dt class="col-sm-4">Staff Name</dt>
                            <dd class="col-sm-8" id="mSName"></dd>

                            <dt class="col-sm-4">PFNo</dt>
                            <dd class="col-sm-8" id="mPFNo"></dd>

                            <dt class="col-sm-4">Type</dt>
                            <dd class="col-sm-8" id="mType"></dd>

                            <dt class="col-sm-4">Increment Date</dt>
                            <dd class="col-sm-8" id="mIncDate"></dd>

                            <dt class="col-sm-4">Grade</dt>
                            <dd class="col-sm-8" id="mGrade"></dd>

                            <dt class="col-sm-4">Increment No</dt>
                            <dd class="col-sm-8" id="mIncNo"></dd>

                            <dt class="col-sm-4">Days</dt>
                            <dd class="col-sm-8" id="mDays"></dd>

                            <dt class="col-sm-4">Pay Type</dt>
                            <dd class="col-sm-8" id="mPayType"></dd>
                        </dl>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                        <button type="button" class="btn btn-danger" id="btnReject">Reject</button>
                        <button type="button" class="btn btn-success" id="btnApprove">Approve</button>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        const modal = new bootstrap.Modal(document.getElementById('detailsModal'));
        let currentAction = { pfno: '', incDate: '', type: '' };

        function viewDetails(pfno, sname, incDateStr, typeName, typeCode, grade, incNo, days, fPay, pPay, wPay) {
            document.getElementById('mPFNo').textContent = pfno;
            document.getElementById('mSName').textContent = sname;
            document.getElementById('mIncDate').textContent = new Date(incDateStr).toLocaleDateString();
            document.getElementById('mType').textContent = typeName;
            document.getElementById('mGrade').textContent = grade;
            document.getElementById('mIncNo').textContent = incNo;
            document.getElementById('mDays').textContent = days;

            let payType = 'Unknown';
            if (fPay) payType = 'Full Pay';
            else if (pPay) payType = 'Part Pay';
            else if (wPay) payType = 'Without Pay';
            document.getElementById('mPayType').textContent = payType;

            currentAction = { pfno, incDate: incDateStr, type: typeCode };
            
            // Set up buttons
            document.getElementById('btnApprove').onclick = () => sendAction('approve');
            document.getElementById('btnReject').onclick = () => sendAction('reject');

            modal.show();
        }

        async function sendAction(action) {
            if (!confirm(`Are you sure you want to ${action} this increment?`)) return;

            try {
                const response = await fetch('/manager/approve/increment', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ ...currentAction, action })
                });

                const result = await response.json();
                if (result.success) {
                    location.reload();
                } else {
                    alert('Error: ' + (result.error || 'Operation failed'));
                }
            } catch (error) {
                console.error(error);
                alert('Network error');
            }
        }
    </script>
</body>
</html>