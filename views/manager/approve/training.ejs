<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> · Manager</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="/css/styles.css" rel="stylesheet" />
</head>
<body>
    <%- include('../partials/topbar', { user }) %>
    <%- include('../partials/sidebar') %>

    <main class="main">
        <div class="container-fluid">
            <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
                <h1 class="h2">Training Approvals</h1>
            </div>

            <div class="card shadow-sm">
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-striped table-hover align-middle">
                            <thead class="table-dark">
                                <tr>
                                    <th>Emp-ID</th>
                                    <th>Name</th>
                                    <th>Course</th>
                                    <th>Duration</th>
                                    <th>Country</th>
                                    <th>Start</th>
                                    <th>Sponsor</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (trainings.length > 0) { %>
                                    <% trainings.forEach(t => { %>
                                        <tr id="row-<%= t.PFNo %>-<%= t.Course %>">
                                            <td><%= t.PFNo %></td>
                                            <td><%= t.SName %></td>
                                            <td><%= t.Course %></td>
                                            <td><%= t.Duration %></td>
                                            <td><%= t.Country %></td>
                                            <td><%= new Date(t.StartDate).toLocaleDateString() %></td>
                                            <td><%= t.SponsorName %></td>
                                            <td>
                                                <button class="btn btn-sm btn-success me-1" onclick="approve('<%= t.PFNo %>', '<%= t.Course %>', '<%= t.StartDate %>')">
                                                    <i class="bi bi-check-lg"></i> Approve
                                                </button>
                                                <button class="btn btn-sm btn-danger" onclick="reject('<%= t.PFNo %>', '<%= t.Course %>', '<%= t.StartDate %>')">
                                                    <i class="bi bi-x-lg"></i> Reject
                                                </button>
                                            </td>
                                        </tr>
                                    <% }); %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="8" class="text-center text-muted">No pending training approvals found.</td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        async function approve(pfno, course, startDate) {
            if (!confirm('Are you sure you want to approve this training?')) return;
            
            try {
                const res = await fetch('/manager/api/approve/training', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ pfno, course, startDate, action: 'approve' })
                });
                
                const data = await res.json();
                if (data.success) {
                    alert('Training approved successfully.');
                    location.reload();
                } else {
                    alert('Error: ' + data.message);
                }
            } catch (err) {
                console.error(err);
                alert('Failed to approve training.');
            }
        }

        async function reject(pfno, course, startDate) {
            if (!confirm('Are you sure you want to reject this training?')) return;
            
            try {
                const res = await fetch('/manager/api/approve/training', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ pfno, course, startDate, action: 'reject' })
                });
                
                const data = await res.json();
                if (data.success) {
                    alert('Training rejected successfully.');
                    location.reload();
                } else {
                    alert('Error: ' + data.message);
                }
            } catch (err) {
                console.error(err);
                alert('Failed to reject training.');
            }
        }
    </script>
</body>
</html>