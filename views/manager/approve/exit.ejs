<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> · HR & Payroll</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="/css/styles.css" rel="stylesheet" />
</head>
<body>
    <%- include('../partials/topbar', { user }) %>
    <%- include('../partials/sidebar') %>

    <main class="main">
        <div class="container-fluid">
            <div class="d-flex align-items-center justify-content-between mb-4">
                <div>
                    <h2 class="mb-0">Approve Staff Exits</h2>
                    <div class="text-muted">Review and approve staff resignation requests</div>
                </div>
            </div>

            <div class="card shadow-sm">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>EMP-ID</th>
                                    <th>Date</th>
                                    <th>Staff Name</th>
                                    <th>Date Left</th>
                                    <th>Reason</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (exitRequests.length > 0) { %>
                                    <% exitRequests.forEach(req => { %>
                                        <% 
                                            function formatDate(d) {
                                                if (!d) return '';
                                                const date = new Date(d);
                                                if (isNaN(date.getTime())) return '';
                                                if (date.getFullYear() < 1900) return '';
                                                return date.toISOString().split('T')[0];
                                            }
                                        %>
                                        <tr>
                                            <td><%= req.PFNo %></td>
                                            <td><%= formatDate(req.DateResigned) %></td>
                                            <td><%= req.SName %></td>
                                            <td><%= formatDate(req.DateLeft) %></td>
                                            <td><%= req.ReasonDesc || req.ReasonCode %></td>
                                            <td>
                                                <form action="/manager/approve/exit" method="POST" onsubmit="return confirm('Approve exit for <%= req.SName %>?');">
                                                    <input type="hidden" name="pfno" value="<%= req.PFNo %>">
                                                    <button type="submit" class="btn btn-sm btn-success">
                                                        <i class="bi bi-check-circle"></i> Approve
                                                    </button>
                                                </form>
                                            </td>
                                        </tr>
                                    <% }) %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="6" class="text-center py-4 text-muted">No pending exit requests</td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>