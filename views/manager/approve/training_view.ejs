<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> · Manager</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="/css/styles.css" rel="stylesheet" />
</head>
<body>
    <%- include('../partials/topbar', { user }) %>
    <%- include('../partials/sidebar') %>

    <main class="main">
        <div class="container-fluid">
            <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
                <h1 class="h2">Training Details</h1>
                <div class="btn-toolbar mb-2 mb-md-0">
                    <a href="/manager/approve/training" class="btn btn-sm btn-outline-secondary">
                        <i class="bi bi-arrow-left"></i> Back to List
                    </a>
                </div>
            </div>

            <div class="card shadow-sm mb-4">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Staff Information</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-4">
                            <strong>Staff Name:</strong>
                            <p class="text-muted"><%= training.SName %></p>
                        </div>
                        <div class="col-md-4">
                            <strong>Employee ID:</strong>
                            <p class="text-muted"><%= training.PFNo %></p>
                        </div>
                        <div class="col-md-4">
                            <strong>Department:</strong>
                            <p class="text-muted"><%= training.DeptName || 'N/A' %></p>
                        </div>
                        <div class="col-md-4">
                            <strong>Job Title:</strong>
                            <p class="text-muted"><%= training.JobName || 'N/A' %></p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm mb-4">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Training Details</h5>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Course Title</label>
                            <input type="text" class="form-control" value="<%= training.Course %>" readonly>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-bold">Level</label>
                            <input type="text" class="form-control" value="<%= training.LevelName || training.Level %>" readonly>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-bold">Type</label>
                            <input type="text" class="form-control" value="<%= training.TypeName || training.Type %>" readonly>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Organised By</label>
                            <input type="text" class="form-control" value="<%= training.OrganisedBy %>" readonly>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-bold">Duration</label>
                            <input type="text" class="form-control" value="<%= training.Duration %>" readonly>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-bold">Country/Location</label>
                            <input type="text" class="form-control" value="<%= training.Country %>" readonly>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-bold">Start Date</label>
                            <input type="text" class="form-control" value="<%= new Date(training.StartDate).toLocaleDateString() %>" readonly>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-bold">Cost</label>
                            <input type="text" class="form-control" value="<%= training.Cost %>" readonly>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-bold">Sponsor</label>
                            <input type="text" class="form-control" value="<%= training.SponsorName || 'Self' %>" readonly>
                        </div>
                    </div>
                </div>
            </div>

            <div class="d-flex justify-content-end gap-2 mb-5">
                <button class="btn btn-danger" onclick="handleAction('reject')">
                    <i class="bi bi-x-circle"></i> Reject
                </button>
                <button class="btn btn-success" onclick="handleAction('approve')">
                    <i class="bi bi-check-circle"></i> Approve
                </button>
            </div>
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        const pfno = '<%= training.PFNo %>';
        const course = '<%= training.Course %>';
        // Pass exact ISO string if possible, or handle on server
        // Using raw EJS value for date might be safer if it's already a string or Date object
        const startDate = '<%= new Date(training.StartDate).toISOString() %>'; 

        async function handleAction(action) {
            if (!confirm(`Are you sure you want to ${action} this training request?`)) return;

            try {
                const res = await fetch('/manager/api/approve/training', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ pfno, course, startDate, action })
                });

                const data = await res.json();
                
                if (data.success) {
                    alert(`Training ${action}ed successfully.`);
                    window.location.href = '/manager/approve/training';
                } else {
                    alert('Error: ' + (data.message || data.error));
                }
            } catch (err) {
                console.error(err);
                alert('Request failed.');
            }
        }
    </script>
</body>
</html>
