<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> · Manager</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="/css/styles.css" rel="stylesheet" />
</head>
<body>
    <%- include('../partials/topbar', { user, role }) %>
    <%- include('../partials/sidebar') %>

    <main class="main">
        <div class="container-fluid">
            <div class="d-flex align-items-center justify-content-between mb-3">
                <div>
                    <h2 class="mb-0">Edited Payroll Detail</h2>
                    <div class="text-muted"><%= rec.PFNo %> - <%= rec.SName %></div>
                </div>
                <a href="/manager/approve/edited-payroll" class="btn btn-outline-secondary btn-sm">
                    <i class="bi bi-arrow-left"></i> Back
                </a>
            </div>

            <form action="/manager/approve/edited-payroll" method="POST">
                <input type="hidden" name="pfno" value="<%= rec.PFNo %>">
                <input type="hidden" name="pdate" value="<%= rec.PDate.toISOString ? rec.PDate.toISOString() : rec.PDate %>">

                <ul class="nav nav-tabs mb-3" role="tablist">
                    <li class="nav-item">
                        <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tab-staff" type="button">Staff Information</button>
                    </li>
                    <li class="nav-item">
                        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-additions" type="button">Monthly Additions</button>
                    </li>
                    <li class="nav-item">
                        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-deductions" type="button">Monthly Deductions</button>
                    </li>
                    <li class="nav-item">
                        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-benefits" type="button">Benefits</button>
                    </li>
                </ul>

                <div class="tab-content">
                    <div class="tab-pane fade show active" id="tab-staff">
                        <div class="row g-3">
                            <div class="col-md-4">
                                <label class="form-label">Staff Grade</label>
                                <input type="text" class="form-control" value="<%= rec.GradeName %>" readonly>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Annual Salary</label>
                                <input type="text" class="form-control" value="<%= rec.Annual %>" readonly>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Job Title</label>
                                <input type="text" class="form-control" value="<%= rec.JobTitleName %>" readonly>
                            </div>
                        </div>
                    </div>

                    <div class="tab-pane fade" id="tab-additions">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Salary</label>
                                <input type="text" class="form-control" value="<%= rec.Salary %>" readonly>
                            </div>
                        </div>
                        <div class="row mt-3">
                            <div class="col-md-6">
                                <% (addItems || []).forEach((it, idx) => { if (idx % 2 === 0) { %>
                                    <% const col = 'Allw' + it.Code; %>
                                    <div class="mb-2">
                                        <label class="form-label"><%= it.Income %></label>
                                        <input type="text" class="form-control" value="<%= rec[col] %>" readonly>
                                    </div>
                                <% } }) %>
                            </div>
                            <div class="col-md-6">
                                <% (addItems || []).forEach((it, idx) => { if (idx % 2 === 1) { %>
                                    <% const col = 'Allw' + it.Code; %>
                                    <div class="mb-2">
                                        <label class="form-label"><%= it.Income %></label>
                                        <input type="text" class="form-control" value="<%= rec[col] %>" readonly>
                                    </div>
                                <% } }) %>
                            </div>
                        </div>
                        <div class="row g-3 mt-2">
                            <div class="col-md-6">
                                <label class="form-label">Total Income</label>
                                <input type="text" class="form-control" value="<%= rec.TotalIncome %>" readonly>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Taxable Income</label>
                                <input type="text" class="form-control" value="<%= rec.Taxable %>" readonly>
                            </div>
                        </div>
                    </div>

                    <div class="tab-pane fade" id="tab-deductions">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <% const d31 = (dedItems || []).find(d => d.Code === '31'); %>
                                <% const d32 = (dedItems || []).find(d => d.Code === '32'); %>
                                <% const d33 = (dedItems || []).find(d => d.Code === '33'); %>
                                <% const d34 = (dedItems || []).find(d => d.Code === '34'); %>
                                <% if (d31) { %>
                                    <div class="mb-2">
                                        <label class="form-label"><%= d31.Income %> (Tax)</label>
                                        <input type="text" class="form-control" value="<%= rec.Tax %>" readonly>
                                    </div>
                                <% } %>
                                <% if (d32) { %>
                                    <div class="mb-2">
                                        <label class="form-label"><%= d32.Income %> (NassitEmp)</label>
                                        <input type="text" class="form-control" value="<%= rec.NassitEmp %>" readonly>
                                    </div>
                                <% } %>
                                <% if (d33) { %>
                                    <div class="mb-2">
                                        <label class="form-label"><%= d33.Income %> (GratEmp)</label>
                                        <input type="text" class="form-control" value="<%= rec.GratEmp %>" readonly>
                                    </div>
                                <% } %>
                                <% if (d34) { %>
                                    <div class="mb-2">
                                        <label class="form-label"><%= d34.Income %> (Ded1)</label>
                                        <input type="text" class="form-control" value="<%= rec.Ded1 %>" readonly>
                                    </div>
                                <% } %>
                            </div>
                            <div class="col-md-6">
                                <% const d35 = (dedItems || []).find(d => d.Code === '35'); %>
                                <% const d36 = (dedItems || []).find(d => d.Code === '36'); %>
                                <% const d37 = (dedItems || []).find(d => d.Code === '37'); %>
                                <% if (d35) { %>
                                    <div class="mb-2">
                                        <label class="form-label"><%= d35.Income %> (UnionDues)</label>
                                        <input type="text" class="form-control" value="<%= rec.UnionDues %>" readonly>
                                    </div>
                                <% } %>
                                <% if (d36) { %>
                                    <div class="mb-2">
                                        <label class="form-label"><%= d36.Income %> (Ded3)</label>
                                        <input type="text" class="form-control" value="<%= rec.Ded3 %>" readonly>
                                    </div>
                                <% } %>
                                <% if (d37) { %>
                                    <div class="mb-2">
                                        <label class="form-label"><%= d37.Income %> (Ded4)</label>
                                        <input type="text" class="form-control" value="<%= rec.Ded4 %>" readonly>
                                    </div>
                                <% } %>
                            </div>
                        </div>
                        <div class="my-3" style="height: 1rem;"></div>
                        <div class="row g-3 mt-1">
                            <div class="col-md-6">
                                <label class="form-label">Total Deductions</label>
                                <input type="text" class="form-control" value="<%= rec.TotalDeduction %>" readonly>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Net Income</label>
                                <input type="text" class="form-control" value="<%= rec.NetIncome %>" readonly>
                            </div>
                        </div>
                    </div>

                    <div class="tab-pane fade" id="tab-benefits">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">NASSIT-Institution</label>
                                <input type="text" class="form-control" value="<%= rec.NassitInst %>" readonly>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Prov-Institution</label>
                                <input type="text" class="form-control" value="<%= rec.GratInst %>" readonly>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="mt-4 d-flex justify-content-end gap-2">
                    <button type="submit" name="action" value="reject" class="btn btn-outline-danger">
                        <i class="bi bi-x-circle"></i> Reject
                    </button>
                    <button type="submit" name="action" value="approve" class="btn btn-success">
                        <i class="bi bi-check-circle"></i> Approve
                    </button>
                </div>
            </form>
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
