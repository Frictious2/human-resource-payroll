<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> · HR & Payroll</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="/css/styles.css" rel="stylesheet" />
</head>
<body>
    <%- include('../partials/topbar', { user }) %>
    <%- include('../partials/sidebar') %>

    <main class="main">
        <div class="container-fluid">
            <div class="d-flex align-items-center justify-content-between mb-3">
                <div>
                    <h2 class="mb-0">View Income Setup</h2>
                    <div class="text-muted">Read-only details</div>
                </div>
            </div>

            <div class="card shadow-sm">
                <div class="card-body">
                    <h5 class="mb-3">Scale Details</h5>
                    <div class="row g-3">
                        <div class="col-md-3">
                            <label class="form-label">Scale Date</label>
                            <input type="text" class="form-control" value="<%= record.ScaleDate ? new Date(record.ScaleDate).toLocaleDateString() : '-' %>" disabled>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Grade</label>
                            <select class="form-select" disabled>
                                <option value="">Select</option>
                                <% (grades || []).forEach(g => { %>
                                    <option value="<%= g.GradeCode %>" <%= record.Grade === g.GradeCode ? 'selected' : '' %>><%= g.GradeCode %> — <%= g.Grade %></option>
                                <% }) %>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Currency</label>
                            <select class="form-select" disabled>
                                <option value="">Select</option>
                                <% (currencies || []).forEach(c => { %>
                                    <option value="<%= c.CurrCode %>" <%= record.PayCurrency === c.CurrCode ? 'selected' : '' %>><%= c.CurrName %></option>
                                <% }) %>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Levels</label>
                            <input type="text" class="form-control" value="<%= (record.StartLevel || '-') %> - <%= (record.EndLevel || '-') %>" disabled>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Notches</label>
                            <input type="text" class="form-control" value="<%= record.Notches || '-' %>" disabled>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Increment</label>
                            <input type="text" class="form-control" value="<%= record.Increment || '-' %>" disabled>
                        </div>
                    </div>

                    <hr class="my-3">
                    <h5 class="mb-3">Items</h5>
                    <div class="table-responsive">
                        <table class="table table-bordered align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>Item</th>
                                    <th>Tax</th>
                                    <th>Threshold</th>
                                    <th>Threshold %</th>
                                    <th>Threshold Rate</th>
                                    <th>Threshold Amount</th>
                                    <th>Fix</th>
                                    <th>Amount</th>
                                    <th>Rate</th>
                                    <th>Frequency</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% (items || []).forEach(it => { 
                                    const code = it.Code;
                                    const get = (name) => record[name] ?? null;
                                    const tax = get('Taxable' + code);
                                    const thresh = get('Thresh' + code);
                                    const tpercent = get('TPercent' + code);
                                    const tpercentage = get('TPercentage' + code);
                                    const tamount = get('TAmount' + code);
                                    const fix = get('Percent' + code);
                                    const amount = get('Amount' + code);
                                    const rate = get('Rate' + code);
                                %>
                                    <tr>
                                        <td><%= it.Income %></td>
                                        <td><input type="checkbox" class="form-check-input" <%= tax === -1 ? 'checked' : '' %> disabled></td>
                                        <td><input type="checkbox" class="form-check-input" <%= thresh === -1 ? 'checked' : '' %> disabled></td>
                                        <td><input type="checkbox" class="form-check-input" <%= tpercent === -1 ? 'checked' : '' %> disabled></td>
                                        <td><input type="text" class="form-control" value="<%= tpercentage ?? '' %>" disabled></td>
                                        <td><input type="text" class="form-control" value="<%= tamount ?? '' %>" disabled></td>
                                        <td><input type="checkbox" class="form-check-input" <%= fix === -1 ? 'checked' : '' %> disabled></td>
                                        <td><input type="text" class="form-control" value="<%= amount ?? '' %>" disabled></td>
                                        <td><input type="text" class="form-control" value="<%= rate ?? '' %>" disabled></td>
                                        <td><input type="text" class="form-control" value="<%= it.Freq || '-' %>" disabled></td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>

                    <div class="mt-4 d-flex justify-content-between">
                        <a href="/manager/approve/income-setup" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Back</a>
                        <form action="/manager/approve/income-setup" method="POST" class="d-inline">
                            <input type="hidden" name="gradeCode" value="<%= record.GradeCode %>">
                            <input type="hidden" name="scaleDate" value="<%= record.ScaleDate %>">
                            <button type="submit" name="action" value="approve" class="btn btn-success">
                                <i class="bi bi-check-circle"></i> Approve
                            </button>
                            <button type="submit" name="action" value="reject" class="btn btn-danger">
                                <i class="bi bi-x-circle"></i> Reject
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
