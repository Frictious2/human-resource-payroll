<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> · Manager</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="/css/styles.css" rel="stylesheet" />
</head>
<body>
    <%- include('../partials/topbar', { user, role }) %>
    <%- include('../partials/sidebar') %>
    <main class="main">
        <div class="container-fluid py-3">
            <div class="d-flex align-items-center justify-content-between mb-4">
                <div><h2 class="mb-0"><%= title %></h2><div class="text-muted">Preview approved salary review rules against current active payroll setup</div></div>
            </div>
            <% if (success) { %>
                <div class="alert alert-success shadow-sm"><%= success %></div>
            <% } %>
            <% if (error) { %>
                <div class="alert alert-danger shadow-sm"><%= error %></div>
            <% } %>
            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <form method="GET" action="/manager/activity/run-salary-review" class="row g-3">
                        <div class="col-md-4"><label class="form-label">Review Date</label><input type="date" class="form-control" name="reviewDate" value="<%= filters.reviewDate %>"></div>
                        <div class="col-md-4"><label class="form-label">Review Type</label><select class="form-select" name="revCode"><option value="">All Approved Review Types</option><% reviewTypes.forEach((type) => { %><option value="<%= type.RevCode %>" <%= filters.revCode === type.RevCode ? 'selected' : '' %>><%= type.RevName %></option><% }) %></select></div>
                        <div class="col-md-4 d-flex align-items-end"><button type="submit" class="btn btn-primary w-100">Preview Eligible Staff</button></div>
                    </form>
                </div>
            </div>
            <div class="card shadow-sm mb-4">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover table-bordered align-middle mb-0">
                            <thead class="table-light"><tr><th>Review Date</th><th>Type</th><th>Start Grade</th><th>End Grade</th><th>Percentage</th><th>Eligible Staff</th><th class="text-end">Action</th></tr></thead>
                            <tbody>
                                <% if (!rules.length) { %><tr><td colspan="7" class="text-center text-muted py-4">No approved salary review rules match the selected filters.</td></tr><% } %>
                                <% rules.forEach((rule) => { %>
                                    <tr>
                                        <td><%= rule.ReviewDateOnly ? new Date(rule.ReviewDateOnly).toLocaleDateString() : '-' %></td>
                                        <td><%= rule.RevName || rule.RevCode %></td>
                                        <td><%= rule.StartGradeName || rule.SGrade %></td>
                                        <td><%= rule.EndGradeName || rule.EGrade %></td>
                                        <td><%= Number(rule.Percentage || 0).toLocaleString() %>%</td>
                                        <td><%= Number(rule.EligibleCount || 0).toLocaleString() %></td>
                                        <td class="text-end">
                                            <form method="POST" action="/manager/activity/run-salary-review" class="d-inline">
                                                <input type="hidden" name="reviewDate" value="<%= rule.ReviewDateOnly || '' %>">
                                                <input type="hidden" name="revCode" value="<%= rule.RevCode %>">
                                                <input type="hidden" name="startGrade" value="<%= rule.SGrade %>">
                                                <input type="hidden" name="endGrade" value="<%= rule.EGrade %>">
                                                <button
                                                    type="submit"
                                                    class="btn btn-sm btn-success"
                                                    <%= Number(rule.EligibleCount || 0) > 0 ? '' : 'disabled' %>
                                                    onclick="return confirm('Create increment records for this approved salary review?');"
                                                >
                                                    Commit / Apply Review
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            <div class="card shadow-sm">
                <div class="card-header bg-white"><strong>Eligible Staff Preview</strong></div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-striped table-hover table-bordered align-middle mb-0">
                            <thead class="table-light"><tr><th>PFNo</th><th>Name</th><th>Dept</th><th>Grade</th><th>Rule</th><th class="text-end">Current Salary</th><th class="text-end">Proposed Salary</th><th class="text-end">Current Total</th><th class="text-end">Proposed Total</th></tr></thead>
                            <tbody>
                                <% if (!previewRows.length) { %><tr><td colspan="9" class="text-center text-muted py-4">Load a review rule to preview affected staff.</td></tr><% } %>
                                <% previewRows.forEach((row) => { %>
                                    <tr>
                                        <td><%= row.PFNo %></td><td><%= row.SName %></td><td><%= row.DeptName || row.CDept %></td><td><%= row.GradeName || row.CGrade %></td><td><%= row.ReviewName %> (<%= Number(row.Percentage || 0).toLocaleString() %>%)</td>
                                        <td class="text-end"><%= Number(row.CurrentSalary || 0).toLocaleString() %></td><td class="text-end"><%= Number(row.ProposedSalary || 0).toLocaleString() %></td><td class="text-end"><%= Number(row.CurrentTotal || 0).toLocaleString() %></td><td class="text-end"><%= Number(row.ProposedTotal || 0).toLocaleString() %></td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </main>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
