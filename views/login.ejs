<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Sign In - HR & Payroll</title>

    <link
        href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
        rel="stylesheet"
        integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDrpNlyT2bRjXh0JMhjY6hW+ALEwIH"
        crossorigin="anonymous"
    />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="/css/styles.css" rel="stylesheet" />
</head>
<body class="login-page">
    <div class="login-shell">
        <section class="login-hero">
            <div class="login-hero__backdrop"></div>
            <div class="login-hero__content">
                <div class="login-brand-pill">
                    <i class="bi bi-buildings"></i>
                    <span>HR & Payroll Platform</span>
                </div>

                <h1 class="login-hero__title">Secure access for payroll, people, and approvals.</h1>
                <p class="login-hero__copy">
                    Keep salary processing, staff changes, and audit activity inside one accountable workspace for every role in the system.
                </p>

                <div class="login-hero__grid">
                    <article class="login-metric-card">
                        <span class="login-metric-card__icon"><i class="bi bi-shield-lock"></i></span>
                        <div>
                            <h2>Role-based access</h2>
                            <p>Each login is routed straight to its own dashboard and protected workspace.</p>
                        </div>
                    </article>
                    <article class="login-metric-card">
                        <span class="login-metric-card__icon"><i class="bi bi-journal-check"></i></span>
                        <div>
                            <h2>Audit-ready actions</h2>
                            <p>Account activity and critical transactions can be reviewed with a clear history trail.</p>
                        </div>
                    </article>
                    <article class="login-metric-card">
                        <span class="login-metric-card__icon"><i class="bi bi-calculator"></i></span>
                        <div>
                            <h2>Payroll operations</h2>
                            <p>From processing to GL posting, monthly payroll flows stay under controlled access.</p>
                        </div>
                    </article>
                </div>
            </div>
        </section>

        <section class="login-panel">
            <div class="login-card">
                <div class="login-card__header">
                    <span class="login-eyebrow">System Access</span>
                    <h2>Sign in</h2>
                    <p>Enter your username or email and password to continue.</p>
                </div>

                <% if (typeof error !== 'undefined' && error) { %>
                    <div class="alert alert-danger login-alert" role="alert"><%= error %></div>
                <% } %>

                <form action="/login" method="post" novalidate>
                    <div class="mb-3">
                        <label for="identifier" class="form-label">Username or Email</label>
                        <div class="login-input-group">
                            <span class="login-input-group__icon"><i class="bi bi-person-circle"></i></span>
                            <input
                                type="text"
                                class="form-control"
                                id="identifier"
                                name="identifier"
                                value="<%= typeof identifier !== 'undefined' ? identifier : '' %>"
                                placeholder="Enter your username or email"
                                required
                                autocomplete="username"
                            />
                        </div>
                    </div>

                    <div class="mb-4">
                        <label for="password" class="form-label">Password</label>
                        <div class="login-input-group">
                            <span class="login-input-group__icon"><i class="bi bi-key"></i></span>
                            <input
                                type="password"
                                class="form-control"
                                id="password"
                                name="password"
                                placeholder="Enter your password"
                                required
                                autocomplete="current-password"
                            />
                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary login-submit-btn">
                        <span>Sign in</span>
                        <i class="bi bi-arrow-right-circle"></i>
                    </button>
                </form>

                <div class="login-card__footer">
                    <div class="login-help-row">
                        <i class="bi bi-envelope-paper"></i>
                        <span>Use the account setup link sent by your administrator to create your password.</span>
                    </div>
                </div>
            </div>
        </section>
    </div>

    <script
        src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-ENjdO4Dr2bkBIFxQpeoYz1F1LGjG7Sk3G2CJJH0bQ9aZB3zv5xRk5MQbN9I5k5WQ"
        crossorigin="anonymous"
    ></script>
</body>
</html>
