<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> · <%= group %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="/css/styles.css" rel="stylesheet" />
    <style>
        @media print {
            .d-print-none { display: none !important; }
        }
    </style>
</head>
<body>
    <%- include('../partials/topbar', { user }) %>
    <%- include('../partials/sidebar') %>

    <main class="main">
        <div class="container-fluid">
            <div class="d-flex align-items-center justify-content-between mb-4">
                <h2 class="mb-0"><%= title %></h2>
            </div>

            <div class="card shadow-sm">
                <div class="card-body">
                    <form id="globalParamsForm">
                        <!-- Row 1: Sequence & Registration -->
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label">Sequence</label>
                                <input type="number" step="1" class="form-control" name="SeqNo" id="SeqNo">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Registration Number</label>
                                <input type="text" class="form-control" name="RegNo" id="RegNo">
                            </div>
                        </div>

                        <hr>

                        <!-- Row 2: Nassit -->
                        <h5 class="text-primary mb-3">Nassit</h5>
                        <div class="row mb-3">
                            <div class="col-md-4">
                                <label class="form-label">Nassit Date</label>
                                <input type="date" class="form-control" name="NDate" id="NDate">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Employee's Contribution (NLe)</label>
                                <input type="number" step="0.01" class="form-control" name="NRate" id="NRate">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Institute Contribution (NLe)</label>
                                <input type="number" step="0.01" class="form-control" name="NORate" id="NORate">
                            </div>
                        </div>

                        <hr>

                        <!-- Row 3: Gratituitty/Provident -->
                        <h5 class="text-primary mb-3">Gratuity / Provident</h5>
                        <div class="row mb-3">
                            <div class="col-md-4">
                                <label class="form-label">Date</label>
                                <input type="date" class="form-control" name="GDate" id="GDate">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Employee Gratuity (NLe)</label>
                                <input type="number" step="0.01" class="form-control" name="GRate" id="GRate">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Institute Gratuity (NLe)</label>
                                <input type="number" step="0.01" class="form-control" name="GORate" id="GORate">
                            </div>
                        </div>

                        <hr>

                        <!-- Row 4: Grid Section (4 rows x 3 columns) -->
                        <h5 class="text-primary mb-3">General Settings</h5>
                        
                        <!-- Grid Row 1 -->
                        <div class="row mb-3">
                            <div class="col-md-4">
                                <label class="form-label">Retirement Age</label>
                                <input type="number" step="1" class="form-control" name="RetireAge" id="RetireAge">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Confirmation Date</label>
                                <input type="number" step="1" class="form-control" name="ConfirmDays" id="ConfirmDays" placeholder="Days">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Child Age</label>
                                <input type="number" step="1" class="form-control" name="ChildAge" id="ChildAge">
                            </div>
                        </div>

                        <!-- Grid Row 2 -->
                        <div class="row mb-3">
                            <div class="col-md-4">
                                <label class="form-label">Min. Employment Age</label>
                                <input type="number" step="1" class="form-control" name="EmpAge" id="EmpAge">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Senior Staff Dues (NLe)</label>
                                <input type="number" step="0.01" class="form-control" name="Management" id="Management">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Junior Staff Dues (NLe)</label>
                                <input type="number" step="0.01" class="form-control" name="UnionDues" id="UnionDues">
                            </div>
                        </div>

                        <!-- Grid Row 3 -->
                        <div class="row mb-3">
                            <div class="col-md-4">
                                <label class="form-label">Max Dependants</label>
                                <input type="number" step="1" class="form-control" name="Max_Dependants" id="Max_Dependants">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Retirement Notice in Years</label>
                                <input type="number" step="1" class="form-control" name="RetireNotice" id="RetireNotice">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Interest (%)</label>
                                <input type="number" step="0.01" class="form-control" name="AdvanceInt" id="AdvanceInt">
                            </div>
                        </div>

                        <!-- Grid Row 4 -->
                        <div class="row mb-3">
                            <div class="col-md-4">
                                <label class="form-label">Max Queries</label>
                                <input type="number" step="1" class="form-control" name="QueryLimit" id="QueryLimit">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Clock In</label>
                                <input type="time" class="form-control" name="ClockIn" id="ClockIn">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Interest Threshold (%)</label>
                                <input type="number" step="any" class="form-control" name="LoanDuration" id="LoanDuration" placeholder="Loan Duration">
                            </div>
                        </div>

                        <hr>

                        <!-- Row 5: Department Head & Department -->
                        <h5 class="text-primary mb-3">Department Head</h5>
                        <div class="row mb-3">
                            <div class="col-md-4">
                                <label class="form-label">Department Head (HOD)</label>
                                <input type="text" class="form-control" name="HOD" id="HOD">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Department Code</label>
                                <input type="text" class="form-control" name="Dept" id="Dept">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Department Name</label>
                                <input type="text" class="form-control" name="DeptName" id="DeptName">
                            </div>
                        </div>

                        <!-- Row 6: Vehicle Policy Checkbox -->
                        <div class="row mb-3">
                            <div class="col-12">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="VPolicy" id="VPolicy">
                                    <label class="form-check-label" for="VPolicy">
                                        Invoke Vehicle Policy
                                    </label>
                                </div>
                            </div>
                        </div>

                        <div class="text-end mt-4">
                            <button type="submit" class="btn btn-primary px-4" id="saveBtn">Save</button>
                        </div>
                    </form>
                </div>
            </div>

            <footer class="mt-4 py-3 text-center text-muted border-top">
                <%- include('../partials/footer') %>
            </footer>
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        (async () => {
            const form = document.getElementById('globalParamsForm');
            const saveBtn = document.getElementById('saveBtn');

            // Fetch existing data
            try {
                const res = await fetch('/admin/api/parameters/global-params');
                if (!res.ok) throw new Error('API response not ok');
                
                let d = await res.json();
                console.log('Global Params Data:', d);
                
                // Handle if array is returned
                if (Array.isArray(d)) d = d[0];

                if (d && Object.keys(d).length > 0) {
                    // Helper to set value safely
                    const setVal = (id, val) => {
                        const el = document.getElementById(id);
                        if(el && val !== undefined && val !== null) el.value = val;
                    };

                    setVal('SeqNo', d.SeqNo);
                    setVal('RegNo', d.RegNo);
                    
                    if(d.NDate) setVal('NDate', String(d.NDate).split('T')[0]);
                    setVal('NRate', d.NRate);
                    setVal('NORate', d.NORate);
                    
                    if(d.GDate) setVal('GDate', String(d.GDate).split('T')[0]);
                    setVal('GRate', d.GRate);
                    setVal('GORate', d.GORate);

                    setVal('RetireAge', d.RetireAge);
                    setVal('ConfirmDays', d.ConfirmDays);
                    setVal('ChildAge', d.ChildAge);

                    setVal('EmpAge', d.EmpAge);
                    setVal('Management', d.Management);
                    setVal('UnionDues', d.UnionDues);

                    setVal('Max_Dependants', d.Max_Dependants);
                    setVal('RetireNotice', d.RetireNotice);
                    setVal('AdvanceInt', d.AdvanceInt);

                    setVal('QueryLimit', d.QueryLimit);
                    
                    // ClockIn
                    if (d.ClockIn) {
                         const cIn = String(d.ClockIn);
                         if (cIn.includes('T')) {
                             const timePart = cIn.split('T')[1].substring(0, 5);
                             setVal('ClockIn', timePart);
                         } else {
                             // "09:00:00.000" -> "09:00"
                             setVal('ClockIn', cIn.substring(0, 5));
                         }
                    }

                    // LoanDuration - if it exists in DB response
                    if (d.LoanDuration !== undefined) setVal('LoanDuration', d.LoanDuration);

                    setVal('HOD', d.HOD);
                    setVal('Dept', d.Dept);
                    setVal('DeptName', d.DeptName);

                    // VPolicy Checkbox
                    const vp = d.VPolicy;
                    if (vp == '1' || vp == '-1' || vp == 'true') {
                        const vpEl = document.getElementById('VPolicy');
                        if(vpEl) vpEl.checked = true;
                    }
                }
            } catch (err) {
                console.error('Failed to load Global Params', err);
            }

            // Handle Submit
            if(form) {
                form.addEventListener('submit', async (e) => {
                    e.preventDefault();
                    if(saveBtn) {
                        saveBtn.disabled = true;
                        saveBtn.textContent = 'Saving...';
                    }

                    try {
                        const formData = new FormData(form);
                        const data = Object.fromEntries(formData.entries());
                        
                        // Handle Checkbox
                        const vpEl = document.getElementById('VPolicy');
                        data.VPolicy = (vpEl && vpEl.checked) ? '-1' : '0'; 

                        const res = await fetch('/admin/api/parameters/global-params', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify(data)
                        });

                        const result = await res.json();
                        if (result.success) {
                            alert('Global Parameters saved successfully!');
                        } else {
                            alert('Error saving: ' + (result.error || 'Unknown error'));
                        }
                    } catch (err) {
                        console.error(err);
                        alert('Failed to save data.');
                    } finally {
                        if(saveBtn) {
                            saveBtn.disabled = false;
                            saveBtn.textContent = 'Save';
                        }
                    }
                });
            }
        })();
    </script>
</body>
</html>