<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> · <%= group %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="/css/styles.css" rel="stylesheet" />
    <style>
        .editable-cell {
            padding: 0.25rem;
        }
        .editable-cell input, .editable-cell select {
            width: 100%;
            border: 1px solid transparent;
            background: transparent;
            padding: 2px 4px;
        }
        .editable-cell input:focus, .editable-cell select:focus {
            border: 1px solid #0d6efd;
            background: #fff;
            outline: none;
        }
        .cell-updated {
            animation: highlight 1s ease-out;
        }
        @keyframes highlight {
            0% { background-color: #d1e7dd; }
            100% { background-color: transparent; }
        }
        .cell-error {
            animation: highlight-error 1s ease-out;
            border: 1px solid red !important;
        }
        @keyframes highlight-error {
            0% { background-color: #f8d7da; }
            100% { background-color: transparent; }
        }
    </style>
</head>
<body>
    <%- include('../partials/topbar', { user }) %>
    <%- include('../partials/sidebar') %>

    <main class="main">
        <div class="container-fluid">
            <div class="d-flex align-items-center justify-content-between mb-4">
                <h2 class="mb-0">Grades</h2>
                <div class="d-flex gap-2 d-print-none">
                    <button type="button" class="btn btn-success" onclick="exportExcel()">
                        <i class="bi bi-file-earmark-excel"></i> Export to Excel
                    </button>
                    <button type="button" class="btn btn-danger" onclick="exportPDF()">
                        <i class="bi bi-file-earmark-pdf"></i> Export to PDF
                    </button>
                    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addGradeModal">
                        <i class="bi bi-plus-circle me-2"></i>Add Grade
                    </button>
                </div>
            </div>

            <div class="card shadow-sm">
                <div class="card-body p-3 border-bottom">
                    <div class="row">
                        <div class="col-md-4">
                            <input type="text" id="searchInput" class="form-control" placeholder="Search grades...">
                        </div>
                    </div>
                </div>
                <div class="card-body p-0">
                    <div class="d-none d-print-block text-center py-4">
                        <h2 class="fw-bold mt-0">HR Payroll</h2>
                        <h4 class="text-decoration-underline mt-0">Grades</h4>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0" id="gradesTable">
                            <thead class="table-light">
                                <tr>
                                    <th style="width: 5%">No.</th>
                                    <th style="width: 20%">Grade</th>
                                    <th style="width: 20%">Job Title</th>
                                    <th style="width: 8%">LDays</th>
                                    <th style="width: 10%">Med Limit</th>
                                    <th style="width: 8%">C-Days</th>
                                    <th style="width: 7%">Notch</th>
                                    <th style="width: 7%">Notice</th>
                                    <th style="width: 7%">PromPeriod</th>
                                    <th class="text-end" style="width: 8%">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <!-- Rows will be populated by JS -->
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="card-footer bg-white border-top-0 py-3">
                    <nav aria-label="Page navigation">
                        <ul class="pagination justify-content-end mb-0" id="pagination">
                            <!-- Pagination will be populated by JS -->
                        </ul>
                    </nav>
                </div>
            </div>

            <footer class="mt-4 py-3 text-center text-muted border-top">
                <%- include('../partials/footer') %>
            </footer>
        </div>
    </main>

    <!-- Add Grade Modal -->
    <div class="modal fade" id="addGradeModal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Add Grade</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <form id="addGradeForm">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Grade Name *</label>
                                <input type="text" class="form-control" name="Grade" required>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Job Title *</label>
                                <select class="form-select" name="JobTitle" required>
                                    <option value="">Select Job Title</option>
                                    <% jobTitles.forEach(job => { %>
                                        <option value="<%= job.Code %>"><%= job.JobTitle %></option>
                                    <% }); %>
                                </select>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <label class="form-label">LDays</label>
                                <input type="number" class="form-control" name="LDays" value="0">
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="form-label">Med Limit</label>
                                <input type="number" class="form-control" name="Medical" value="0" step="0.01">
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="form-label">C-Days</label>
                                <input type="number" class="form-control" name="Confirm" value="0" step="0.01">
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <label class="form-label">Notch</label>
                                <input type="number" class="form-control" name="NotchIncr" value="0">
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="form-label">Notice</label>
                                <input type="number" class="form-control" name="Notice" value="0">
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="form-label">PromPeriod</label>
                                <input type="number" class="form-control" name="PromPeriod" value="0">
                            </div>
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                    <button type="button" class="btn btn-primary" id="saveNewGradeBtn">Save Grade</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Delete Modal -->
    <div class="modal fade" id="delete_item" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Delete Grade</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p>Are you sure want to delete this grade?</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-danger" id="confirmDeleteBtn">Delete</button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        const jobTitlesData = JSON.parse('<%- JSON.stringify(jobTitles || []).replace(/\\/g, "\\\\").replace(/\'/g, "\\\'").replace(/\"/g, "\\\"") %>');
        
        // State for pagination and search
        let allData = [];
        let filteredData = [];
        let currentPage = 1;
        const rowsPerPage = 10;
        let deleteId = null;

        document.addEventListener('DOMContentLoaded', () => {
            const tableBody = document.querySelector('#gradesTable tbody');
            const addGradeModal = new bootstrap.Modal(document.getElementById('addGradeModal'));
            const addGradeForm = document.getElementById('addGradeForm');
            const searchInput = document.getElementById('searchInput');
            const paginationContainer = document.getElementById('pagination');

            // Load Data
            loadGrades();

            async function loadGrades() {
                try {
                    const res = await fetch('/admin/api/parameters/grades');
                    const json = await res.json();
                    allData = json.data;
                    filterData();
                } catch (err) {
                    console.error('Failed to load grades', err);
                    alert('Error loading grades');
                }
            }

            // Search Logic
            searchInput.addEventListener('input', () => {
                filterData();
            });

            function filterData() {
                const term = searchInput.value.toLowerCase();
                filteredData = allData.filter(item => 
                    Object.values(item).some(val => 
                        String(val).toLowerCase().includes(term)
                    )
                );
                currentPage = 1;
                renderPage();
            }

            function renderPage() {
                const start = (currentPage - 1) * rowsPerPage;
                const end = start + rowsPerPage;
                const pageData = filteredData.slice(start, end);
                renderTable(pageData, start);
                renderPagination();
            }

            function renderPagination() {
                const totalPages = Math.ceil(filteredData.length / rowsPerPage);
                paginationContainer.innerHTML = '';

                if (totalPages <= 1) return;

                // Previous
                const prevLi = document.createElement('li');
                prevLi.className = `page-item ${currentPage === 1 ? 'disabled' : ''}`;
                prevLi.innerHTML = `<a class="page-link" href="#">Previous</a>`;
                prevLi.onclick = (e) => { e.preventDefault(); if (currentPage > 1) { currentPage--; renderPage(); } };
                paginationContainer.appendChild(prevLi);

                // Page Numbers (show max 5 for simplicity or full list)
                // For now, full list as parameters usually don't have hundreds of pages
                // If needed, we can implement smart ellipsis
                let startPage = Math.max(1, currentPage - 2);
                let endPage = Math.min(totalPages, startPage + 4);
                
                if (endPage - startPage < 4) {
                    startPage = Math.max(1, endPage - 4);
                }

                for (let i = startPage; i <= endPage; i++) {
                    const li = document.createElement('li');
                    li.className = `page-item ${i === currentPage ? 'active' : ''}`;
                    li.innerHTML = `<a class="page-link" href="#">${i}</a>`;
                    li.onclick = (e) => { e.preventDefault(); currentPage = i; renderPage(); };
                    paginationContainer.appendChild(li);
                }

                // Next
                const nextLi = document.createElement('li');
                nextLi.className = `page-item ${currentPage === totalPages ? 'disabled' : ''}`;
                nextLi.innerHTML = `<a class="page-link" href="#">Next</a>`;
                nextLi.onclick = (e) => { e.preventDefault(); if (currentPage < totalPages) { currentPage++; renderPage(); } };
                paginationContainer.appendChild(nextLi);
            }

            function generateJobTitleOptions(selectedCode) {
                let options = '<option value="">Select Job Title</option>';
                jobTitlesData.forEach(job => {
                    const selected = job.Code === selectedCode ? 'selected' : '';
                    options += `<option value="${job.Code}" ${selected}>${job.JobTitle}</option>`;
                });
                return options;
            }

            function renderTable(items, startIndex) {
                tableBody.innerHTML = '';
                if (items.length === 0) {
                    tableBody.innerHTML = '<tr><td colspan="10" class="text-center py-3">No grades found</td></tr>';
                    return;
                }
                items.forEach((item, index) => {
                    const tr = document.createElement('tr');
                    tr.dataset.code = item.GradeCode;
                    tr.innerHTML = `
                        <td>${startIndex + index + 1}</td>
                        <td class="editable-cell"><input type="text" name="Grade" value="${item.Grade || ''}" required></td>
                        <td class="editable-cell">
                            <select name="JobTitle" required>
                                ${generateJobTitleOptions(item.JobTitleCode)}
                            </select>
                        </td>
                        <td class="editable-cell"><input type="number" name="LDays" value="${item.LDays || 0}"></td>
                        <td class="editable-cell"><input type="number" name="Medical" value="${item.Medical || 0}" step="0.01"></td>
                        <td class="editable-cell"><input type="number" name="Confirm" value="${item.Confirm || 0}" step="0.01"></td>
                        <td class="editable-cell"><input type="number" name="NotchIncr" value="${item.NotchIncr || 0}"></td>
                        <td class="editable-cell"><input type="number" name="Notice" value="${item.Notice || 0}"></td>
                        <td class="editable-cell"><input type="number" name="PromPeriod" value="${item.PromPeriod || 0}"></td>
                        <td class="text-end">
                            <button class="btn btn-sm btn-outline-danger delete-btn"><i class="bi bi-trash"></i></button>
                        </td>
                    `;
                    tableBody.appendChild(tr);
                });
            }

            // Inline Editing
            tableBody.addEventListener('change', async (e) => {
                const target = e.target;
                if (target.tagName === 'INPUT' || target.tagName === 'SELECT') {
                    handleUpdate(target);
                }
            });

            tableBody.addEventListener('keydown', (e) => {
                if (e.key === 'Enter' && e.target.tagName !== 'SELECT') { // Don't blur on enter for select as it might toggle dropdown
                    e.target.blur(); 
                }
            });

            // Delete Button
            tableBody.addEventListener('click', (e) => {
                const btn = e.target.closest('.delete-btn');
                if (btn) {
                    const row = btn.closest('tr');
                    const code = row.dataset.code;
                    openDeleteModal(code);
                }
            });

            function openDeleteModal(code) {
                deleteId = code;
                const modalEl = document.getElementById('delete_item');
                let modal = bootstrap.Modal.getInstance(modalEl);
                if (!modal) {
                    modal = new bootstrap.Modal(modalEl);
                }
                modal.show();
            }

            document.getElementById('confirmDeleteBtn').addEventListener('click', async () => {
                if (!deleteId) return;
                
                try {
                    const res = await fetch(`/admin/api/parameters/grades/${deleteId}`, { method: 'DELETE' });
                    const json = await res.json();
                    if (json.success) {
                        // Remove from allData and re-render
                        allData = allData.filter(i => i.GradeCode != deleteId);
                        filterData();
                        
                        // Close modal
                        const modalEl = document.getElementById('delete_item');
                        const modal = bootstrap.Modal.getInstance(modalEl);
                        if (modal) modal.hide();
                    } else {
                        alert('Failed to delete');
                    }
                } catch (err) {
                    console.error(err);
                    alert('Error deleting grade');
                }
            });

            async function handleUpdate(input) {
                const row = input.closest('tr');
                const code = row.dataset.code;
                const fieldName = input.name;
                const value = input.value;

                if (!value) {
                    showError(input);
                    alert(`${fieldName} is required`);
                    return; 
                }

                input.disabled = true;

                try {
                    const payload = {};
                    payload[fieldName] = value;

                    const res = await fetch(`/admin/api/parameters/grades/${code}`, {
                        method: 'PATCH',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(payload)
                    });
                    const json = await res.json();
                    
                    input.disabled = false;
                    input.focus(); 
                    
                    if (json.success) {
                        input.parentElement.classList.add('cell-updated');
                        setTimeout(() => input.parentElement.classList.remove('cell-updated'), 1000);
                        
                        // Update local data
                        const itemIndex = allData.findIndex(i => i.GradeCode == code);
                        if (itemIndex > -1) {
                            allData[itemIndex][fieldName] = value;
                            if (fieldName === 'JobTitle') {
                                // Assuming value is code, but we might need JobTitle text for search?
                                // Actually JobTitle in table is select, so value is code.
                                // But if search looks for JobTitle text, we might need to update that too if available
                                // The select shows text, so value is code.
                                // Let's keep it simple.
                                allData[itemIndex]['JobTitleCode'] = value; 
                            }
                        }
                    } else {
                        showError(input);
                    }
                } catch (err) {
                    console.error(err);
                    input.disabled = false;
                    showError(input);
                }
            }

            function showError(input) {
                input.parentElement.classList.add('cell-error');
                setTimeout(() => input.parentElement.classList.remove('cell-error'), 1000);
            }

            // Add New Grade
            document.getElementById('saveNewGradeBtn').addEventListener('click', async () => {
                const formData = new FormData(addGradeForm);
                const data = Object.fromEntries(formData.entries());

                if (!data.Grade || !data.JobTitle) {
                    alert('Grade Name and Job Title are required');
                    return;
                }

                try {
                    const res = await fetch('/admin/api/parameters/grades', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(data)
                    });
                    const json = await res.json();

                    if (json.success) {
                        addGradeModal.hide();
                        addGradeForm.reset();
                        
                        // Add to allData and re-render
                        allData.push(json.item);
                        filterData();
                        
                        // Go to last page to see new item? Or just stay on current?
                        // Let's go to last page where new item is likely added (if sorted by ID)
                        // Or just filterData resets to page 1. Let's keep it at page 1 for now or calculate page.
                        // Ideally we should sort by GradeCode descending if we want to see new items first,
                        // but currently it's likely sorted by DB default (usually insertion order).
                        // Let's just stay on filtered view.
                    } else {
                        alert(json.error || 'Failed to add grade');
                    }
                } catch (err) {
                    console.error(err);
                    alert('Error adding grade');
                }
            });
        });
    </script>
</body>
</html>