<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> · <%= group %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="/css/styles.css" rel="stylesheet" />
    <style>
        .range-label {
            display: flex;
            align-items: center;
            font-weight: 500;
        }
        .form-control-sm-custom {
            padding: 0.25rem 0.5rem;
            font-size: 0.875rem;
        }
    </style>
</head>
<body>
    <%- include('../partials/topbar', { user }) %>
    <%- include('../partials/sidebar') %>

    <main class="main">
        <div class="container-fluid">
            <div class="d-flex align-items-center justify-content-between mb-4">
                <h2 class="mb-0"><%= title %></h2>
            </div>

            <div class="card shadow-sm" id="printableArea">
                <div class="card-body">
                    <div class="d-none d-print-block text-center py-4">
                        <h2 class="fw-bold mt-0">HR Payroll</h2>
                        <h4 class="text-decoration-underline mt-0">End of Service Benefit</h4>
                    </div>
                    <form id="eosForm">
                        <!-- EOS Date -->
                        <div class="row mb-4">
                            <div class="col-md-12">
                                <label class="form-label">EOS Date</label>
                                <input type="date" class="form-control" name="EOSDate" id="EOSDate">
                            </div>
                        </div>

                        <!-- Main Grid -->
                        <div class="row">
                            <!-- Left Column (Ranges + Exemption/Tax) -->
                            <div class="col-md-7 border-end">
                                <!-- Ranges Section -->
                                <h5 class="text-primary border-bottom pb-2 mb-3">Ranges</h5>
                                
                                <div class="row mb-2 text-center fw-bold">
                                    <div class="col-3"></div>
                                    <div class="col-3">Years</div>
                                    <div class="col-3">Days</div>
                                    <div class="col-3">Redundant</div>
                                </div>

                                <!-- Range 1 -->
                                <div class="row mb-2 align-items-center">
                                    <div class="col-3 range-label">Range 1</div>
                                    <div class="col-3"><input type="number" step="1" min="0" class="form-control form-control-sm-custom" name="Y1" id="Y1"></div>
                                    <div class="col-3"><input type="number" step="1" min="0" class="form-control form-control-sm-custom" name="D1" id="D1"></div>
                                    <div class="col-3"><input type="number" step="any" class="form-control form-control-sm-custom" name="R1" id="R1"></div>
                                </div>

                                <!-- Range 2 -->
                                <div class="row mb-2 align-items-center">
                                    <div class="col-3 range-label">Range 2</div>
                                    <div class="col-3"><input type="number" step="1" min="0" class="form-control form-control-sm-custom" name="Y2" id="Y2"></div>
                                    <div class="col-3"><input type="number" step="1" min="0" class="form-control form-control-sm-custom" name="D2" id="D2"></div>
                                    <div class="col-3"><input type="number" step="any" class="form-control form-control-sm-custom" name="R2" id="R2"></div>
                                </div>

                                <!-- Range 3 -->
                                <div class="row mb-2 align-items-center">
                                    <div class="col-3 range-label">Range 3</div>
                                    <div class="col-3"><input type="number" step="1" min="0" class="form-control form-control-sm-custom" name="Y3" id="Y3"></div>
                                    <div class="col-3"><input type="number" step="1" min="0" class="form-control form-control-sm-custom" name="D3" id="D3"></div>
                                    <div class="col-3"><input type="number" step="any" class="form-control form-control-sm-custom" name="R3" id="R3"></div>
                                </div>

                                <!-- Range 4 -->
                                <div class="row mb-2 align-items-center">
                                    <div class="col-3 range-label">Range 4</div>
                                    <div class="col-3"><input type="number" step="1" min="0" class="form-control form-control-sm-custom" name="Y4" id="Y4"></div>
                                    <div class="col-3"><input type="number" step="1" min="0" class="form-control form-control-sm-custom" name="D4" id="D4"></div>
                                    <div class="col-3"><input type="number" step="any" class="form-control form-control-sm-custom" name="R4" id="R4"></div>
                                </div>

                                <!-- Range 5 -->
                                <div class="row mb-2 align-items-center">
                                    <div class="col-3 range-label">Range 5</div>
                                    <div class="col-3"><input type="number" step="1" min="0" class="form-control form-control-sm-custom" name="Y5" id="Y5"></div>
                                    <div class="col-3"><input type="number" step="1" min="0" class="form-control form-control-sm-custom" name="D5" id="D5"></div>
                                    <div class="col-3"><input type="number" step="any" class="form-control form-control-sm-custom" name="R5" id="R5"></div>
                                </div>

                                <!-- Exemption & Tax Section -->
                                <h5 class="text-primary border-bottom pb-2 mb-3 mt-4">Exemption & Tax</h5>
                                <div class="row mb-2 align-items-center">
                                    <div class="col-3 range-label">Exemption</div>
                                    <div class="col-9"><input type="number" step="any" class="form-control" name="Exemption" id="Exemption" placeholder="Exemption Amount"></div>
                                </div>
                                <div class="row mb-2 align-items-center">
                                    <div class="col-3 range-label">Tax %</div>
                                    <div class="col-9"><input type="number" step="0.01" min="0" max="100" class="form-control" name="EOSTax" id="EOSTax" placeholder="Tax Percentage"></div>
                                </div>
                            </div>

                            <!-- Right Column (Ex-Gratia + Long Service) -->
                            <div class="col-md-5">
                                <!-- Ex-Gratia Section -->
                                <h5 class="text-primary border-bottom pb-2 mb-3">Ex-Gratia</h5>
                                
                                <div class="row mb-2 text-center fw-bold">
                                    <div class="col-4">S-Yrs</div>
                                    <div class="col-4">E-Yrs</div>
                                    <div class="col-4">Yrs</div>
                                </div>

                                <!-- Row 1 -->
                                <div class="row mb-2">
                                    <div class="col-4"><input type="number" step="1" min="0" class="form-control form-control-sm-custom" name="E1" id="E1"></div>
                                    <div class="col-4"><input type="number" step="1" min="0" class="form-control form-control-sm-custom" name="E2" id="E2"></div>
                                    <div class="col-4"><input type="number" step="1" min="0" class="form-control form-control-sm-custom" name="B1" id="B1"></div>
                                </div>

                                <!-- Row 2 -->
                                <div class="row mb-3">
                                    <div class="col-4"><input type="number" step="1" min="0" class="form-control form-control-sm-custom" name="E3" id="E3"></div>
                                    <div class="col-4"><input type="number" step="1" min="0" class="form-control form-control-sm-custom" name="E4" id="E4"></div>
                                    <div class="col-4"><input type="number" step="1" min="0" class="form-control form-control-sm-custom" name="B2" id="B2"></div>
                                </div>

                                <!-- Min Age -->
                                <div class="row mb-4">
                                    <div class="col-12">
                                        <label class="form-label">Min Age</label>
                                        <input type="number" step="1" min="0" class="form-control" name="MinAge" id="MinAge">
                                    </div>
                                </div>

                                <!-- Long Service Section -->
                                <h5 class="text-primary border-bottom pb-2 mb-3">Long Service</h5>
                                <div class="row mb-2 text-center fw-bold">
                                    <div class="col-4">S-Yrs</div>
                                    <div class="col-4">Percent</div>
                                    <div class="col-4">USD</div>
                                </div>

                                <!-- Row 1 -->
                                <div class="row mb-2">
                                    <div class="col-4"><input type="number" step="1" min="0" class="form-control form-control-sm-custom" name="LS1" id="LS1"></div>
                                    <div class="col-4"><input type="number" step="0.01" min="0" max="100" class="form-control form-control-sm-custom" name="L1Percent" id="L1Percent"></div>
                                    <div class="col-4"><input type="number" step="any" class="form-control form-control-sm-custom" name="L1_USD" id="L1_USD"></div>
                                </div>

                                <!-- Row 2 -->
                                <div class="row mb-2">
                                    <div class="col-4"><input type="number" step="1" min="0" class="form-control form-control-sm-custom" name="LS2" id="LS2"></div>
                                    <div class="col-4"><input type="number" step="0.01" min="0" max="100" class="form-control form-control-sm-custom" name="L2ercent" id="L2ercent"></div>
                                    <div class="col-4"><input type="number" step="any" class="form-control form-control-sm-custom" name="L2_USD" id="L2_USD"></div>
                                </div>

                                <!-- Row 3 -->
                                <div class="row mb-2">
                                    <div class="col-4"><input type="number" step="1" min="0" class="form-control form-control-sm-custom" name="LS3" id="LS3"></div>
                                    <div class="col-4"><input type="number" step="0.01" min="0" max="100" class="form-control form-control-sm-custom" name="L3Percent" id="L3Percent"></div>
                                    <div class="col-4"><input type="number" step="any" class="form-control form-control-sm-custom" name="L3_USD" id="L3_USD"></div>
                                </div>
                            </div>
                        </div>

                        <div class="text-end mt-4 d-print-none">
                            <button type="submit" class="btn btn-primary px-4" id="saveBtn">Save</button>
                        </div>
                    </form>
                </div>
            </div>

            <footer class="mt-4 py-3 text-center text-muted border-top">
                <%- include('../partials/footer') %>
            </footer>
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', async () => {
            const form = document.getElementById('eosForm');
            const saveBtn = document.getElementById('saveBtn');

            // Fetch existing data
            try {
                const res = await fetch('/admin/api/parameters/end-of-service-benefit');
                const json = await res.json();
                
                // Since the API returns the row directly (res.json(rows[0] || {})), 
                // we should check if it's an object. 
                // Note: The previous code expected {success: true, data: ...}, but getEOSBenefit in adminController 
                // now returns `res.json(rows[0] || {});`.
                // So `json` IS the data.
                
                const d = json;
                
                if (d) {
                    // EOS Date
                    if(d.EOSDate) document.getElementById('EOSDate').value = d.EOSDate.split('T')[0];
                    
                    // Helper to set value safely
                    const setVal = (id, val) => {
                        const el = document.getElementById(id);
                        if(el && val !== undefined && val !== null) el.value = val;
                    };

                    // Ranges
                    setVal('Y1', d.Y1); setVal('D1', d.D1); setVal('R1', d.R1);
                    setVal('Y2', d.Y2); setVal('D2', d.D2); setVal('R2', d.R2);
                    setVal('Y3', d.Y3); setVal('D3', d.D3); setVal('R3', d.R3);
                    setVal('Y4', d.Y4); setVal('D4', d.D4); setVal('R4', d.R4);
                    setVal('Y5', d.Y5); setVal('D5', d.D5); setVal('R5', d.R5);

                    // Ex-Gratia
                    setVal('E1', d.E1); setVal('E2', d.E2); setVal('B1', d.B1);
                    setVal('E3', d.E3); setVal('E4', d.E4); setVal('B2', d.B2);
                    setVal('MinAge', d.MinAge);

                    // Exemption & Tax
                    setVal('Exemption', d.Exemption);
                    setVal('EOSTax', d.EOSTax);

                    // Long Service
                    setVal('LS1', d.LS1); setVal('L1Percent', d.L1Percent); setVal('L1_USD', d.L1_USD);
                    setVal('LS2', d.LS2); setVal('L2ercent', d.L2ercent); setVal('L2_USD', d.L2_USD);
                    setVal('LS3', d.LS3); setVal('L3Percent', d.L3Percent); setVal('L3_USD', d.L3_USD);
                }

            } catch (err) {
                console.error('Failed to load EOS data', err);
            }

            // Handle Submit
            form.addEventListener('submit', async (e) => {
                e.preventDefault();
                saveBtn.disabled = true;
                saveBtn.textContent = 'Saving...';

                try {
                    const formData = new FormData(form);
                    const data = Object.fromEntries(formData.entries());

                    const res = await fetch('/admin/api/parameters/end-of-service-benefit', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(data)
                    });

                    const result = await res.json();
                    
                    if (result.success) {
                        alert('EOS Benefits saved successfully!');
                        location.reload(); // Reload to reflect any server-side formatting
                    } else {
                        alert('Error: ' + (result.error || 'Failed to save'));
                    }
                } catch (err) {
                    console.error(err);
                    alert('An error occurred while saving.');
                } finally {
                    saveBtn.disabled = false;
                    saveBtn.textContent = 'Save';
                }
            });
        });
    </script>
</body>
</html>