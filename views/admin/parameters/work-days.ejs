<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> · <%= group %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="/css/styles.css" rel="stylesheet" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
    <script src="https://cdn.sheetjs.com/xlsx-0.20.0/package/dist/xlsx.full.min.js"></script>
    <style>
        @media print {
            .d-print-none { display: none !important; }
        }
    </style>
</head>
<body>
    <%- include('../partials/topbar', { user }) %>
    <%- include('../partials/sidebar') %>

    <main class="main">
        <div class="container-fluid">
            <div class="d-flex align-items-center justify-content-between mb-4">
                <h2 class="mb-0"><%= title %></h2>
            </div>

            <div class="card shadow-sm">
                <div class="card-body">
                    <form id="workDaysForm">
                        <div class="table-responsive">
                            <table class="table table-bordered table-hover align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th style="width: 30%;">Week No</th>
                                        <th style="width: 40%;">Week Name</th>
                                        <th style="width: 30%;" class="text-center">Week Day</th>
                                    </tr>
                                </thead>
                                <tbody id="tableBody">
                                    <!-- Rows will be populated by JS -->
                                </tbody>
                            </table>
                        </div>

                        <div class="text-end mt-4 d-print-none">
                            <button type="submit" class="btn btn-primary px-4" id="saveBtn">Save</button>
                        </div>
                    </form>
                </div>
            </div>

            <footer class="mt-4 py-3 text-center text-muted border-top">
                <%- include('../partials/footer') %>
            </footer>
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', async () => {
            const form = document.getElementById('workDaysForm');
            const tbody = document.getElementById('tableBody');
            const saveBtn = document.getElementById('saveBtn');

            // Fetch existing data
            try {
                const res = await fetch('/admin/api/parameters/work-days');
                const days = await res.json();

                if (days && Array.isArray(days)) {
                    days.forEach(day => {
                        const tr = document.createElement('tr');
                        tr.dataset.dayNo = day.DayNo; // Store PK

                        // Week No (WDayNo)
                        const tdNo = document.createElement('td');
                        const inputNo = document.createElement('input');
                        inputNo.type = 'number';
                        inputNo.className = 'form-control';
                        inputNo.value = day.WDayNo;
                        inputNo.name = `WDayNo_${day.DayNo}`;
                        tdNo.appendChild(inputNo);
                        tr.appendChild(tdNo);

                        // Week Name (DayName)
                        const tdName = document.createElement('td');
                        tdName.textContent = day.DayName;
                        tr.appendChild(tdName);

                        // Week Day (WorkDay) - Checkbox
                        const tdWork = document.createElement('td');
                        tdWork.className = 'text-center';
                        const divCheck = document.createElement('div');
                        divCheck.className = 'form-check d-inline-block';
                        const inputCheck = document.createElement('input');
                        inputCheck.className = 'form-check-input';
                        inputCheck.type = 'checkbox';
                        // Assuming -1 is true/checked based on dump, 0 is false
                        inputCheck.checked = (day.WorkDay == -1 || day.WorkDay == 1 || day.WorkDay === true);
                        inputCheck.name = `WorkDay_${day.DayNo}`;
                        divCheck.appendChild(inputCheck);
                        tdWork.appendChild(divCheck);
                        tr.appendChild(tdWork);

                        tbody.appendChild(tr);
                    });
                }
            } catch (err) {
                console.error('Failed to load Work Days', err);
                tbody.innerHTML = '<tr><td colspan="3" class="text-center text-danger">Failed to load data</td></tr>';
            }

            // Handle Submit
            form.addEventListener('submit', async (e) => {
                e.preventDefault();
                saveBtn.disabled = true;
                saveBtn.textContent = 'Saving...';

                try {
                    const rows = Array.from(tbody.querySelectorAll('tr'));
                    const data = rows.map(tr => {
                        const dayNo = tr.dataset.dayNo;
                        const wDayNo = tr.querySelector(`input[name="WDayNo_${dayNo}"]`).value;
                        const isChecked = tr.querySelector(`input[name="WorkDay_${dayNo}"]`).checked;
                        
                        return {
                            DayNo: dayNo,
                            WDayNo: wDayNo,
                            WorkDay: isChecked ? -1 : 0 // Save as -1 for checked, 0 for unchecked
                        };
                    });

                    const res = await fetch('/admin/api/parameters/work-days', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(data)
                    });

                    const result = await res.json();
                    
                    if (result.success) {
                        alert('Work Days updated successfully!');
                        location.reload(); 
                    } else {
                        alert('Error: ' + (result.error || 'Failed to save'));
                    }
                } catch (err) {
                    console.error(err);
                    alert('An error occurred while saving.');
                } finally {
                    saveBtn.disabled = false;
                    saveBtn.textContent = 'Save';
                }
            });
            window.exportExcel = function() {
                const tbody = document.getElementById('tableBody');
                const rows = Array.from(tbody.querySelectorAll('tr'));
                
                if (rows.length === 0) {
                    alert("No data to export");
                    return;
                }

                const exportData = rows.map(tr => {
                    const dayNo = tr.dataset.dayNo;
                    const wDayNo = tr.querySelector(`input[name="WDayNo_${dayNo}"]`).value;
                    // Week Name is in the second td
                    const dayName = tr.cells[1].textContent;
                    const isChecked = tr.querySelector(`input[name="WorkDay_${dayNo}"]`).checked;
                    
                    return {
                        WeekNo: wDayNo,
                        WeekName: dayName,
                        WorkDay: isChecked ? 'Yes' : 'No'
                    };
                });

                const ws = XLSX.utils.json_to_sheet(exportData);
                const wb = XLSX.utils.book_new();
                XLSX.utils.book_append_sheet(wb, ws, "WorkDays");
                XLSX.writeFile(wb, "WorkDays.xlsx");
            };

            window.exportPDF = function() {
                const element = document.getElementById('printableArea');
                const header = element.querySelector('.d-print-block');
                const wasHidden = header && header.classList.contains('d-none');
                
                if (wasHidden) header.classList.remove('d-none');

                const opt = {
                    margin: 10,
                    filename: 'WorkDays.pdf',
                    image: { type: 'jpeg', quality: 0.98 },
                    html2canvas: { scale: 2 },
                    jsPDF: { unit: 'mm', format: 'a4', orientation: 'portrait' }
                };
                html2pdf().set(opt).from(element).save().then(() => {
                    if (wasHidden) header.classList.add('d-none');
                });
            };
        });
    </script>
</body>
</html>
