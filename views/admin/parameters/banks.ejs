<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> · <%= group %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="/css/styles.css" rel="stylesheet" />
    <style>
        .editable-cell {
            padding: 0.25rem;
        }
        .editable-cell input {
            width: 100%;
            border: 1px solid transparent;
            background: transparent;
            padding: 2px 4px;
        }
        .editable-cell input:focus {
            border: 1px solid #0d6efd;
            background: #fff;
            outline: none;
        }
        .cell-updated {
            animation: highlight 1s ease-out;
        }
        @keyframes highlight {
            0% { background-color: #d1e7dd; }
            100% { background-color: transparent; }
        }
        .cell-error {
            animation: highlight-error 1s ease-out;
            border: 1px solid red !important;
        }
        @keyframes highlight-error {
            0% { background-color: #f8d7da; }
            100% { background-color: transparent; }
        }
    </style>
</head>
<body>
    <%- include('../partials/topbar', { user }) %>
    <%- include('../partials/sidebar') %>

    <main class="main">
        <div class="container-fluid">
            <div class="d-flex align-items-center justify-content-between mb-4">
                <h2 class="mb-0">Banks</h2>
                <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addBankModal">
                    <i class="bi bi-plus-circle me-2"></i>Add Bank
                </button>
            </div>

            <div class="card shadow-sm">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0" id="banksTable">
                            <thead class="table-light">
                                <tr>
                                    <th style="width: 5%">No.</th>
                                    <th style="width: 25%">Bank</th>
                                    <th style="width: 10%">Short</th>
                                    <th style="width: 10%">Bank Code</th>
                                    <th style="width: 20%">Street Address</th>
                                    <th style="width: 20%">Town Address</th>
                                    <th class="text-end" style="width: 10%">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <!-- Rows will be populated by JS -->
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <footer class="mt-4 py-3 text-center text-muted border-top">
                <%- include('../partials/footer') %>
            </footer>
        </div>
    </main>

    <!-- Add Bank Modal -->
    <div class="modal fade" id="addBankModal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Add Bank</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <form id="addBankForm">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Bank Name *</label>
                                <input type="text" class="form-control" name="Bank" required>
                            </div>
                            <div class="col-md-3 mb-3">
                                <label class="form-label">Short Name</label>
                                <input type="text" class="form-control" name="Short">
                            </div>
                            <div class="col-md-3 mb-3">
                                <label class="form-label">Bank Code</label>
                                <input type="text" class="form-control" name="BankCode">
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Street Address</label>
                                <input type="text" class="form-control" name="Street_Address">
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Town Address</label>
                                <input type="text" class="form-control" name="Town_Address">
                            </div>
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                    <button type="button" class="btn btn-primary" id="saveNewBankBtn">Save Bank</button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const tableBody = document.querySelector('#banksTable tbody');
            const addBankModal = new bootstrap.Modal(document.getElementById('addBankModal'));
            const addBankForm = document.getElementById('addBankForm');

            // Load Data
            loadBanks();

            async function loadBanks() {
                try {
                    const res = await fetch('/admin/api/parameters/banks');
                    const json = await res.json();
                    renderTable(json.data);
                } catch (err) {
                    console.error('Failed to load banks', err);
                    alert('Error loading banks');
                }
            }

            function renderTable(items) {
                tableBody.innerHTML = '';
                items.forEach((item, index) => {
                    const tr = document.createElement('tr');
                    tr.dataset.code = item.Code;
                    tr.innerHTML = `
                        <td>${index + 1}</td>
                        <td class="editable-cell"><input type="text" name="Bank" value="${item.Bank || ''}" required></td>
                        <td class="editable-cell"><input type="text" name="Short" value="${item.Short || ''}"></td>
                        <td class="editable-cell"><input type="text" name="BankCode" value="${item.BankCode || ''}"></td>
                        <td class="editable-cell"><input type="text" name="Street_Address" value="${item.Street_Address || ''}"></td>
                        <td class="editable-cell"><input type="text" name="Town_Address" value="${item.Town_Address || ''}"></td>
                        <td class="text-end">
                            <button class="btn btn-sm btn-outline-danger delete-btn"><i class="bi bi-trash"></i></button>
                        </td>
                    `;
                    tableBody.appendChild(tr);
                });
            }

            // Inline Editing
            tableBody.addEventListener('change', async (e) => {
                const target = e.target;
                if (target.tagName === 'INPUT') {
                    handleUpdate(target);
                }
            });

            tableBody.addEventListener('keydown', (e) => {
                if (e.key === 'Enter') {
                    e.target.blur(); 
                }
            });

            // Delete Button
            tableBody.addEventListener('click', async (e) => {
                const btn = e.target.closest('.delete-btn');
                if (btn) {
                    const row = btn.closest('tr');
                    const code = row.dataset.code;
                    if (confirm('Are you sure you want to delete this bank?')) {
                        try {
                            const res = await fetch(`/admin/api/parameters/banks/${code}`, { method: 'DELETE' });
                            const json = await res.json();
                            if (json.success) {
                                row.remove();
                                // Re-index rows
                                Array.from(tableBody.children).forEach((tr, idx) => {
                                    tr.cells[0].textContent = idx + 1;
                                });
                            } else {
                                alert('Failed to delete');
                            }
                        } catch (err) {
                            console.error(err);
                            alert('Error deleting bank');
                        }
                    }
                }
            });

            async function handleUpdate(input) {
                const row = input.closest('tr');
                const code = row.dataset.code;
                const fieldName = input.name;
                const value = input.value;

                if (fieldName === 'Bank' && !value) {
                    showError(input);
                    alert('Bank Name is required');
                    return; 
                }

                input.disabled = true;

                try {
                    const payload = {};
                    payload[fieldName] = value;

                    const res = await fetch(`/admin/api/parameters/banks/${code}`, {
                        method: 'PATCH',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(payload)
                    });
                    const json = await res.json();
                    
                    input.disabled = false;
                    input.focus(); 
                    
                    if (json.success) {
                        input.parentElement.classList.add('cell-updated');
                        setTimeout(() => input.parentElement.classList.remove('cell-updated'), 1000);
                    } else {
                        showError(input);
                    }
                } catch (err) {
                    console.error(err);
                    input.disabled = false;
                    showError(input);
                }
            }

            function showError(input) {
                input.parentElement.classList.add('cell-error');
                setTimeout(() => input.parentElement.classList.remove('cell-error'), 1000);
            }

            // Add New Bank
            document.getElementById('saveNewBankBtn').addEventListener('click', async () => {
                const formData = new FormData(addBankForm);
                const data = Object.fromEntries(formData.entries());

                if (!data.Bank) {
                    alert('Bank Name is required');
                    return;
                }

                try {
                    const res = await fetch('/admin/api/parameters/banks', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(data)
                    });
                    const json = await res.json();

                    if (json.success) {
                        addBankModal.hide();
                        addBankForm.reset();
                        
                        // Reload or Append
                        const tr = document.createElement('tr');
                        tr.dataset.code = json.item.Code;
                        const newIndex = tableBody.children.length + 1;
                        tr.innerHTML = `
                            <td>${newIndex}</td>
                            <td class="editable-cell"><input type="text" name="Bank" value="${json.item.Bank || ''}" required></td>
                            <td class="editable-cell"><input type="text" name="Short" value="${json.item.Short || ''}"></td>
                            <td class="editable-cell"><input type="text" name="BankCode" value="${json.item.BankCode || ''}"></td>
                            <td class="editable-cell"><input type="text" name="Street_Address" value="${json.item.Street_Address || ''}"></td>
                            <td class="editable-cell"><input type="text" name="Town_Address" value="${json.item.Town_Address || ''}"></td>
                            <td class="text-end">
                                <button class="btn btn-sm btn-outline-danger delete-btn"><i class="bi bi-trash"></i></button>
                            </td>
                        `;
                        tableBody.appendChild(tr);
                    } else {
                        alert(json.error || 'Failed to add bank');
                    }
                } catch (err) {
                    console.error(err);
                    alert('Error adding bank');
                }
            });
        });
    </script>
</body>
</html>