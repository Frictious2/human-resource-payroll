<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> · <%= group %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="/css/styles.css" rel="stylesheet" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
    <script src="https://cdn.sheetjs.com/xlsx-0.20.0/package/dist/xlsx.full.min.js"></script>
    <style>
        @media print {
            tr { page-break-inside: avoid; }
            .d-print-none { display: none !important; }
        }
        tr { page-break-inside: avoid; }
        .editable-cell {
            padding: 0.25rem;
        }
        .editable-cell input {
            width: 100%;
            border: 1px solid transparent;
            background: transparent;
            padding: 2px 4px;
        }
        .editable-cell input:focus {
            border: 1px solid #0d6efd;
            background: #fff;
            outline: none;
        }
        .cell-updated {
            animation: highlight 1s ease-out;
        }
        @keyframes highlight {
            0% { background-color: #d1e7dd; }
            100% { background-color: transparent; }
        }
        .cell-error {
            animation: highlight-error 1s ease-out;
            border: 1px solid red !important;
        }
        @keyframes highlight-error {
            0% { background-color: #f8d7da; }
            100% { background-color: transparent; }
        }
    </style>
</head>
<body>
    <%- include('../partials/topbar', { user }) %>
    <%- include('../partials/sidebar') %>

    <main class="main">
        <div class="container-fluid">
            <div class="d-flex align-items-center justify-content-between mb-4">
                <h2 class="mb-0">GL Accounts</h2>
                <div class="d-flex gap-2 d-print-none">
                    <button type="button" class="btn btn-success" onclick="exportExcel()">
                        <i class="bi bi-file-earmark-excel"></i> Export to Excel
                    </button>
                    <button type="button" class="btn btn-danger" onclick="exportPDF()">
                        <i class="bi bi-file-earmark-pdf"></i> Export to PDF
                    </button>
                    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addGLAccountModal">
                        <i class="bi bi-plus-circle me-2"></i>Add GL Account
                    </button>
                </div>
            </div>

            <div class="card shadow-sm" id="printableArea">
                <div class="d-none d-print-block text-center mb-4">
                    <h2>HR Payroll</h2>
                    <h3>GL Accounts</h3>
                </div>
                <div class="card-body p-3 border-bottom d-print-none">
                    <div class="row">
                        <div class="col-md-4">
                            <input type="text" id="searchInput" class="form-control" placeholder="Search GL accounts...">
                        </div>
                    </div>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0" id="glAccountsTable">
                            <thead class="table-light">
                                <tr>
                                    <th style="width: 5%">No.</th>
                                    <th style="width: 50%">Account Head</th>
                                    <th style="width: 35%">Code</th>
                                    <th class="text-end d-print-none" style="width: 10%">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <!-- Rows will be populated by JS -->
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="card-footer bg-white border-top-0 py-3 d-print-none">
                    <nav aria-label="Page navigation">
                        <ul class="pagination justify-content-end mb-0" id="pagination">
                            <!-- Pagination will be populated by JS -->
                        </ul>
                    </nav>
                </div>
            </div>

            <footer class="mt-4 py-3 text-center text-muted border-top">
                <%- include('../partials/footer') %>
            </footer>
        </div>
    </main>

    <!-- Add GL Account Modal -->
    <div class="modal fade" id="addGLAccountModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Add GL Account</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <form id="addGLAccountForm">
                        <div class="mb-3">
                            <label class="form-label">Account Head *</label>
                            <input type="text" class="form-control" name="AccountsHead" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Code</label>
                            <input type="text" class="form-control" name="Code">
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                    <button type="button" class="btn btn-primary" id="saveNewGLAccountBtn">Save</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Delete Modal -->
    <div class="modal fade" id="delete_item" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Delete GL Account</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p>Are you sure want to delete this gl account?</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-danger" id="confirmDeleteBtn">Delete</button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // State for pagination and search
        let allData = [];
        let filteredData = [];
        let currentPage = 1;
        const rowsPerPage = 10;
        let deleteId = null;

        document.addEventListener('DOMContentLoaded', () => {
            const tableBody = document.querySelector('#glAccountsTable tbody');
            const addGLAccountModal = new bootstrap.Modal(document.getElementById('addGLAccountModal'));
            const addGLAccountForm = document.getElementById('addGLAccountForm');
            const searchInput = document.getElementById('searchInput');
            const paginationContainer = document.getElementById('pagination');

            // Load Data
            loadGLAccounts();

            async function loadGLAccounts() {
                try {
                    const res = await fetch('/admin/api/parameters/gl-accounts');
                    const json = await res.json();
                    allData = json.data;
                    filterData();
                } catch (err) {
                    console.error('Failed to load gl accounts', err);
                    alert('Error loading gl accounts');
                }
            }

            // Search Logic
            searchInput.addEventListener('input', () => {
                filterData();
            });

            function filterData() {
                const term = searchInput.value.toLowerCase();
                filteredData = allData.filter(item => 
                    Object.values(item).some(val => 
                        String(val).toLowerCase().includes(term)
                    )
                );
                currentPage = 1;
                renderPage();
            }

            function renderPage() {
                const start = (currentPage - 1) * rowsPerPage;
                const end = start + rowsPerPage;
                const pageData = filteredData.slice(start, end);
                renderTable(pageData, start);
                renderPagination();
            }

            function renderPagination() {
                const totalPages = Math.ceil(filteredData.length / rowsPerPage);
                paginationContainer.innerHTML = '';

                if (totalPages <= 1) return;

                // Previous
                const prevLi = document.createElement('li');
                prevLi.className = `page-item ${currentPage === 1 ? 'disabled' : ''}`;
                prevLi.innerHTML = `<a class="page-link" href="#">Previous</a>`;
                prevLi.onclick = (e) => { e.preventDefault(); if (currentPage > 1) { currentPage--; renderPage(); } };
                paginationContainer.appendChild(prevLi);

                // Page Numbers
                let startPage = Math.max(1, currentPage - 2);
                let endPage = Math.min(totalPages, startPage + 4);
                
                if (endPage - startPage < 4) {
                    startPage = Math.max(1, endPage - 4);
                }

                for (let i = startPage; i <= endPage; i++) {
                    const li = document.createElement('li');
                    li.className = `page-item ${i === currentPage ? 'active' : ''}`;
                    li.innerHTML = `<a class="page-link" href="#">${i}</a>`;
                    li.onclick = (e) => { e.preventDefault(); currentPage = i; renderPage(); };
                    paginationContainer.appendChild(li);
                }

                // Next
                const nextLi = document.createElement('li');
                nextLi.className = `page-item ${currentPage === totalPages ? 'disabled' : ''}`;
                nextLi.innerHTML = `<a class="page-link" href="#">Next</a>`;
                nextLi.onclick = (e) => { e.preventDefault(); if (currentPage < totalPages) { currentPage++; renderPage(); } };
                paginationContainer.appendChild(nextLi);
            }

            function renderTable(items, startIndex) {
                tableBody.innerHTML = '';
                if (items.length === 0) {
                    tableBody.innerHTML = '<tr><td colspan="4" class="text-center py-3">No gl accounts found</td></tr>';
                    return;
                }
                items.forEach((item, index) => {
                    const tr = document.createElement('tr');
                    tr.dataset.glno = item.GLNo;
                    tr.innerHTML = `
                        <td>${startIndex + index + 1}</td>
                        <td class="editable-cell"><input type="text" name="AccountsHead" value="${item.AccountsHead || ''}" required></td>
                        <td class="editable-cell"><input type="text" name="Code" value="${item.Code || ''}"></td>
                        <td class="text-end d-print-none">
                            <button class="btn btn-sm btn-outline-danger delete-btn"><i class="bi bi-trash"></i></button>
                        </td>
                    `;
                    tableBody.appendChild(tr);
                });
            }

            // Inline Editing
            tableBody.addEventListener('change', async (e) => {
                const target = e.target;
                if (target.tagName === 'INPUT') {
                    handleUpdate(target);
                }
            });

            tableBody.addEventListener('keydown', (e) => {
                if (e.key === 'Enter') {
                    e.target.blur(); 
                }
            });

            // Delete Button
            tableBody.addEventListener('click', (e) => {
                const btn = e.target.closest('.delete-btn');
                if (btn) {
                    const row = btn.closest('tr');
                    const glNo = row.dataset.glno;
                    openDeleteModal(glNo);
                }
            });

            function openDeleteModal(code) {
                deleteId = code;
                const modalEl = document.getElementById('delete_item');
                let modal = bootstrap.Modal.getInstance(modalEl);
                if (!modal) {
                    modal = new bootstrap.Modal(modalEl);
                }
                modal.show();
            }

            document.getElementById('confirmDeleteBtn').addEventListener('click', async () => {
                if (!deleteId) return;
                
                try {
                    const res = await fetch(`/admin/api/parameters/gl-accounts/${deleteId}`, { method: 'DELETE' });
                    const json = await res.json();
                    if (json.success) {
                        // Remove from allData and re-render
                        allData = allData.filter(i => i.GLNo != deleteId);
                        filterData();
                        
                        // Close modal
                        const modalEl = document.getElementById('delete_item');
                        const modal = bootstrap.Modal.getInstance(modalEl);
                        if (modal) modal.hide();
                    } else {
                        alert('Failed to delete');
                    }
                } catch (err) {
                    console.error(err);
                    alert('Error deleting gl account');
                }
            });

            async function handleUpdate(input) {
                const row = input.closest('tr');
                const glNo = row.dataset.glno;
                const fieldName = input.name;
                const value = input.value;

                if (fieldName === 'AccountsHead' && !value) {
                    showError(input);
                    alert('Account Head is required');
                    return; 
                }

                input.disabled = true;

                try {
                    const payload = {};
                    payload[fieldName] = value;

                    const res = await fetch(`/admin/api/parameters/gl-accounts/${glNo}`, {
                        method: 'PATCH',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(payload)
                    });
                    const json = await res.json();
                    
                    input.disabled = false;
                    input.focus(); 
                    
                    if (json.success) {
                        input.parentElement.classList.add('cell-updated');
                        setTimeout(() => input.parentElement.classList.remove('cell-updated'), 1000);
                        
                        // Update local data
                        const itemIndex = allData.findIndex(i => i.GLNo == glNo);
                        if (itemIndex > -1) {
                            allData[itemIndex][fieldName] = value;
                        }
                    } else {
                        showError(input);
                    }
                } catch (err) {
                    console.error(err);
                    input.disabled = false;
                    showError(input);
                }
            }

            function showError(input) {
                input.parentElement.classList.add('cell-error');
                setTimeout(() => input.parentElement.classList.remove('cell-error'), 1000);
            }

            // Add New GL Account
            document.getElementById('saveNewGLAccountBtn').addEventListener('click', async () => {
                const formData = new FormData(addGLAccountForm);
                const data = Object.fromEntries(formData.entries());

                if (!data.AccountsHead) {
                    alert('Account Head is required');
                    return;
                }

                try {
                    const res = await fetch('/admin/api/parameters/gl-accounts', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(data)
                    });
                    const json = await res.json();

                    if (json.success) {
                        addGLAccountModal.hide();
                        addGLAccountForm.reset();
                        
                        // Add to allData and re-render
                        allData.push(json.item);
                        filterData();
                    } else {
                        alert(json.error || 'Failed to add gl account');
                    }
                } catch (err) {
                    console.error(err);
                    alert('Error adding gl account');
                }
            });

            window.exportExcel = function() {
                if (filteredData.length === 0) {
                    alert("No data to export");
                    return;
                }
                
                const data = filteredData.map(item => ({
                    AccountsHead: item.AccountsHead,
                    Code: item.Code
                }));

                const ws = XLSX.utils.json_to_sheet(data);
                const wb = XLSX.utils.book_new();
                XLSX.utils.book_append_sheet(wb, ws, "GLAccounts");
                XLSX.writeFile(wb, "GLAccounts.xlsx");
            };

            window.exportPDF = async function() {
                const element = document.getElementById('printableArea');
                const header = element.querySelector('.d-print-block');
                const originalPage = currentPage;
                
                if (header) header.classList.remove('d-none');
                renderTable(filteredData, 0);
                
                const opt = {
                    margin: 10,
                    filename: 'GLAccounts.pdf',
                    image: { type: 'jpeg', quality: 0.98 },
                    html2canvas: { scale: 2 },
                    jsPDF: { unit: 'mm', format: 'a4', orientation: 'portrait' }
                };
                
                try {
                    await html2pdf().set(opt).from(element).save();
                } finally {
                    if (header) header.classList.add('d-none');
                    currentPage = originalPage;
                    renderPage();
                }
            };
        });
    </script>
</body>
</html>
