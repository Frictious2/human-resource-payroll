<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> · <%= group %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="/css/styles.css" rel="stylesheet" />
    <style>
        .editable-cell {
            padding: 0.25rem;
        }
        .editable-cell input, .editable-cell select {
            width: 100%;
            border: 1px solid transparent;
            background: transparent;
            padding: 2px 4px;
        }
        .editable-cell input:focus, .editable-cell select:focus {
            border: 1px solid #0d6efd;
            background: #fff;
            outline: none;
        }
        .editable-cell input[type="checkbox"] {
            width: auto;
        }
        .cell-updated {
            animation: highlight 1s ease-out;
        }
        @keyframes highlight {
            0% { background-color: #d1e7dd; }
            100% { background-color: transparent; }
        }
        .cell-error {
            animation: highlight-error 1s ease-out;
            border: 1px solid red !important;
        }
        @keyframes highlight-error {
            0% { background-color: #f8d7da; }
            100% { background-color: transparent; }
        }
    </style>
</head>
<body>
    <%- include('../partials/topbar', { user }) %>
    <%- include('../partials/sidebar') %>

    <main class="main">
        <div class="container-fluid">
            <div class="d-flex align-items-center justify-content-between mb-4">
                <h2 class="mb-0">Payroll Items</h2>
                <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addItemModal">
                    <i class="bi bi-plus-circle me-2"></i>Add Item
                </button>
            </div>

            <div class="card shadow-sm">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0" id="payrollItemsTable">
                            <thead class="table-light">
                                <tr>
                                    <th>No.</th>
                                    <th>Description</th>
                                    <th class="text-center">Taxable</th>
                                    <th class="text-center">Thresh</th>
                                    <th class="text-center">T%</th>
                                    <th>T% Val</th>
                                    <th>T Amt</th>
                                    <th>Mode</th>
                                    <th class="text-center">Fixed</th>
                                    <th>%</th>
                                    <th>Freq</th>
                                    <th class="text-end">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <!-- Rows will be populated by JS -->
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <footer class="mt-4 py-3 text-center text-muted border-top">
                <%- include('../partials/footer') %>
            </footer>
        </div>
    </main>

    <!-- Add Item Modal -->
    <div class="modal fade" id="addItemModal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Add Payroll Item</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <form id="addItemForm">
                        <div class="mb-3">
                            <label class="form-label">Description (Income) *</label>
                            <input type="text" class="form-control" name="Income" required>
                        </div>
                        <div class="row g-3 mb-3">
                            <div class="col-md-3">
                                <div class="form-check mt-4">
                                    <input class="form-check-input" type="checkbox" name="Taxable" id="checkTaxable">
                                    <label class="form-check-label" for="checkTaxable">Taxable</label>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="form-check mt-4">
                                    <input class="form-check-input" type="checkbox" name="Threshhold" id="checkThresh">
                                    <label class="form-check-label" for="checkThresh">Threshhold</label>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="form-check mt-4">
                                    <input class="form-check-input" type="checkbox" name="TPercent" id="checkTPercent">
                                    <label class="form-check-label" for="checkTPercent">TPercent</label>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="form-check mt-4">
                                    <input class="form-check-input" type="checkbox" name="Fixed" id="checkFixed">
                                    <label class="form-check-label" for="checkFixed">Fixed</label>
                                </div>
                            </div>
                        </div>
                        <div class="row g-3 mb-3">
                            <div class="col-md-4">
                                <label class="form-label">TPercentage</label>
                                <input type="number" step="0.01" class="form-control" name="TPercentage" min="0" max="100">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">TAmount</label>
                                <input type="number" step="0.01" class="form-control" name="TAmount" min="0">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Percent</label>
                                <input type="number" step="0.01" class="form-control" name="Percent" min="0" max="100">
                            </div>
                        </div>
                        <div class="row g-3">
                            <div class="col-md-4">
                                <label class="form-label">Mode</label>
                                <input type="text" class="form-control" name="Mode" maxlength="2">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Freq</label>
                                <select class="form-select" name="Freq">
                                    <option value="">Select...</option>
                                    <option value="M">Monthly (M)</option>
                                    <option value="Y">Yearly (Y)</option>
                                </select>
                            </div>
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                    <button type="button" class="btn btn-primary" id="saveNewItemBtn">Save Item</button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const tableBody = document.querySelector('#payrollItemsTable tbody');
            const addItemModal = new bootstrap.Modal(document.getElementById('addItemModal'));
            const addItemForm = document.getElementById('addItemForm');

            // Load Data
            loadItems();

            async function loadItems() {
                try {
                    const res = await fetch('/admin/api/parameters/payroll-items');
                    const json = await res.json();
                    renderTable(json.data);
                } catch (err) {
                    console.error('Failed to load items', err);
                    alert('Error loading payroll items');
                }
            }

            function renderTable(items) {
                tableBody.innerHTML = '';
                items.forEach((item, index) => {
                    const tr = document.createElement('tr');
                    tr.dataset.code = item.Code;
                    tr.innerHTML = `
                        <td>${index + 1}</td>
                        <td class="editable-cell"><input type="text" name="Income" value="${item.Income || ''}" required style="min-width: 150px;"></td>
                        <td class="text-center editable-cell"><input type="checkbox" name="Taxable" ${item.Taxable ? 'checked' : ''}></td>
                        <td class="text-center editable-cell"><input type="checkbox" name="Threshhold" ${item.Threshhold ? 'checked' : ''}></td>
                        <td class="text-center editable-cell"><input type="checkbox" name="TPercent" ${item.TPercent ? 'checked' : ''}></td>
                        <td class="editable-cell"><input type="number" step="0.01" name="TPercentage" value="${item.TPercentage !== null ? item.TPercentage : ''}" min="0" max="100"></td>
                        <td class="editable-cell"><input type="number" step="0.01" name="TAmount" value="${item.TAmount !== null ? item.TAmount : ''}" min="0"></td>
                        <td class="editable-cell"><input type="text" name="Mode" value="${item.Mode || ''}" maxlength="2"></td>
                        <td class="text-center editable-cell"><input type="checkbox" name="Fixed" ${item.Fixed ? 'checked' : ''}></td>
                        <td class="editable-cell"><input type="number" step="0.01" name="Percent" value="${item.Percent !== null ? item.Percent : ''}" min="0" max="100"></td>
                        <td class="editable-cell">
                            <select name="Freq">
                                <option value=""></option>
                                <option value="M" ${item.Freq === 'M' ? 'selected' : ''}>M</option>
                                <option value="Y" ${item.Freq === 'Y' ? 'selected' : ''}>Y</option>
                            </select>
                        </td>
                        <td class="text-end">
                            <button class="btn btn-sm btn-outline-danger delete-btn"><i class="bi bi-trash"></i></button>
                        </td>
                    `;
                    tableBody.appendChild(tr);
                });
            }

            // Event Delegation for Inline Editing
            tableBody.addEventListener('change', async (e) => {
                const target = e.target;
                if (target.tagName === 'INPUT' || target.tagName === 'SELECT') {
                    handleUpdate(target);
                }
            });

            tableBody.addEventListener('keydown', (e) => {
                if (e.key === 'Enter') {
                    e.target.blur(); 
                }
            });
            
            // Delete Button
            tableBody.addEventListener('click', async (e) => {
                const btn = e.target.closest('.delete-btn');
                if (btn) {
                    const row = btn.closest('tr');
                    const code = row.dataset.code;
                    if (confirm('Are you sure you want to delete this item?')) {
                        try {
                            const res = await fetch(`/admin/api/parameters/payroll-items/${code}`, { method: 'DELETE' });
                            const json = await res.json();
                            if (json.success) {
                                row.remove();
                            } else {
                                alert('Failed to delete');
                            }
                        } catch (err) {
                            console.error(err);
                            alert('Error deleting item');
                        }
                    }
                }
            });

            async function handleUpdate(input) {
                const row = input.closest('tr');
                const code = row.dataset.code;
                const field = input.name;
                let value;

                if (input.type === 'checkbox') {
                    value = input.checked ? 1 : 0;
                } else {
                    value = input.value;
                }

                // Validation
                if (field === 'Income' && !value) {
                    showError(input);
                    return; 
                }
                if ((field === 'Percent' || field === 'TPercentage') && value !== '') {
                    if (value < 0 || value > 100) {
                        showError(input);
                        alert('Percentage must be between 0 and 100');
                        return;
                    }
                }
                if (field === 'TAmount' && value !== '') {
                    if (value < 0) {
                        showError(input);
                        alert('Amount must be positive');
                        return;
                    }
                }

                input.disabled = true;

                try {
                    const res = await fetch(`/admin/api/parameters/payroll-items/${code}`, {
                        method: 'PATCH',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ field, value })
                    });
                    const json = await res.json();
                    
                    input.disabled = false;
                    input.focus(); 
                    
                    if (json.success) {
                        input.parentElement.classList.add('cell-updated');
                        setTimeout(() => input.parentElement.classList.remove('cell-updated'), 1000);
                    } else {
                        showError(input);
                    }
                } catch (err) {
                    console.error(err);
                    input.disabled = false;
                    showError(input);
                }
            }

            function showError(input) {
                input.parentElement.classList.add('cell-error');
                setTimeout(() => input.parentElement.classList.remove('cell-error'), 1000);
            }

            // Add New Item
            document.getElementById('saveNewItemBtn').addEventListener('click', async () => {
                const formData = new FormData(addItemForm);
                const data = Object.fromEntries(formData.entries());

                ['Taxable', 'Threshhold', 'TPercent', 'Fixed'].forEach(key => {
                    data[key] = addItemForm.querySelector(`[name="${key}"]`).checked ? 1 : 0;
                });

                if (!data.Income) {
                    alert('Description is required');
                    return;
                }
                if (data.Percent && (data.Percent < 0 || data.Percent > 100)) {
                    alert('Percent must be 0-100');
                    return;
                }

                try {
                    const res = await fetch('/admin/api/parameters/payroll-items', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(data)
                    });
                    const json = await res.json();

                    if (json.success) {
                        addItemModal.hide();
                        addItemForm.reset();
                        
                        const tr = document.createElement('tr');
                        tr.dataset.code = json.item.Code;
                        const newIndex = tableBody.children.length + 1;
                        tr.innerHTML = `
                            <td>${newIndex}</td>
                            <td class="editable-cell"><input type="text" name="Income" value="${json.item.Income || ''}" required style="min-width: 150px;"></td>
                            <td class="text-center editable-cell"><input type="checkbox" name="Taxable" ${json.item.Taxable ? 'checked' : ''}></td>
                            <td class="text-center editable-cell"><input type="checkbox" name="Threshhold" ${json.item.Threshhold ? 'checked' : ''}></td>
                            <td class="text-center editable-cell"><input type="checkbox" name="TPercent" ${json.item.TPercent ? 'checked' : ''}></td>
                            <td class="editable-cell"><input type="number" step="0.01" name="TPercentage" value="${json.item.TPercentage !== null ? json.item.TPercentage : ''}" min="0" max="100"></td>
                            <td class="editable-cell"><input type="number" step="0.01" name="TAmount" value="${json.item.TAmount !== null ? json.item.TAmount : ''}" min="0"></td>
                            <td class="editable-cell"><input type="text" name="Mode" value="${json.item.Mode || ''}" maxlength="2"></td>
                            <td class="text-center editable-cell"><input type="checkbox" name="Fixed" ${json.item.Fixed ? 'checked' : ''}></td>
                            <td class="editable-cell"><input type="number" step="0.01" name="Percent" value="${json.item.Percent !== null ? json.item.Percent : ''}" min="0" max="100"></td>
                            <td class="editable-cell">
                                <select name="Freq">
                                    <option value=""></option>
                                    <option value="M" ${json.item.Freq === 'M' ? 'selected' : ''}>M</option>
                                    <option value="Y" ${json.item.Freq === 'Y' ? 'selected' : ''}>Y</option>
                                </select>
                            </td>
                            <td class="text-end">
                                <button class="btn btn-sm btn-outline-danger delete-btn"><i class="bi bi-trash"></i></button>
                            </td>
                        `;
                        tableBody.appendChild(tr);
                    } else {
                        alert(json.error || 'Failed to add item');
                    }
                } catch (err) {
                    console.error(err);
                    alert('Error adding item');
                }
            });
        });
    </script>
</body>
</html>