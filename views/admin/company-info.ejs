<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> · HR & Payroll</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="/css/styles.css" rel="stylesheet" />
</head>
<body>
    <!-- Top Navbar -->
    <%- include('./partials/topbar', { user }) %>

    <!-- Sidebar -->
    <%- include('./partials/sidebar') %>

    <!-- Main Content -->
    <main class="main">
        <div class="container-fluid">
            <!-- Header -->
            <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
                <h1 class="h2"><%= title %></h1>
            </div>

            <!-- Alerts -->
            <% if (typeof success !== 'undefined' && success) { %>
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="bi bi-check-circle-fill"></i> <%= success %>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            <% } %>
            <% if (typeof error !== 'undefined' && error) { %>
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-triangle-fill"></i> <%= error %>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            <% } %>

            <!-- Company Info Form -->
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="bi bi-building"></i> Company Details</h5>
                </div>
                <div class="card-body">
                    <form action="/admin/company-info" method="POST" enctype="multipart/form-data">
                        <div class="row g-3">
                            <!-- Logo Section -->
                            <div class="col-md-12 text-center mb-3">
                                <div class="mb-2">
                                    <% if (company.Logopath) { %>
                                        <img src="<%= company.Logopath %>" alt="Company Logo" class="img-thumbnail" style="max-height: 150px;">
                                    <% } else { %>
                                        <div class="text-muted p-4 border rounded bg-light d-inline-block">
                                            <i class="bi bi-image fs-1"></i>
                                            <p class="mb-0">No Logo Uploaded</p>
                                        </div>
                                    <% } %>
                                </div>
                                <div class="col-md-4 mx-auto">
                                    <label for="logo" class="form-label">Update Logo</label>
                                    <input class="form-control" type="file" id="logo" name="logo" accept="image/*">
                                    <input type="hidden" name="currentLogo" value="<%= company.Logopath || '' %>">
                                </div>
                            </div>

                            <hr>

                            <!-- Basic Info -->
                            <div class="col-md-6">
                                <label for="Com_Name" class="form-label">Company Name</label>
                                <input type="text" class="form-control" id="Com_Name" name="Com_Name" value="<%= company.Com_Name || '' %>" required>
                            </div>
                            <div class="col-md-6">
                                <label for="TinNo" class="form-label">TIN Number</label>
                                <input type="text" class="form-control" id="TinNo" name="TinNo" value="<%= company.TinNo || '' %>">
                            </div>

                            <div class="col-md-12">
                                <label for="Address" class="form-label">Address</label>
                                <input type="text" class="form-control" id="Address" name="Address" value="<%= company.Address || '' %>">
                            </div>

                            <div class="col-md-4">
                                <label for="Town" class="form-label">Town</label>
                                <input type="text" class="form-control" id="Town" name="Town" value="<%= company.Town || '' %>">
                            </div>
                            <div class="col-md-4">
                                <label for="City" class="form-label">City</label>
                                <input type="text" class="form-control" id="City" name="City" value="<%= company.City || '' %>">
                            </div>
                            <div class="col-md-4">
                                <label for="Country" class="form-label">Country</label>
                                <input type="text" class="form-control" id="Country" name="Country" value="<%= company.Country || '' %>">
                            </div>

                            <!-- Contact & Bank Info -->
                            <div class="col-md-6">
                                <label for="Email" class="form-label">Email</label>
                                <input type="email" class="form-control" id="Email" name="Email" value="<%= company.Email || '' %>">
                            </div>
                            <div class="col-md-6">
                                <label for="Phone" class="form-label">Phone</label>
                                <input type="text" class="form-control" id="Phone" name="Phone" value="<%= company.Phone || '' %>">
                            </div>

                            <div class="col-md-6">
                                <label for="Bank" class="form-label">Bank Name</label>
                                <input type="text" class="form-control" id="Bank" name="Bank" value="<%= company.Bank || '' %>">
                            </div>
                            <div class="col-md-6">
                                <label for="AccNo" class="form-label">Account Number</label>
                                <input type="text" class="form-control" id="AccNo" name="AccNo" value="<%= company.AccNo || '' %>">
                            </div>

                            <div class="col-md-6">
                                <label for="PayingBank" class="form-label">Paying Bank Code</label>
                                <input type="text" class="form-control" id="PayingBank" name="PayingBank" value="<%= company.PayingBank || '' %>">
                            </div>
                            <div class="col-md-6">
                                <label for="Manager" class="form-label">Manager Name</label>
                                <input type="text" class="form-control" id="Manager" name="Manager" value="<%= company.Manager || '' %>">
                            </div>

                            <div class="col-12 text-end mt-4">
                                <button type="submit" class="btn btn-primary"><i class="bi bi-save"></i> Update Information</button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </main>

    <!-- Footer -->
    <%- include('./partials/footer') %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Parse URL params for alerts
        const urlParams = new URLSearchParams(window.location.search);
        const success = urlParams.get('success');
        const error = urlParams.get('error');
        
        // This is handled by EJS server-side rendering in this template, 
        // but client-side cleanup of URL can be nice
        if (success || error) {
            window.history.replaceState({}, document.title, window.location.pathname);
        }
    </script>
</body>
</html>
