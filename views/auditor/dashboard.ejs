<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
  <link href="/css/styles.css" rel="stylesheet" />
</head>
<body>
  <%- include('./partials/topbar', { user }) %>
  <%- include('./partials/sidebar') %>

  <main class="main">
    <div class="container-fluid">
      <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
        <div>
          <h1 class="h3 mb-1">Auditor Dashboard</h1>
          <p class="text-muted mb-0">Monitor activity, approvals, and field-level changes across the system.</p>
        </div>
        <a class="btn btn-primary" href="/auditor/audit-trail">
          <i class="bi bi-journal-text me-2"></i>Open Full Audit Trail
        </a>
      </div>

      <div class="row g-3 mb-4">
        <div class="col-12 col-md-4">
          <div class="card shadow-sm h-100">
            <div class="card-body">
              <div class="text-muted small mb-2">Total Audit Entries</div>
              <div class="display-6 fw-semibold"><%= metrics.totalCount %></div>
            </div>
          </div>
        </div>
        <div class="col-12 col-md-4">
          <div class="card shadow-sm h-100">
            <div class="card-body">
              <div class="text-muted small mb-2">Today’s Activity</div>
              <div class="display-6 fw-semibold"><%= metrics.todayCount %></div>
            </div>
          </div>
        </div>
        <div class="col-12 col-md-4">
          <div class="card shadow-sm h-100">
            <div class="card-body">
              <div class="text-muted small mb-2">Active Users Today</div>
              <div class="display-6 fw-semibold"><%= metrics.activeUsers %></div>
            </div>
          </div>
        </div>
      </div>

      <div class="row g-4">
        <div class="col-12 col-xl-4">
          <div class="card shadow-sm h-100">
            <div class="card-header bg-body">
              <h2 class="h6 mb-0">Action Breakdown</h2>
            </div>
            <div class="card-body">
              <% if (!actionBreakdown.length) { %>
                <p class="text-muted mb-0">No audit activity found.</p>
              <% } else { %>
                <div class="list-group list-group-flush">
                  <% actionBreakdown.forEach(function(item) { %>
                    <div class="list-group-item px-0 d-flex justify-content-between align-items-center">
                      <span><%= item.Action || 'Unspecified' %></span>
                      <span class="badge bg-primary-subtle text-primary-emphasis rounded-pill"><%= item.total %></span>
                    </div>
                  <% }) %>
                </div>
              <% } %>
            </div>
          </div>
        </div>

        <div class="col-12 col-xl-8">
          <div class="card shadow-sm">
            <div class="card-header bg-body d-flex justify-content-between align-items-center">
              <h2 class="h6 mb-0">Recent Activity</h2>
              <a class="btn btn-sm btn-outline-primary" href="/auditor/audit-trail">View all</a>
            </div>
            <div class="card-body p-0">
              <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                  <thead class="table-light">
                    <tr>
                      <th>Date</th>
                      <th>User</th>
                      <th>Form</th>
                      <th>Action</th>
                      <th>Field</th>
                      <th>Record</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% if (!recentActivity.length) { %>
                      <tr>
                        <td colspan="6" class="text-center py-4 text-muted">No audit activity found.</td>
                      </tr>
                    <% } %>
                    <% recentActivity.forEach(function(entry) { %>
                      <tr>
                        <td><%= entry.ChangeDate ? new Date(entry.ChangeDate).toLocaleString() : '' %></td>
                        <td><%= entry.UserName || 'System' %></td>
                        <td><%= entry.FormName || '-' %></td>
                        <td><span class="badge text-bg-light"><%= entry.Action || '-' %></span></td>
                        <td><%= entry.FieldName || '-' %></td>
                        <td><%= entry.RecordID || '-' %></td>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>
      </div>

      <footer class="mt-4 py-3 text-center text-muted border-top">
        <%- include('./partials/footer') %>
      </footer>
    </div>
  </main>

  <script src="/vendor/bootstrap.bundle.min.js"></script>
  <script src="/js/dashboard.js"></script>
</body>
</html>
