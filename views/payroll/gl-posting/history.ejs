<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> · Data Entry</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="/css/styles.css" rel="stylesheet" />
    <style>
        @media print {
            .no-print {
                display: none !important;
            }
        }
    </style>
</head>
<body>
    <%- include('../../data_entry/partials/topbar', { user }) %>
    <%- include('../../data_entry/partials/sidebar') %>

    <main class="main">
        <div class="container-fluid py-3">
            <div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3 mb-4 no-print">
                <div>
                    <h2 class="mb-1"><%= title %></h2>
                    <p class="text-muted mb-0"><%= subtitle %></p>
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb mt-2 mb-0">
                            <li class="breadcrumb-item"><a class="text-decoration-none" href="/data-entry/dashboard">Home</a></li>
                            <li class="breadcrumb-item">Payroll</li>
                            <li class="breadcrumb-item"><a class="text-decoration-none" href="/data-entry/payroll/post-to-accounts">Post to Accounts</a></li>
                            <li class="breadcrumb-item active" aria-current="page"><%= breadcrumbCurrent %></li>
                        </ol>
                    </nav>
                </div>
                <div class="d-flex gap-2">
                    <a href="/data-entry/payroll/post-to-accounts" class="btn btn-outline-primary">
                        <i class="bi bi-plus-circle"></i> New Posting
                    </a>
                    <a href="/data-entry/payroll/process-emoluments" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left"></i> Back to Payroll
                    </a>
                </div>
            </div>

            <div class="card shadow-sm mb-4">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Batch</th>
                                    <th>Activity</th>
                                    <th>Month/Year</th>
                                    <th>Posting Date</th>
                                    <th>Total Amount</th>
                                    <th>Total Lines</th>
                                    <th>Posted By</th>
                                    <th>Status</th>
                                    <th class="no-print">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (batches.length === 0) { %>
                                    <tr>
                                        <td colspan="9" class="text-center py-4 text-muted">No posting batches have been recorded yet.</td>
                                    </tr>
                                <% } %>
                                <% batches.forEach(batch => { %>
                                    <tr>
                                        <td>#<%= batch.id %></td>
                                        <td><%= batch.activity_code %><%= batch.activity_name ? ` - ${batch.activity_name}` : '' %></td>
                                        <td><%= String(batch.posting_month).padStart(2, '0') %>/<%= batch.posting_year %></td>
                                        <td><%= batch.posting_date ? new Date(batch.posting_date).toISOString().split('T')[0] : '' %></td>
                                        <td><%= Number(batch.total_amount || 0).toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></td>
                                        <td><%= batch.total_lines %></td>
                                        <td><%= batch.posted_by %></td>
                                        <td><span class="badge text-bg-success text-capitalize"><%= batch.status %></span></td>
                                        <td class="no-print">
                                            <div class="btn-group btn-group-sm">
                                                <a class="btn btn-outline-primary" href="/data-entry/payroll/post-to-accounts/history?batchId=<%= batch.id %>">View Lines</a>
                                                <a class="btn btn-outline-secondary" href="/data-entry/payroll/post-to-accounts/history?batchId=<%= batch.id %>&print=1">Print</a>
                                                <button type="button" class="btn btn-outline-danger" disabled>Reverse</button>
                                            </div>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <% if (selectedBatch) { %>
                <div class="card shadow-sm">
                    <div class="card-header bg-white d-flex align-items-center justify-content-between">
                        <div>
                            <h5 class="mb-1">Batch #<%= selectedBatch.id %> Lines</h5>
                            <div class="text-muted small">
                                <%= selectedBatch.activity_code %><%= selectedBatch.activity_name ? ` - ${selectedBatch.activity_name}` : '' %> |
                                <%= String(selectedBatch.posting_month).padStart(2, '0') %>/<%= selectedBatch.posting_year %>
                            </div>
                        </div>
                        <div class="no-print">
                            <button type="button" class="btn btn-outline-secondary btn-sm" onclick="window.print()">
                                <i class="bi bi-printer"></i> Print Lines
                            </button>
                        </div>
                    </div>
                    <div class="card-body">
                        <div class="row g-3 mb-3">
                            <div class="col-md-3">
                                <div class="text-muted small">Posting Date</div>
                                <div class="fw-semibold"><%= selectedBatch.posting_date ? new Date(selectedBatch.posting_date).toISOString().split('T')[0] : '' %></div>
                            </div>
                            <div class="col-md-3">
                                <div class="text-muted small">Total Amount</div>
                                <div class="fw-semibold"><%= Number(selectedBatch.total_amount || 0).toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></div>
                            </div>
                            <div class="col-md-3">
                                <div class="text-muted small">Total Lines</div>
                                <div class="fw-semibold"><%= selectedBatch.total_lines %></div>
                            </div>
                            <div class="col-md-3">
                                <div class="text-muted small">Posted By</div>
                                <div class="fw-semibold"><%= selectedBatch.posted_by %></div>
                            </div>
                        </div>

                        <div class="table-responsive">
                            <table class="table table-bordered table-sm">
                                <thead class="table-light">
                                    <tr>
                                        <th>GL Account</th>
                                        <th>Account Name</th>
                                        <th>Narration</th>
                                        <th>Source</th>
                                        <th>Entry Type</th>
                                        <th class="text-end">Amount</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% selectedLines.forEach(line => { %>
                                        <tr>
                                            <td><%= line.gl_account_code %></td>
                                            <td><%= line.gl_account_name %></td>
                                            <td><%= line.narration || '' %></td>
                                            <td><%= line.source_table || '' %></td>
                                            <td class="text-capitalize"><%= line.entry_type || '' %></td>
                                            <td class="text-end"><%= Number(line.amount || 0).toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></td>
                                        </tr>
                                    <% }) %>
                                </tbody>
                                <% if (typeof debitTotal !== 'undefined' && typeof creditTotal !== 'undefined') { %>
                                    <tfoot class="table-light">
                                        <tr>
                                            <th colspan="4" class="text-end">Totals</th>
                                            <th class="text-end">
                                                Debit: <%= Number(debitTotal || 0).toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %>
                                                <br>
                                                Credit: <%= Number(creditTotal || 0).toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %>
                                            </th>
                                        </tr>
                                    </tfoot>
                                <% } %>
                            </table>
                        </div>
                    </div>
                </div>
            <% } %>

            <footer class="mt-4 py-3 text-center text-muted border-top no-print">
                <%- include('../../data_entry/partials/footer') %>
            </footer>
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <% if (printMode && selectedBatch) { %>
        <script>
            window.addEventListener('load', () => window.print());
        </script>
    <% } %>
</body>
</html>
