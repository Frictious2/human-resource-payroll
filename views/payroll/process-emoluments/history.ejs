<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> · Data Entry</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="/css/styles.css" rel="stylesheet" />
</head>
<body>
    <%- include('../../data_entry/partials/topbar', { user }) %>
    <%- include('../../data_entry/partials/sidebar') %>

    <main class="main">
        <div class="container-fluid py-3">
            <div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3 mb-4">
                <div>
                    <h2 class="mb-1"><%= title %></h2>
                    <p class="text-muted mb-0">Review monthly payroll processing batches by activity and period.</p>
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb mt-2 mb-0">
                            <li class="breadcrumb-item"><a class="text-decoration-none" href="/data-entry/dashboard">Home</a></li>
                            <li class="breadcrumb-item">Payroll</li>
                            <li class="breadcrumb-item"><a class="text-decoration-none" href="<%= formUrl %>">Process Emoluments</a></li>
                            <li class="breadcrumb-item active" aria-current="page">History</li>
                        </ol>
                    </nav>
                </div>
                <div class="d-flex gap-2">
                    <a href="<%= formUrl %>" class="btn btn-outline-primary">
                        <i class="bi bi-plus-circle"></i> New Process Run
                    </a>
                </div>
            </div>

            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <form class="row g-3" method="GET" action="/data-entry/payroll/process-emoluments/history">
                        <div class="col-md-3">
                            <label for="activityCode" class="form-label">Activity</label>
                            <select class="form-select" id="activityCode" name="activityCode">
                                <option value="">All Activities</option>
                                <% activities.forEach(activity => { %>
                                    <option value="<%= activity.code %>" <%= filters.activityCode === activity.code ? 'selected' : '' %>>
                                        <%= activity.code %> - <%= activity.name %>
                                    </option>
                                <% }) %>
                            </select>
                        </div>
                        <div class="col-md-2">
                            <label for="month" class="form-label">Month</label>
                            <input type="number" min="1" max="12" class="form-control" id="month" name="month" value="<%= filters.month %>">
                        </div>
                        <div class="col-md-2">
                            <label for="year" class="form-label">Year</label>
                            <input type="number" min="2000" max="2100" class="form-control" id="year" name="year" value="<%= filters.year %>">
                        </div>
                        <div class="col-md-3">
                            <label for="status" class="form-label">Status</label>
                            <select class="form-select" id="status" name="status">
                                <option value="">All Statuses</option>
                                <option value="processed" <%= filters.status === 'processed' ? 'selected' : '' %>>Processed</option>
                                <option value="reversed" <%= filters.status === 'reversed' ? 'selected' : '' %>>Reversed</option>
                            </select>
                        </div>
                        <div class="col-md-2 d-flex align-items-end gap-2">
                            <button type="submit" class="btn btn-primary w-100">Filter</button>
                            <a href="/data-entry/payroll/process-emoluments/history" class="btn btn-outline-secondary">Reset</a>
                        </div>
                    </form>
                </div>
            </div>

            <div class="card shadow-sm">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Batch</th>
                                    <th>Activity</th>
                                    <th>Month/Year</th>
                                    <th>Date Processed</th>
                                    <th>Staff</th>
                                    <th>Gross</th>
                                    <th>Tax</th>
                                    <th>Deductions</th>
                                    <th>Net</th>
                                    <th>Processed By</th>
                                    <th>Status</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (!batches.length) { %>
                                    <tr>
                                        <td colspan="12" class="text-center py-4 text-muted">No processing batches found for the selected filters.</td>
                                    </tr>
                                <% } %>
                                <% batches.forEach(batch => { %>
                                    <tr>
                                        <td>#<%= batch.id %></td>
                                        <td><%= batch.activity_code %> - <%= batch.activity_name %></td>
                                        <td><%= String(batch.payroll_month).padStart(2, '0') %>/<%= batch.payroll_year %></td>
                                        <td><%= batch.processed_at ? new Date(batch.processed_at).toISOString().slice(0, 10) : '' %></td>
                                        <td><%= batch.total_staff %></td>
                                        <td><%= Number(batch.total_gross || 0).toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></td>
                                        <td><%= Number(batch.total_tax || 0).toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></td>
                                        <td><%= Number(batch.total_deductions || 0).toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></td>
                                        <td><%= Number(batch.total_net || 0).toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></td>
                                        <td><%= batch.processed_by_name %></td>
                                        <td><span class="badge text-bg-success text-capitalize"><%= batch.status %></span></td>
                                        <td>
                                            <a class="btn btn-sm btn-outline-primary" href="<%= detailsBaseUrl %>/<%= batch.id %>">View Details</a>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <footer class="mt-4 py-3 text-center text-muted border-top">
                <%- include('../../data_entry/partials/footer') %>
            </footer>
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
