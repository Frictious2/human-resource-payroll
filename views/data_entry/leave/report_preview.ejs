<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            font-family: 'Times New Roman', Times, serif;
            background-color: #f8f9fa;
        }
        .a4-page {
            width: 210mm;
            min-height: 297mm;
            padding: 20mm;
            margin: 10mm auto;
            background: white;
            box-shadow: 0 0 10px rgba(0,0,0,0.1);
            position: relative;
        }
        .header {
            text-align: center;
            margin-bottom: 20px;
            border-bottom: 2px solid #000;
            padding-bottom: 10px;
        }
        .company-logo {
            max-height: 80px;
            margin-bottom: 10px;
        }
        .company-name {
            font-size: 24px;
            font-weight: bold;
            text-transform: uppercase;
            margin: 0;
        }
        .company-address {
            font-size: 14px;
            margin: 5px 0;
        }
        .report-title {
            text-align: center;
            font-size: 18px;
            font-weight: bold;
            margin: 20px 0;
            text-transform: uppercase;
        }
        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 12px;
        }
        th, td {
            border: 1px solid #000;
            padding: 5px;
            text-align: left;
        }
        th {
            background-color: #f0f0f0;
        }
        .no-print {
            position: fixed;
            top: 20px;
            right: 20px;
            z-index: 1000;
        }
        @media print {
            body {
                background: none;
                margin: 0;
                padding: 0;
            }
            .a4-page {
                width: 100%;
                margin: 0;
                padding: 0; /* Let printer handle margins or set specifically */
                box-shadow: none;
                page-break-after: always;
            }
            .no-print {
                display: none;
            }
            @page {
                size: A4;
                margin: 10mm;
            }
        }
    </style>
</head>
<body>

    <div class="no-print">
        <button onclick="window.print()" class="btn btn-primary">Print Report</button>
        <button onclick="window.close()" class="btn btn-secondary">Close</button>
    </div>

    <div class="a4-page">
        <!-- Header -->
        <div class="header">
            <% if (company.LogoPath) { %>
                <img src="<%= company.LogoPath %>" alt="Company Logo" class="company-logo">
            <% } %>
            <h1 class="company-name"><%= company.Com_Name || company.CName || 'Company Name' %></h1>
            <p class="company-address"><%= company.Address || '' %></p>
        </div>

        <!-- Title -->
        <div class="report-title">
            <% if (type === 'Outstanding') { %>
                Outstanding Leave for Year <%= year %>
            <% } else if (type === 'Recalled') { %>
                Recalled Leave for Year <%= year %>
            <% } else if (type === 'Purchased') { %>
                Purchased Leave for Year <%= year %>
            <% } %>
        </div>

        <!-- Table -->
        <% if (reportData && reportData.length > 0) { 
            let currentDept = null;
        %>
            <table>
                <thead>
                    <tr>
                        <th>Emp-ID</th>
                        <th>Name</th>
                        <th>Job Title</th>
                        <th>Leave Days (Annual)</th>
                        <% if (type === 'Outstanding') { %>
                            <th>Outstanding Days</th>
                        <% } else if (type === 'Recalled') { %>
                            <th>Day Recalled</th>
                            <th>Outstanding Days</th>
                        <% } else if (type === 'Purchased') { %>
                            <th>Days Purchased</th>
                            <th>Amount</th>
                            <th>Outstanding Days</th>
                        <% } %>
                    </tr>
                </thead>
                <tbody>
                    <% reportData.forEach(row => { 
                        if (row.Dept !== currentDept) {
                            currentDept = row.Dept;
                    %>
                        <tr class="table-light">
                            <td colspan="<%= type === 'Outstanding' ? 5 : (type === 'Recalled' ? 6 : 7) %>" style="background-color: #e9ecef; font-weight: bold;">
                                <%= currentDept || 'Unknown Department' %>
                            </td>
                        </tr>
                    <% } %>
                        <tr>
                            <td><%= row.PFNo %></td>
                            <td><%= row.SName %></td>
                            <td><%= row.JobTitle %></td>
                            <td><%= row.LeaveDays %></td>
                            <% if (type === 'Outstanding') { %>
                                <td><%= row.OutstandingDays %></td>
                            <% } else if (type === 'Recalled') { %>
                                <td><%= row.DateRecalled %></td>
                                <td><%= row.OutstandingDays %></td>
                            <% } else if (type === 'Purchased') { %>
                                <td><%= row.DaysPurchased %></td>
                                <td><%= parseFloat(row.Allowance || 0).toFixed(2) %></td>
                                <td><%= row.OutstandingDays %></td>
                            <% } %>
                        </tr>
                    <% }); %>
                </tbody>
            </table>
        <% } else { %>
            <div class="text-center mt-5">
                <p>No records found for this selection.</p>
            </div>
        <% } %>

        <div style="margin-top: 30px; font-size: 12px; text-align: right;">
            Generated on: <%= new Date().toLocaleDateString() %> <%= new Date().toLocaleTimeString() %>
        </div>
    </div>

</body>
</html>
