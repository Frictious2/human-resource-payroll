<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="/css/styles.css" rel="stylesheet" />
</head>
<body>
    <%- include('../partials/topbar', { user }) %>
    <%- include('../partials/sidebar') %>

    <main class="main">
        <div class="container-fluid">
            <div class="d-flex align-items-center justify-content-between mb-4">
                <h2 class="mb-0"><%= title %></h2>
                <a href="/data-entry/welfare/leave" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left"></i> Back
                </a>
            </div>

            <div class="card shadow-sm">
                <div class="card-header bg-white">
                    <h5 class="mb-0">Staff Currently on Leave</h5>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>Emp-ID</th>
                                    <th>Name</th>
                                    <th>Leave Type</th>
                                    <th>Start Date</th>
                                    <th>End Date</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (staffOnLeave && staffOnLeave.length > 0) { %>
                                    <% staffOnLeave.forEach(leave => { %>
                                        <tr>
                                            <td><%= leave.PFNO %></td>
                                            <td><%= leave.SName %></td>
                                            <td><%= leave.LeaveType %></td>
                                            <td><%= new Date(leave.StartDate).toLocaleDateString() %></td>
                                            <td><%= new Date(leave.ResumptionDate).toLocaleDateString() %></td>
                                            <td>
                                                <button class="btn btn-sm btn-warning recall-btn" 
                                                        data-leave='<%- JSON.stringify(leave) %>'>
                                                    <i class="bi bi-arrow-return-left"></i> Recall
                                                </button>
                                            </td>
                                        </tr>
                                    <% }); %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="6" class="text-center py-4 text-muted">
                                            No staff currently on leave
                                        </td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <footer class="mt-4 py-3 text-center text-muted border-top">
                <%- include('../partials/footer') %>
            </footer>
        </div>
    </main>

    <!-- Recall Modal -->
    <div class="modal fade" id="recallModal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Recall Staff</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <form id="recallForm">
                        <input type="hidden" id="lCount">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Emp-ID</label>
                                <input type="text" class="form-control" id="pfno" readonly>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Name</label>
                                <input type="text" class="form-control" id="sName" readonly>
                            </div>

                            <div class="col-md-4">
                                <label class="form-label">Date Started</label>
                                <input type="text" class="form-control" id="startDate" readonly>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Days Remaining</label>
                                <input type="number" class="form-control" id="daysRemaining" readonly>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Leave Year</label>
                                <input type="text" class="form-control" id="lYear" readonly>
                            </div>

                            <div class="col-md-4">
                                <label class="form-label">Leave Type</label>
                                <input type="text" class="form-control" value="RECALL" readonly>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Date Recalled</label>
                                <input type="date" class="form-control" id="dateRecalled" required>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Resumption Date</label>
                                <input type="date" class="form-control" id="resumptionDate" required>
                            </div>
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                    <button type="button" class="btn btn-warning" id="submitRecallBtn">Submit for Approval</button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const recallModal = new bootstrap.Modal(document.getElementById('recallModal'));
            const recallBtns = document.querySelectorAll('.recall-btn');
            const submitBtn = document.getElementById('submitRecallBtn');
            const dateRecalledInput = document.getElementById('dateRecalled');
            const resumptionDateInput = document.getElementById('resumptionDate');
            const daysRemainingInput = document.getElementById('daysRemaining');
            const lCountInput = document.getElementById('lCount');
            const pfnoInput = document.getElementById('pfno');
            const sNameInput = document.getElementById('sName');
            const startDateInput = document.getElementById('startDate');
            const lYearInput = document.getElementById('lYear');
            
            let currentLeave = null;

            recallBtns.forEach(btn => {
                btn.addEventListener('click', function() {
                    const leave = JSON.parse(this.dataset.leave);
                    currentLeave = leave;
                    
                    lCountInput.value = leave.LCount;
                    pfnoInput.value = leave.PFNO;
                    sNameInput.value = leave.SName;
                    startDateInput.value = new Date(leave.StartDate).toLocaleDateString();
                    lYearInput.value = leave.LYear;
                    
                    // Reset inputs
                    daysRemainingInput.value = '';
                    dateRecalledInput.value = '';
                    resumptionDateInput.value = '';
                    
                    recallModal.show();
                });
            });
            
            // Calculate Days Remaining when Date Recalled changes
            dateRecalledInput.addEventListener('change', function() {
                if (!currentLeave || !this.value) return;
                
                const recallDate = new Date(this.value);
                const originalResumption = new Date(currentLeave.ResumptionDate);
                
                // If Recall Date is before Original Resumption Date
                if (recallDate < originalResumption) {
                    const diffTime = Math.abs(originalResumption - recallDate);
                    const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24)); 
                    daysRemainingInput.value = diffDays;
                } else {
                    daysRemainingInput.value = 0;
                }
            });

            submitBtn.addEventListener('click', async () => {
                const lCount = lCountInput.value;
                const dateRecalled = dateRecalledInput.value;
                const resumptionDate = resumptionDateInput.value;
                
                if (!dateRecalled || !resumptionDate) {
                    alert('Please enter Date Recalled and Resumption Date');
                    return;
                }
                
                try {
                    const response = await fetch('/data-entry/api/leave/recall', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ lCount, dateRecalled, resumptionDate })
                    });
                    
                    const result = await response.json();
                    if (result.success) {
                        alert('Recall request submitted for approval');
                        location.reload();
                    } else {
                        alert(result.error || 'Error submitting request');
                    }
                } catch (error) {
                    console.error(error);
                    alert('Server Error');
                }
            });
        });
    </script>
</body>
</html>