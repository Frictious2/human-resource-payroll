<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> · HR & Payroll</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="/css/styles.css" rel="stylesheet" />
</head>
<body>
<%- include('../partials/topbar') %>
<%- include('../partials/sidebar') %>

<main class="main">
    <div class="container-fluid">
        <h2 class="mb-4">End Of Service Benefits</h2>

        <div class="card shadow-sm mb-4">
            <div class="card-body">
                <form id="benefitForm" action="/data-entry/api/welfare/benefits/calculate" method="POST">
                    <div class="row g-3">
                        <!-- Select Section -->
                        <div class="col-md-4">
                            <div class="form-check form-check-inline">
                                <input class="form-check-input" type="radio" name="section" id="sectionAll" value="all" checked>
                                <label class="form-check-label" for="sectionAll">All</label>
                            </div>
                            <div class="form-check form-check-inline">
                                <input class="form-check-input" type="radio" name="section" id="sectionStaff" value="staff">
                                <label class="form-check-label" for="sectionStaff">Staff</label>
                            </div>
                            <div class="form-check form-check-inline">
                                <input class="form-check-input" type="radio" name="section" id="sectionFormer" value="former">
                                <label class="form-check-label" for="sectionFormer">Former</label>
                            </div>
                        </div>
                    </div>

                    <div class="row mb-3 d-none" id="staffIdRow">
                        <label for="staffId" class="col-sm-2 col-form-label">Staff ID:</label>
                        <div class="col-sm-4">
                            <input type="text" class="form-control" id="staffId" name="staffId" placeholder="Enter Staff ID">
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-2 col-form-label fw-bold">Search Type:</label>
                        <div class="col-sm-10">
                            <div class="form-check form-check-inline">
                                <input class="form-check-input" type="radio" name="searchType" id="typeExGracia" value="ex-gracia">
                                <label class="form-check-label" for="typeExGracia">Ex-Gracia</label>
                            </div>
                            <div class="form-check form-check-inline">
                                <input class="form-check-input" type="radio" name="searchType" id="typeEOS" value="eos" checked>
                                <label class="form-check-label" for="typeEOS">End of Service Benefit</label>
                            </div>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label for="endDate" class="col-sm-2 col-form-label">End Date:</label>
                        <div class="col-sm-4">
                            <input type="date" class="form-control" id="endDate" name="endDate" required>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-sm-10 offset-sm-2">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-calculator"></i> Calculate / Preview
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="card-header bg-light">
                <h5 class="mb-0">Benefit Calculation Results</h5>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-bordered table-striped table-hover">
                        <thead class="table-dark">
                            <tr>
                                <th>PF No</th>
                                <th>Name</th>
                                <th>Dept</th>
                                <th>Grade</th>
                                <th>Date Emp</th>
                                <th>Age</th>
                                <th>Years</th>
                                <th>Salary</th>
                                <th>Days</th>
                                <th>Benefit</th>
                                <th>Taxable</th>
                                <th>Tax</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (results && results.length > 0) { %>
                                <% results.forEach(row => { %>
                                    <tr>
                                        <td><%= row.PFNo %></td>
                                        <td><%= row.SName %></td>
                                        <td><%= row.Dept %></td>
                                        <td><%= row.Grade %></td>
                                        <td><%= new Date(row.DateEmp).toLocaleDateString() %></td>
                                        <td><%= row.Age %></td>
                                        <td><%= row.Years %></td>
                                        <td><%= parseFloat(row.Salary).toLocaleString(undefined, {minimumFractionDigits: 2}) %></td>
                                        <td><%= row.Days %></td>
                                        <td><%= parseFloat(row.Benefit).toLocaleString(undefined, {minimumFractionDigits: 2}) %></td>
                                        <td><%= parseFloat(row.Taxable).toLocaleString(undefined, {minimumFractionDigits: 2}) %></td>
                                        <td><%= parseFloat(row.Tax).toLocaleString(undefined, {minimumFractionDigits: 2}) %></td>
                                    </tr>
                                <% }); %>
                            <% } else { %>
                                <tr>
                                    <td colspan="12" class="text-center">No records found. Run calculation to view results.</td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
    
    <footer class="mt-4 py-3 text-center text-muted border-top">
        <%- include('../partials/footer') %>
    </footer>
</main>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
    document.addEventListener('DOMContentLoaded', function() {
        const sectionRadios = document.querySelectorAll('input[name="section"]');
        const staffIdRow = document.getElementById('staffIdRow');
        const benefitForm = document.getElementById('benefitForm');

        sectionRadios.forEach(radio => {
            radio.addEventListener('change', function() {
                if (this.value === 'staff') {
                    staffIdRow.classList.remove('d-none');
                } else {
                    staffIdRow.classList.add('d-none');
                }
            });
        });

        benefitForm.addEventListener('submit', function(e) {
            // Let the form submit normally
        });
    });
</script>
</body>
</html>
