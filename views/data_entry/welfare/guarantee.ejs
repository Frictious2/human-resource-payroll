<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Bank Loan Guarantee · HR & Payroll</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet"
          integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
          crossorigin="anonymous" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css"
          rel="stylesheet" />
    <link href="/css/styles.css" rel="stylesheet" />
</head>
<body>
<%- include('../partials/topbar') %>
<%- include('../partials/sidebar') %>

<main class="main">
    <div class="container-fluid">
        <h2 class="mb-4">Bank Loan Guarantee</h2>

        <!-- Action Bar -->
        <div class="d-flex justify-content-between mb-3">
            <button class="btn btn-primary" onclick="openGuaranteeModal()">
                <i class="bi bi-plus-circle"></i> New Bank Loan Guarantee
            </button>
        </div>

        <!-- Guarantee List -->
        <div class="card shadow-sm">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Ref No</th>
                                <th>EMP-ID</th>
                                <th>Name</th>
                                <th>Bank</th>
                                <th>Amount</th>
                                <th>Duration</th>
                                <th>Monthly</th>
                                <th>Loan Date</th>
                                <th>Expiry Date</th>
                                <th>Clearance</th>
                                <th>Status</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% guarantees.forEach(g => { %>
                                <tr>
                                    <td><%= g.RefNo %></td>
                                    <td><%= g.PFNO %></td>
                                    <td><%= g.Name %></td>
                                    <td><%= g.BankName %></td>
                                    <td><%= parseFloat(g.LoanAmount).toFixed(2) %></td>
                                    <td><%= g.Duration %> M</td>
                                    <td><%= parseFloat(g.Monthly).toFixed(2) %></td>
                                    <td><%= new Date(g.LoanDate).toLocaleDateString() %></td>
                                    <td><%= g.ExpiryDate ? new Date(g.ExpiryDate).toLocaleDateString() : '-' %></td>
                                    <td>
                                        <% if (g.Clearance == 1) { %>
                                            <span class="badge bg-success">Received</span>
                                        <% } else { %>
                                            <span class="badge bg-secondary">Pending</span>
                                        <% } %>
                                    </td>
                                    <td>
                                        <% if (g.Approved == 1) { %>
                                            <span class="badge bg-success">Approved</span>
                                        <% } else if (g.Approved == 2) { %>
                                            <span class="badge bg-danger">Rejected</span>
                                        <% } else { %>
                                            <span class="badge bg-warning text-dark">Pending</span>
                                        <% } %>
                                    </td>
                                    <td>
                                        <button class="btn btn-sm btn-outline-primary" 
                                            onclick="openEditModal(<%= JSON.stringify(g) %>)">
                                            Edit
                                        </button>
                                    </td>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    
    <footer class="mt-4 py-3 text-center text-muted border-top">
        <%- include('../partials/footer') %>
    </footer>
</div>
</main>

<!-- Guarantee Modal -->
<div class="modal fade" id="guaranteeModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalTitle">New Bank Loan Guarantee</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="guaranteeForm">
                    <input type="hidden" name="refNo" id="refNo">
                    
                    <div class="row g-3">
                        <!-- Employee Selection -->
                        <div class="col-md-6">
                            <label class="form-label">EMP-ID</label>
                            <select class="form-select" name="pfno" id="pfno" required onchange="updateStaffName()">
                                <option value="">Select Staff...</option>
                                <% staff.forEach(s => { %>
                                    <option value="<%= s.PFNo %>" data-name="<%= s.SName %>">
                                        <%= s.PFNo %> - <%= s.SName %>
                                    </option>
                                <% }); %>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Staff Name</label>
                            <input type="text" class="form-control" id="staffName" readonly>
                        </div>

                        <!-- Bank Selection -->
                        <div class="col-md-6">
                            <label class="form-label">Bank</label>
                            <select class="form-select" name="bank" id="bank" required>
                                <option value="">Select Bank...</option>
                                <% banks.forEach(b => { %>
                                    <option value="<%= b.Code %>"><%= b.Bank %></option>
                                <% }); %>
                            </select>
                        </div>

                        <!-- Loan Details -->
                        <div class="col-md-6">
                            <label class="form-label">Loan Amount</label>
                            <input type="number" class="form-control" name="loanAmount" id="loanAmount" step="0.01" required oninput="calculateMonthly()">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Duration (Months)</label>
                            <input type="number" class="form-control" name="duration" id="duration" required oninput="calculateMonthly()">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Monthly Repayment</label>
                            <input type="text" class="form-control" name="monthly" id="monthly" readonly>
                        </div>

                        <!-- Dates -->
                        <div class="col-md-6">
                            <label class="form-label">Guarantee Date</label>
                            <input type="date" class="form-control" name="loanDate" id="loanDate" required onchange="calculateExpiry()">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Expiry Date</label>
                            <input type="text" class="form-control" name="expiryDate" id="expiryDate" readonly>
                        </div>

                        <!-- Clearance Section (Only visible on Edit for Approved Loans) -->
                        <div id="clearanceSection" class="col-12 border-top pt-3 mt-3 d-none">
                            <h6 class="text-primary mb-3">Bank Clearance Details</h6>
                            <div class="row g-3">
                                <div class="col-md-4">
                                    <div class="form-check mt-4">
                                        <input class="form-check-input" type="checkbox" name="clearance" id="clearance" value="1">
                                        <label class="form-check-label" for="clearance">
                                            Bank Clearance Letter Received
                                        </label>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label">Received Date</label>
                                    <input type="date" class="form-control" name="clearanceDate" id="clearanceDate">
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label">Received By</label>
                                    <select class="form-select" name="receivedBy" id="receivedBy">
                                        <option value="">Select Staff...</option>
                                        <% staff.forEach(s => { %>
                                            <option value="<%= s.PFNo %>"><%= s.SName %></option>
                                        <% }); %>
                                    </select>
                                </div>
                            </div>
                        </div>

                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn btn-primary" onclick="submitGuarantee()">Save Guarantee</button>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

<script>
    let guaranteeModal;
    document.addEventListener('DOMContentLoaded', function() {
        const modalEl = document.getElementById('guaranteeModal');
        if (modalEl) {
            guaranteeModal = new bootstrap.Modal(modalEl);
        }
    });

    function openGuaranteeModal() {
        if (!guaranteeModal) {
            guaranteeModal = new bootstrap.Modal(document.getElementById('guaranteeModal'));
        }
        
        document.getElementById('guaranteeForm').reset();
        document.getElementById('refNo').value = '';
        document.getElementById('modalTitle').textContent = 'New Bank Loan Guarantee';
        document.getElementById('clearanceSection').classList.add('d-none');
        
        // Enable fields
        toggleFields(false);
        
        guaranteeModal.show();
    }

    function openEditModal(guarantee) {
        if (!guaranteeModal) {
            guaranteeModal = new bootstrap.Modal(document.getElementById('guaranteeModal'));
        }
        document.getElementById('guaranteeForm').reset();
        document.getElementById('refNo').value = guarantee.RefNo;
        document.getElementById('modalTitle').textContent = 'Edit Guarantee';
        
        // Populate fields
        document.getElementById('pfno').value = guarantee.PFNO;
        updateStaffName();
        document.getElementById('bank').value = guarantee.Bank; // Assuming Bank code is stored
        document.getElementById('loanAmount').value = guarantee.LoanAmount;
        document.getElementById('duration').value = guarantee.Duration;
        document.getElementById('monthly').value = parseFloat(guarantee.Monthly).toFixed(2);
        
        if (guarantee.LoanDate) {
            document.getElementById('loanDate').value = new Date(guarantee.LoanDate).toISOString().split('T')[0];
        }
        
        // Calculate expiry for display
        calculateExpiry();

        // Handle Approved Status
        const isApproved = guarantee.Approved == 1;
        toggleFields(isApproved);

        // Show Clearance Section if Approved
        const clearanceSection = document.getElementById('clearanceSection');
        if (isApproved) {
            clearanceSection.classList.remove('d-none');
            // Populate Clearance fields
            document.getElementById('clearance').checked = guarantee.Clearance == 1;
            if (guarantee.ClearanceDate) {
                document.getElementById('clearanceDate').value = new Date(guarantee.ClearanceDate).toISOString().split('T')[0];
            }
            document.getElementById('receivedBy').value = guarantee.ReceivedBy || '';
        } else {
            clearanceSection.classList.add('d-none');
        }

        guaranteeModal.show();
    }

    function toggleFields(disabled) {
        const fields = ['pfno', 'bank', 'loanAmount', 'duration', 'loanDate'];
        fields.forEach(id => {
            document.getElementById(id).disabled = disabled;
        });
    }

    function updateStaffName() {
        const select = document.getElementById('pfno');
        const nameInput = document.getElementById('staffName');
        const selectedOption = select.options[select.selectedIndex];
        
        if (selectedOption.value) {
            nameInput.value = selectedOption.getAttribute('data-name');
        } else {
            nameInput.value = '';
        }
    }

    function calculateMonthly() {
        const amount = parseFloat(document.getElementById('loanAmount').value) || 0;
        const duration = parseInt(document.getElementById('duration').value) || 0;
        
        if (amount > 0 && duration > 0) {
            const monthly = amount / duration;
            document.getElementById('monthly').value = monthly.toFixed(2);
        } else {
            document.getElementById('monthly').value = '';
        }
    }

    function calculateExpiry() {
        const loanDateStr = document.getElementById('loanDate').value;
        const duration = parseInt(document.getElementById('duration').value) || 0;
        
        if (loanDateStr && duration > 0) {
            const loanDate = new Date(loanDateStr);
            loanDate.setMonth(loanDate.getMonth() + duration);
            document.getElementById('expiryDate').value = loanDate.toLocaleDateString();
        } else {
            document.getElementById('expiryDate').value = '';
        }
    }

    function submitGuarantee() {
        const form = document.getElementById('guaranteeForm');
        if (!form.checkValidity()) {
            form.reportValidity();
            return;
        }

        const formData = new FormData(form);
        const data = Object.fromEntries(formData.entries());
        
        // Add checkbox value manually if not checked (though only needed if checked usually)
        if (!document.getElementById('clearance').checked) {
            data.clearance = 0; // Or handle in backend as undefined/false
        } else {
            data.clearance = 1;
        }

        // Add disabled fields back to data because disabled inputs aren't submitted
        if (document.getElementById('pfno').disabled) {
            data.pfno = document.getElementById('pfno').value;
            data.bank = document.getElementById('bank').value;
            data.loanAmount = document.getElementById('loanAmount').value;
            data.duration = document.getElementById('duration').value;
            data.loanDate = document.getElementById('loanDate').value;
        }

        fetch('/data-entry/api/welfare/guarantee', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                location.reload();
            } else {
                alert('Error: ' + (data.error || 'Operation failed'));
            }
        })
        .catch(error => console.error('Error:', error));
    }
</script>

</body>
</html>