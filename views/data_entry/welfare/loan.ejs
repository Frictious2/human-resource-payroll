<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <link href="/css/styles.css" rel="stylesheet">
</head>
<body>
    <%- include('../partials/topbar') %>
    <%- include('../partials/sidebar') %>

    <main class="main">
        <div class="container-fluid">
            <h2 class="mb-4">Loan Management</h2>

            <!-- Tabs -->
            <ul class="nav nav-tabs mb-4" id="loanTabs" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active" id="application-tab" data-bs-toggle="tab" data-bs-target="#application" type="button" role="tab">Loan Application</button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="repayment-tab" data-bs-toggle="tab" data-bs-target="#repayment" type="button" role="tab">Loan Repayment</button>
                </li>
            </ul>

            <div class="tab-content" id="loanTabsContent">
                <!-- Loan Application Tab -->
                <div class="tab-pane fade show active" id="application" role="tabpanel">
                    <div class="card">
                        <div class="card-header d-flex justify-content-between align-items-center">
                            <h5 class="mb-0">Loan Applications</h5>
                            <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#newApplicationModal">
                                <i class="bi bi-plus-circle me-2"></i>New Application
                            </button>
                        </div>
                        <div class="card-body">
                            <div class="table-responsive">
                                <table class="table table-striped table-hover">
                                    <thead>
                                        <tr>
                                            <th>Emp ID</th>
                                            <th>Name</th>
                                            <th>Loan Date</th>
                                            <th>Loan Amount</th>
                                            <th>Interest</th>
                                            <th>Action</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% applications.forEach(app => { %>
                                            <tr>
                                                <td><%= app.PFNo %></td>
                                                <td><%= app.SName %></td>
                                                <td><%= new Date(app.EntryDate).toLocaleDateString() %></td>
                                                <td><%= parseFloat(app.Amount).toFixed(2) %></td>
                                                <td><%= parseFloat(app.Interest || 0).toFixed(2) %></td>
                                                <td>
                                                    <% if (app.Approved == 1) { %>
                                                        <span class="badge bg-success">Approved</span>
                                                    <% } else { %>
                                                        <button class="btn btn-sm btn-outline-primary" onclick="openEditModal(<%= JSON.stringify(app) %>)">Edit</button>
                                                    <% } %>
                                                </td>
                                            </tr>
                                        <% }); %>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Loan Repayment Tab -->
                <div class="tab-pane fade" id="repayment" role="tabpanel">
                    <div class="card">
                        <div class="card-header">
                            <h5 class="mb-0">Loan Repayments</h5>
                        </div>
                        <div class="card-body">
                            <div class="table-responsive">
                                <table class="table table-striped table-hover">
                                    <thead>
                                        <tr>
                                            <th>Emp-ID</th>
                                            <th>Name</th>
                                            <th>Loan Amount</th>
                                            <th>Loan Taken</th>
                                            <th>Duration</th>
                                            <th>Amount Paid</th>
                                            <th>Amount Left</th>
                                            <th>Status</th>
                                            <th>Action</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% repayments.forEach(rep => { 
                                            let status = 'Paying';
                                            if (rep.LoanBal <= 0) status = 'Completed';
                                            // Simple overdue check logic could be added here
                                        %>
                                            <tr>
                                                <td><%= rep.PFNo %></td>
                                                <td><%= rep.SName %></td>
                                                <td><%= parseFloat(rep.Amount).toFixed(2) %></td>
                                                <td><%= new Date(rep.LoanDate).toLocaleDateString() %></td>
                                                <td><%= rep.Duration %> Months</td>
                                                <td><%= parseFloat(rep.RepaidAmount || 0).toFixed(2) %></td>
                                                <td><%= parseFloat(rep.LoanBal || 0).toFixed(2) %></td>
                                                <td>
                                                    <span class="badge <%= status === 'Completed' ? 'text-bg-success' : 'text-bg-warning' %>">
                                                        <%= status %>
                                                    </span>
                                                </td>
                                                <td>
                                                    <button class="btn btn-sm btn-outline-primary" 
                                                        onclick="openRepaymentModal(<%= JSON.stringify(rep) %>)">
                                                        Edit
                                                    </button>
                                                </td>
                                            </tr>
                                        <% }); %>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <!-- New Application Modal -->
    <div class="modal fade" id="newApplicationModal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">New Loan Application</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <form id="applicationForm">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Entry Date</label>
                                <input type="datetime-local" class="form-control" name="entryDate" id="appEntryDate" required>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Emp-ID</label>
                                <div class="input-group">
                                    <select class="form-select" name="pfno" id="appPfno" required onchange="fetchStaffDetails(this.value)">
                                        <option value="">Select Staff...</option>
                                        <% staffList.forEach(staff => { %>
                                            <option value="<%= staff.PFNo %>" data-name="<%= staff.SName %>" data-acct="<%= staff.AccountNo %>"><%= staff.PFNo %> - <%= staff.SName %></option>
                                        <% }); %>
                                    </select>
                                    <input type="text" class="form-control" id="appName" readonly placeholder="Name">
                                </div>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Account No</label>
                                <input type="text" class="form-control" id="appAccount" readonly>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Transaction</label>
                                <select class="form-select" name="lTrans" required>
                                    <% loanCodes.forEach(code => { %>
                                        <option value="<%= code.TCode %>"><%= code.TransName %></option>
                                    <% }); %>
                                </select>
                            </div>
                            
                            <!-- Last Loan Info -->
                            <div class="col-md-4">
                                <label class="form-label">Last Loan Date</label>
                                <input type="text" class="form-control" id="lastLoanDate" readonly>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Last Loan Amount</label>
                                <input type="text" class="form-control" id="lastLoanAmount" readonly>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Completed</label>
                                <input type="text" class="form-control" id="lastLoanCompleted" readonly>
                            </div>

                            <!-- Calculations -->
                            <div class="col-md-4">
                                <label class="form-label">Amount</label>
                                <input type="number" step="0.01" class="form-control" name="amount" id="appAmount" required oninput="calculateLoan()">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Duration (Months)</label>
                                <input type="number" class="form-control" name="duration" id="appDuration" required oninput="calculateLoan()">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Interest Rate (%)</label>
                                <input type="text" class="form-control" id="appRate" readonly value="0%">
                            </div>

                            <div class="col-md-4">
                                <label class="form-label">Monthly Repayment</label>
                                <input type="number" step="0.01" class="form-control" name="monthlyRepayment" id="appMonthlyRepayment" readonly>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Interest</label>
                                <input type="number" step="0.01" class="form-control" name="interest" id="appInterest" readonly>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Monthly Interest</label>
                                <input type="number" step="0.01" class="form-control" name="monthlyInt" id="appMonthlyInt" readonly>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label">Start Date</label>
                                <input type="date" class="form-control" name="startDate" id="appStartDate" required>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Balance</label>
                                <input type="number" step="0.01" class="form-control" id="appBalance" readonly>
                            </div>
                            <div class="col-md-12">
                                <div class="form-check mt-2">
                                    <input class="form-check-input" type="checkbox" name="surcharge" id="appSurcharge" value="Yes">
                                    <label class="form-check-label" for="appSurcharge">
                                        Apply Surcharge (Deduct from Salary monthly)
                                    </label>
                                </div>
                            </div>
                        </div>
                        <div class="mt-3 text-end">
                            <button type="submit" class="btn btn-primary">Submit Application</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Repayment Modal -->
    <div class="modal fade" id="repaymentModal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Loan Repayment</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <form id="repaymentForm">
                        <input type="hidden" name="transNo" id="repTransNo">
                        <input type="hidden" name="pfno" id="repHiddenPfno">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Emp-ID</label>
                                <input type="text" class="form-control" id="repPfno" readonly>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Name</label>
                                <input type="text" class="form-control" id="repName" readonly>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Entry Date (Repayment Date)</label>
                                <input type="date" class="form-control" name="repaymentDate" id="repDate" required>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Duration (Months)</label>
                                <input type="text" class="form-control" id="repDuration" readonly>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Loan Amount</label>
                                <input type="text" class="form-control" id="repLoanAmount" readonly>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Loan Date</label>
                                <input type="text" class="form-control" id="repLoanDate" readonly>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Repayment Amount</label>
                                <input type="number" step="0.01" class="form-control" name="repaymentAmount" id="repAmount" required oninput="calculateRepayment()">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Balance</label>
                                <input type="text" class="form-control" id="repBalance" readonly>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Repaid Amount</label>
                                <input type="text" class="form-control" id="repRepaidTotal" readonly>
                            </div>
                            <div class="col-md-12">
                                <label class="form-label">End Date</label>
                                <input type="text" class="form-control" id="repEndDate" readonly>
                            </div>
                        </div>
                        <div class="mt-3 text-end">
                            <button type="submit" class="btn btn-primary">Save Repayment</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Set Default Date
        document.getElementById('appEntryDate').value = new Date().toISOString().slice(0, 16);
        document.getElementById('repDate').value = new Date().toISOString().split('T')[0];

        // Fetch Staff Details & History
        async function fetchStaffDetails(pfno) {
            if (!pfno) return;
            
            // Set Name and Account from selected option
            const select = document.getElementById('appPfno');
            const option = select.options[select.selectedIndex];
            document.getElementById('appName').value = option.dataset.name;
            document.getElementById('appAccount').value = option.dataset.acct || '';

            // Fetch History via API
            try {
                const res = await fetch(`/data-entry/api/staff/${pfno}/loan-history`);
                const data = await res.json();
                
                if (data.lastLoan) {
                    document.getElementById('lastLoanDate').value = new Date(data.lastLoan.EntryDate).toLocaleDateString();
                    document.getElementById('lastLoanAmount').value = data.lastLoan.Amount;
                    document.getElementById('lastLoanCompleted').value = data.lastLoan.Completed;
                } else {
                    document.getElementById('lastLoanDate').value = '';
                    document.getElementById('lastLoanAmount').value = '';
                    document.getElementById('lastLoanCompleted').value = '';
                }
            } catch (err) {
                console.error(err);
            }
        }

        // Calculate Loan Fields
        function calculateLoan() {
            const amount = parseFloat(document.getElementById('appAmount').value) || 0;
            const duration = parseInt(document.getElementById('appDuration').value) || 0;

            if (amount > 0 && duration > 0) {
                let interest = 0;
                let rate = 0;
                
                if (duration > 5) {
                    rate = 4;
                    interest = amount * 0.04;
                }

                const monthlyRepayment = amount / duration;
                const monthlyInt = interest / duration;
                const balance = amount + interest;

                document.getElementById('appRate').value = rate + '%';
                document.getElementById('appInterest').value = interest.toFixed(2);
                document.getElementById('appMonthlyRepayment').value = monthlyRepayment.toFixed(2);
                document.getElementById('appMonthlyInt').value = monthlyInt.toFixed(2);
                document.getElementById('appBalance').value = balance.toFixed(2);
            } else {
                document.getElementById('appRate').value = '0%';
                document.getElementById('appInterest').value = '';
                document.getElementById('appMonthlyRepayment').value = '';
                document.getElementById('appMonthlyInt').value = '';
                document.getElementById('appBalance').value = '';
            }
        }

        // Repayment Modal
        let currentRepaymentLoan = null;

        function openRepaymentModal(loan) {
            currentRepaymentLoan = loan;
            
            document.getElementById('repTransNo').value = loan.TransNo;
            document.getElementById('repPfno').value = loan.PFNo;
            document.getElementById('repHiddenPfno').value = loan.PFNo;
            document.getElementById('repName').value = loan.SName;
            document.getElementById('repDuration').value = loan.Duration;
            document.getElementById('repLoanAmount').value = parseFloat(loan.Amount).toFixed(2);
            document.getElementById('repLoanDate').value = new Date(loan.LoanDate).toLocaleDateString();
            document.getElementById('repEndDate').value = loan.ExpDate ? new Date(loan.ExpDate).toLocaleDateString() : '-';
            
            // Reset fields
            document.getElementById('repAmount').value = '';
            document.getElementById('repBalance').value = parseFloat(loan.LoanBal).toFixed(2);
            document.getElementById('repRepaidTotal').value = parseFloat(loan.RepaidAmount || 0).toFixed(2);

            const modal = new bootstrap.Modal(document.getElementById('repaymentModal'));
            modal.show();
        }

        function calculateRepayment() {
            if (!currentRepaymentLoan) return;

            const payAmount = parseFloat(document.getElementById('repAmount').value) || 0;
            const currentBal = parseFloat(currentRepaymentLoan.LoanBal);
            const currentRepaid = parseFloat(currentRepaymentLoan.RepaidAmount || 0);

            const newBal = currentBal - payAmount;
            const newRepaid = currentRepaid + payAmount;

            document.getElementById('repBalance').value = newBal.toFixed(2);
            document.getElementById('repRepaidTotal').value = newRepaid.toFixed(2);
        }

        // Submit Application
        document.getElementById('applicationForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const formData = new FormData(e.target);
            const data = Object.fromEntries(formData.entries());

            try {
                const res = await fetch('/data-entry/api/welfare/loan/add', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });
                const result = await res.json();
                if (result.success) {
                    alert('Loan application submitted successfully');
                    location.reload();
                } else {
                    alert('Error: ' + result.error);
                }
            } catch (err) {
                console.error(err);
                alert('Server Error');
            }
        });

        // Submit Repayment
        document.getElementById('repaymentForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const formData = new FormData(e.target);
            const data = Object.fromEntries(formData.entries());

            try {
                const res = await fetch('/data-entry/api/welfare/loan/repayment', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });
                const result = await res.json();
                if (result.success) {
                    alert('Repayment recorded successfully');
                    location.reload();
                } else {
                    alert('Error: ' + result.error);
                }
            } catch (err) {
                console.error(err);
                alert('Server Error');
            }
        });
    </script>
</body>
</html>