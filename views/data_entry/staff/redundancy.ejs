<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> · HR & Payroll</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="/css/styles.css" rel="stylesheet" />
</head>
<body>
    <%- include('../partials/topbar', { user }) %>
    <%- include('../partials/sidebar') %>

    <main class="main">
        <div class="container-fluid">
            <div class="d-flex align-items-center justify-content-between mb-4">
                <div>
                    <h2 class="mb-0">Staff Redundancy</h2>
                    <div class="text-muted">Manage staff redundancy status</div>
                </div>
            </div>

            <!-- Search Form -->
            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <form action="/data-entry/staff/redundancy" method="GET" class="row g-3">
                        <div class="col-md-4">
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-search"></i></span>
                                <input type="text" class="form-control" name="search" placeholder="Search by PFNo or Name" value="<%= search || '' %>">
                            </div>
                        </div>
                        <div class="col-md-2">
                            <button type="submit" class="btn btn-primary w-100">Search</button>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Staff Table -->
            <div class="card shadow-sm">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Emp-ID</th>
                                    <th>DOE</th>
                                    <th>Staff Name</th>
                                    <th>Department</th>
                                    <th>Served (Years)</th>
                                    <th>Redundant Date</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (staffList.length > 0) { %>
                                    <% staffList.forEach(staff => { %>
                                        <% 
                                            function formatDate(d) {
                                                if (!d) return '';
                                                const date = new Date(d);
                                                if (isNaN(date.getTime())) return '';
                                                // Handle '0000-00-00' cases which might come as invalid dates or year 1899/1900 depending on driver
                                                if (date.getFullYear() < 1900) return '';
                                                return date.toISOString().split('T')[0];
                                            }
                                        %>
                                        <tr>
                                            <td><%= staff.PFNo %></td>
                                            <td><%= formatDate(staff.DOE) %></td>
                                            <td><%= staff.SName %></td>
                                            <td><%= staff.Department %></td>
                                            <td><%= staff.Served %></td>
                                            <td><%= formatDate(staff.DateRedundant) %></td>
                                            <td>
                                                <% if (staff.Redundant == 1) { %>
                                                    <span class="badge bg-danger">Redundant</span>
                                                <% } else if (staff.Redundant == 2) { %>
                                                    <span class="badge bg-warning text-dark">Pending</span>
                                                <% } else { %>
                                                    <form action="/data-entry/staff/redundancy/initiate" method="POST" onsubmit="return confirm('Are you sure you want to mark this staff as redundant?');">
                                                        <input type="hidden" name="pfno" value="<%= staff.PFNo %>">
                                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                                            <i class="bi bi-exclamation-triangle"></i> Redundant
                                                        </button>
                                                    </form>
                                                <% } %>
                                            </td>
                                        </tr>
                                    <% }) %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="7" class="text-center py-4 text-muted">No staff found</td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
                <!-- Pagination -->
                <% if (pagination.totalPages > 1) { %>
                    <div class="card-footer d-flex justify-content-center">
                        <nav>
                            <ul class="pagination mb-0">
                                <% for(let i = 1; i <= pagination.totalPages; i++) { %>
                                    <li class="page-item <%= pagination.page === i ? 'active' : '' %>">
                                        <a class="page-link" href="/data-entry/staff/redundancy?page=<%= i %>&search=<%= search %>"><%= i %></a>
                                    </li>
                                <% } %>
                            </ul>
                        </nav>
                    </div>
                <% } %>
            </div>
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
