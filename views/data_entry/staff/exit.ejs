<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> · HR & Payroll</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="/css/styles.css" rel="stylesheet" />
</head>
<body>
    <%- include('../partials/topbar', { user }) %>
    <%- include('../partials/sidebar') %>

    <main class="main">
        <div class="container-fluid">
            <div class="d-flex align-items-center justify-content-between mb-4">
                <div>
                    <h2 class="mb-0">Staff Exit Management</h2>
                    <div class="text-muted">Process staff resignations and exits</div>
                </div>
            </div>

            <% if (typeof success !== 'undefined' && success) { %>
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <%= success %>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            <% } %>

            <div class="card shadow-sm">
                <div class="card-body">
                    <form action="/data-entry/staff/exit" method="POST">
                        <div class="row g-3">
                            <!-- Staff Selection -->
                            <div class="col-md-6">
                                <label for="pfno" class="form-label">Staff ID/PFNo</label>
                                <select class="form-select" id="pfno" name="pfno" required onchange="onStaffSelect(this)">
                                    <option value="">Select Staff...</option>
                                    <% staffList.forEach(staff => { %>
                                        <option value="<%= staff.PFNo %>" data-name="<%= staff.SName %>">
                                            <%= staff.PFNo %> - <%= staff.SName %>
                                        </option>
                                    <% }) %>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label for="staffName" class="form-label">Staff Name</label>
                                <input type="text" class="form-control" id="staffName" readonly>
                            </div>

                            <!-- Reason -->
                            <div class="col-md-6">
                                <label for="reason" class="form-label">Reason</label>
                                <select class="form-select" id="reason" name="reason">
                                    <option value="">Select Reason...</option>
                                    <% reasons.forEach(r => { %>
                                        <option value="<%= r.ReasonCode %>"><%= r.ReasonCode %> - <%= r.Reason %></option>
                                    <% }) %>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label for="reasonDate" class="form-label">Reason Date</label>
                                <input type="date" class="form-control" id="reasonDate" name="reasonDate">
                            </div>

                            <!-- Notice -->
                            <div class="col-md-6">
                                <label for="noticeDate" class="form-label">Notice Date</label>
                                <input type="date" class="form-control" id="noticeDate" name="noticeDate">
                            </div>
                            <div class="col-md-6">
                                <label for="noticeExpiry" class="form-label">Notice Expiry</label>
                                <input type="date" class="form-control" id="noticeExpiry" name="noticeExpiry">
                            </div>

                            <!-- Exit Info -->
                            <div class="col-md-6">
                                <label for="dateLeft" class="form-label">Date Left</label>
                                <input type="date" class="form-control" id="dateLeft" name="dateLeft">
                            </div>
                            <div class="col-md-6">
                                <label for="dateAccepted" class="form-label">Date Accepted</label>
                                <input type="date" class="form-control" id="dateAccepted" name="dateAccepted">
                            </div>

                            <div class="col-12">
                                <label for="briefDetails" class="form-label">Brief Details</label>
                                <textarea class="form-control" id="briefDetails" name="briefDetails" rows="3"></textarea>
                            </div>

                            <!-- Interview -->
                            <div class="col-md-6">
                                <div class="form-check mt-4">
                                    <input class="form-check-input" type="checkbox" id="interviewed" name="interviewed">
                                    <label class="form-check-label" for="interviewed">
                                        Exit Interview Conducted
                                    </label>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <label for="dateInterviewed" class="form-label">Date Interviewed</label>
                                <input type="date" class="form-control" id="dateInterviewed" name="dateInterviewed">
                            </div>

                            <div class="col-12 mt-4">
                                <button type="submit" class="btn btn-primary">Save & Submit for Approval</button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        async function onStaffSelect(select) {
            const pfno = select.value;
            const option = select.options[select.selectedIndex];
            const name = option.getAttribute('data-name');
            
            document.getElementById('staffName').value = name || '';

            if (pfno) {
                try {
                    const response = await fetch(`/data-entry/staff/exit/search?pfno=${pfno}`);
                    const result = await response.json();

                    if (result.found) {
                        const data = result.data;
                        document.getElementById('reason').value = data.Reason || '';
                        document.getElementById('reasonDate').value = data.DateResigned || '';
                        document.getElementById('noticeDate').value = data.NoticeDate || '';
                        document.getElementById('noticeExpiry').value = data.ExpDate || '';
                        document.getElementById('dateLeft').value = data.DateLeft || '';
                        document.getElementById('briefDetails').value = data.BriefInfo || '';
                        document.getElementById('dateAccepted').value = data.DateAccepted || '';
                        document.getElementById('interviewed').checked = data.ExitInterview == 1;
                        document.getElementById('dateInterviewed').value = data.DateInterviewed || '';
                    } else {
                        // Clear fields if new entry (except name)
                        document.getElementById('reason').value = '';
                        document.getElementById('reasonDate').value = '';
                        document.getElementById('noticeDate').value = '';
                        document.getElementById('noticeExpiry').value = '';
                        document.getElementById('dateLeft').value = '';
                        document.getElementById('briefDetails').value = '';
                        document.getElementById('dateAccepted').value = '';
                        document.getElementById('interviewed').checked = false;
                        document.getElementById('dateInterviewed').value = '';
                    }
                } catch (error) {
                    console.error('Error fetching staff details:', error);
                }
            }
        }
    </script>
</body>
</html>