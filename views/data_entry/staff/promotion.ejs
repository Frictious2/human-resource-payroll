<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> · HR & Payroll</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="/css/styles.css" rel="stylesheet" />
</head>
<body>
    <%- include('../partials/topbar', { user }) %>
    <%- include('../partials/sidebar') %>

    <main class="main">
        <div class="container-fluid">
            <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
                <h1 class="h2"><%= companyName %></h1>
                <div class="btn-toolbar mb-2 mb-md-0">
                    <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#promotionModal">
                        <i class="bi bi-plus-circle"></i> Add Promotion / Demotion
                    </button>
                </div>
            </div>

            <div class="card shadow-sm mb-4">
                <div class="card-header bg-white">
                    <h5 class="mb-0">Pending Promotions / Demotions</h5>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-hover table-bordered">
                            <thead class="table-light">
                                <tr>
                                    <th>PFNo</th>
                                    <th>Name</th>
                                    <th>Date</th>
                                    <th>Type</th>
                                    <th>Current Grade</th>
                                    <th>New Grade</th>
                                    <th>New Job Title</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (promotions.length === 0) { %>
                                    <tr><td colspan="8" class="text-center">No pending records found.</td></tr>
                                <% } else { %>
                                    <% promotions.forEach(p => { %>
                                        <tr>
                                            <td><%= p.PFNO %></td>
                                            <td><%= p.SName %></td>
                                            <td><%= new Date(p.PDate).toLocaleDateString() %></td>
                                            <td>
                                                <!-- Assuming Mode P=Promotion, D=Demotion. If Mode is null or 1, defaulting to Promotion -->
                                                <% if (p.Mode === 'D') { %>
                                                    <span class="badge bg-danger">Demotion</span>
                                                <% } else { %>
                                                    <span class="badge bg-success">Promotion</span>
                                                <% } %>
                                            </td>
                                            <td><%= p.PrevGradeDesc %></td>
                                            <td><%= p.NewGradeDesc %></td>
                                            <td><%= p.NewJobTitleDesc %></td>
                                            <td><span class="badge bg-warning">Pending</span></td>
                                        </tr>
                                    <% }) %>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <!-- Modal -->
    <div class="modal fade" id="promotionModal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Add Promotion / Demotion</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form action="/data-entry/staff/promotion-demotion" method="POST">
                    <div class="modal-body">
                        <div class="row g-3">
                            <div class="col-12">
                                <label class="form-label d-block">Type</label>
                                <div class="form-check form-check-inline">
                                    <input class="form-check-input" type="radio" name="type" id="typePromotion" value="promotion" checked>
                                    <label class="form-check-label" for="typePromotion">Promotion</label>
                                </div>
                                <div class="form-check form-check-inline">
                                    <input class="form-check-input" type="radio" name="type" id="typeDemotion" value="demotion">
                                    <label class="form-check-label" for="typeDemotion">Demotion</label>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label">Emp-ID</label>
                                <select class="form-select" name="pfno" id="pfnoSelect" required>
                                    <option value="">Select Staff...</option>
                                    <% staffList.forEach(s => { %>
                                        <option value="<%= s.PFNo %>"><%= s.PFNo %> - <%= s.SName %></option>
                                    <% }) %>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Staff Name</label>
                                <input type="text" class="form-control" id="staffName" readonly>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Current Grade</label>
                                <input type="text" class="form-control" id="currentGradeDesc" readonly>
                                <input type="hidden" name="currentGradeCode" id="currentGradeCode">
                                <input type="hidden" id="currentJobTitleCode"> <!-- Hidden field for Job Title Code -->
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Previous Grade (History)</label>
                                <input type="text" class="form-control" id="prevGradeDesc" readonly>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Date</label>
                                <input type="date" class="form-control" name="promotionDate" required>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">New Job Title</label>
                                <select class="form-select" name="newJobTitle" id="newJobTitleSelect" required>
                                    <option value="">Select Job Title...</option>
                                    <% jobTitles.forEach(j => { %>
                                        <option value="<%= j.Code %>"><%= j.JobTitle %></option>
                                    <% }) %>
                                </select>
                            </div>
                             <div class="col-md-6">
                                <label class="form-label">New Grade</label>
                                <select class="form-select" name="newGrade" id="newGradeSelect" required>
                                    <option value="">Select Grade...</option>
                                    <% grades.forEach(g => { %>
                                        <option value="<%= g.GradeCode %>" data-jobtitle="<%= g.JobTitle %>"><%= g.Grade %></option>
                                    <% }) %>
                                </select>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                        <button type="submit" class="btn btn-primary">Save</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        const pfnoSelect = document.getElementById('pfnoSelect');
        const jobTitleSelect = document.getElementById('newJobTitleSelect');
        const gradeSelect = document.getElementById('newGradeSelect');
        const typeRadios = document.querySelectorAll('input[name="type"]');
        let currentJobTitleCode = '';

        // Function to filter Job Titles based on selection
        function filterJobTitles() {
            if (!currentJobTitleCode) return;

            const isPromotion = document.getElementById('typePromotion').checked;
            const currentCodeInt = parseInt(currentJobTitleCode, 10);

            // 0101 is highest, 9001 is lowest.
            // Promotion: New Code < Current Code (Higher Rank)
            // Demotion: New Code > Current Code (Lower Rank)

            for (let i = 0; i < jobTitleSelect.options.length; i++) {
                const option = jobTitleSelect.options[i];
                if (!option.value) continue;

                const optionCodeInt = parseInt(option.value, 10);
                
                if (isNaN(optionCodeInt) || isNaN(currentCodeInt)) {
                     option.hidden = false; // Fallback
                     continue;
                }

                if (isPromotion) {
                    // Show only if Option Code < Current Code (Higher Rank)
                    if (optionCodeInt < currentCodeInt) {
                        option.hidden = false;
                    } else {
                        option.hidden = true;
                    }
                } else {
                    // Demotion: Show only if Option Code > Current Code (Lower Rank)
                    if (optionCodeInt > currentCodeInt) {
                        option.hidden = false;
                    } else {
                        option.hidden = true;
                    }
                }
            }
            // Reset selection if hidden
            if (jobTitleSelect.selectedOptions[0] && jobTitleSelect.selectedOptions[0].hidden) {
                jobTitleSelect.value = "";
                gradeSelect.value = ""; // Also reset grade
            }
        }
        
        // Auto-select Grade when Job Title changes
        jobTitleSelect.addEventListener('change', function() {
            const selectedJobTitle = this.value;
            
            // Reset grade first
            gradeSelect.value = "";
            
            if (!selectedJobTitle) return;

            // Find matching grade
            for (let i = 0; i < gradeSelect.options.length; i++) {
                const option = gradeSelect.options[i];
                if (option.dataset.jobtitle === selectedJobTitle) {
                    gradeSelect.value = option.value;
                    break; // Select first match
                }
            }
        });

        // Listen for Radio Changes
        typeRadios.forEach(radio => {
            radio.addEventListener('change', filterJobTitles);
        });

        pfnoSelect.addEventListener('change', async function() {
            const pfno = this.value;
            if (!pfno) return;

            try {
                const res = await fetch(`/data-entry/api/staff/${pfno}/promotion-details`);
                const data = await res.json();
                
                if (data.error) {
                    alert(data.error);
                    return;
                }

                document.getElementById('staffName').value = data.name;
                document.getElementById('currentGradeDesc').value = data.currentGradeDesc || 'N/A';
                document.getElementById('currentGradeCode').value = data.currentGradeCode;
                document.getElementById('prevGradeDesc').value = data.prevGradeDesc || 'None';
                
                // Store Job Title Code and Filter
                currentJobTitleCode = data.currentJobTitleCode;
                document.getElementById('currentJobTitleCode').value = currentJobTitleCode;
                
                filterJobTitles();
                
            } catch (err) {
                console.error(err);
                alert('Error fetching staff details');
            }
        });
    </script>
</body>
</html>
