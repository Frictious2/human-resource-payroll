<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> · Data Entry</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="/css/styles.css" rel="stylesheet" />
</head>
<body>
    <%- include('../partials/topbar', { user }) %>
    <%- include('../partials/sidebar') %>

    <main class="main">
        <div class="container-fluid py-3">
            <div class="d-flex align-items-center justify-content-between mb-4">
                <div>
                    <h2 class="mb-0"><%= title %></h2>
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb mt-2 mb-0">
                            <li class="breadcrumb-item"><a href="/data-entry/dashboard" class="text-decoration-none">Home</a></li>
                            <li class="breadcrumb-item">Staff</li>
                            <li class="breadcrumb-item active">Attendance</li>
                        </ol>
                    </nav>
                </div>
            </div>

            <% if (success) { %><div class="alert alert-success"><%= success %></div><% } %>
            <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>

            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <h5 class="card-title mb-3">Add / Update Attendance</h5>
                    <form method="POST" action="/data-entry/staff/attendance" class="row g-3">
                        <div class="col-md-3">
                            <label for="workDay" class="form-label">Work Day</label>
                            <input type="date" class="form-control" id="workDay" name="workDay" required value="<%= filters.workDay || new Date().toISOString().slice(0, 10) %>">
                        </div>
                        <div class="col-md-3">
                            <label for="pfNo" class="form-label">Staff PFNo</label>
                            <input type="text" class="form-control" id="pfNo" name="pfNo" list="attendanceStaffList" required>
                            <datalist id="attendanceStaffList">
                                <% staffList.forEach((staff) => { %>
                                    <option value="<%= staff.PFNo %>" data-name="<%= staff.SName %>"><%= staff.SName %></option>
                                <% }) %>
                            </datalist>
                        </div>
                        <div class="col-md-3">
                            <label for="staffName" class="form-label">Staff Name</label>
                            <input type="text" class="form-control" id="staffName" readonly>
                        </div>
                        <div class="col-md-3">
                            <label for="workStatus" class="form-label">Work Status</label>
                            <input type="text" class="form-control" id="workStatus" name="workStatus" list="attendanceStatusList" required>
                            <datalist id="attendanceStatusList">
                                <% statusOptions.forEach((status) => { %>
                                    <option value="<%= status %>"></option>
                                <% }) %>
                            </datalist>
                        </div>
                        <div class="col-md-3">
                            <label for="timeIn" class="form-label">Time In</label>
                            <input type="time" class="form-control" id="timeIn" name="timeIn">
                        </div>
                        <div class="col-md-3">
                            <label for="timeOut" class="form-label">Time Out</label>
                            <input type="time" class="form-control" id="timeOut" name="timeOut">
                        </div>
                        <div class="col-md-6 d-flex align-items-end justify-content-end">
                            <button type="submit" class="btn btn-primary"><i class="bi bi-save"></i> Save Attendance</button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="card shadow-sm">
                <div class="card-body">
                    <div class="d-flex flex-wrap align-items-center justify-content-between gap-3 mb-3">
                        <h5 class="card-title mb-0">Attendance Records</h5>
                        <form method="GET" action="/data-entry/staff/attendance" class="row g-2">
                            <div class="col-auto"><input type="text" class="form-control" name="pfNo" placeholder="PFNo" value="<%= filters.pfNo %>"></div>
                            <div class="col-auto">
                                <select class="form-select" name="workStatus">
                                    <option value="">All Statuses</option>
                                    <% statusOptions.forEach((status) => { %>
                                        <option value="<%= status %>" <%= filters.workStatus === status ? 'selected' : '' %>><%= status %></option>
                                    <% }) %>
                                </select>
                            </div>
                            <div class="col-auto"><input type="date" class="form-control" name="dateFrom" value="<%= filters.dateFrom %>"></div>
                            <div class="col-auto"><input type="date" class="form-control" name="dateTo" value="<%= filters.dateTo %>"></div>
                            <div class="col-auto"><button type="submit" class="btn btn-outline-primary">Filter</button></div>
                        </form>
                    </div>

                    <div class="table-responsive">
                        <table class="table table-hover table-bordered align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>Work Day</th>
                                    <th>PFNo</th>
                                    <th>Name</th>
                                    <th>Dept</th>
                                    <th>Status</th>
                                    <th>Time In</th>
                                    <th>Time Out</th>
                                    <th>Approval</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (!rows.length) { %>
                                    <tr><td colspan="8" class="text-center text-muted py-4">No attendance records found.</td></tr>
                                <% } %>
                                <% rows.forEach((row) => { %>
                                    <tr>
                                        <td><%= row.Work_Day ? new Date(row.Work_Day).toLocaleDateString() : '-' %></td>
                                        <td><%= row.PFNo %></td>
                                        <td><%= row.StaffName || '-' %></td>
                                        <td><%= row.DeptName || row.Dept || '-' %></td>
                                        <td><%= row.Work_Status || '-' %></td>
                                        <td><%= row.Time_in ? new Date(row.Time_in).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }) : '-' %></td>
                                        <td><%= row.Time_out ? new Date(row.Time_out).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }) : '-' %></td>
                                        <td>
                                            <% if (Number(row.Approved || 0) === 0) { %><span class="badge bg-warning text-dark">Pending</span>
                                            <% } else if (Number(row.Approved || 0) === 2) { %><span class="badge bg-danger">Rejected</span>
                                            <% } else { %><span class="badge bg-success">Approved</span><% } %>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <footer class="mt-4 py-3 text-center text-muted border-top"><%- include('../partials/footer') %></footer>
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const pfNoInput = document.getElementById('pfNo');
            const staffNameInput = document.getElementById('staffName');
            const staffOptions = Array.from(document.querySelectorAll('#attendanceStaffList option'));
            function syncStaffName() {
                const selectedOption = staffOptions.find((option) => option.value === pfNoInput.value);
                staffNameInput.value = selectedOption ? selectedOption.dataset.name : '';
            }
            pfNoInput.addEventListener('change', syncStaffName);
            pfNoInput.addEventListener('input', syncStaffName);
            syncStaffName();
        });
    </script>
</body>
</html>
