<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> · HR & Payroll</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <!-- Summernote CSS -->
    <link href="https://cdn.jsdelivr.net/npm/summernote@0.8.18/dist/summernote-lite.min.css" rel="stylesheet">
    <link href="/css/styles.css" rel="stylesheet" />
</head>
<body>
    <%- include('../partials/topbar', { user }) %>
    <%- include('../partials/sidebar') %>

    <main class="main">
        <div class="container-fluid">
            <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
                <h1 class="h2"><%= companyName %></h1>
            </div>

            <!-- Search Section -->
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="bi bi-search"></i> Search Staff Queries</h5>
                </div>
                <div class="card-body">
                    <div class="row g-3 align-items-end">
                        <div class="col-md-4">
                            <label for="searchPFNo" class="form-label">Staff ID / PFNo</label>
                            <input type="text" class="form-control" id="searchPFNo" placeholder="Enter PFNo">
                        </div>
                        <div class="col-md-2">
                            <button type="button" class="btn btn-primary w-100" id="btnSearch">
                                <i class="bi bi-search"></i> Search
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Staff Details & Queries Section -->
            <div id="staffSection" class="d-none">
                <div class="alert alert-info d-flex justify-content-between align-items-center">
                    <div>
                        <strong>Staff Name: </strong> <span id="staffName"></span> | 
                        <strong>PFNo: </strong> <span id="staffPFNo"></span>
                    </div>
                </div>

                <div class="card shadow-sm">
                    <div class="card-header bg-white d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">Queries List</h5>
                        <button class="btn btn-success btn-sm" id="btnAddQuery">
                            <i class="bi bi-plus-circle"></i> Add Query
                        </button>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-hover table-bordered" id="queriesTable">
                                <thead class="table-light">
                                    <tr>
                                        <th>Date</th>
                                        <th>Query Type</th>
                                        <th>Outcome</th>
                                        <th>Start Date</th>
                                        <th>End Date</th>
                                        <th>Approved</th>
                                        <th>Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <!-- Rows populated by JS -->
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <!-- Add/Edit Modal -->
    <div class="modal fade" id="queryModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="modalTitle">Add Query</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <form id="queryForm">
                        <input type="hidden" id="originalQDate">
                        
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label for="qDate" class="form-label">Query Date & Time</label>
                                <input type="datetime-local" class="form-control" id="qDate" required>
                            </div>
                            <div class="col-md-6">
                                <label for="qType" class="form-label">Query Type</label>
                                <select class="form-select" id="qType" required>
                                    <option value="">Select Type...</option>
                                    <% qTypes.forEach(t => { %>
                                        <option value="<%= t.Code %>"><%= t.QType %></option>
                                    <% }) %>
                                </select>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label for="qDetails" class="form-label">Details</label>
                            <textarea id="qDetails" name="qDetails"></textarea>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label for="mResponse" class="form-label">Outcome (Reaction)</label>
                                <select class="form-select" id="mResponse">
                                    <option value="">Select Outcome...</option>
                                    <% mReactions.forEach(r => { %>
                                        <option value="<%= r.Code %>"><%= r.Reaction %></option>
                                    <% }) %>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label for="percent" class="form-label">Percent</label>
                                <input type="number" class="form-control" id="percent" min="0" max="100">
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label for="sDate" class="form-label">Start Date</label>
                                <input type="date" class="form-control" id="sDate">
                            </div>
                            <div class="col-md-6">
                                <label for="eDate" class="form-label">End Date</label>
                                <input type="date" class="form-control" id="eDate">
                            </div>
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                    <button type="button" class="btn btn-primary" id="btnSaveQuery">Save</button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/summernote@0.8.18/dist/summernote-lite.min.js"></script>
    
    <script>
        $(document).ready(function() {
            $('#qDetails').summernote({
                placeholder: 'Enter query details...',
                tabsize: 2,
                height: 150,
                toolbar: [
                  ['style', ['style']],
                  ['font', ['bold', 'underline', 'clear']],
                  ['color', ['color']],
                  ['para', ['ul', 'ol', 'paragraph']],
                  ['table', ['table']],
                  ['insert', ['link', 'picture', 'video']],
                  ['view', ['fullscreen', 'codeview', 'help']]
                ]
            });
        });

        const btnSearch = document.getElementById('btnSearch');
        const searchPFNo = document.getElementById('searchPFNo');
        const staffSection = document.getElementById('staffSection');
        const staffNameSpan = document.getElementById('staffName');
        const staffPFNoSpan = document.getElementById('staffPFNo');
        const btnAddQuery = document.getElementById('btnAddQuery');
        const queriesTableBody = document.querySelector('#queriesTable tbody');
        
        const queryModal = new bootstrap.Modal(document.getElementById('queryModal'));
        const modalTitle = document.getElementById('modalTitle');
        const btnSaveQuery = document.getElementById('btnSaveQuery');
        
        const originalQDateInput = document.getElementById('originalQDate');
        const qDateInput = document.getElementById('qDate');
        const qTypeInput = document.getElementById('qType');
        // qDetails is handled by summernote
        const mResponseInput = document.getElementById('mResponse');
        const sDateInput = document.getElementById('sDate');
        const eDateInput = document.getElementById('eDate');
        const percentInput = document.getElementById('percent');

        let currentStaffPFNo = '';
        let currentQueries = [];

        btnSearch.addEventListener('click', searchStaff);
        
        async function searchStaff() {
            const pfno = searchPFNo.value.trim();
            if (!pfno) {
                alert('Please enter a Staff ID / PFNo');
                return;
            }

            try {
                const res = await fetch(`/data-entry/api/staff/${pfno}/queries`);
                if (!res.ok) {
                    if (res.status === 404) alert('Staff not found');
                    else alert('Error searching staff');
                    return;
                }

                const data = await res.json();
                currentStaffPFNo = data.staff.pfno;
                currentQueries = data.queries;

                staffNameSpan.textContent = data.staff.name;
                staffPFNoSpan.textContent = data.staff.pfno;
                
                renderTable();
                staffSection.classList.remove('d-none');
            } catch (err) {
                console.error(err);
                alert('Error connecting to server');
            }
        }

        function renderTable() {
            queriesTableBody.innerHTML = '';
            
            currentQueries.forEach(q => {
                const tr = document.createElement('tr');
                
                // Format dates for display
                const qDateDisplay = q.QDateFormatted || q.QDate;
                const sDateDisplay = q.SDateFormatted || '';
                const eDateDisplay = q.EDateFormatted || '';
                
                const approvedStatus = q.Approved == -1 ? '<span class="badge bg-success">Approved</span>' : '<span class="badge bg-warning">Pending</span>';

                tr.innerHTML = `
                    <td>${qDateDisplay}</td>
                    <td>${q.QTypeName || q.QTypeCode}</td>
                    <td>${q.MResponseName || ''}</td>
                    <td>${sDateDisplay}</td>
                    <td>${eDateDisplay}</td>
                    <td>${approvedStatus}</td>
                    <td>
                        <button class="btn btn-sm btn-primary me-1" onclick="openEditModal('${q.QDateFormatted}')"><i class="bi bi-pencil"></i></button>
                    </td>
                `;
                queriesTableBody.appendChild(tr);
            });
        }

        btnAddQuery.addEventListener('click', () => {
            modalTitle.textContent = 'Add Query';
            originalQDateInput.value = '';
            
            // Reset form
            document.getElementById('queryForm').reset();
            $('#qDetails').summernote('code', ''); // Clear summernote

            // Set default date/time to now
            const now = new Date();
            now.setMinutes(now.getMinutes() - now.getTimezoneOffset());
            qDateInput.value = now.toISOString().slice(0, 16);

            queryModal.show();
        });

        window.openEditModal = (qDateFormatted) => {
            // Find query by formatted date string (approximate match if needed, but should be exact from API)
            const query = currentQueries.find(q => q.QDateFormatted === qDateFormatted);
            if (!query) return;

            modalTitle.textContent = 'Edit Query';
            originalQDateInput.value = query.QDate; // Use raw DB date for identification if possible, or formatted
            
            // Set fields
            // For datetime-local, format is YYYY-MM-DDTHH:mm
            const qDateObj = new Date(query.QDate);
            // Adjust for timezone offset to show correct local time in input
            const tzOffset = qDateObj.getTimezoneOffset() * 60000; 
            const localISOTime = (new Date(qDateObj - tzOffset)).toISOString().slice(0, 16);
            
            qDateInput.value = localISOTime; // or use QDateFormatted replacing ' ' with 'T'
            
            qTypeInput.value = query.QTypeCode;
            $('#qDetails').summernote('code', query.QDetails || '');
            mResponseInput.value = query.MResponseCode;
            sDateInput.value = query.SDateFormatted || '';
            eDateInput.value = query.EDateFormatted || '';
            percentInput.value = query.Percent || '';

            queryModal.show();
        };

        btnSaveQuery.addEventListener('click', async () => {
            const originalQDate = originalQDateInput.value;
            const payload = {
                pfno: currentStaffPFNo,
                originalQDate: originalQDate,
                qDate: qDateInput.value, // YYYY-MM-DDTHH:mm
                qType: qTypeInput.value,
                qDetails: $('#qDetails').summernote('code'),
                mResponse: mResponseInput.value,
                sDate: sDateInput.value,
                eDate: eDateInput.value,
                percent: percentInput.value
            };

            if (!payload.qDate || !payload.qType) {
                alert('Date and Type are required');
                return;
            }

            const url = '/data-entry/api/staff/queries';
            const method = originalQDate ? 'PUT' : 'POST';

            try {
                const res = await fetch(url, {
                    method: method,
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });

                const result = await res.json();
                if (!res.ok) {
                    alert(result.error || 'Operation failed');
                    return;
                }

                queryModal.hide();
                searchStaff(); // Refresh list
            } catch (err) {
                console.error(err);
                alert('Error saving data');
            }
        });
    </script>
</body>
</html>