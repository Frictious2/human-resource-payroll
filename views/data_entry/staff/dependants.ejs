<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> · HR & Payroll</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="/css/styles.css" rel="stylesheet" />
</head>
<body>
    <%- include('../partials/topbar', { user }) %>
    <%- include('../partials/sidebar') %>

    <main class="main">
        <div class="container-fluid">
            <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
                <h1 class="h2"><%= companyName %></h1>
                <button id="btnCheckOver18" class="btn btn-warning">
                    <i class="bi bi-hourglass-split"></i> Check Over 18
                </button>
            </div>

            <!-- Search Section -->
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="bi bi-search"></i> Search Staff</h5>
                </div>
                <div class="card-body">
                    <div class="row g-3 align-items-end">
                        <div class="col-md-4">
                            <label for="searchPFNo" class="form-label">Staff ID / PFNo</label>
                            <input type="text" class="form-control" id="searchPFNo" placeholder="Enter PFNo">
                        </div>
                        <div class="col-md-2">
                            <button type="button" class="btn btn-primary w-100" id="btnSearch">
                                <i class="bi bi-search"></i> Search
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Staff Details & Dependants Section -->
            <div id="staffSection" class="d-none">
                <div class="alert alert-info d-flex justify-content-between align-items-center">
                    <div>
                        <strong>Staff Name: </strong> <span id="staffName"></span> | 
                        <strong>PFNo: </strong> <span id="staffPFNo"></span>
                    </div>
                    <div>
                        <strong>Dependants: </strong> <span id="depCount">0</span> / <span id="maxDep">0</span>
                    </div>
                </div>

                <div class="card shadow-sm">
                    <div class="card-header bg-white d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">Dependants List</h5>
                        <button class="btn btn-success btn-sm" id="btnAddDep">
                            <i class="bi bi-plus-circle"></i> Add Dependant
                        </button>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-hover table-bordered" id="dependantsTable">
                                <thead class="table-light">
                                    <tr>
                                        <th>DepNo</th>
                                        <th>Dependant</th>
                                        <th>Relation</th>
                                        <th>Birthdate</th>
                                        <th>Phone</th>
                                        <th>Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <!-- Rows populated by JS -->
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <!-- Add/Edit Modal -->
    <div class="modal fade" id="depModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="modalTitle">Add Dependant</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <form id="depForm">
                        <input type="hidden" id="editDepNo">
                        <div class="mb-3">
                            <label for="dependantName" class="form-label">Dependant Name</label>
                            <input type="text" class="form-control" id="dependantName" required>
                        </div>
                        <div class="mb-3">
                            <label for="relation" class="form-label">Relation</label>
                            <select class="form-select" id="relation" required>
                                <option value="">Select Relation...</option>
                                <% relations.forEach(r => { %>
                                    <option value="<%= r.RCode %>"><%= r.Relation %></option>
                                <% }) %>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label for="dob" class="form-label">Birthdate</label>
                            <input type="date" class="form-control" id="dob" required>
                        </div>
                        <div class="mb-3">
                            <label for="phone" class="form-label">Phone</label>
                            <input type="text" class="form-control" id="phone">
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                    <button type="button" class="btn btn-primary" id="btnSaveDep">Save</button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        const btnSearch = document.getElementById('btnSearch');
        const searchPFNo = document.getElementById('searchPFNo');
        const staffSection = document.getElementById('staffSection');
        const staffNameSpan = document.getElementById('staffName');
        const staffPFNoSpan = document.getElementById('staffPFNo');
        const depCountSpan = document.getElementById('depCount');
        const maxDepSpan = document.getElementById('maxDep');
        const btnAddDep = document.getElementById('btnAddDep');
        const dependantsTableBody = document.querySelector('#dependantsTable tbody');
        
        const depModal = new bootstrap.Modal(document.getElementById('depModal'));
        const modalTitle = document.getElementById('modalTitle');
        const btnSaveDep = document.getElementById('btnSaveDep');
        const editDepNoInput = document.getElementById('editDepNo');
        const dependantNameInput = document.getElementById('dependantName');
        const relationInput = document.getElementById('relation');
        const dobInput = document.getElementById('dob');
        const phoneInput = document.getElementById('phone');

        let currentStaffPFNo = '';
        let currentMaxDependants = 0;
        let currentDependants = [];

        btnSearch.addEventListener('click', searchStaff);
        
        async function searchStaff() {
            const pfno = searchPFNo.value.trim();
            if (!pfno) {
                alert('Please enter a Staff ID / PFNo');
                return;
            }

            try {
                const res = await fetch(`/data-entry/api/staff/${pfno}/dependants`);
                if (!res.ok) {
                    if (res.status === 404) alert('Staff not found');
                    else alert('Error searching staff');
                    return;
                }

                const data = await res.json();
                currentStaffPFNo = data.staff.pfno;
                currentMaxDependants = data.maxDependants;
                currentDependants = data.dependants;

                staffNameSpan.textContent = data.staff.name;
                staffPFNoSpan.textContent = data.staff.pfno;
                maxDepSpan.textContent = currentMaxDependants;
                
                renderTable();
                staffSection.classList.remove('d-none');
            } catch (err) {
                console.error(err);
                alert('Error connecting to server');
            }
        }

        function renderTable() {
            dependantsTableBody.innerHTML = '';
            depCountSpan.textContent = currentDependants.length;
            
            // Check max dependants for Add button
            if (currentDependants.length >= currentMaxDependants) {
                btnAddDep.disabled = true;
                btnAddDep.title = 'Maximum dependants reached';
            } else {
                btnAddDep.disabled = false;
                btnAddDep.title = '';
            }

            currentDependants.forEach(dep => {
                const tr = document.createElement('tr');
                tr.innerHTML = `
                    <td>${dep.DepNo}</td>
                    <td>${dep.Dependant}</td>
                    <td>${dep.Relation || ''}</td>
                    <td>${dep.Birthdate || ''}</td>
                    <td>${dep.PhoneNo || ''}</td>
                    <td>
                        <button class="btn btn-sm btn-primary me-1" onclick="openEditModal('${dep.DepNo}')"><i class="bi bi-pencil"></i></button>
                    </td>
                `;
                dependantsTableBody.appendChild(tr);
            });
        }

        btnAddDep.addEventListener('click', () => {
            modalTitle.textContent = 'Add Dependant';
            editDepNoInput.value = '';
            dependantNameInput.value = '';
            relationInput.value = '';
            dobInput.value = '';
            phoneInput.value = '';
            depModal.show();
        });

        window.openEditModal = (depNo) => {
            const dep = currentDependants.find(d => d.DepNo == depNo);
            if (!dep) return;

            modalTitle.textContent = 'Edit Dependant';
            editDepNoInput.value = dep.DepNo;
            dependantNameInput.value = dep.Dependant;
            relationInput.value = dep.RCode;
            dobInput.value = dep.Birthdate;
            phoneInput.value = dep.PhoneNo;
            depModal.show();
        };

        btnSaveDep.addEventListener('click', async () => {
            const depNo = editDepNoInput.value;
            const payload = {
                pfno: currentStaffPFNo,
                dependant: dependantNameInput.value,
                rcode: relationInput.value,
                dob: dobInput.value,
                phone: phoneInput.value
            };

            if (!payload.dependant || !payload.rcode || !payload.dob) {
                alert('Please fill required fields');
                return;
            }

            const url = '/data-entry/api/staff/dependants';
            const method = depNo ? 'PUT' : 'POST';
            if (depNo) payload.depNo = depNo;

            try {
                const res = await fetch(url, {
                    method: method,
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });

                const result = await res.json();
                if (!res.ok) {
                    alert(result.error || 'Operation failed');
                    return;
                }

                depModal.hide();
                searchStaff(); // Refresh list
            } catch (err) {
                console.error(err);
                alert('Error saving data');
            }
        });

        document.getElementById('btnCheckOver18').addEventListener('click', async () => {
            if (!confirm('This will check for all dependants over 18 (Son/Daughter), send emails to staff, and close the records with reason OFF AGE. Continue?')) {
                return;
            }
            
            try {
                const btn = document.getElementById('btnCheckOver18');
                const originalText = btn.innerHTML;
                btn.innerHTML = '<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> Processing...';
                btn.disabled = true;

                const res = await fetch('/data-entry/api/staff/dependants/check-over-18', {
                    method: 'POST'
                });
                const data = await res.json();
                
                if (data.success) {
                    alert(data.message);
                    // Refresh current staff if selected
                    if (currentStaffPFNo) {
                        searchStaff();
                    }
                } else {
                    alert('Error: ' + (data.error || 'Unknown error'));
                }
                
                btn.innerHTML = originalText;
                btn.disabled = false;
            } catch (err) {
                console.error(err);
                alert('Failed to process request.');
                const btn = document.getElementById('btnCheckOver18');
                btn.disabled = false;
                btn.innerHTML = '<i class="bi bi-hourglass-split"></i> Check Over 18';
            }
        });
    </script>
</body>
</html>
