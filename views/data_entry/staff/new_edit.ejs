<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> · HR & Payroll</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="/css/styles.css" rel="stylesheet" />
    <style>
        .nav-tabs .nav-link.active {
            font-weight: bold;
            border-top: 3px solid #0d6efd;
        }
        .dependant-over-age {
            color: #dc3545;
            font-weight: 600;
        }
        body.staff-new-edit-page {
            overflow-y: auto !important;
        }
        body.staff-new-edit-page.modal-open {
            overflow-y: auto !important;
            padding-right: 0 !important;
        }
    </style>
</head>
<body class="staff-new-edit-page">
    <%- include('../partials/topbar', { user }) %>
    <%- include('../partials/sidebar') %>

    <main class="main">
        <div class="container-fluid">
            <div class="d-flex align-items-center justify-content-between mb-4">
                <div>
                    <h2 class="mb-0">Staff Information Management</h2>
                    <div class="text-muted">Create new staff or edit existing records</div>
                </div>
            </div>

            <% if (typeof success !== 'undefined' && success) { %>
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <%= success %>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            <% } %>

            <!-- Search Section -->
            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <div class="row g-3 align-items-end">
                        <div class="col-md-6">
                            <label for="searchStaff" class="form-label">Search Staff (PFNo or Name)</label>
                            <div class="input-group">
                                <input type="text" class="form-control" id="searchStaff" placeholder="Enter PFNo or Name...">
                                <button class="btn btn-primary" type="button" id="searchStaffButton" onclick="searchStaff({ manual: true })">
                                    <i class="bi bi-search"></i> Search
                                </button>
                            </div>
                            <div class="d-flex align-items-center gap-2 mt-2 small text-muted" id="searchStaffStatus" aria-live="polite"></div>
                        </div>
                        <div class="col-md-6">
                            <div class="text-muted small mt-2">
                                Search to edit an existing staff member. To create a new staff, simply fill out the form below.
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Main Form -->
            <div class="card shadow-sm">
                <div class="card-header bg-white">
                    <ul class="nav nav-tabs card-header-tabs" id="staffTabs" role="tablist">
                        <li class="nav-item" role="presentation">
                            <button class="nav-link active" id="personal-tab" data-bs-toggle="tab" data-bs-target="#personal" type="button" role="tab" aria-controls="personal" aria-selected="true">1. Personal Details</button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link" id="employment-tab" data-bs-toggle="tab" data-bs-target="#employment" type="button" role="tab" aria-controls="employment" aria-selected="false">2. Employment Details</button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link" id="nkin-tab" data-bs-toggle="tab" data-bs-target="#nkin" type="button" role="tab" aria-controls="nkin" aria-selected="false">3. Next of Kin</button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link" id="education-tab" data-bs-toggle="tab" data-bs-target="#education" type="button" role="tab" aria-controls="education" aria-selected="false">4. Education</button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link" id="dependants-tab" data-bs-toggle="tab" data-bs-target="#dependants" type="button" role="tab" aria-controls="dependants" aria-selected="false">5. Dependants</button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link" id="financial-tab" data-bs-toggle="tab" data-bs-target="#financial" type="button" role="tab" aria-controls="financial" aria-selected="false">6. Financial</button>
                        </li>
                    </ul>
                </div>
                <div class="card-body">
                    <form action="/data-entry/staff/new-edit" method="POST" id="staffForm" enctype="multipart/form-data">
                        <div class="tab-content" id="staffTabsContent">
                            
                            <!-- Section 1: Personal Details -->
                            <div class="tab-pane fade show active" id="personal" role="tabpanel" aria-labelledby="personal-tab">
                                <h5 class="card-title mb-3">Personal Information</h5>
                                <div class="row g-3">
                                    <div class="col-md-12">
                                        <label for="sname" class="form-label">Staff Name <span class="text-danger">*</span></label>
                                        <input type="text" class="form-control" id="sname" name="sname" required>
                                    </div>
                                    <div class="col-md-3">
                                        <label for="dob" class="form-label">Date of Birth</label>
                                        <input type="date" class="form-control" id="dob" name="dob" onchange="calculateStats()">
                                    </div>
                                    <div class="col-md-3">
                                        <label for="sex" class="form-label">Gender</label>
                                        <select class="form-select" id="sex" name="sex">
                                            <option value="">Select...</option>
                                            <% sex.forEach(s => { %>
                                                <option value="<%= s.SexCode %>"><%= s.Status %></option>
                                            <% }) %>
                                        </select>
                                    </div>
                                    <div class="col-md-3">
                                        <label for="mstatus" class="form-label">Marital Status</label>
                                        <select class="form-select" id="mstatus" name="mstatus">
                                            <option value="">Select...</option>
                                            <% mstatus.forEach(m => { %>
                                                <option value="<%= m.Code %>"><%= m.Status %></option>
                                            <% }) %>
                                        </select>
                                    </div>
                                    <div class="col-md-3">
                                        <label for="nation" class="form-label">Nationality</label>
                                        <select class="form-select" id="nation" name="nation">
                                            <option value="">Select...</option>
                                            <% nations.forEach(n => { %>
                                                <option value="<%= n.NationCode %>"><%= n.Nation %></option>
                                            <% }) %>
                                        </select>
                                    </div>
                                    <div class="col-md-12">
                                        <label for="address" class="form-label">Address</label>
                                        <input type="text" class="form-control" id="address" name="address">
                                    </div>
                                    <div class="col-md-4">
                                        <label for="city" class="form-label">City</label>
                                        <input type="text" class="form-control" id="city" name="city">
                                    </div>
                                    <div class="col-md-4">
                                        <label for="phone" class="form-label">Phone</label>
                                        <input type="text" class="form-control" id="phone" name="phone">
                                    </div>
                                    <div class="col-md-4">
                                        <label for="email" class="form-label">Email</label>
                                        <input type="email" class="form-control" id="email" name="email">
                                    </div>
                                    <div class="col-md-12">
                                        <label for="photo" class="form-label">Photo</label>
                                        <input type="file" class="form-control" id="photo" name="photo" accept="image/*">
                                        <div id="currentPhoto" class="mt-2" style="display:none;">
                                            <img src="" alt="Staff Photo" style="max-height: 100px; border: 1px solid #ddd; padding: 5px;">
                                        </div>
                                    </div>
                                </div>
                                <div class="mt-4 text-end">
                                    <button type="button" class="btn btn-primary" onclick="nextTab('employment-tab')">Next <i class="bi bi-arrow-right"></i></button>
                                </div>
                            </div>

                            <!-- Section 2: Employment Details -->
                            <div class="tab-pane fade" id="employment" role="tabpanel" aria-labelledby="employment-tab">
                                <h5 class="card-title mb-3">Employment Information</h5>
                                <div class="row g-3">
                                    <div class="col-md-3">
                                        <label for="pfno" class="form-label">Staff ID <span class="text-danger">*</span></label>
                                        <input type="text" class="form-control" id="pfno" name="pfno" required>
                                    </div>
                                    <div class="col-md-3">
                                        <label for="doe" class="form-label">Date Employed</label>
                                        <input type="date" class="form-control" id="doe" name="doe" onchange="calculateStats()">
                                    </div>
                                    <div class="col-md-3">
                                        <label for="dateConfirmed" class="form-label">Date Confirmed</label>
                                        <input type="date" class="form-control" id="dateConfirmed" name="dateConfirmed">
                                    </div>
                                    <div class="col-md-3">
                                        <label for="cGradeDate" class="form-label">Current Grade Date</label>
                                        <input type="date" class="form-control" id="cGradeDate" name="cGradeDate" onchange="calculateStats()">
                                    </div>
                                    <div class="col-md-3">
                                        <label for="cDeptDate" class="form-label">Current Dept Date</label>
                                        <input type="date" class="form-control" id="cDeptDate" name="cDeptDate" onchange="calculateStats()">
                                    </div>
                                    <div class="col-md-3">
                                        <label for="cGrade" class="form-label">Current Grade</label>
                                        <select class="form-select" id="cGrade" name="cGrade">
                                            <option value="">Select...</option>
                                            <% grades.forEach(g => { %>
                                                <option
                                                    value="<%= g.GradeCode %>"
                                                    data-notch-incr="<%= g.NotchIncr || 0 %>"
                                                    data-start-salary="<%= g.StartLevel || 0 %>"
                                                    data-end-salary="<%= g.EndLevel || 0 %>"
                                                    data-scale-notches="<%= g.ScaleNotches || 0 %>"
                                                    data-increment="<%= g.ScaleIncrement || 0 %>"
                                                ><%= g.Grade %></option>
                                            <% }) %>
                                        </select>
                                    </div>
                                    <div class="col-md-3">
                                        <label for="gradeEmployed" class="form-label">Grade Employed</label>
                                        <select class="form-select" id="gradeEmployed" name="gradeEmployed">
                                            <option value="">Select...</option>
                                            <% grades.forEach(g => { %>
                                                <option value="<%= g.GradeCode %>"><%= g.Grade %></option>
                                            <% }) %>
                                        </select>
                                    </div>
                                    <div class="col-md-3">
                                        <label for="dEmp" class="form-label">Department Employed</label>
                                        <select class="form-select" id="dEmp" name="dEmp">
                                            <option value="">Select...</option>
                                            <% depts.forEach(d => { %>
                                                <option value="<%= d.Code %>"><%= d.Dept %></option>
                                            <% }) %>
                                        </select>
                                    </div>
                                    <div class="col-md-3">
                                        <label for="empStatus" class="form-label">Employment Status</label>
                                        <select class="form-select" id="empStatus" name="empStatus">
                                            <option value="">Select...</option>
                                            <% empStatuses.forEach(s => { %>
                                                <option value="<%= s.Code %>"><%= s.EmpStatus %></option>
                                            <% }) %>
                                        </select>
                                    </div>
                                    <div class="col-md-3">
                                        <label for="dept" class="form-label">Current Department</label>
                                        <select class="form-select" id="dept" name="dept">
                                            <option value="">Select...</option>
                                            <% depts.forEach(d => { %>
                                                <option value="<%= d.Code %>"><%= d.Dept %></option>
                                            <% }) %>
                                        </select>
                                    </div>
                                    <div class="col-md-3">
                                        <label for="jobTitle" class="form-label">Job Title</label>
                                        <select class="form-select" id="jobTitle" name="jobTitle">
                                            <option value="">Select...</option>
                                            <% jobTitles.forEach(j => { %>
                                                <option value="<%= j.Code %>"><%= j.JobTitle %></option>
                                            <% }) %>
                                        </select>
                                    </div>
                                    <div class="col-md-3">
                                        <label for="empType" class="form-label">Employment Type</label>
                                        <select class="form-select" id="empType" name="empType">
                                            <option value="">Select...</option>
                                            <% empTypes.forEach(e => { %>
                                                <option value="<%= e.TypeCode %>"><%= e.TypeName %></option>
                                            <% }) %>
                                        </select>
                                    </div>
                                    <div class="col-md-3">
                                        <label for="notch" class="form-label">Notch</label>
                                        <input type="number" class="form-control" id="notch" name="notch">
                                    </div>
                                    <div class="col-md-3">
                                        <label class="form-label">Start Salary</label>
                                        <input type="text" class="form-control bg-light" id="calcStartSalary" readonly>
                                    </div>
                                    <div class="col-md-3">
                                        <label class="form-label">End Salary</label>
                                        <input type="text" class="form-control bg-light" id="calcEndSalary" readonly>
                                    </div>
                                    <div class="col-md-3">
                                        <label class="form-label">Basic Salary</label>
                                        <input type="text" class="form-control bg-light" id="calcBasicSalary" readonly>
                                    </div>
                                    <div class="col-md-3">
                                        <label class="form-label">Annual Salary</label>
                                        <input type="text" class="form-control bg-light" id="calcAnnualSalary" readonly>
                                    </div>
                                    <div class="col-md-3">
                                        <label class="form-label">Increment Per Notch</label>
                                        <input type="text" class="form-control bg-light" id="calcSalaryIncrement" readonly>
                                    </div>
                                    <div class="col-md-3">
                                        <label for="level" class="form-label">Level</label>
                                        <select class="form-select" id="level" name="level">
                                            <option value="">Select...</option>
                                            <% levels.forEach(l => { %>
                                                <option value="<%= l.LCode %>"><%= l.Level %></option>
                                            <% }) %>
                                        </select>
                                    </div>
                                    <div class="col-md-3 d-flex align-items-center mt-4">
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" id="unionMember" name="unionMember">
                                            <label class="form-check-label" for="unionMember">Union Member</label>
                                        </div>
                                    </div>
                                    <div class="col-md-3">
                                        <label for="hod" class="form-label">HOD</label>
                                        <select class="form-select" id="hod" name="hod" onchange="toggleHODDates()">
                                            <option value="N">No</option>
                                            <option value="Y">Yes</option>
                                        </select>
                                    </div>
                                    <div class="col-md-3">
                                        <label for="hodStartDate" class="form-label">HOD Start Date</label>
                                        <input type="date" class="form-control" id="hodStartDate" name="hodStartDate">
                                    </div>
                                    <div class="col-md-3">
                                        <label for="hodEndDate" class="form-label">HOD End Date</label>
                                        <input type="date" class="form-control" id="hodEndDate" name="hodEndDate">
                                    </div>
                                    <div class="col-md-3">
                                        <label for="vehicle" class="form-label">Vehicle</label>
                                        <select class="form-select" id="vehicle" name="vehicle" onchange="toggleVehicleDates()">
                                            <option value="">Select...</option>
                                            <% vehicles.forEach(v => { %>
                                                <option value="<%= v.VType %>"><%= v.VType %></option>
                                            <% }) %>
                                        </select>
                                    </div>
                                    <div class="col-md-3">
                                        <label for="vehicleStartDate" class="form-label">Vehicle Start Date</label>
                                        <input type="date" class="form-control" id="vehicleStartDate" name="vehicleStartDate">
                                    </div>
                                    <div class="col-md-3">
                                        <label for="vehicleEndDate" class="form-label">Vehicle End Date</label>
                                        <input type="date" class="form-control" id="vehicleEndDate" name="vehicleEndDate">
                                    </div>

                                    <!-- Readonly Calculated Values -->
                                    <div class="col-12 mt-4">
                                        <h6 class="text-muted border-bottom pb-2">In Years (Calculated)</h6>
                                    </div>
                                    <div class="col-md-2">
                                        <label class="form-label">Age</label>
                                        <input type="text" class="form-control bg-light" id="calcAge" readonly>
                                    </div>
                                    <div class="col-md-2">
                                        <label class="form-label">Served</label>
                                        <input type="text" class="form-control bg-light" id="calcServed" readonly>
                                    </div>
                                    <div class="col-md-2">
                                        <label class="form-label">To Retirement</label>
                                        <input type="text" class="form-control bg-light" id="calcRetire" readonly>
                                    </div>
                                    <div class="col-md-3">
                                        <label class="form-label">Department Tenure</label>
                                        <input type="text" class="form-control bg-light" id="calcDeptTenure" readonly>
                                    </div>
                                    <div class="col-md-3">
                                        <label class="form-label">Grade Tenure</label>
                                        <input type="text" class="form-control bg-light" id="calcGradeTenure" readonly>
                                    </div>
                                    <div class="col-md-3">
                                        <label class="form-label">Last Leave</label>
                                        <input type="text" class="form-control bg-light" id="lastLeave" readonly>
                                    </div>
                                    <div class="col-md-3">
                                        <label class="form-label">Retires (Year)</label>
                                        <input type="text" class="form-control bg-light" id="retiresYear" readonly>
                                    </div>
                                    <div class="col-md-3">
                                        <label class="form-label">Dependants (Count)</label>
                                        <input type="text" class="form-control bg-light" id="dependantsCount" readonly>
                                    </div>
                                </div>
                                <div class="mt-4 d-flex justify-content-between">
                                    <button type="button" class="btn btn-secondary" onclick="prevTab('personal-tab')"><i class="bi bi-arrow-left"></i> Previous</button>
                                    <button type="button" class="btn btn-primary" onclick="nextTab('nkin-tab')">Next <i class="bi bi-arrow-right"></i></button>
                                </div>
                            </div>

                            <!-- Section 3: Next of Kin -->
                            <div class="tab-pane fade" id="nkin" role="tabpanel" aria-labelledby="nkin-tab">
                                <h5 class="card-title mb-3">Next of Kin Details</h5>
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <label for="nkinName" class="form-label">Next of Kin Name</label>
                                        <input type="text" class="form-control" id="nkinName" name="nkin">
                                    </div>
                                    <div class="col-md-6">
                                        <label for="nkinRelationship" class="form-label">Relationship</label>
                                        <select class="form-select" id="nkinRelationship" name="nkinRelationship">
                                            <option value="">Select...</option>
                                            <% relations.forEach(r => { %>
                                                <option value="<%= r.RCode %>"><%= r.Relation %></option>
                                            <% }) %>
                                        </select>
                                    </div>
                                    <div class="col-md-6">
                                        <label for="nkinAddr" class="form-label">Address</label>
                                        <input type="text" class="form-control" id="nkinAddr" name="nkinAddr">
                                    </div>
                                    <div class="col-md-6">
                                        <label for="nkinPhone" class="form-label">Phone</label>
                                        <input type="text" class="form-control" id="nkinPhone" name="nkinPhone">
                                    </div>
                                </div>
                                <div class="mt-4 d-flex justify-content-between">
                                    <button type="button" class="btn btn-secondary" onclick="prevTab('employment-tab')"><i class="bi bi-arrow-left"></i> Previous</button>
                                    <button type="button" class="btn btn-primary" onclick="nextTab('education-tab')">Next <i class="bi bi-arrow-right"></i></button>
                                </div>
                            </div>

                            <!-- Section 4: Education -->
                            <div class="tab-pane fade" id="education" role="tabpanel" aria-labelledby="education-tab">
                                <h5 class="card-title mb-3">Education & Qualifications</h5>
                                
                                <div class="mb-3">
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" id="academic" name="academic" onchange="toggleAcademic()">
                                        <label class="form-check-label fw-bold" for="academic">Academic Qualification?</label>
                                    </div>
                                </div>

                                <div id="academicSection" style="display:none;">
                                    <div class="mb-3">
                                        <label class="form-label">Staff ID: <span id="displayPfno" class="fw-bold"></span></label>
                                    </div>
                                    
                                    <div class="table-responsive">
                                        <table class="table table-bordered" id="qualifTable">
                                            <thead class="table-light">
                                                <tr>
                                                    <th>Code</th>
                                                    <th>Qualification Name</th>
                                                    <th style="width: 100px;">Action</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <!-- Dynamic Rows -->
                                            </tbody>
                                        </table>
                                        <button type="button" class="btn btn-sm btn-primary" onclick="addQualifRow()">
                                            <i class="bi bi-plus"></i> Add Qualification
                                        </button>
                                    </div>
                                </div>

                                <div class="mt-4 d-flex justify-content-between">
                                    <button type="button" class="btn btn-secondary" onclick="prevTab('nkin-tab')"><i class="bi bi-arrow-left"></i> Previous</button>
                                    <button type="button" class="btn btn-primary" onclick="nextTab('financial-tab')">Next <i class="bi bi-arrow-right"></i></button>
                                </div>
                            </div>

                            <!-- Section 5: Financial -->
                            <div class="tab-pane fade" id="financial" role="tabpanel" aria-labelledby="financial-tab">
                                <h5 class="card-title mb-3">Financial Information</h5>
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <label for="accountNo" class="form-label">Bank Account Number</label>
                                        <input type="text" class="form-control" id="accountNo" name="accountNo">
                                    </div>
                                    <div class="col-md-6">
                                        <label for="nassitNo" class="form-label">NASSIT Number</label>
                                        <input type="text" class="form-control" id="nassitNo" name="nassitNo">
                                    </div>
                                    <div class="col-md-6">
                                        <label for="contractExp" class="form-label">Contract Exp</label>
                                        <input type="date" class="form-control" id="contractExp" name="contractExp">
                                    </div>
                                </div>
                                <div class="mt-4 d-flex justify-content-between">
                                    <button type="button" class="btn btn-secondary" onclick="prevTab('dependants-tab')"><i class="bi bi-arrow-left"></i> Previous</button>
                                    <button type="submit" class="btn btn-success"><i class="bi bi-save"></i> Save Record</button>
                                </div>
                            </div>
                            
                            <!-- Section 5: Dependants -->
                            <div class="tab-pane fade" id="dependants" role="tabpanel" aria-labelledby="dependants-tab">
                                <h5 class="card-title mb-3">Dependants</h5>
                                <div class="table-responsive">
                                    <table class="table table-bordered">
                                        <thead class="table-light">
                                            <tr>
                                                <th>Name</th>
                                                <th>Relationship</th>
                                                <th>Date of Birth</th>
                                            </tr>
                                        </thead>
                                        <tbody id="dependantsBody">
                                        </tbody>
                                    </table>
                                    <div class="text-muted small">Dependants above 18 are shown in red.</div>
                                </div>
                                <div class="mt-4 d-flex justify-content-between">
                                    <button type="button" class="btn btn-secondary" onclick="prevTab('education-tab')"><i class="bi bi-arrow-left"></i> Previous</button>
                                    <button type="button" class="btn btn-primary" onclick="nextTab('financial-tab')">Next <i class="bi bi-arrow-right"></i></button>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </main>

    <!-- Search Results Modal -->
    <div class="modal fade" id="searchModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Select Staff</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>PFNo</th>
                                    <th>Name</th>
                                    <th>Dept</th>
                                    <th>Job Title</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody id="searchResultsBody"></tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="notchLimitModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title">Notch Limit Reached</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p class="mb-0" id="notchLimitMessage">
                        The data-entry officer has gone beyond the total notch value for this grade for the staff and cannot be increased further.
                    </p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-danger" data-bs-dismiss="modal">Close</button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        let searchResults = [];
         const qualifTypes = <%- JSON.stringify(qualifTypes) %>;
         const retireAge = <%= retireAge %>;
         let lastNotchLimitMessage = '';
         let searchTimeout = null;
         let activeSearchController = null;

        function setSearchLoading(isLoading, message = '') {
            const searchButton = document.getElementById('searchStaffButton');
            const searchStatus = document.getElementById('searchStaffStatus');

            if (isLoading) {
                searchButton.disabled = true;
                searchStatus.innerHTML = '<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span><span>Searching staff records...</span>';
                return;
            }

            searchButton.disabled = false;
            searchStatus.textContent = message;
        }

        function formatMoney(value) {
            const numericValue = Number(value);
            if (!Number.isFinite(numericValue)) {
                return '';
            }

            return numericValue.toLocaleString(undefined, {
                minimumFractionDigits: 2,
                maximumFractionDigits: 2
            });
        }

        function getSelectedGradeScale() {
            const gradeSelect = document.getElementById('cGrade');
            const selectedOption = gradeSelect.options[gradeSelect.selectedIndex];

            if (!selectedOption || !selectedOption.value) {
                return {
                    maxNotch: null,
                    startSalary: 0,
                    endSalary: 0,
                    scaleNotches: 0,
                    increment: 0
                };
            }

            const maxNotch = Number(selectedOption.dataset.notchIncr);
            const startSalary = Number(selectedOption.dataset.startSalary);
            const endSalary = Number(selectedOption.dataset.endSalary);
            const scaleNotches = Number(selectedOption.dataset.scaleNotches);
            let increment = Number(selectedOption.dataset.increment);

            const safeMaxNotch = Number.isFinite(maxNotch) ? maxNotch : 0;
            const safeScaleNotches = Number.isFinite(scaleNotches) && scaleNotches > 0 ? scaleNotches : safeMaxNotch;
            const safeStartSalary = Number.isFinite(startSalary) ? startSalary : 0;
            const safeEndSalary = Number.isFinite(endSalary) ? endSalary : 0;

            if ((!Number.isFinite(increment) || increment === 0) && safeScaleNotches > 0) {
                increment = (safeEndSalary - safeStartSalary) / safeScaleNotches;
            }

            return {
                maxNotch: Number.isFinite(maxNotch) ? maxNotch : null,
                startSalary: safeStartSalary,
                endSalary: safeEndSalary,
                scaleNotches: safeScaleNotches,
                increment: Number.isFinite(increment) ? increment : 0
            };
        }

        function updateSalaryPreview() {
            const notchInput = document.getElementById('notch');
            const {
                maxNotch,
                startSalary,
                endSalary,
                increment
            } = getSelectedGradeScale();
            const enteredNotch = Math.max(Number(notchInput.value) || 0, 0);
            const appliedNotch = maxNotch === null ? enteredNotch : Math.min(enteredNotch, maxNotch);
            const annualSalary = startSalary + (appliedNotch * increment);
            const basicSalary = annualSalary / 12;

            document.getElementById('calcStartSalary').value = formatMoney(startSalary);
            document.getElementById('calcEndSalary').value = formatMoney(endSalary);
            document.getElementById('calcSalaryIncrement').value = formatMoney(increment);
            document.getElementById('calcAnnualSalary').value = formatMoney(annualSalary);
            document.getElementById('calcBasicSalary').value = formatMoney(basicSalary);
        }

        function showNotchLimitModal(message) {
            if (lastNotchLimitMessage === message) {
                return;
            }

            lastNotchLimitMessage = message;
            document.getElementById('notchLimitMessage').textContent = message;
            const modal = new bootstrap.Modal(document.getElementById('notchLimitModal'));
            modal.show();
        }

        function closeSearchModal() {
            const modalEl = document.getElementById('searchModal');
            const modal = bootstrap.Modal.getInstance(modalEl);

            if (modal) {
                modal.hide();
            }

            document.body.classList.remove('modal-open');
            document.body.style.removeProperty('padding-right');
            document.body.style.removeProperty('overflow');
            document.querySelectorAll('.modal-backdrop').forEach(backdrop => backdrop.remove());
        }

        function restorePageScroll() {
            document.body.classList.remove('modal-open');
            document.body.style.removeProperty('padding-right');
            document.body.style.removeProperty('overflow');
            document.documentElement.style.removeProperty('overflow');
            document.querySelectorAll('.modal-backdrop').forEach(backdrop => backdrop.remove());
        }

        function validateNotchLimit() {
            const notchInput = document.getElementById('notch');
            const { maxNotch } = getSelectedGradeScale();
            const notchValue = Number(notchInput.value);

            if (!notchInput.value || !Number.isFinite(notchValue) || maxNotch === null) {
                notchInput.setCustomValidity('');
                lastNotchLimitMessage = '';
                updateSalaryPreview();
                return true;
            }

            if (notchValue > maxNotch) {
                const message = `The data-entry officer has gone beyond the total notch value for this grade for the staff. The notch cannot be increased beyond ${maxNotch}.`;
                notchInput.value = maxNotch;
                notchInput.setCustomValidity(message);
                updateSalaryPreview();
                showNotchLimitModal(message);
                notchInput.reportValidity();
                notchInput.focus();
                return false;
            }

            notchInput.setCustomValidity('');
            lastNotchLimitMessage = '';
            updateSalaryPreview();
            return true;
        }

        function nextTab(tabId) {
            const tab = new bootstrap.Tab(document.getElementById(tabId));
            tab.show();
        }

        function prevTab(tabId) {
            const tab = new bootstrap.Tab(document.getElementById(tabId));
            tab.show();
        }

        async function searchStaff(options = {}) {
            const { manual = false } = options;
            const query = document.getElementById('searchStaff').value.trim();
            if (!query) {
                setSearchLoading(false, '');
                if (manual) {
                    alert('Enter a PF number or staff name to search.');
                }
                return;
            }

            try {
                if (activeSearchController) {
                    activeSearchController.abort();
                }

                activeSearchController = new AbortController();
                setSearchLoading(true);

                const response = await fetch(`/data-entry/staff/new-edit/search?q=${encodeURIComponent(query)}`, {
                    signal: activeSearchController.signal
                });
                const data = await response.json();

                if (!response.ok) {
                    throw new Error(data.error || 'Search failed');
                }

                searchResults = data;

                if (data.length === 0) {
                    setSearchLoading(false, 'No staff found.');
                    alert('No staff found.');
                } else if (data.length === 1) {
                    setSearchLoading(false, '1 staff record found.');
                    populateForm(0);
                    setSearchLoading(false, 'Staff details loaded.');
                } else {
                    setSearchLoading(false, `${data.length} staff records found.`);
                    // Show modal
                    const tbody = document.getElementById('searchResultsBody');
                    tbody.innerHTML = '';
                    data.forEach((staff, index) => {
                        tbody.innerHTML += `
                            <tr>
                                <td>${staff.PFNo}</td>
                                <td>${staff.SName}</td>
                                <td>${staff.CDeptName || staff.CDept || '-'}</td>
                                <td>${staff.JobTitleName || staff.JobTitle || '-'}</td>
                                <td>
                                    <button type="button" class="btn btn-sm btn-primary" onclick="selectStaff(${index})">
                                        Select
                                    </button>
                                </td>
                            </tr>
                        `;
                    });
                    const modal = new bootstrap.Modal(document.getElementById('searchModal'));
                    modal.show();
                }
            } catch (err) {
                if (err.name === 'AbortError') {
                    return;
                }

                console.error(err);
                setSearchLoading(false, '');
                alert(err.message || 'Error searching staff.');
            } finally {
                activeSearchController = null;
            }
        }

        function selectStaff(index) {
            closeSearchModal();
            populateForm(index);
            setSearchLoading(false, 'Staff details loaded.');
        }

        function populateForm(index) {
            const staff = searchResults[index];
            if (!staff) return;

            // Personal
            document.getElementById('sname').value = staff.SName || '';
            if (staff.DOB) document.getElementById('dob').value = staff.DOB.split('T')[0];
            document.getElementById('sex').value = staff.SexCode || '';
            document.getElementById('mstatus').value = staff.MStatus || '';
            document.getElementById('nation').value = staff.NationCode || '';
            document.getElementById('address').value = staff.Address || '';
            document.getElementById('city').value = staff.City || '';
            document.getElementById('phone').value = staff.Phone || '';
            document.getElementById('email').value = staff.Email || '';
            
            // Photo
            if (staff.PhotoPath) {
                const img = document.querySelector('#currentPhoto img');
                img.src = staff.PhotoPath;
                document.getElementById('currentPhoto').style.display = 'block';
            } else {
                document.getElementById('currentPhoto').style.display = 'none';
            }

            // Employment
            document.getElementById('pfno').value = staff.PFNo || '';
            if (staff.DOE) document.getElementById('doe').value = staff.DOE.split('T')[0];
            if (staff.DateConfirmed) document.getElementById('dateConfirmed').value = staff.DateConfirmed.split('T')[0];
            document.getElementById('jobTitle').value = staff.JobTitle || '';
            document.getElementById('cGrade').value = staff.CGrade || '';
            document.getElementById('gradeEmployed').value = staff.GradeCode || '';
            document.getElementById('dept').value = staff.CDept || '';
            document.getElementById('empType').value = staff.EmpType || '';
            document.getElementById('empStatus').value = staff.EmpStatus || '';
            
            if (staff.CGradeDate) document.getElementById('cGradeDate').value = staff.CGradeDate.split('T')[0];
            if (staff.CDeptDate) document.getElementById('cDeptDate').value = staff.CDeptDate.split('T')[0];
            document.getElementById('dEmp').value = staff.DEmp || '';
            document.getElementById('notch').value = staff.Notch || '';
            validateNotchLimit();
            document.getElementById('level').value = staff.Level || '';
            document.getElementById('unionMember').checked = staff.UnionMember === 'Y';
            document.getElementById('hod').value = staff.HOD === 'Y' ? 'Y' : 'N';
            document.getElementById('hodStartDate').value = staff.HOD_SDate ? staff.HOD_SDate.split('T')[0] : '';
            document.getElementById('hodEndDate').value = staff.HOD_EDate ? staff.HOD_EDate.split('T')[0] : '';
            document.getElementById('vehicle').value = staff.Vehicle || '';
            document.getElementById('vehicleStartDate').value = staff.CarSDate ? staff.CarSDate.split('T')[0] : '';
            document.getElementById('vehicleEndDate').value = staff.CarEDate ? staff.CarEDate.split('T')[0] : '';
            
            calculateStats();
            fetchLastLeave(staff.PFNo);
            fetchDependants(staff.PFNo);

            // Next of Kin
            document.getElementById('nkinName').value = staff.NKin || '';
            document.getElementById('nkinRelationship').value = staff.NKinRelationship || '';
            document.getElementById('nkinAddr').value = staff.NKinAddr || '';
            document.getElementById('nkinPhone').value = staff.NKinPhone || '';

            // Education
            document.getElementById('academic').checked = staff.Academic === 'Y';
            toggleAcademic();
            
            // Clear existing rows
            document.querySelector('#qualifTable tbody').innerHTML = '';

            if (staff.Academic === 'Y') {
                 fetchQualifications(staff.PFNo);
            }

            // Financial
            document.getElementById('accountNo').value = staff.AccountNo || '';
            document.getElementById('nassitNo').value = staff.NASSITNo || '';
            
            // Hide modal if open
            closeSearchModal();
        }
        
        function calculateStats() {
            const dob = document.getElementById('dob').value;
            const doe = document.getElementById('doe').value;
            const cGradeDate = document.getElementById('cGradeDate').value;
            const cDeptDate = document.getElementById('cDeptDate').value;
            const now = new Date();

            // Age & Retirement
            if (dob) {
                const birthDate = new Date(dob);
                let age = now.getFullYear() - birthDate.getFullYear();
                const m = now.getMonth() - birthDate.getMonth();
                if (m < 0 || (m === 0 && now.getDate() < birthDate.getDate())) {
                    age--;
                }
                document.getElementById('calcAge').value = age;
                
                const remaining = retireAge - age;
                document.getElementById('calcRetire').value = remaining > 0 ? remaining : 0;
            } else {
                document.getElementById('calcAge').value = '';
                document.getElementById('calcRetire').value = '';
            }

            // Served
            if (doe) {
                const empDate = new Date(doe);
                let served = now.getFullYear() - empDate.getFullYear();
                const m = now.getMonth() - empDate.getMonth();
                if (m < 0 || (m === 0 && now.getDate() < empDate.getDate())) {
                    served--;
                }
                document.getElementById('calcServed').value = served;
            } else {
                document.getElementById('calcServed').value = '';
            }

            // Grade Tenure
            if (cGradeDate) {
                 const gDate = new Date(cGradeDate);
                let tenure = now.getFullYear() - gDate.getFullYear();
                const m = now.getMonth() - gDate.getMonth();
                if (m < 0 || (m === 0 && now.getDate() < gDate.getDate())) {
                    tenure--;
                }
                document.getElementById('calcGradeTenure').value = tenure;
            } else {
                document.getElementById('calcGradeTenure').value = '';
            }

             // Dept Tenure
              if (cDeptDate) {
                  const dDate = new Date(cDeptDate);
                 let tenure = now.getFullYear() - dDate.getFullYear();
                 const m = now.getMonth() - dDate.getMonth();
                 if (m < 0 || (m === 0 && now.getDate() < dDate.getDate())) {
                     tenure--;
                 }
                 document.getElementById('calcDeptTenure').value = tenure;
             } else {
                 document.getElementById('calcDeptTenure').value = '';
             }
 
             // Retires Year (DOB + retireAge)
             if (dob) {
                 const birthDate = new Date(dob);
                 const retiresYear = birthDate.getFullYear() + retireAge;
                 document.getElementById('retiresYear').value = retiresYear;
             } else {
                 document.getElementById('retiresYear').value = '';
             }
         }

         function toggleAcademic() {
             const isChecked = document.getElementById('academic').checked;
             const section = document.getElementById('academicSection');
             const pfno = document.getElementById('pfno').value;
             
             section.style.display = isChecked ? 'block' : 'none';
             document.getElementById('displayPfno').textContent = pfno;
         }
 
         function toggleHODDates() {
             const hod = document.getElementById('hod').value;
             const sDate = document.getElementById('hodStartDate');
             const eDate = document.getElementById('hodEndDate');
             if (hod === 'Y') {
                 sDate.setAttribute('required', 'required');
             } else {
                 sDate.removeAttribute('required');
             }
         }
 
         function toggleVehicleDates() {
             const vehicle = document.getElementById('vehicle').value;
             const sDate = document.getElementById('vehicleStartDate');
             const eDate = document.getElementById('vehicleEndDate');
             if (vehicle && vehicle !== 'NO') {
                 sDate.setAttribute('required', 'required');
             } else {
                 sDate.removeAttribute('required');
             }
         }

        function addQualifRow(code = '', name = '') {
            const tbody = document.querySelector('#qualifTable tbody');
            const tr = document.createElement('tr');
            
            let options = '<option value="">Select...</option>';
            qualifTypes.forEach(q => {
                options += `<option value="${q.Code}" ${q.Code == code ? 'selected' : ''}>${q.QType}</option>`;
            });

            tr.innerHTML = `
                <td>
                    <select class="form-select" name="qualifCode" required>
                        ${options}
                    </select>
                </td>
                <td>
                    <input type="text" class="form-control" name="qualifName" value="${name}" required>
                </td>
                <td>
                    <button type="button" class="btn btn-sm btn-danger" onclick="this.closest('tr').remove()">
                        <i class="bi bi-trash"></i>
                    </button>
                </td>
            `;
            tbody.appendChild(tr);
        }

         async function fetchQualifications(pfno) {
             try {
                 const response = await fetch(`/data-entry/api/staff/${pfno}/qualifications`);
                 const data = await response.json();
                 
                 const tbody = document.querySelector('#qualifTable tbody');
                 tbody.innerHTML = '';
                 
                 if (data.length > 0) {
                     data.forEach(q => {
                         addQualifRow(q.Code, q.QName);
                     });
                 } else {
                     addQualifRow(); // Add empty row if none
                 }
             } catch (error) {
                 console.error('Error fetching qualifications:', error);
             }
         }
 
         async function fetchLastLeave(pfno) {
             try {
                 const resp = await fetch(`/data-entry/api/staff/${pfno}/last-leave`);
                 const data = await resp.json();
                 document.getElementById('lastLeave').value = data.lastLeave || '';
             } catch (e) {
                 console.error('Error fetching last leave:', e);
             }
         }
 
         async function fetchDependants(pfno) {
             try {
                 const resp = await fetch(`/data-entry/api/staff/${pfno}/dependants`);
                 const data = await resp.json();
                 const tbody = document.getElementById('dependantsBody');
                 tbody.innerHTML = '';
                 const list = data.dependants || [];
                 let count = 0;
                 list.forEach(d => {
                     let isOver18 = false;
                     if (d.Birthdate) {
                         const dob = new Date(d.Birthdate);
                         const now = new Date();
                         let age = now.getFullYear() - dob.getFullYear();
                         const m = now.getMonth() - dob.getMonth();
                         if (m < 0 || (m === 0 && now.getDate() < dob.getDate())) {
                             age--;
                         }
                         isOver18 = age > 18;
                     }
                     tbody.innerHTML += `
                         <tr class="${isOver18 ? 'dependant-over-age' : ''}">
                             <td>${d.Dependant}</td>
                             <td>${d.Relation}</td>
                             <td>${d.Birthdate || ''}</td>
                         </tr>
                     `;
                 });
                 // Count of active dependants (Closed=0 in API already)
                 count = list.length;
                 document.getElementById('dependantsCount').value = count;
             } catch (e) {
                 console.error('Error fetching dependants:', e);
             }
         }
        
         // Update PFNo display in education tab when typing
         document.getElementById('pfno').addEventListener('input', function() {
             document.getElementById('displayPfno').textContent = this.value;
             const pfno = this.value;
             if (pfno && pfno.length > 0) {
                 fetchLastLeave(pfno);
                 fetchDependants(pfno);
             }
         });

         document.getElementById('searchStaff').addEventListener('keydown', function(event) {
             if (event.key === 'Enter') {
                 event.preventDefault();
                 if (searchTimeout) {
                     clearTimeout(searchTimeout);
                     searchTimeout = null;
                 }
                 searchStaff({ manual: true });
             }
         });

         document.getElementById('searchStaff').addEventListener('input', function() {
             const query = this.value.trim();

             if (searchTimeout) {
                 clearTimeout(searchTimeout);
             }

             if (!query) {
                 if (activeSearchController) {
                     activeSearchController.abort();
                 }
                 setSearchLoading(false, '');
                 return;
             }

             setSearchLoading(false, 'Waiting for you to finish typing...');
             searchTimeout = setTimeout(() => {
                 searchStaff();
             }, 450);
         });

         document.getElementById('cGrade').addEventListener('change', validateNotchLimit);
         document.getElementById('notch').addEventListener('input', validateNotchLimit);
         document.getElementById('notch').addEventListener('change', validateNotchLimit);
         document.getElementById('staffForm').addEventListener('submit', function(event) {
             if (!validateNotchLimit()) {
                 event.preventDefault();
             }
         });
         updateSalaryPreview();
         document.getElementById('searchModal').addEventListener('hidden.bs.modal', restorePageScroll);
         window.addEventListener('pageshow', restorePageScroll);
         document.addEventListener('DOMContentLoaded', restorePageScroll);
    </script>
</body>
</html>
