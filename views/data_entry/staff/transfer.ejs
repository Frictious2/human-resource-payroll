<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> · HR & Payroll</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="/css/styles.css" rel="stylesheet" />
</head>
<body>
    <%- include('../partials/topbar', { user }) %>
    <%- include('../partials/sidebar') %>

    <main class="main">
        <div class="container-fluid">
            <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
                <h1 class="h2"><%= companyName %></h1>
            </div>

            <div class="card shadow-sm mb-4">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="bi bi-search"></i> Search Staff for Transfer</h5>
                </div>
                <div class="card-body">
                    <div class="row g-3 align-items-end">
                        <div class="col-md-4">
                            <label for="searchPFNo" class="form-label">Staff ID / PFNo</label>
                            <input type="text" class="form-control" id="searchPFNo" placeholder="Enter PFNo">
                        </div>
                        <div class="col-md-2">
                            <button type="button" class="btn btn-primary w-100" id="btnSearch">
                                <i class="bi bi-search"></i> Search
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <div id="transferFormSection" class="card shadow-sm mb-4 d-none">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0"><i class="bi bi-arrow-left-right"></i> Transfer Details</h5>
                </div>
                <div class="card-body">
                    <form id="transferForm">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label for="pfno" class="form-label">Staff ID</label>
                                <input type="text" class="form-control" id="pfno" name="pfno" readonly>
                            </div>
                            <div class="col-md-6">
                                <label for="sname" class="form-label">Staff Name</label>
                                <input type="text" class="form-control" id="sname" name="sname" readonly>
                            </div>
                            <div class="col-md-6">
                                <label for="currentDept" class="form-label">Current Department</label>
                                <input type="text" class="form-control" id="currentDept" readonly>
                            </div>
                            <div class="col-md-6">
                                <label for="currentDeptDate" class="form-label">Date of Current Department Assignment</label>
                                <input type="text" class="form-control" id="currentDeptDate" readonly>
                            </div>
                            
                            <hr class="my-4">
                            <h5 class="mb-3">New Assignment Details</h5>

                            <div class="col-md-6">
                                <label for="transferDate" class="form-label">New Transfer Date</label>
                                <input type="date" class="form-control" id="transferDate" name="transferDate" required>
                            </div>
                            <div class="col-md-6">
                                <label for="newDeptCode" class="form-label">Transfer To (New Department)</label>
                                <select class="form-select" id="newDeptCode" name="newDeptCode" required>
                                    <option value="">Select Department...</option>
                                    <% departments.forEach(dept => { %>
                                        <option value="<%= dept.Code %>"><%= dept.Dept %></option>
                                    <% }); %>
                                </select>
                            </div>

                            <div class="col-12 mt-4">
                                <button type="submit" class="btn btn-success">
                                    <i class="bi bi-save"></i> Submit Transfer Request
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>

        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        const btnSearch = document.getElementById('btnSearch');
        const searchPFNo = document.getElementById('searchPFNo');
        const transferFormSection = document.getElementById('transferFormSection');
        const transferForm = document.getElementById('transferForm');

        // Set default date to today
        document.getElementById('transferDate').valueAsDate = new Date();

        btnSearch.addEventListener('click', async () => {
            const pfno = searchPFNo.value.trim();
            if (!pfno) {
                alert('Please enter a Staff ID / PFNo');
                return;
            }

            try {
                const res = await fetch(`/data-entry/api/staff/transfer/search?pfno=${pfno}`);
                const data = await res.json();

                if (res.ok) {
                    document.getElementById('pfno').value = data.PFNo;
                    document.getElementById('sname').value = data.SName;
                    document.getElementById('currentDept').value = data.DeptName || 'N/A';
                    
                    // Format date
                    const cDeptDate = data.CDeptDate ? new Date(data.CDeptDate).toISOString().split('T')[0] : 'N/A';
                    document.getElementById('currentDeptDate').value = cDeptDate;

                    transferFormSection.classList.remove('d-none');
                } else {
                    alert(data.error || 'Staff not found');
                    transferFormSection.classList.add('d-none');
                }
            } catch (error) {
                console.error(error);
                alert('Error searching for staff');
            }
        });

        transferForm.addEventListener('submit', async (e) => {
            e.preventDefault();

            if (!confirm('Are you sure you want to submit this transfer request?')) {
                return;
            }

            const formData = {
                pfno: document.getElementById('pfno').value,
                newDeptCode: document.getElementById('newDeptCode').value,
                transferDate: document.getElementById('transferDate').value
            };

            try {
                const res = await fetch('/data-entry/staff/transfer', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(formData)
                });
                const result = await res.json();

                if (res.ok) {
                    alert('Transfer request submitted successfully!');
                    // Reset and hide
                    searchPFNo.value = '';
                    transferFormSection.classList.add('d-none');
                    transferForm.reset();
                } else {
                    alert(result.error || 'Failed to submit transfer');
                }
            } catch (error) {
                console.error(error);
                alert('Server error');
            }
        });
    </script>
</body>
</html>