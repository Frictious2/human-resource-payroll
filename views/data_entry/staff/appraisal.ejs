<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> · HR & Payroll</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <!-- Summernote CSS -->
    <link href="https://cdn.jsdelivr.net/npm/summernote@0.8.18/dist/summernote-lite.min.css" rel="stylesheet">
    <link href="/css/styles.css" rel="stylesheet" />
</head>
<body>
    <%- include('../partials/topbar', { user }) %>
    <%- include('../partials/sidebar') %>

    <main class="main">
        <div class="container-fluid">
            <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
                <h1 class="h2"><%= companyName %></h1>
                <div class="btn-toolbar mb-2 mb-md-0">
                    <button type="button" class="btn btn-primary" id="btnAppraise">
                        <i class="bi bi-plus-circle"></i> Appraise Staff
                    </button>
                </div>
            </div>

            <div class="card shadow-sm mb-4">
                <div class="card-header bg-white">
                    <h5 class="mb-0">Pending Appraisals (Unapproved)</h5>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-hover table-bordered">
                            <thead class="table-light">
                                <tr>
                                    <th>Appraisal No</th>
                                    <th>PFNo</th>
                                    <th>Name</th>
                                    <th>Start Date</th>
                                    <th>End Date</th>
                                    <th>Manager</th>
                                    <th>Post Date</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (appraisals.length === 0) { %>
                                    <tr><td colspan="8" class="text-center">No pending appraisals found.</td></tr>
                                <% } else { %>
                                    <% appraisals.forEach(a => { %>
                                        <tr>
                                            <td><%= a.AppraisalNo %></td>
                                            <td><%= a.PFNo %></td>
                                            <td><%= a.SName %></td>
                                            <td><%= a.StartDate ? new Date(a.StartDate).toLocaleDateString() : '' %></td>
                                            <td><%= a.EndDate ? new Date(a.EndDate).toLocaleDateString() : '' %></td>
                                            <td><%= a.Manager %></td>
                                            <td><%= a.PostDate ? new Date(a.PostDate).toLocaleDateString() : '' %></td>
                                            <td>
                                                <button class="btn btn-sm btn-primary btn-edit" 
                                                    data-id="<%= a.AppraisalNo %>"
                                                    data-pfno="<%= a.PFNo %>"
                                                    data-manager="<%= a.Manager %>"
                                                    data-startdate="<%= a.StartDate %>"
                                                    data-enddate="<%= a.EndDate %>"
                                                    data-punc="<%= a.Punc %>"
                                                    data-perf="<%= a.Perf %>"
                                                    data-com="<%= a.Com %>"
                                                    data-lead="<%= a.Lead %>"
                                                    data-team="<%= a.Team %>"
                                                    data-rela="<%= a.Rela %>"
                                                    data-attd="<%= a.Attd %>"
                                                    data-output="<%= a.Output %>"
                                                    data-managercomments="<%= a.Manager_Comments %>"
                                                    data-postdate="<%= a.PostDate %>"
                                                    data-staffcomments="<%= a.Staff_Comments %>"
                                                    data-staffdate="<%= a.StaffDate %>"
                                                    data-staffoption="<%= a.StaffOption %>"
                                                    data-committeecomments="<%= a.Committee_Comments %>"
                                                    data-committeedate="<%= a.CommitteeDate %>"
                                                >
                                                    <i class="bi bi-pencil"></i> Edit
                                                </button>
                                            </td>
                                        </tr>
                                    <% }) %>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                    
                    <!-- Pagination -->
                    <% if (pagination.totalPages > 1) { %>
                        <nav aria-label="Page navigation">
                            <ul class="pagination justify-content-center">
                                <% for(let i = 1; i <= pagination.totalPages; i++) { %>
                                    <li class="page-item <%= pagination.page === i ? 'active' : '' %>">
                                        <a class="page-link" href="?page=<%= i %>"><%= i %></a>
                                    </li>
                                <% } %>
                            </ul>
                        </nav>
                    <% } %>
                </div>
            </div>
        </div>
    </main>

    <!-- Appraise Modal -->
    <div class="modal fade" id="appraiseModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-xl">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="modalTitle">Appraise Staff</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <form id="appraisalForm">
                        <input type="hidden" id="appraisalNo" name="appraisalNo">
                        
                        <!-- Staff Details Section -->
                        <h6 class="border-bottom pb-2 mb-3">Staff Details</h6>
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label for="pfno" class="form-label">Staff Name</label>
                                <select class="form-select" id="pfno" name="pfno" required>
                                    <option value="">Select Staff</option>
                                    <% staffList.forEach(s => { %>
                                        <option value="<%= s.PFNo %>"><%= s.PFNo %> - <%= s.SName %></option>
                                    <% }) %>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label for="jobTitle" class="form-label">Job Title</label>
                                <input type="text" class="form-control" id="jobTitle" readonly>
                            </div>
                        </div>
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label for="department" class="form-label">Department</label>
                                <input type="text" class="form-control" id="department" readonly>
                            </div>
                            <div class="col-md-6">
                                <label for="hireDate" class="form-label">Hire Date</label>
                                <input type="text" class="form-control" id="hireDate" readonly>
                            </div>
                        </div>
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label for="manager" class="form-label">Manager</label>
                                <select class="form-select" id="manager" name="manager" required>
                                    <option value="">Select Manager</option>
                                    <% staffList.forEach(s => { %>
                                        <option value="<%= s.PFNo %>"><%= s.PFNo %> - <%= s.SName %></option>
                                    <% }) %>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label for="lastReview" class="form-label">Last Review Date</label>
                                <input type="text" class="form-control" id="lastReview" readonly>
                            </div>
                        </div>
                        <div class="row mb-3">
                             <div class="col-md-6">
                                <label for="startDate" class="form-label">Appraisal Start Date</label>
                                <input type="datetime-local" class="form-control" id="startDate" name="startDate" required>
                            </div>
                            <div class="col-md-6">
                                <label for="endDate" class="form-label">Appraisal End Date</label>
                                <input type="datetime-local" class="form-control" id="endDate" name="endDate" required>
                            </div>
                        </div>

                        <!-- Assessment Section -->
                        <h6 class="border-bottom pb-2 mb-3 mt-4">Assessment</h6>
                        <div class="row mb-3">
                            <% const assessmentFields = [
                                { id: 'punc', label: 'Punctuality' },
                                { id: 'perf', label: 'Performance' },
                                { id: 'com', label: 'Communication Skills' },
                                { id: 'lead', label: 'Leadership' },
                                { id: 'team', label: 'Team Work' },
                                { id: 'rela', label: 'Relationship' },
                                { id: 'attd', label: 'Attitude' },
                                { id: 'output', label: 'Output' }
                            ]; %>
                            <% assessmentFields.forEach(field => { %>
                                <div class="col-md-3 mb-3">
                                    <label for="<%= field.id %>" class="form-label"><%= field.label %></label>
                                    <select class="form-select" id="<%= field.id %>" name="<%= field.id %>">
                                        <option value="">Select...</option>
                                        <% assessments.forEach(a => { %>
                                            <option value="<%= a.Code %>"><%= a.Assessment %></option>
                                        <% }) %>
                                    </select>
                                </div>
                            <% }) %>
                        </div>

                        <!-- Manager Comments -->
                        <div class="mb-3">
                            <label for="managerComments" class="form-label">Manager's Comments</label>
                            <textarea id="managerComments" name="managerComments"></textarea>
                        </div>
                        <div class="mb-3">
                            <label for="postDate" class="form-label">Date (Manager)</label>
                            <input type="datetime-local" class="form-control w-auto" id="postDate" name="postDate">
                        </div>

                        <!-- Staff Comments -->
                        <div class="mb-3">
                            <label for="staffComments" class="form-label">Staff's Comments</label>
                            <textarea id="staffComments" name="staffComments"></textarea>
                        </div>
                        <div class="mb-3">
                            <label for="staffDate" class="form-label">Date (Staff)</label>
                            <input type="datetime-local" class="form-control w-auto" id="staffDate" name="staffDate">
                        </div>
                        
                        <!-- Staff Option -->
                        <div class="mb-3">
                            <label class="form-label">Staff Confirmation</label>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="staffOption" id="staffOption1" value="1">
                                <label class="form-check-label" for="staffOption1">
                                    Performance Discussed with my Supervisor. My comments are above.
                                </label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="staffOption" id="staffOption2" value="2">
                                <label class="form-check-label" for="staffOption2">
                                    Performance Discussed with my Supervisor. I do not wish to comment.
                                </label>
                            </div>
                        </div>

                        <!-- Committee Comments -->
                        <div class="mb-3">
                            <label for="committeeComments" class="form-label">Committee's Comments</label>
                            <textarea id="committeeComments" name="committeeComments"></textarea>
                        </div>
                        <div class="mb-3">
                            <label for="committeeDate" class="form-label">Date (Committee)</label>
                            <input type="datetime-local" class="form-control w-auto" id="committeeDate" name="committeeDate">
                        </div>

                        <div class="text-end">
                             <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                             <button type="submit" class="btn btn-primary">Save Appraisal</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/summernote@0.8.18/dist/summernote-lite.min.js"></script>
    <script>
        $(document).ready(function() {
            // Initialize Summernote
            $('#managerComments, #staffComments, #committeeComments').summernote({
                height: 100,
                toolbar: [
                    ['style', ['style']],
                    ['font', ['bold', 'underline', 'clear']],
                    ['para', ['ul', 'ol', 'paragraph']],
                    ['insert', ['link']],
                    ['view', ['fullscreen', 'codeview', 'help']]
                ]
            });

            const modal = new bootstrap.Modal(document.getElementById('appraiseModal'));

            // Format date for input datetime-local
            function formatDateTimeLocal(dateStr) {
                if (!dateStr) return '';
                const d = new Date(dateStr);
                if (isNaN(d.getTime())) return '';
                const pad = (n) => n < 10 ? '0' + n : n;
                return d.getFullYear() + '-' + 
                       pad(d.getMonth() + 1) + '-' + 
                       pad(d.getDate()) + 'T' + 
                       pad(d.getHours()) + ':' + 
                       pad(d.getMinutes());
            }

            // Populate Staff Details on selection
            $('#pfno').change(function() {
                const pfno = $(this).val();
                if (pfno) {
                    $.get(`/data-entry/api/staff/${pfno}/appraisals`, function(data) {
                        $('#jobTitle').val(data.staff.JobTitle || '');
                        $('#department').val(data.staff.Dept || '');
                        $('#hireDate').val(data.staff.HireDate || '');
                        $('#lastReview').val(data.lastReview || 'N/A');
                    }).fail(function() {
                        alert('Error fetching staff details');
                    });
                } else {
                    $('#jobTitle').val('');
                    $('#department').val('');
                    $('#hireDate').val('');
                    $('#lastReview').val('');
                }
            });

            // Add Appraise Button
            $('#btnAppraise').click(function() {
                $('#appraisalForm')[0].reset();
                $('#appraisalNo').val('');
                $('#modalTitle').text('Appraise Staff');
                $('#pfno').prop('disabled', false).trigger('change');
                
                // Reset Summernote
                $('#managerComments').summernote('code', '');
                $('#staffComments').summernote('code', '');
                $('#committeeComments').summernote('code', '');
                
                modal.show();
            });

            // Edit Button
            $('.btn-edit').click(function() {
                const btn = $(this);
                $('#appraisalNo').val(btn.data('id'));
                $('#modalTitle').text('Edit Appraisal');
                
                const pfno = btn.data('pfno');
                $('#pfno').val(pfno).prop('disabled', true).trigger('change'); // Trigger change to load readonly fields

                $('#manager').val(btn.data('manager'));
                $('#startDate').val(formatDateTimeLocal(btn.data('startdate')));
                $('#endDate').val(formatDateTimeLocal(btn.data('enddate')));
                
                $('#punc').val(btn.data('punc'));
                $('#perf').val(btn.data('perf'));
                $('#com').val(btn.data('com'));
                $('#lead').val(btn.data('lead'));
                $('#team').val(btn.data('team'));
                $('#rela').val(btn.data('rela'));
                $('#attd').val(btn.data('attd'));
                $('#output').val(btn.data('output'));
                
                $('#managerComments').summernote('code', btn.data('managercomments'));
                $('#postDate').val(formatDateTimeLocal(btn.data('postdate')));
                
                $('#staffComments').summernote('code', btn.data('staffcomments'));
                $('#staffDate').val(formatDateTimeLocal(btn.data('staffdate')));
                
                const staffOption = btn.data('staffoption');
                if (staffOption == 1) $('#staffOption1').prop('checked', true);
                if (staffOption == 2) $('#staffOption2').prop('checked', true);
                
                $('#committeeComments').summernote('code', btn.data('committeecomments'));
                $('#committeeDate').val(formatDateTimeLocal(btn.data('committeedate')));
                
                modal.show();
            });

            // Submit Form
            $('#appraisalForm').submit(function(e) {
                e.preventDefault();
                const formData = $(this).serialize();
                const appraisalNo = $('#appraisalNo').val();
                const url = appraisalNo ? '/data-entry/api/staff/appraisals' : '/data-entry/api/staff/appraisals';
                const method = appraisalNo ? 'PUT' : 'POST';
                
                // Add disabled pfno back to data if editing
                let data = formData;
                if (appraisalNo) {
                    data += '&pfno=' + $('#pfno').val();
                }

                $.ajax({
                    url: url,
                    type: method,
                    data: data,
                    success: function(response) {
                        if (response.success) {
                            location.reload();
                        } else {
                            alert('Error saving appraisal');
                        }
                    },
                    error: function(err) {
                        alert('Server Error');
                        console.error(err);
                    }
                });
            });
        });
    </script>
</body>
</html>