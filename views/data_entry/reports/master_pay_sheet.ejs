<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> · <%= group %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="/css/styles.css" rel="stylesheet" />
    <style>@media print { @page { size: A4 landscape; margin: 10mm; } .no-print { display:none !important; } .main{margin-left:0 !important;} }</style>
</head>
<body>
    <%- include('../partials/topbar', { user }) %>
    <%- include('../partials/sidebar') %>
    <main class="main">
        <div class="container-fluid py-3">
            <div class="d-flex align-items-center justify-content-between mb-4">
                <div><h2 class="mb-0"><%= title %></h2><div class="text-muted">Payroll master sheet based on processed payroll rows</div></div>
                <button class="btn btn-secondary no-print" onclick="window.print()"><i class="bi bi-printer"></i> Print</button>
            </div>
            <div class="card shadow-sm mb-4 no-print">
                <div class="card-body">
                    <form method="GET" action="/data-entry/reports/master-pay-sheet" class="row g-3">
                        <div class="col-md-2"><label class="form-label">Month</label><input type="number" class="form-control" name="month" min="1" max="12" value="<%= filters.month %>"></div>
                        <div class="col-md-2"><label class="form-label">Year</label><input type="number" class="form-control" name="year" min="2000" max="2100" value="<%= filters.year %>"></div>
                        <div class="col-md-3"><label class="form-label">Activity</label><select class="form-select" name="payType"><option value="">All Activities</option><% payTypes.forEach((type) => { %><option value="<%= type.Code %>" <%= filters.payType === type.Code ? 'selected' : '' %>><%= type.Code %> - <%= type.PayType %></option><% }) %></select></div>
                        <div class="col-md-3"><label class="form-label">Department</label><select class="form-select" name="department"><option value="">All Departments</option><% departments.forEach((department) => { %><option value="<%= department.Code %>" <%= filters.department === department.Code ? 'selected' : '' %>><%= department.Dept %></option><% }) %></select></div>
                        <div class="col-md-2 d-flex align-items-end"><button type="submit" class="btn btn-primary w-100">Load Sheet</button></div>
                    </form>
                </div>
            </div>
            <div class="row g-3 mb-4">
                <div class="col-md-3"><div class="card shadow-sm"><div class="card-body"><div class="text-muted small">Rows</div><div class="fs-4 fw-bold"><%= Number(totals.totalRows || 0).toLocaleString() %></div></div></div></div>
                <div class="col-md-3"><div class="card shadow-sm"><div class="card-body"><div class="text-muted small">Gross</div><div class="fs-4 fw-bold"><%= Number(totals.totalIncome || 0).toLocaleString() %></div></div></div></div>
                <div class="col-md-3"><div class="card shadow-sm"><div class="card-body"><div class="text-muted small">Tax</div><div class="fs-4 fw-bold"><%= Number(totals.totalTax || 0).toLocaleString() %></div></div></div></div>
                <div class="col-md-3"><div class="card shadow-sm"><div class="card-body"><div class="text-muted small">Net</div><div class="fs-4 fw-bold"><%= Number(totals.totalNet || 0).toLocaleString() %></div></div></div></div>
            </div>
            <div class="card shadow-sm">
                <div class="card-header bg-white"><strong><%= company.Com_Name %></strong></div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-striped table-hover table-bordered align-middle mb-0">
                            <thead class="table-light"><tr><th>PFNo</th><th>Name</th><th>Dept</th><th>Grade</th><th>Job Title</th><th>Activity</th><th class="text-end">Gross</th><th class="text-end">Tax</th><th class="text-end">Deductions</th><th class="text-end">Net</th></tr></thead>
                            <tbody>
                                <% if (!rows.length) { %><tr><td colspan="10" class="text-center text-muted py-4">No payroll rows found for the selected filters.</td></tr><% } %>
                                <% rows.forEach((row) => { const deductions = Number(row.NassitEmp || 0) + Number(row.UnionDues || 0) + Number(row.GratEmp || 0) + Number(row.Ded1 || 0) + Number(row.Ded2 || 0) + Number(row.Ded3 || 0) + Number(row.Ded4 || 0) + Number(row.Ded5 || 0) + Number(row.Ded6 || 0) + Number(row.Ded7 || 0); %>
                                    <tr>
                                        <td><%= row.PFNo %></td><td><%= row.SName %></td><td><%= row.DeptName || row.Dept %></td><td><%= row.GradeName || row.Grade %></td><td><%= row.JobTitleName || row.JobTitle %></td><td><%= row.PayTypeName || row.PType %></td>
                                        <td class="text-end"><%= Number(row.TotalIncome || 0).toLocaleString() %></td><td class="text-end"><%= Number(row.Tax || 0).toLocaleString() %></td><td class="text-end"><%= deductions.toLocaleString() %></td><td class="text-end"><%= Number(row.NetIncome || 0).toLocaleString() %></td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            <footer class="mt-4 py-3 text-center text-muted border-top no-print"><%- include('../partials/footer') %></footer>
        </div>
    </main>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
