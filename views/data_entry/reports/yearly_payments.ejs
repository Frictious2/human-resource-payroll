<!DOCTYPE html>
<html lang="en" data-bs-theme="light"><head><meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1" /><title><%= title %> · Data Entry</title><link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" /><link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" /><link href="/css/styles.css" rel="stylesheet" /></head>
<body><%- include('../partials/topbar', { user }) %><%- include('../partials/sidebar') %><main class="main"><div class="container-fluid py-3">
<div class="d-flex align-items-center justify-content-between mb-4"><div><h2 class="mb-0"><%= title %></h2><nav aria-label="breadcrumb"><ol class="breadcrumb mt-2 mb-0"><li class="breadcrumb-item"><a href="/data-entry/dashboard" class="text-decoration-none">Home</a></li><li class="breadcrumb-item">Reports</li><li class="breadcrumb-item active">Yearly Payments</li></ol></nav></div></div>
<div class="card mb-4 shadow-sm"><div class="card-body"><form method="GET" class="row g-3"><div class="col-md-2"><label class="form-label">PFNo</label><input class="form-control" name="pfNo" value="<%= filters.pfNo %>"></div><div class="col-md-3"><label class="form-label">Type</label><select class="form-select" name="payType"><option value="">All Types</option><% payTypes.forEach((type)=>{ %><option value="<%= type.Code %>" <%= filters.payType===type.Code?'selected':'' %>><%= type.Code %> - <%= type.PayType %></option><% }) %></select></div><div class="col-md-2"><label class="form-label">Month</label><input type="number" min="1" max="12" class="form-control" name="month" value="<%= filters.month %>"></div><div class="col-md-2"><label class="form-label">Year</label><input type="number" min="2000" max="2100" class="form-control" name="year" value="<%= filters.year %>"></div><div class="col-md-3 d-flex align-items-end gap-2"><button class="btn btn-primary">Load Report</button><a href="/data-entry/reports/yearly-payments" class="btn btn-secondary">Reset</a></div></form></div></div>
<div class="d-flex justify-content-end mb-3 d-print-none"><div class="btn-group"><button class="btn btn-success" onclick="exportExcel()">Export to Excel</button><button class="btn btn-danger" onclick="exportPDF()">Export to PDF</button><button class="btn btn-secondary" onclick="window.print()">Print</button></div></div>
<div class="card shadow-sm" id="printableArea"><div class="card-header bg-white"><strong><%= company.Com_Name %></strong></div><div class="card-body p-0"><div class="d-none d-print-block text-center mb-4 mt-4"><h2 class="fw-bold"><%= company.Com_Name %></h2><h4 class="text-decoration-underline">Yearly Payments Report</h4></div><div class="table-responsive"><table class="table table-striped table-hover table-bordered align-middle mb-0" id="dataTable"><thead class="table-light"><tr><th>Date</th><th>PFNo</th><th>Name</th><th>Type</th><th>Dept</th><th>Grade</th><th class="text-end">Total</th><th class="text-end">Tax</th><th class="text-end">Net</th><th>Status</th></tr></thead><tbody><% if (!records.length) { %><tr><td colspan="10" class="text-center text-muted py-4">No yearly payment rows found.</td></tr><% } %><% records.forEach((record)=>{ %><tr><td><%= record.PDate ? new Date(record.PDate).toLocaleDateString() : '-' %></td><td><%= record.PFNo %></td><td><%= record.SName %></td><td><%= record.PayTypeName %></td><td><%= record.DeptName || record.Dept %></td><td><%= record.GradeName || record.Grade %></td><td class="text-end"><%= Number(record.TotalIncome || 0).toLocaleString() %></td><td class="text-end"><%= Number(record.Tax || 0).toLocaleString() %></td><td class="text-end"><%= Number(record.NetIncome || 0).toLocaleString() %></td><td><% if (Number(record.Approved || 0) === 0) { %>Pending<% } else if (Number(record.Approved || 0) === 2) { %>Rejected<% } else { %>Approved<% } %></td></tr><% }) %></tbody></table></div></div></div>
<footer class="mt-4 py-3 text-center text-muted border-top d-print-none"><%- include('../partials/footer') %></footer></div></main><script src="/vendor/bootstrap.bundle.min.js"></script><script src="/js/dashboard.js"></script><script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script><script src="https://cdn.sheetjs.com/xlsx-0.19.3/package/dist/xlsx.full.min.js"></script><script>function exportPDF(){const e=document.getElementById('printableArea');const h=e.querySelector('.d-print-block');const x=h&&h.classList.contains('d-none');if(x)h.classList.remove('d-none');html2pdf().set({margin:10,filename:'yearly_payments_report.pdf',image:{type:'jpeg',quality:0.98},html2canvas:{scale:2},jsPDF:{unit:'mm',format:'a4',orientation:'landscape'}}).from(e).save().then(()=>{if(x)h.classList.add('d-none');});}function exportExcel(){const wb=XLSX.utils.table_to_book(document.getElementById('dataTable'),{sheet:'Yearly Payments'});XLSX.writeFile(wb,'yearly_payments_report.xlsx');}</script></body></html>
