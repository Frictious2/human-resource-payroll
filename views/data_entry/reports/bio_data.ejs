<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> · Data Entry</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="/css/styles.css" rel="stylesheet" />
</head>
<body>
    <%- include('../partials/topbar', { user }) %>
    <%- include('../partials/sidebar') %>
    <main class="main">
        <div class="container-fluid py-3">
            <div class="d-flex align-items-center justify-content-between mb-4">
                <div>
                    <h2 class="mb-0"><%= title %></h2>
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb mt-2 mb-0">
                            <li class="breadcrumb-item"><a href="/data-entry/dashboard" class="text-decoration-none">Home</a></li>
                            <li class="breadcrumb-item">Reports</li>
                            <li class="breadcrumb-item active">Bio-Data</li>
                        </ol>
                    </nav>
                </div>
            </div>
            <div class="card mb-4 shadow-sm">
                <div class="card-body">
                    <form method="GET" class="row g-3">
                        <div class="col-md-2"><label class="form-label">PFNo</label><input class="form-control" name="pfNo" value="<%= filters.pfNo %>"></div>
                        <div class="col-md-3"><label class="form-label">Staff Name</label><input class="form-control" name="staffName" value="<%= filters.staffName %>"></div>
                        <div class="col-md-3"><label class="form-label">Department</label><select class="form-select" name="department"><option value="">All</option><% departments.forEach((item) => { %><option value="<%= item.Code %>" <%= filters.department === item.Code ? 'selected' : '' %>><%= item.Dept %></option><% }) %></select></div>
                        <div class="col-md-2"><label class="form-label">Status</label><select class="form-select" name="statusCode"><option value="">All</option><% statuses.forEach((item) => { %><option value="<%= item.Code %>" <%= filters.statusCode === item.Code ? 'selected' : '' %>><%= item.Status %></option><% }) %></select></div>
                        <div class="col-md-2"><label class="form-label">From DOE</label><input type="date" class="form-control" name="dateFrom" value="<%= filters.dateFrom %>"></div>
                        <div class="col-md-2"><label class="form-label">To DOE</label><input type="date" class="form-control" name="dateTo" value="<%= filters.dateTo %>"></div>
                        <div class="col-md-3 d-flex align-items-end gap-2"><button class="btn btn-primary" type="submit"><i class="bi bi-filter"></i> Filter</button><a href="/data-entry/reports/bio-data" class="btn btn-secondary">Reset</a></div>
                    </form>
                </div>
            </div>
            <div class="d-flex justify-content-end mb-3 d-print-none">
                <div class="btn-group">
                    <button class="btn btn-success" onclick="exportExcel()"><i class="bi bi-file-earmark-excel"></i> Export to Excel</button>
                    <button class="btn btn-danger" onclick="exportPDF()"><i class="bi bi-file-earmark-pdf"></i> Export to PDF</button>
                    <button class="btn btn-secondary" onclick="window.print()"><i class="bi bi-printer"></i> Print</button>
                </div>
            </div>
            <div class="card shadow-sm" id="printableArea">
                <div class="card-body">
                    <div class="d-none d-print-block text-center mb-4"><h2 class="fw-bold"><%= company.Com_Name %></h2><h4 class="text-decoration-underline">Bio-Data Report</h4></div>
                    <div class="table-responsive">
                        <table class="table table-striped table-hover" id="dataTable">
                            <thead><tr><th>PFNo</th><th>Name</th><th>Department</th><th>Grade</th><th>Job Title</th><th>Status</th><th>DOB</th><th>DOE</th><th>Confirmed</th><th>Phone</th><th>Email</th><th>Account</th></tr></thead>
                            <tbody>
                                <% if (!rows.length) { %><tr><td colspan="12" class="text-center">No records found.</td></tr><% } %>
                                <% rows.forEach((row) => { %>
                                    <tr>
                                        <td><%= row.PFNo %></td><td><%= row.SName %></td><td><%= row.DeptName || '-' %></td><td><%= row.GradeName || row.CGrade || '-' %></td><td><%= row.JobTitleName || '-' %></td><td><%= row.StatusName || row.EmpStatus || '-' %></td><td><%= row.DOB ? new Date(row.DOB).toLocaleDateString() : '-' %></td><td><%= row.DOE ? new Date(row.DOE).toLocaleDateString() : '-' %></td><td><%= row.DateConfirmed ? new Date(row.DateConfirmed).toLocaleDateString() : '-' %></td><td><%= row.Phone || '-' %></td><td><%= row.Email || '-' %></td><td><%= row.AccountNo || '-' %></td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            <footer class="mt-4 py-3 text-center text-muted border-top d-print-none"><%- include('../partials/footer') %></footer>
        </div>
    </main>
    <script src="/vendor/bootstrap.bundle.min.js"></script>
    <script src="/js/dashboard.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
    <script src="https://cdn.sheetjs.com/xlsx-0.19.3/package/dist/xlsx.full.min.js"></script>
    <script>
        function exportPDF(){const element=document.getElementById('printableArea');const header=element.querySelector('.d-print-block');const hidden=header&&header.classList.contains('d-none');if(hidden)header.classList.remove('d-none');html2pdf().set({margin:10,filename:'bio_data_report.pdf',image:{type:'jpeg',quality:0.98},html2canvas:{scale:2},jsPDF:{unit:'mm',format:'a4',orientation:'landscape'}}).from(element).save().then(()=>{if(hidden)header.classList.add('d-none');});}
        function exportExcel(){const wb=XLSX.utils.table_to_book(document.getElementById('dataTable'),{sheet:'Bio Data'});XLSX.writeFile(wb,'bio_data_report.xlsx');}
    </script>
</body>
</html>
