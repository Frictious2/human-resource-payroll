<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> · Data Entry</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="/css/styles.css" rel="stylesheet" />
</head>
<body>
    <%- include('../partials/topbar', { user }) %>
    <%- include('../partials/sidebar') %>
    <main class="main">
        <div class="container-fluid py-3">
            <div class="d-flex align-items-center justify-content-between mb-4">
                <div>
                    <h2 class="mb-0"><%= title %></h2>
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb mt-2 mb-0">
                            <li class="breadcrumb-item"><a href="/data-entry/dashboard" class="text-decoration-none">Home</a></li>
                            <li class="breadcrumb-item">Reports</li>
                            <li class="breadcrumb-item active">Loan</li>
                        </ol>
                    </nav>
                </div>
            </div>
            <div class="row g-3 mb-4">
                <div class="col-md-3"><div class="card shadow-sm"><div class="card-body"><div class="text-muted small">Loans</div><div class="fs-4 fw-semibold"><%= totals.totalLoans %></div></div></div></div>
                <div class="col-md-3"><div class="card shadow-sm"><div class="card-body"><div class="text-muted small">Total Amount</div><div class="fs-4 fw-semibold"><%= Number(totals.totalAmount || 0).toLocaleString() %></div></div></div></div>
                <div class="col-md-3"><div class="card shadow-sm"><div class="card-body"><div class="text-muted small">Outstanding</div><div class="fs-4 fw-semibold"><%= Number(totals.totalOutstanding || 0).toLocaleString() %></div></div></div></div>
                <div class="col-md-3"><div class="card shadow-sm"><div class="card-body"><div class="text-muted small">Monthly Repayment</div><div class="fs-4 fw-semibold"><%= Number(totals.totalMonthlyRepayment || 0).toLocaleString() %></div></div></div></div>
            </div>
            <div class="card mb-4 shadow-sm">
                <div class="card-body">
                    <form method="GET" class="row g-3">
                        <div class="col-md-2"><label for="pfNo" class="form-label">PFNo</label><input type="text" class="form-control" id="pfNo" name="pfNo" value="<%= filters.pfNo %>"></div>
                        <div class="col-md-3"><label for="staffName" class="form-label">Staff Name</label><input type="text" class="form-control" id="staffName" name="staffName" value="<%= filters.staffName %>"></div>
                        <div class="col-md-3"><label for="department" class="form-label">Department</label><select class="form-select" id="department" name="department"><option value="">All</option><% departments.forEach((item) => { %><option value="<%= item.Code %>" <%= filters.department === item.Code ? 'selected' : '' %>><%= item.Dept %></option><% }) %></select></div>
                        <div class="col-md-2"><label for="loanType" class="form-label">Loan Type</label><select class="form-select" id="loanType" name="loanType"><option value="">All</option><% loanCodes.forEach((item) => { %><option value="<%= item.TCode %>" <%= filters.loanType === item.TCode ? 'selected' : '' %>><%= item.TransName %></option><% }) %></select></div>
                        <div class="col-md-2"><label for="loanStatus" class="form-label">Status</label><select class="form-select" id="loanStatus" name="loanStatus"><option value="">All</option><option value="active" <%= filters.loanStatus === 'active' ? 'selected' : '' %>>Active</option><option value="completed" <%= filters.loanStatus === 'completed' ? 'selected' : '' %>>Completed</option></select></div>
                        <div class="col-md-2"><label for="dateFrom" class="form-label">From Date</label><input type="date" class="form-control" id="dateFrom" name="dateFrom" value="<%= filters.dateFrom %>"></div>
                        <div class="col-md-2"><label for="dateTo" class="form-label">To Date</label><input type="date" class="form-control" id="dateTo" name="dateTo" value="<%= filters.dateTo %>"></div>
                        <div class="col-md-3 d-flex align-items-end gap-2"><button type="submit" class="btn btn-primary"><i class="bi bi-filter"></i> Filter</button><a href="/data-entry/reports/loan" class="btn btn-secondary"><i class="bi bi-arrow-counterclockwise"></i> Reset</a></div>
                    </form>
                </div>
            </div>
            <div class="d-flex justify-content-end mb-3 d-print-none"><div class="btn-group"><button type="button" class="btn btn-success" onclick="exportExcel()"><i class="bi bi-file-earmark-excel"></i> Export to Excel</button><button type="button" class="btn btn-danger" onclick="exportPDF()"><i class="bi bi-file-earmark-pdf"></i> Export to PDF</button><button type="button" class="btn btn-secondary" onclick="window.print()"><i class="bi bi-printer"></i> Print</button></div></div>
            <div class="card shadow-sm" id="printableArea"><div class="card-body"><div class="d-none d-print-block text-center mb-4"><h2 class="fw-bold"><%= company.Com_Name %></h2><h4 class="text-decoration-underline">Loan Report</h4></div><div class="table-responsive"><table class="table table-striped table-hover" id="dataTable"><thead><tr><th>PFNo</th><th>Name</th><th>Dept</th><th>Type</th><th>Amount</th><th>Outstanding</th><th>Repaid</th><th>Monthly Repay.</th><th>Payroll Deductions</th><th>Pending Repayments</th><th>Start</th><th>Expiry</th><th>Status</th></tr></thead><tbody><% if (!rows.length) { %><tr><td colspan="13" class="text-center">No records found.</td></tr><% } %><% rows.forEach((row) => { const status = (Number(row.Repaid || 0) || Number(row.Expired || 0) || Number(row.LoanBal || 0) <= 0) ? 'Completed' : 'Active'; %><tr><td><%= row.PFNo %></td><td><%= row.SName || '-' %></td><td><%= row.DeptName || '-' %></td><td><%= row.LoanTypeName || '-' %></td><td><%= Number(row.Amount || 0).toLocaleString() %></td><td><%= Number(row.LoanBal || 0).toLocaleString() %></td><td><%= Number(row.RepaidAmount || 0).toLocaleString() %></td><td><%= Number(row.MonthlyRepayment || 0).toLocaleString() %></td><td><%= Number(row.TotalPayrollDeductions || 0).toLocaleString() %></td><td><%= Number(row.PendingRepayments || 0).toLocaleString() %></td><td><%= row.StartDate ? new Date(row.StartDate).toLocaleDateString() : '-' %></td><td><%= row.ExpDate ? new Date(row.ExpDate).toLocaleDateString() : '-' %></td><td><%= status %></td></tr><% }) %></tbody></table></div></div></div>
            <footer class="mt-4 py-3 text-center text-muted border-top d-print-none"><%- include('../partials/footer') %></footer>
        </div>
    </main>
    <script src="/vendor/bootstrap.bundle.min.js"></script><script src="/js/dashboard.js"></script><script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script><script src="https://cdn.sheetjs.com/xlsx-0.19.3/package/dist/xlsx.full.min.js"></script>
    <script>
        function exportPDF(){const element=document.getElementById('printableArea');const header=element.querySelector('.d-print-block');const wasHidden=header&&header.classList.contains('d-none');if(wasHidden)header.classList.remove('d-none');html2pdf().set({margin:10,filename:'loan_report.pdf',image:{type:'jpeg',quality:0.98},html2canvas:{scale:2},jsPDF:{unit:'mm',format:'a4',orientation:'landscape'}}).from(element).save().then(()=>{if(wasHidden)header.classList.add('d-none');});}
        function exportExcel(){const wb=XLSX.utils.table_to_book(document.getElementById('dataTable'),{sheet:'Loan Report'});XLSX.writeFile(wb,'loan_report.xlsx');}
    </script>
</body>
</html>
