<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> · Data Entry</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="/css/styles.css" rel="stylesheet" />
</head>
<body>
    <%- include('../partials/topbar', { user }) %>
    <%- include('../partials/sidebar') %>

    <main class="main">
        <div class="container-fluid py-3">
            <div class="d-flex align-items-center justify-content-between mb-4">
                <div>
                    <h2 class="mb-0"><%= title %></h2>
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb mt-2 mb-0">
                            <li class="breadcrumb-item"><a href="/data-entry/dashboard" class="text-decoration-none">Home</a></li>
                            <li class="breadcrumb-item">Payroll</li>
                            <li class="breadcrumb-item active">Bonus Awards</li>
                        </ol>
                    </nav>
                </div>
                <button class="btn btn-primary" id="btnAddBonus" data-bs-toggle="modal" data-bs-target="#bonusModal">
                    <i class="bi bi-plus-circle"></i> Add Bonus
                </button>
            </div>

            <div class="card shadow-sm">
                <div class="card-body">
                    <h5 class="card-title mb-3">Pending Bonus Awards</h5>
                    <div class="table-responsive">
                        <table class="table table-hover table-bordered" id="bonusTable">
                            <thead class="table-light">
                                <tr>
                                    <th>Entry Date</th>
                                    <th>Bonus Year</th>
                                    <th>Months</th>
                                    <th>Bonus</th>
                                    <th>Taxable</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody id="bonusTBody">
                                <tr><td colspan="6" class="text-center">Loading...</td></tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <footer class="mt-4 py-3 text-center text-muted border-top">
                <%- include('../partials/footer') %>
            </footer>
        </div>
    </main>

    <!-- Add/Edit Bonus Modal -->
    <div class="modal fade" id="bonusModal" tabindex="-1" aria-labelledby="bonusModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="bonusModalLabel">Add Bonus Award</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <form id="bonusForm">
                        <input type="hidden" id="recordId" name="id" />
                        <div class="row mb-3">
                            <label for="entryDate" class="col-sm-4 col-form-label">Entry Date</label>
                            <div class="col-sm-8">
                                <input type="date" class="form-control" id="entryDate" name="entryDate" required />
                            </div>
                        </div>
                        <div class="row mb-3">
                            <label for="bonusYear" class="col-sm-4 col-form-label">Bonus Year</label>
                            <div class="col-sm-8">
                                <input type="number" min="1900" max="2100" class="form-control" id="bonusYear" name="bonusYear" required />
                            </div>
                        </div>
                        <div class="row mb-3">
                            <label for="months" class="col-sm-4 col-form-label">Months</label>
                            <div class="col-sm-8">
                                <input type="number" min="1" max="12" class="form-control" id="months" name="month" required />
                            </div>
                        </div>
                        <div class="row mb-3">
                            <label class="col-sm-4 col-form-label">Type</label>
                            <div class="col-sm-8 d-flex gap-4 align-items-center">
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="type" id="typeFixed" value="fixed" checked />
                                    <label class="form-check-label" for="typeFixed">Fixed</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="type" id="typePercent" value="percent" />
                                    <label class="form-check-label" for="typePercent">Percent</label>
                                </div>
                            </div>
                        </div>
                        <div class="row mb-3">
                            <label for="bonus" class="col-sm-4 col-form-label">Bonus</label>
                            <div class="col-sm-8">
                                <input type="number" step="0.01" class="form-control" id="bonus" name="bonus" required />
                            </div>
                        </div>
                        <div class="row mb-3">
                            <label for="taxable" class="col-sm-4 col-form-label">Taxable</label>
                            <div class="col-sm-8">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="taxable" name="taxable" />
                                    <label class="form-check-label" for="taxable">Yes</label>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                    <button type="button" class="btn btn-primary" id="btnSaveBonus">Save</button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
    document.addEventListener('DOMContentLoaded', () => {
        const tbody = document.getElementById('bonusTBody');
        const bonusModalEl = document.getElementById('bonusModal');
        const btnAddBonus = document.getElementById('btnAddBonus');
        const btnSave = document.getElementById('btnSaveBonus');
        const form = document.getElementById('bonusForm');
        const modal = typeof bootstrap !== 'undefined' ? new bootstrap.Modal(bonusModalEl) : null;

        const recordId = document.getElementById('recordId');
        const entryDate = document.getElementById('entryDate');
        const bonusYear = document.getElementById('bonusYear');
        const months = document.getElementById('months');
        const bonus = document.getElementById('bonus');
        const taxable = document.getElementById('taxable');
        const typeFixed = document.getElementById('typeFixed');
        const typePercent = document.getElementById('typePercent');

        btnAddBonus.addEventListener('click', () => {
            form.reset();
            recordId.value = '';
            typeFixed.checked = true;
            typePercent.checked = false;
            document.getElementById('bonusModalLabel').textContent = 'Add Bonus Award';
        });

        async function loadPending() {
            tbody.innerHTML = '<tr><td colspan="6" class="text-center">Loading...</td></tr>';
            try {
                const res = await fetch('/data-entry/api/payroll/bonus-awards/pending');
                const data = await res.json();
                if (!Array.isArray(data) || data.length === 0) {
                    tbody.innerHTML = '<tr><td colspan="6" class="text-center">No pending bonus awards.</td></tr>';
                    return;
                }
                tbody.innerHTML = '';
                data.forEach(row => {
                    const id = row.RefNo || row.Id || row.BonusID || '';
                    const tr = document.createElement('tr');
                    const entry = row.EntryDate ? new Date(row.EntryDate).toISOString().split('T')[0] : '';
                    const taxableText = (row.BTaxable == 1) ? 'Yes' : 'No';
                    tr.innerHTML = `
                        <td>${entry}</td>
                        <td>${row.BonusYear ?? ''}</td>
                        <td>${row.Month ?? ''}</td>
                        <td>${row.Bonus ?? ''}</td>
                        <td>${taxableText}</td>
                        <td>
                            <button class="btn btn-sm btn-outline-primary" data-id="${id}" data-action="edit">
                                <i class="bi bi-pencil-square"></i> Edit
                            </button>
                        </td>
                    `;
                    tbody.appendChild(tr);
                });
            } catch (e) {
                tbody.innerHTML = '<tr><td colspan="6" class="text-danger text-center">Failed to load.</td></tr>';
                console.error(e);
            }
        }

        tbody.addEventListener('click', async (ev) => {
            const btn = ev.target.closest('button[data-action="edit"]');
            if (!btn) return;
            const id = btn.getAttribute('data-id');
            if (!id) return;
            try {
                const res = await fetch(`/data-entry/api/payroll/bonus-awards/${id}`);
                const row = await res.json();
                if (!row) return;
                recordId.value = id;
                entryDate.value = row.EntryDate ? new Date(row.EntryDate).toISOString().split('T')[0] : '';
                bonusYear.value = row.BonusYear ?? '';
                months.value = row.Month ?? '';
                bonus.value = row.Bonus ?? '';
                taxable.checked = (row.BTaxable == 1);
                typeFixed.checked = (row.Fixed == 1);
                typePercent.checked = (row.Percent == 1);
                document.getElementById('bonusModalLabel').textContent = 'Edit Bonus Award';
                if (modal) modal.show();
            } catch (e) {
                console.error(e);
            }
        });

        btnSave.addEventListener('click', async () => {
            const payload = {
                id: recordId.value || undefined,
                entryDate: entryDate.value,
                bonusYear: bonusYear.value,
                month: months.value,
                type: typePercent.checked ? 'percent' : 'fixed',
                bonus: bonus.value,
                taxable: taxable.checked ? '1' : '0'
            };
            btnSave.disabled = true;
            btnSave.textContent = 'Saving...';
            try {
                const res = await fetch('/data-entry/api/payroll/bonus-awards', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });
                const result = await res.json();
                if (result && result.success) {
                    if (modal) modal.hide();
                    await loadPending();
                } else {
                    alert(result.error || result.message || 'Failed to save');
                }
            } catch (e) {
                console.error(e);
                alert('Error saving bonus award');
            } finally {
                btnSave.disabled = false;
                btnSave.textContent = 'Save';
            }
        });

        loadPending();
    });
    </script>
</body>
</html>
