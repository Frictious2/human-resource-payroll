<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <title>Payroll Review</title>
    <style>
        @page {
            size: landscape;
            margin: 20mm;
        }
        body {
            font-family: Arial, sans-serif;
            font-size: 11px;
        }
        .print-btn-container {
            text-align: right;
            margin-bottom: 10px;
        }
        .print-btn {
            padding: 6px 16px;
            background-color: #0d6efd;
            color: white;
            border: none;
            border-radius: 4px;
            cursor: pointer;
            font-size: 13px;
        }
        .print-btn:hover {
            background-color: #0b5ed7;
        }
        .header {
            text-align: center;
            margin-bottom: 10px;
        }
        .header table {
            width: 100%;
        }
        .logo {
            width: 80px;
            height: 80px;
            object-fit: contain;
        }
        .company-name {
            font-size: 18px;
            font-weight: bold;
        }
        .company-address {
            font-size: 12px;
        }
        .title {
            margin-top: 5px;
            font-size: 16px;
            font-weight: bold;
            text-decoration: underline;
        }
        .meta {
            margin-top: 4px;
            font-size: 11px;
        }
        .dept-title {
            margin-top: 12px;
            margin-bottom: 4px;
            font-weight: bold;
            font-size: 12px;
        }
        table.report {
            width: 100%;
            border-collapse: collapse;
        }
        table.report th,
        table.report td {
            border: 1px solid #000;
            padding: 3px 4px;
        }
        table.report thead th {
            background-color: #f0f0f0;
        }
        .text-right {
            text-align: right;
        }
        .text-center {
            text-align: center;
        }
        .subtotal-row {
            font-weight: bold;
            background-color: #fafafa;
        }
        .grandtotal-row {
            font-weight: bold;
            background-color: #e0e0e0;
        }
        @media print {
            .print-btn-container {
                display: none;
            }
        }
    </style>
</head>
<body>
    <div class="print-btn-container">
        <button onclick="window.print()" class="print-btn">Print Payroll Review</button>
    </div>

    <div class="header">
        <table>
            <tr>
                <td style="width: 80px;">
                    <% if (company.Logopath) { %>
                        <img src="<%= baseUrl %><%= company.Logopath %>" alt="Company Logo" class="logo" />
                    <% } %>
                </td>
                <td>
                    <div class="company-name"><%= company.Com_Name %></div>
                    <div class="company-address"><%= company.Address %></div>
                    <div class="title">Payroll Review</div>
                    <%
                        const monthNames = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
                        const monthLabel = monthNames[month - 1] || '';
                        const today = new Date();
                        const dd = String(today.getDate()).padStart(2, '0');
                        const mmm = monthNames[today.getMonth()];
                        const yyyy = today.getFullYear();
                    %>
                    <div class="meta">
                        Period: <strong><%= monthLabel %> <%= year %></strong> |
                        Date: <strong><%= dd %>/<%= mmm %>/<%= yyyy %></strong>
                    </div>
                </td>
            </tr>
        </table>
    </div>

    <% if (!departments || departments.length === 0) { %>
        <p class="text-center"><em>No records found for the selected criteria.</em></p>
    <% } else { %>
        <% departments.forEach(group => { %>
            <div class="dept-title">Department: <%= group.name %></div>
            <table class="report">
                <thead>
                    <tr>
                        <th style="width: 60px;">Emp-ID</th>
                        <th>Name</th>
                        <th style="width: 70px;">Grade</th>
                        <th style="width: 90px;" class="text-right">Salary</th>
                        <th style="width: 110px;" class="text-right">Total Allowance</th>
                        <th style="width: 90px;" class="text-right">Tax</th>
                        <th style="width: 100px;" class="text-right">Net Income</th>
                    </tr>
                </thead>
                <tbody>
                    <% group.rows.forEach(r => { %>
                        <tr>
                            <td><%= r.PFNo %></td>
                            <td><%= r.SName %></td>
                            <td><%= r.GradeCode %></td>
                            <td class="text-right"><%= Number(r.Salary || 0).toFixed(2) %></td>
                            <td class="text-right"><%= Number(r.TotAllw || 0).toFixed(2) %></td>
                            <td class="text-right"><%= Number(r.Tax || 0).toFixed(2) %></td>
                            <td class="text-right"><%= Number(r.NetIncome || 0).toFixed(2) %></td>
                        </tr>
                    <% }) %>
                    <tr class="subtotal-row">
                        <td colspan="4" class="text-right">Department Total:</td>
                        <td class="text-right"><%= group.totals.totAllw.toFixed(2) %></td>
                        <td class="text-right"><%= group.totals.tax.toFixed(2) %></td>
                        <td class="text-right"><%= group.totals.net.toFixed(2) %></td>
                    </tr>
                </tbody>
            </table>
        <% }) %>

        <table class="report" style="margin-top: 12px;">
            <tbody>
                <tr class="grandtotal-row">
                    <td style="text-align:right;" colspan="4">Grand Total:</td>
                    <td class="text-right"><%= grandTotals.totAllw.toFixed(2) %></td>
                    <td class="text-right"><%= grandTotals.tax.toFixed(2) %></td>
                    <td class="text-right"><%= grandTotals.net.toFixed(2) %></td>
                </tr>
            </tbody>
        </table>
    <% } %>
</body>
</html>

