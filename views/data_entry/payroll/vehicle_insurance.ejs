<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> · Data Entry</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="/css/styles.css" rel="stylesheet" />
</head>
<body>
    <%- include('../partials/topbar', { user }) %>
    <%- include('../partials/sidebar') %>

    <main class="main">
        <div class="container-fluid py-3">
            <div class="d-flex align-items-center justify-content-between mb-4">
                <div>
                    <h2 class="mb-0"><%= title %></h2>
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb mt-2 mb-0">
                            <li class="breadcrumb-item"><a href="/data-entry/dashboard" class="text-decoration-none">Home</a></li>
                            <li class="breadcrumb-item">Payroll</li>
                            <li class="breadcrumb-item active">Vehicle Insurance</li>
                        </ol>
                    </nav>
                </div>
            </div>

            <% if (success) { %><div class="alert alert-success"><%= success %></div><% } %>
            <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>

            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <h5 class="card-title mb-3">Add / Update Insurance Record</h5>
                    <form method="POST" action="/data-entry/payroll/vehicle-insurance" class="row g-3">
                        <div class="col-md-3">
                            <label for="pfNo" class="form-label">Staff PFNo</label>
                            <input type="text" class="form-control" id="pfNo" name="pfNo" list="insuranceStaffList" required>
                            <datalist id="insuranceStaffList">
                                <% staffList.forEach((staff) => { %>
                                    <option value="<%= staff.PFNo %>" data-name="<%= staff.SName %>"><%= staff.SName %></option>
                                <% }) %>
                            </datalist>
                        </div>
                        <div class="col-md-3">
                            <label for="staffName" class="form-label">Staff Name</label>
                            <input type="text" class="form-control" id="staffName" readonly>
                        </div>
                        <div class="col-md-3">
                            <label for="insType" class="form-label">Insurance Type</label>
                            <select class="form-select" id="insType" name="insType" required>
                                <option value="">Select type</option>
                                <% insuranceTypes.forEach((item) => { %>
                                    <option value="<%= item.InsCode %>"><%= item.InsCode %> - <%= item.InsType %></option>
                                <% }) %>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label for="insurer" class="form-label">Insurer</label>
                            <select class="form-select" id="insurer" name="insurer" required>
                                <option value="">Select insurer</option>
                                <% insurers.forEach((item) => { %>
                                    <option value="<%= item.InsCode %>"><%= item.InsName %></option>
                                <% }) %>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label for="policyNo" class="form-label">Policy Number</label>
                            <input type="text" class="form-control" id="policyNo" name="policyNo" required>
                        </div>
                        <div class="col-md-3">
                            <label for="loanGranted" class="form-label">Loan Granted Date</label>
                            <input type="date" class="form-control" id="loanGranted" name="loanGranted">
                        </div>
                        <div class="col-md-3">
                            <label for="loanLife" class="form-label">Loan Life</label>
                            <input type="number" min="0" class="form-control" id="loanLife" name="loanLife" value="0">
                        </div>
                        <div class="col-md-3">
                            <label for="premSequence" class="form-label">Premium Sequence</label>
                            <input type="text" class="form-control" id="premSequence" name="premSequence">
                        </div>
                        <div class="col-md-3">
                            <label for="insAmount" class="form-label">Insurance Amount</label>
                            <input type="number" step="0.01" class="form-control" id="insAmount" name="insAmount" value="0">
                        </div>
                        <div class="col-md-3">
                            <label for="premium" class="form-label">Premium</label>
                            <input type="number" step="0.01" class="form-control" id="premium" name="premium" value="0">
                        </div>
                        <div class="col-md-3">
                            <label for="dateExp" class="form-label">Expiry Date</label>
                            <input type="date" class="form-control" id="dateExp" name="dateExp">
                        </div>
                        <div class="col-md-2">
                            <label for="noOfPayments" class="form-label">No. of Payments</label>
                            <input type="number" min="0" class="form-control" id="noOfPayments" name="noOfPayments" value="0">
                        </div>
                        <div class="col-md-2">
                            <label class="form-label d-block">Renewed</label>
                            <div class="form-check mt-2">
                                <input class="form-check-input" type="checkbox" id="renewed" name="renewed" value="1">
                                <label class="form-check-label" for="renewed">Yes</label>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <label for="dateRenewed" class="form-label">Date Renewed</label>
                            <input type="date" class="form-control" id="dateRenewed" name="dateRenewed">
                        </div>
                        <div class="col-md-2 d-flex align-items-end justify-content-end">
                            <button type="submit" class="btn btn-primary"><i class="bi bi-save"></i> Save Record</button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="card shadow-sm">
                <div class="card-body">
                    <div class="d-flex flex-wrap align-items-center justify-content-between gap-3 mb-3">
                        <h5 class="card-title mb-0">Vehicle Insurance Records</h5>
                        <form method="GET" action="/data-entry/payroll/vehicle-insurance" class="row g-2">
                            <div class="col-auto"><input type="text" class="form-control" name="pfNo" placeholder="PFNo" value="<%= filters.pfNo %>"></div>
                            <div class="col-auto">
                                <select class="form-select" name="insType">
                                    <option value="">All Types</option>
                                    <% insuranceTypes.forEach((item) => { %>
                                        <option value="<%= item.InsCode %>" <%= filters.insType === item.InsCode ? 'selected' : '' %>><%= item.InsType %></option>
                                    <% }) %>
                                </select>
                            </div>
                            <div class="col-auto">
                                <select class="form-select" name="insurer">
                                    <option value="">All Insurers</option>
                                    <% insurers.forEach((item) => { %>
                                        <option value="<%= item.InsCode %>" <%= filters.insurer === item.InsCode ? 'selected' : '' %>><%= item.InsName %></option>
                                    <% }) %>
                                </select>
                            </div>
                            <div class="col-auto">
                                <select class="form-select" name="status">
                                    <option value="">All Status</option>
                                    <option value="pending" <%= filters.status === 'pending' ? 'selected' : '' %>>Pending</option>
                                    <option value="approved" <%= filters.status === 'approved' ? 'selected' : '' %>>Approved</option>
                                    <option value="rejected" <%= filters.status === 'rejected' ? 'selected' : '' %>>Rejected</option>
                                </select>
                            </div>
                            <div class="col-auto"><button type="submit" class="btn btn-outline-primary">Filter</button></div>
                        </form>
                    </div>

                    <div class="table-responsive">
                        <table class="table table-hover table-bordered align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>PFNo</th>
                                    <th>Name</th>
                                    <th>Type</th>
                                    <th>Insurer</th>
                                    <th>Policy No</th>
                                    <th class="text-end">Amount</th>
                                    <th class="text-end">Premium</th>
                                    <th>Expiry</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (!rows.length) { %>
                                    <tr><td colspan="9" class="text-center text-muted py-4">No insurance records found.</td></tr>
                                <% } %>
                                <% rows.forEach((row) => { %>
                                    <tr>
                                        <td><%= row.PFNo %></td>
                                        <td><%= row.SName || '-' %></td>
                                        <td><%= row.InsuranceTypeName || row.InsType %></td>
                                        <td><%= row.InsurerName || row.Insurer %></td>
                                        <td><%= row.PolNo %></td>
                                        <td class="text-end"><%= Number(row.InsAmount || 0).toLocaleString() %></td>
                                        <td class="text-end"><%= Number(row.Premium || 0).toLocaleString() %></td>
                                        <td><%= row.DateExp ? new Date(row.DateExp).toLocaleDateString() : '-' %></td>
                                        <td>
                                            <% if (Number(row.Approved || 0) === 0) { %><span class="badge bg-warning text-dark">Pending</span>
                                            <% } else if (Number(row.Approved || 0) === 2) { %><span class="badge bg-danger">Rejected</span>
                                            <% } else { %><span class="badge bg-success">Approved</span><% } %>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <footer class="mt-4 py-3 text-center text-muted border-top"><%- include('../partials/footer') %></footer>
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const pfNoInput = document.getElementById('pfNo');
            const staffNameInput = document.getElementById('staffName');
            const staffOptions = Array.from(document.querySelectorAll('#insuranceStaffList option'));
            function syncStaffName() {
                const selectedOption = staffOptions.find((option) => option.value === pfNoInput.value);
                staffNameInput.value = selectedOption ? selectedOption.dataset.name : '';
            }
            pfNoInput.addEventListener('change', syncStaffName);
            pfNoInput.addEventListener('input', syncStaffName);
            syncStaffName();
        });
    </script>
</body>
</html>
