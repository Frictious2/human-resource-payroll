<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> · Data Entry</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" 
          rel="stylesheet" 
          integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" 
          crossorigin="anonymous" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="/css/styles.css" rel="stylesheet" />
</head>
<body>
    <%- include('../partials/topbar', { user }) %>
    <%- include('../partials/sidebar') %>

    <main class="main">
        <div class="container-fluid py-3">
            <div class="d-flex align-items-center justify-content-between mb-4">
                <div>
                    <h2 class="mb-0"><%= title %></h2>
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb mt-2 mb-0">
                            <li class="breadcrumb-item"><a href="/data-entry/dashboard" class="text-decoration-none">Home</a></li>
                            <li class="breadcrumb-item">Payroll</li>
                            <li class="breadcrumb-item active">Process Emoluments</li>
                        </ol>
                    </nav>
                </div>
            </div>

            <div class="row">
                <div class="col-lg-6 mx-auto">
                    <div class="card shadow-sm">
                        <div class="card-body">
                            <h5 class="card-title mb-4">Process Monthly Salaries, Allowances, etc</h5>

                            <form id="processForm" action="/data-entry/payroll/process-emoluments" method="POST">
                                
                                <!-- 1. Enter Activity -->
                                <div class="row mb-3">
                                    <label for="activity" class="col-sm-4 col-form-label">Enter Activity</label>
                                    <div class="col-sm-8">
                                        <select class="form-select" id="activity" name="activity" required>
                                            <option value="" selected disabled>Select Activity</option>
                                            <% if (payTypes && payTypes.length > 0) { %>
                                                <% payTypes.forEach(pt => { %>
                                                    <option value="<%= pt.Code %>"><%= pt.PayType %></option>
                                                <% }) %>
                                            <% } else { %>
                                                <option value="" disabled>No activities found</option>
                                            <% } %>
                                        </select>
                                    </div>
                                </div>

                                <!-- 2. Enter Date -->
                                <div class="row mb-3">
                                    <label for="pdate" class="col-sm-4 col-form-label">Enter Date</label>
                                    <div class="col-sm-8">
                                        <input type="date" class="form-control" id="pdate" name="pdate" required>
                                    </div>
                                </div>

                                <!-- 3. Last Pay Date -->
                                <div class="row mb-3">
                                    <label for="lastPayDate" class="col-sm-4 col-form-label">Last Pay Date</label>
                                    <div class="col-sm-8">
                                        <input type="text" class="form-control" id="lastPayDate" 
                                            value="<%= lastPayDate ? new Date(lastPayDate).toISOString().split('T')[0] : 'No Record' %>" 
                                            readonly disabled>
                                    </div>
                                </div>

                                <!-- 4. Post Button -->
                                <div class="row mb-3">
                                    <div class="col-sm-8 offset-sm-4">
                                        <button type="button" class="btn btn-primary" id="btnPost">Post</button>
                                    </div>
                                </div>

                            </form>
                        </div>
                    </div>
                </div>
            </div>
            
            <footer class="mt-4 py-3 text-center text-muted border-top">
                <%- include('../partials/footer') %>
            </footer>
        </div>
    </main>

    <!-- Warning Modal -->
    <div class="modal fade" id="warningModal" tabindex="-1" aria-labelledby="warningModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title text-danger" id="warningModalLabel">
                        <i class="bi bi-exclamation-triangle-fill"></i> Warning
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body" id="warningMessage">
                    <!-- Message will be inserted here -->
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" 
            integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" 
            crossorigin="anonymous"></script>
    <script src="/js/main.js"></script>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const btnPost = document.getElementById('btnPost');
            const processForm = document.getElementById('processForm');
            const warningModalElement = document.getElementById('warningModal');
            // Use Bootstrap's Modal API if available via window.bootstrap, otherwise basic toggle
            let warningModal;
            if (typeof bootstrap !== 'undefined') {
                 warningModal = new bootstrap.Modal(warningModalElement);
            }

            const warningMessage = document.getElementById('warningMessage');

            btnPost.addEventListener('click', async () => {
                const pdateInput = document.getElementById('pdate');
                const activityInput = document.getElementById('activity');
                
                if (!activityInput.value) {
                    alert('Please select an activity.');
                    return;
                }

                if (!pdateInput.value) {
                    alert('Please select a date.');
                    return;
                }

                // Disable button to prevent double clicks
                btnPost.disabled = true;
                btnPost.textContent = 'Checking...';

                try {
                    try {
                const response = await fetch(`/data-entry/api/payroll/check-process-status?pdate=${pdateInput.value}&activity=${activityInput.value}`);
                const result = await response.json();

                    if (result.valid) {
                        // All good, submit the form
                        processForm.submit();
                    } else {
                        // Show warning modal
                        warningMessage.textContent = result.message;
                        if (warningModal) {
                            warningModal.show();
                        } else {
                            // Fallback if bootstrap object isn't directly available
                            alert("Warning: " + result.message);
                        }
                        
                        btnPost.disabled = false;
                        btnPost.textContent = 'Post';
                    }
                } catch (error) {
                    console.error('Error checking status:', error);
                    alert('An error occurred while checking validation rules. Please try again.');
                    btnPost.disabled = false;
                    btnPost.textContent = 'Post';
                }
            });
        });
    </script>
</body>
</html>