<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %> · HR & Payroll</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="/css/styles.css" rel="stylesheet" />
</head>
<body>
    <%- include('../partials/topbar', { user }) %>
    <%- include('../partials/sidebar') %>

    <main class="main">
        <div class="container-fluid">
            <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
                <h1 class="h2"><%= title %></h1>
            </div>

            <div class="card mb-4 shadow-sm">
                <div class="card-body">
                    <form method="GET" class="row g-3">
                        <div class="col-md-2">
                            <label for="pfno" class="form-label">PFNo / Emp ID</label>
                            <input type="text" class="form-control" id="pfno" name="pfno" value="<%= filters.pfno || '' %>" />
                        </div>
                        <div class="col-md-3">
                            <label for="dept" class="form-label">Department</label>
                            <select class="form-select" id="dept" name="dept">
                                <option value="">All</option>
                                <% depts.forEach(item => { %>
                                    <option value="<%= item.Code %>" <%= filters.dept === item.Code ? 'selected' : '' %>><%= item.Dept %></option>
                                <% }) %>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label for="grade" class="form-label">Grade</label>
                            <select class="form-select" id="grade" name="grade">
                                <option value="">All</option>
                                <% grades.forEach(item => { %>
                                    <option value="<%= item.GradeCode %>" <%= filters.grade === item.GradeCode ? 'selected' : '' %>><%= item.Grade %></option>
                                <% }) %>
                            </select>
                        </div>
                        <div class="col-md-2">
                            <label for="gender" class="form-label">Gender</label>
                            <select class="form-select" id="gender" name="gender">
                                <option value="">All</option>
                                <% sexes.forEach(item => { %>
                                    <option value="<%= item.SexCode %>" <%= filters.gender === item.SexCode ? 'selected' : '' %>><%= item.Status %></option>
                                <% }) %>
                            </select>
                        </div>
                        <div class="col-md-2">
                            <label for="profession" class="form-label">Profession</label>
                            <select class="form-select" id="profession" name="profession">
                                <option value="">All</option>
                                <% professions.forEach(item => { %>
                                    <option value="<%= item.Code %>" <%= filters.profession === item.Code ? 'selected' : '' %>><%= item.QType %></option>
                                <% }) %>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label for="course" class="form-label">Course</label>
                            <input type="text" class="form-control" id="course" name="course" value="<%= filters.course || '' %>" />
                        </div>
                        <div class="col-md-2">
                            <label for="dateFrom" class="form-label">From Date</label>
                            <input type="date" class="form-control" id="dateFrom" name="dateFrom" value="<%= filters.dateFrom || '' %>" />
                        </div>
                        <div class="col-md-2">
                            <label for="dateTo" class="form-label">To Date</label>
                            <input type="date" class="form-control" id="dateTo" name="dateTo" value="<%= filters.dateTo || '' %>" />
                        </div>
                        <div class="col-md-3 d-flex align-items-end">
                            <button type="submit" class="btn btn-primary me-2"><i class="bi bi-filter"></i> Filter</button>
                            <a href="/data-entry/enquiry/training" class="btn btn-secondary"><i class="bi bi-arrow-counterclockwise"></i> Reset</a>
                        </div>
                    </form>
                </div>
            </div>

            <div class="d-flex justify-content-end mb-3 d-print-none">
                <div class="btn-group">
                    <button type="button" class="btn btn-success" onclick="exportExcel()">
                        <i class="bi bi-file-earmark-excel"></i> Export to Excel
                    </button>
                    <button type="button" class="btn btn-danger" onclick="exportPDF()">
                        <i class="bi bi-file-earmark-pdf"></i> Export to PDF
                    </button>
                    <button type="button" class="btn btn-secondary" onclick="window.print()">
                        <i class="bi bi-printer"></i> Print
                    </button>
                </div>
            </div>

            <div class="card shadow-sm" id="printableArea">
                <div class="card-body">
                    <!-- Print Header -->
                    <div class="d-none d-print-block text-center mb-4">
                        <h2 class="fw-bold"><%= companyName %></h2>
                        <h4 class="text-decoration-underline">Training Enquiry</h4>
                    </div>

                    <div class="table-responsive">
                        <table class="table table-striped table-hover" id="dataTable">
                            <thead>
                                <tr>
                                    <th>EMP-ID</th>
                                    <th>Name</th>
                                    <th>Location</th>
                                    <th>Course</th>
                                    <th>Level</th>
                                    <th>Type</th>
                                    <th>Start</th>
                                    <th>Duration</th>
                                    <th>End</th>
                                    <th>W/H</th>
                                    <th>Resumes</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (data.length > 0) { %>
                                    <% data.forEach((row, index) => { %>
                                        <tr>
                                            <td><%= row.PFNo %></td>
                                            <td><%= row.SName %></td>
                                            <td><%= row.Location || '' %></td>
                                            <td><%= row.Course || '' %></td>
                                            <td><%= row.Level || '' %></td>
                                            <td><%= row.Type || '' %></td>
                                            <td><%= row.StartDate ? new Date(row.StartDate).toLocaleDateString() : '' %></td>
                                            <td><%= row.Duration || '' %></td>
                                            <td><%= '' %></td>
                                            <td><%= '' %></td>
                                            <td><%= '' %></td>
                                        </tr>
                                    <% }) %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="11" class="text-center">No records found</td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>

                    <% if (pagination.totalPages > 1) { %>
                        <nav aria-label="Page navigation" class="mt-3 d-print-none">
                            <ul class="pagination justify-content-center">
                                <li class="page-item <%= pagination.page === 1 ? 'disabled' : '' %>">
                                    <a class="page-link" href="?page=<%= pagination.page - 1 %>&pfno=<%= filters.pfno || '' %>&dept=<%= filters.dept || '' %>&grade=<%= filters.grade || '' %>&gender=<%= filters.gender || '' %>&profession=<%= filters.profession || '' %>&course=<%= filters.course || '' %>&dateFrom=<%= filters.dateFrom || '' %>&dateTo=<%= filters.dateTo || '' %>">Previous</a>
                                </li>
                                <% for (let i = 1; i <= pagination.totalPages; i++) { %>
                                    <li class="page-item <%= pagination.page === i ? 'active' : '' %>">
                                        <a class="page-link" href="?page=<%= i %>&pfno=<%= filters.pfno || '' %>&dept=<%= filters.dept || '' %>&grade=<%= filters.grade || '' %>&gender=<%= filters.gender || '' %>&profession=<%= filters.profession || '' %>&course=<%= filters.course || '' %>&dateFrom=<%= filters.dateFrom || '' %>&dateTo=<%= filters.dateTo || '' %>"><%= i %></a>
                                    </li>
                                <% } %>
                                <li class="page-item <%= pagination.page === pagination.totalPages ? 'disabled' : '' %>">
                                    <a class="page-link" href="?page=<%= pagination.page + 1 %>&pfno=<%= filters.pfno || '' %>&dept=<%= filters.dept || '' %>&grade=<%= filters.grade || '' %>&gender=<%= filters.gender || '' %>&profession=<%= filters.profession || '' %>&course=<%= filters.course || '' %>&dateFrom=<%= filters.dateFrom || '' %>&dateTo=<%= filters.dateTo || '' %>">Next</a>
                                </li>
                            </ul>
                        </nav>
                    <% } %>
                </div>
            </div>

            <footer class="mt-4 py-3 text-center text-muted border-top d-print-none">
                <%- include('../partials/footer') %>
            </footer>
        </div>
    </main>

    <script src="/vendor/bootstrap.bundle.min.js"></script>
    <script src="/js/dashboard.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
    <script src="https://cdn.sheetjs.com/xlsx-0.19.3/package/dist/xlsx.full.min.js"></script>
    <script>
        function exportPDF() {
            const element = document.getElementById('printableArea');
            // Temporarily show the header for PDF generation
            const header = element.querySelector('.d-print-block');
            const wasHidden = header && header.classList.contains('d-none');
            
            if (wasHidden) {
                header.classList.remove('d-none');
            }

            const opt = {
                margin:       10,
                filename:     'training_enquiry.pdf',
                image:        { type: 'jpeg', quality: 0.98 },
                html2canvas:  { scale: 2 },
                jsPDF:        { unit: 'mm', format: 'a4', orientation: 'landscape' }
            };
            
            html2pdf().set(opt).from(element).save().then(() => {
                // Revert visibility
                if (wasHidden) {
                    header.classList.add('d-none');
                }
            });
        }

        function exportExcel() {
            const table = document.getElementById("dataTable");
            const wb = XLSX.utils.table_to_book(table, {sheet: "Training Enquiry"});
            XLSX.writeFile(wb, "training_enquiry.xlsx");
        }
    </script>
    <style>
        @media print {
            body * {
                visibility: hidden;
            }
            #printableArea, #printableArea * {
                visibility: visible;
            }
            #printableArea {
                position: absolute;
                left: 0;
                top: 0;
                width: 100%;
                box-shadow: none !important;
                border: none !important;
            }
            .card {
                border: none !important;
            }
            .d-print-none {
                display: none !important;
            }
        }
    </style>
</body>
</html>