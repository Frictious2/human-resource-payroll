<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="/css/styles.css" rel="stylesheet" />
</head>
<body>
    <% if (role === 'admin') { %>
        <%- include('../admin/partials/topbar', { user }) %>
        <%- include('../admin/partials/sidebar') %>
    <% } else if (role === 'manager') { %>
        <%- include('../manager/partials/topbar', { user }) %>
        <%- include('../manager/partials/sidebar') %>
    <% } else { %>
        <%- include('../data_entry/partials/topbar', { user }) %>
        <%- include('../data_entry/partials/sidebar') %>
    <% } %>

    <main class="main">
        <div class="container-fluid">
            <!-- Modal Trigger Button (Hidden as we open automatically) -->
            <button type="button" class="btn btn-primary d-none" data-bs-toggle="modal" data-bs-target="#journalModal">
                Launch Journal Modal
            </button>

            <!-- Journal Report Modal -->
            <div class="modal fade" id="journalModal" tabindex="-1" aria-labelledby="journalModalLabel" aria-hidden="true" data-bs-backdrop="static" data-bs-keyboard="false">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title" id="journalModalLabel">Journal Report</h5>
                            <!-- Close button redirects to dashboard -->
                            <a href="/<%= role === 'manager' ? 'manager' : 'data-entry' %>/dashboard" class="btn-close" aria-label="Close"></a>
                        </div>
                        <div class="modal-body">
                            <form action="/<%= role === 'manager' ? 'manager' : 'data-entry' %>/reports/journal/preview" method="GET" target="_blank">
                                <div class="mb-3">
                                    <label for="glDate" class="form-label">Pick a date</label>
                                    <select class="form-select" id="glDate" name="glDate" required>
                                        <option value="" selected disabled>Select a GL Date...</option>
                                        <% dates.forEach(date => { %>
                                            <% 
                                                const val = String(date.GLDateVal || '').slice(0, 10);
                                                const display = val
                                                    ? new Date(`${val}T00:00:00`).toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' })
                                                    : '';
                                            %>
                                            <option value="<%= val %>"><%= display %></option>
                                        <% }); %>
                                    </select>
                                </div>
                                <div class="d-grid gap-2">
                                    <button type="submit" class="btn btn-primary">
                                        <i class="bi bi-file-earmark-text"></i> Preview Journal
                                    </button>
                                </div>
                            </form>
                        </div>
                        <div class="modal-footer">
                            <a href="/<%= role === 'manager' ? 'manager' : 'data-entry' %>/dashboard" class="btn btn-secondary">Close</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            var myModal = new bootstrap.Modal(document.getElementById('journalModal'));
            myModal.show();
        });
    </script>
</body>
</html>
