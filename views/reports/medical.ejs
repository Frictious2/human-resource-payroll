<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Medical Reports</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="/css/styles.css" rel="stylesheet" />
    <style>
        @media print {
            @page { size: portrait; margin: 1cm; }
            .no-print { display: none !important; }
            .print-only { display: block !important; }
            body { background: white; font-size: 12pt; }
            .container { max-width: 100% !important; width: 100% !important; margin: 0; padding: 0; }
            table { width: 100%; border-collapse: collapse; }
            th, td { border: 1px solid #000; padding: 5px; }
            .page-break { page-break-after: always; }
        }
        .print-only { display: none; }
        .report-header { text-align: center; margin-bottom: 20px; }
        .company-logo { max-height: 80px; }
        .proof-img { max-height: 100px; max-width: 100px; cursor: pointer; }
    </style>
</head>
<body>
    <div class="no-print">
        <% if (role === 'admin') { %>
            <%- include('../admin/partials/topbar', { user }) %>
            <%- include('../admin/partials/sidebar') %>
        <% } else if (role === 'manager') { %>
            <%- include('../manager/partials/topbar', { user }) %>
            <%- include('../manager/partials/sidebar') %>
        <% } else { %>
            <%- include('../data_entry/partials/topbar', { user }) %>
            <%- include('../data_entry/partials/sidebar') %>
        <% } %>
    </div>
    
    <main class="main">
    <div class="container mt-4">
        <!-- Search Form -->
        <div class="card no-print mb-4">
            <div class="card-header">
                <h4>Generate Medical Report</h4>
            </div>
            <div class="card-body">
                <form action="" method="GET" id="searchForm">
                    <div class="row mb-3">
                        <div class="col-md-3">
                            <label class="form-label">Report Type</label>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="type" id="typeAll" value="all" <%= (searchParams.type === 'all' || !searchParams.type) ? 'checked' : '' %>>
                                <label class="form-check-label" for="typeAll">All Staff</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="type" id="typeSpecific" value="specific" <%= searchParams.type === 'specific' ? 'checked' : '' %>>
                                <label class="form-check-label" for="typeSpecific">Specific Staff</label>
                            </div>
                        </div>
                        <div class="col-md-3" id="pfnoGroup" style="<%= searchParams.type === 'specific' ? '' : 'display:none;' %>">
                            <label for="pfno" class="form-label">Staff ID (PFNo)</label>
                            <input type="text" class="form-control" id="pfno" name="pfno" value="<%= searchParams.pfno || '' %>">
                        </div>
                        <div class="col-md-3">
                            <label for="dateFrom" class="form-label">From Date</label>
                            <input type="date" class="form-control" id="dateFrom" name="dateFrom" value="<%= searchParams.dateFrom || '' %>">
                        </div>
                        <div class="col-md-3">
                            <label for="dateTo" class="form-label">To Date</label>
                            <input type="date" class="form-control" id="dateTo" name="dateTo" value="<%= searchParams.dateTo || '' %>">
                        </div>
                    </div>
                    <button type="submit" class="btn btn-primary">Generate Report</button>
                    <button type="button" class="btn btn-secondary" onclick="window.print()">Print Preview</button>
                </form>
            </div>
        </div>

        <% if (records && records.length > 0) { %>
            <!-- Report Content -->
            <div class="report-content">
                <!-- Header -->
                <div class="report-header">
                    <div class="row align-items-center">
                        <div class="col-3 text-start">
                            <% if (companyInfo.LogoPath) { %>
                                <img src="/uploads/<%= companyInfo.LogoPath.replace(/^.*[\\\/]/, '') %>" class="company-logo" alt="Logo">
                            <% } else if (companyInfo.Logopath) { %>
                                <img src="/uploads/<%= companyInfo.Logopath.replace(/^.*[\\\/]/, '') %>" class="company-logo" alt="Logo">
                            <% } %>
                        </div>
                        <div class="col-6">
                            <h3><%= companyInfo.Com_Name || 'Company Name' %></h3>
                            <p><%= companyInfo.Address || 'Address' %></p>
                            <h4>Medical Report</h4>
                        </div>
                        <div class="col-3 text-end">
                            <p>Date: <%= new Date().toLocaleDateString() %></p>
                        </div>
                    </div>
                    <hr>
                </div>

                <!-- Table -->
                <table class="table table-bordered table-striped">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>PFNo</th>
                            <th>Name</th>
                            <th>Dependant</th>
                            <th>Description</th>
                            <th>Amount</th>
                            <% if (searchParams.type === 'specific') { %>
                                <th>Proof</th>
                            <% } %>
                        </tr>
                    </thead>
                    <tbody>
                        <% let totalAmount = 0; %>
                        <% records.forEach(record => { 
                            totalAmount += parseFloat(record.Amount || 0);
                        %>
                            <tr>
                                <td><%= new Date(record.EntryDate).toLocaleDateString() %></td>
                                <td><%= record.PFNo %></td>
                                <td><%= record.SName %></td>
                                <td><%= record.Dependant %></td>
                                <td><%= record.Description %></td>
                                <td class="text-end"><%= parseFloat(record.Amount).toFixed(2) %></td>
                                <% if (searchParams.type === 'specific') { %>
                                    <td class="text-center">
                                        <% if (record.PicturePath) { %>
                                            <img src="<%= record.PicturePath %>" class="proof-img" alt="Proof">
                                        <% } else { %>
                                            -
                                        <% } %>
                                    </td>
                                <% } %>
                            </tr>
                        <% }); %>
                        <tr>
                            <td colspan="<%= searchParams.type === 'specific' ? 5 : 5 %>" class="text-end fw-bold">Total</td>
                            <td class="text-end fw-bold"><%= totalAmount.toFixed(2) %></td>
                            <% if (searchParams.type === 'specific') { %>
                                <td></td>
                            <% } %>
                        </tr>
                    </tbody>
                </table>
            </div>
        <% } else if (searchParams.type) { %>
            <div class="alert alert-info no-print">No records found matching your criteria.</div>
        <% } %>
    </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Toggle PFNo field based on radio selection
        const typeAll = document.getElementById('typeAll');
        const typeSpecific = document.getElementById('typeSpecific');
        const pfnoGroup = document.getElementById('pfnoGroup');
        const pfnoInput = document.getElementById('pfno');

        function togglePfno() {
            if (typeSpecific.checked) {
                pfnoGroup.style.display = 'block';
                pfnoInput.setAttribute('required', 'required');
            } else {
                pfnoGroup.style.display = 'none';
                pfnoInput.removeAttribute('required');
                pfnoInput.value = '';
            }
        }

        typeAll.addEventListener('change', togglePfno);
        typeSpecific.addEventListener('change', togglePfno);
    </script>
</body>
</html>
